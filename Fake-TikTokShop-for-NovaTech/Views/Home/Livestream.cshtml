    .chat-username {
        font-weight: 600;
        margin-right: 4px;
    }
    .color-teal { color: #25F4EE; }
    .color-red { color: #FE2C55; }
    .color-yellow { color: #FFC107; }
    .color-pink { color: #FF4081; }
    .color-green { color: #4CAF50; }

    /* Pinned product card in video feed */
    .pinned-product-card {
        background: rgba(18, 19, 26, 0.85);
        border: 1px solid rgba(37, 244, 238, 0.3);
        box-shadow: 0 0 15px rgba(37, 244, 238, 0.15);
        backdrop-filter: blur(10px);
        position: relative;
    }
    .pinned-product-card .pinned-badge {
        position: absolute;
        top: -8px;
        left: 10px;
        background: #FE2C55;
        color: white;
        font-size: 0.55rem;
        font-weight: bold;
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
        box-shadow: 0 2px 5px rgba(254, 44, 85, 0.3);
    }
    .pinned-product-card .product-img {
        width: 50px;
        height: 50px;
        object-fit: cover;
    }

    .shopping-bag-icon:hover {
        transform: scale(1.1);
        transition: all 0.2s;
    }

    /* Floating hearts animation styling */
    .hearts-container {
        position: absolute;
        bottom: 70px;
        right: 15px;
        width: 60px;
        height: 250px;
        z-index: 9;
        pointer-events: none;
        overflow: hidden;
    }
    
    .floating-heart {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        font-size: 1.5rem;
        opacity: 0.8;
        animation: floatHeart 2.5s ease-out forwards;
    }
    @@keyframes floatHeart {
        0% {
            bottom: 0;
            opacity: 0.8;
            transform: translateX(-50%) scale(0.5);
        }
        50% {
            transform: translateX(var(--drift-x)) scale(1.2);
            opacity: 1;
        }
        100% {
            bottom: 220px;
            opacity: 0;
            transform: translateX(var(--drift-x-end)) scale(0.8);
        }
    }

    /* Shopping list overlay inside screen */
    .shopping-list-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 60%;
        background-color: rgba(18, 19, 26, 0.95);
        border-top: 2px solid #232533;
        z-index: 20;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        display: flex;
        flex-direction: column;
