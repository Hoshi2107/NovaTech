@{
    ViewData["Title"] = "TikTok Live Studio & Stream Viewer";
}

<div id="livestream-app" class="container-fluid py-4" v-cloak>
    <!-- TOP BAR -->
    <nav class="navbar navbar-expand-lg bg-tiktok-navbar rounded-4 mb-4 px-4 py-3 shadow-sm">
        <div class="container-fluid p-0 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a href="/" class="btn btn-tiktok-dark me-3 py-2 px-3">
                    <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
                </a>
                <i class="fa-solid fa-circle-dot text-tiktok-red me-2 animate-pulse fs-4"></i>
                <div>
                    <h4 class="mb-0 fw-bold text-white d-flex align-items-center gap-2">
                        TikTok Live Control Center
                        <span class="badge bg-danger animate-pulse text-xs py-1 px-2" style="font-size: 0.7rem;">LIVE</span>
                    </h4>
                    <small class="text-muted-custom text-xs">Trình Quản Lý & Giả Lập Live Stream Bán Hàng</small>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="bg-tiktok-dark rounded-pill px-3 py-2 border border-secondary border-opacity-25 d-flex align-items-center gap-3">
                    <span class="text-xs text-muted-custom"><i class="fa-solid fa-clock text-tiktok-red me-1"></i>Thời gian: <strong class="text-light">${formattedDuration}</strong></span>
                    <span class="text-xs text-muted-custom"><i class="fa-solid fa-eye text-tiktok-teal me-1"></i>Mắt xem: <strong class="text-light">${viewerCount}</strong></span>
                    <span class="text-xs text-muted-custom"><i class="fa-solid fa-heart text-tiktok-red me-1"></i>Thích: <strong class="text-light">${formatNumber(likesCount)}</strong></span>
                </div>
                <a href="/Home/LiveViewer" target="_blank" class="btn btn-outline-info py-2 px-3 d-flex align-items-center gap-2">
                    <i class="fa-solid fa-users"></i>
                    Màn hình Viewer
                </a>
                <button class="btn btn-tiktok-primary py-2 px-4" @@click="toggleLive">
                    <i class="fa-solid" :class="isLive ? 'fa-video-slash' : 'fa-video'"></i>
                    ${isLive ? 'Dừng Phát Sóng' : 'Bắt Đầu Phát Sóng'}
                </button>
            </div>
        </div>
    </nav>

    <div class="row g-4">
        <!-- LEFT SCREEN: LIVE STREAM SIMULATOR (MOBILE VIEW) -->
        <div class="col-xl-5 col-lg-6 d-flex justify-content-center">
            <div class="tiktok-mobile-frame shadow-lg position-relative">
                <!-- Inner screen container -->
                <div class="tiktok-screen-inner">
                    <!-- VIDEO BACKDROP / CAMERA STREAM -->
                    <div class="video-backdrop-container">
                        <video ref="videoPlayer" class="webcam-video" :style="mirrorCamera ? 'transform: scaleX(-1);' : ''" autoplay playsinline muted v-show="cameraActive && isLive"></video>
                        <canvas ref="captureCanvas" style="display: none;"></canvas>
                        
                        <!-- Floating controls for camera -->
                        <div class="position-absolute top-0 end-0 m-3 d-flex flex-column gap-2" style="z-index: 99;" v-show="cameraActive && isLive">
                            <button class="btn btn-dark bg-opacity-75 text-white rounded-circle p-2 border-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;" @@click="toggleMirror" title="Lật gương camera">
                                <i class="fa-solid fa-arrows-left-right"></i>
                            </button>
                            <button class="btn btn-dark bg-opacity-75 text-white rounded-circle p-2 border-0 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;" @@click="stopCamera" title="Tắt camera">
                                <i class="fa-solid fa-video-slash text-danger"></i>
                            </button>
                        </div>

                        <!-- Pulse neon overlay when not live or camera is off -->
                        <div class="neon-stream-placeholder d-flex flex-column align-items-center justify-content-center text-center p-4" v-show="!cameraActive || !isLive">
                            <div class="pulse-ring mb-4">
                                <i class="fa-brands fa-tiktok text-white fs-1"></i>
                            </div>
                            <h5 class="fw-bold text-white mb-2">
                                ${isLive ? 'Đang đợi tín hiệu Camera...' : 'Bắt đầu phát sóng'}
                            </h5>
                            <p class="text-muted text-xs px-4">
                                ${isLive ? 'Vui lòng cho phép quyền truy cập camera để truyền hình ảnh trực tiếp!' : 'Nhấn nút "Bắt Đầu Phát Sóng" để mở giao diện live stream.'}
                            </p>
                            <button v-if="isLive && !cameraActive" class="btn btn-sm btn-tiktok-secondary mt-2 px-3" @@click="initCamera">
                                <i class="fa-solid fa-camera me-1"></i>Bật Camera
                            </button>
                        </div>
                    </div>

                    <!-- FLOATING hearts CONTAINER -->
                    <div class="hearts-container" ref="heartsContainer"></div>

                    <!-- TIKTOK LIVE HUD OVERLAY -->
                    <div class="live-hud d-flex flex-column justify-content-between p-3">
                        <!-- TOP HUD: Host info, stats -->
                        <div class="d-flex justify-content-between align-items-start w-100">
                            <div class="d-flex align-items-center bg-dark bg-opacity-50 rounded-pill p-1 pe-3">
                                <div class="host-avatar bg-tiktok-teal text-dark fw-bold rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                    NT
                                </div>
                                <div>
                                    <h6 class="mb-0 text-white fw-bold text-xs" style="line-height: 1.1;">NovaTech Shop</h6>
                                    <small class="text-tiktok-teal text-2xs" style="font-size: 0.65rem;">Host</small>
                                </div>
                                <button class="btn btn-tiktok-primary p-0 rounded-circle ms-2 d-flex align-items-center justify-content-center" style="width: 18px; height: 18px; font-size: 0.6rem;">
                                    <i class="fa-solid fa-plus text-white"></i>
                                </button>
                            </div>
                            
                            <!-- Viewer List bubbles -->
                            <div class="d-flex align-items-center gap-1 bg-dark bg-opacity-40 rounded-pill px-2 py-1">
                                <span class="badge bg-tiktok-red px-2 py-1 text-2xs me-1">LIVE</span>
                                <div class="viewer-bubbles d-flex align-items-center">
                                    <div class="viewer-bubble bg-purple">A</div>
                                    <div class="viewer-bubble bg-danger">B</div>
                                    <div class="viewer-bubble bg-warning">C</div>
                                </div>
                            </div>
                        </div>

                        <!-- MIDDLE: Spaced out for streaming view -->
                        <div class="flex-grow-1"></div>

                        <!-- BOTTOM HUD: Chat box & pinned product -->
                        <div class="w-100 d-flex flex-column gap-2">
                            
                            <!-- SCROLLING LIVE CHAT -->
                            <div class="live-chat-box" ref="chatBox">
                                <div v-for="(chat, index) in chats" :key="index" class="chat-message animate-fade-in">
                                    <span class="chat-username" :class="chat.color">${chat.username}:</span>
                                    <span class="chat-text text-white">${chat.text}</span>
                                </div>
                            </div>

                            <!-- PINNED PRODUCT AT BOTTOM -->
                            <div class="pinned-product-card d-flex align-items-center p-2 rounded-3 animate-fade-in" v-if="pinnedProduct">
                                <div class="pinned-badge">Đang Ghim</div>
                                <img :src="pinnedProduct.imageUrl || 'https://via.placeholder.com/80'" class="product-img bg-secondary rounded" alt="Pinned Product">
                                <div class="product-details ms-2 flex-grow-1">
                                    <h6 class="product-title mb-0 text-white text-xs text-truncate">${pinnedProduct.name}</h6>
                                    <div class="d-flex align-items-center justify-content-between mt-1">
                                        <span class="product-price text-tiktok-teal fw-bold text-xs">${formatCurrency(pinnedProduct.price)}</span>
                                        <span class="product-stock text-muted text-3xs" style="font-size: 0.65rem;">Kho Live: ${pinnedProduct.stock}</span>
                                    </div>
                                </div>
                                <button class="btn btn-tiktok-primary btn-sm px-3 py-1 ms-2 text-xs" @@click="openBuyModal(pinnedProduct)">
                                    Mua Ngay
                                </button>
                            </div>

                            <!-- ACTIONS LINE (Like, Shopping Bag, Chat) -->
                            <div class="d-flex align-items-center justify-content-between mt-1">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="shopping-bag-icon position-relative cursor-pointer" @@click="toggleShoppingList">
                                        <i class="fa-solid fa-bag-shopping text-white fs-4 bg-dark bg-opacity-50 p-2 rounded-circle"></i>
                                        <span class="badge bg-tiktok-red position-absolute top-0 start-100 translate-middle rounded-pill" style="font-size: 0.6rem;">
                                            ${liveProducts.length}
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center gap-2">
                                    <button class="btn btn-dark bg-opacity-50 rounded-circle p-2 text-white border-0" @@click="sendHeart">
                                        <i class="fa-solid fa-heart text-tiktok-red fs-4"></i>
                                    </button>
                                    <button class="btn btn-dark bg-opacity-50 rounded-circle p-2 text-white border-0" @@click="triggerSimulatedComment">
                                        <i class="fa-solid fa-comment-dots fs-4"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- OVERLAY SHOPPING LIST (Toggled via shopping bag icon) -->
                    <div class="shopping-list-overlay p-3 text-light" v-if="showShoppingList" class="animate-fade-in">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0 text-white"><i class="fa-solid fa-store text-tiktok-teal me-2"></i>Sản phẩm trong Live (${liveProducts.length})</h6>
                            <i class="fa-solid fa-xmark cursor-pointer fs-5" @@click="toggleShoppingList"></i>
                        </div>
                        
                        <div class="shopping-items-wrapper">
                            <div v-if="liveProducts.length === 0" class="text-center py-5">
                                <p class="text-muted text-xs">Chưa có sản phẩm nào được đưa lên livestream.</p>
                            </div>
                            
                            <div class="shopping-item d-flex align-items-center p-2 mb-2 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10" v-for="p in liveProducts" :key="p.productId">
                                <img :src="p.imageUrl || 'https://via.placeholder.com/80'" class="rounded bg-secondary" width="50" height="50">
                                <div class="ms-2 flex-grow-1">
                                    <div class="fw-bold text-white text-xs text-truncate" style="max-width: 150px;">${p.name}</div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="text-tiktok-teal fw-bold text-xs">${formatCurrency(p.price)}</span>
                                        <span class="text-muted text-3xs" style="font-size: 0.65rem;">Còn: ${p.stock}</span>
                                    </div>
                                </div>
                                <button class="btn btn-tiktok-primary btn-sm px-2 py-1 text-2xs ms-2" @@click="openBuyModal(p)" :disabled="p.stock <= 0">
                                    Mua
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT SCREEN: LIVESTREAM CONTROL PANEL -->
        <div class="col-xl-7 col-lg-6">
            <!-- CATALOG ADDER CARD -->
            <div class="card bg-tiktok-card mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-white d-flex align-items-center justify-content-between">
                        <span><i class="fa-solid fa-plus-minus text-tiktok-teal me-2"></i>Đưa Sản Phẩm Vào Live Stream</span>
                        <button class="btn btn-sm btn-tiktok-dark py-1 px-3" @@click="syncCatalogFromWarehouse" :disabled="syncingCatalog">
                            <span v-if="syncingCatalog" class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <i class="fa-solid fa-rotate me-1"></i>Đồng bộ tồn kho gốc
                        </button>
                    </h5>
                    <hr class="border-secondary opacity-25">
                    
                    <div class="row g-2 mb-3 align-items-center">
                        <div class="col-md-8 col-sm-7">
                            <select class="form-select form-select-tiktok" v-model="selectedCatalogProductId">
                                <option value="" disabled>-- Chọn sản phẩm từ Catalog của NovaTech --</option>
                                <option v-for="p in availableCatalogProducts" :value="p.productId">
                                    ${p.name} - ${formatCurrency(p.price)} (Tồn: ${p.stock})
                                </option>
                            </select>
                        </div>
                        <div class="col-md-4 col-sm-5">
                            <button class="btn btn-tiktok-secondary w-100 py-2" @@click="addCatalogProductToLive" :disabled="!selectedCatalogProductId">
                                <i class="fa-solid fa-cloud-arrow-up me-2"></i>Đưa lên Live Stream
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- LIVE PRODUCTS LIST AND STOCK CONTROL -->
            <div class="card bg-tiktok-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0 text-white">
                            <i class="fa-solid fa-bars-progress text-tiktok-red me-2"></i>
                            Quản Lý Mặt Hàng Trực Tiếp
                        </h5>
                        <button class="btn btn-sm btn-tiktok-dark" @@click="fetchLiveProducts">
                            <i class="fa-solid fa-arrows-rotate me-1"></i>Làm mới live
                        </button>
                    </div>
                    <hr class="border-secondary opacity-25">

                    <div v-if="liveProducts.length === 0" class="text-center py-5 border border-secondary border-dashed rounded-3">
                        <i class="fa-solid fa-box-open fs-1 text-muted mb-3 opacity-50"></i>
                        <p class="text-muted">Chưa có sản phẩm nào được đưa lên livestream.</p>
                        <p class="text-muted-custom text-xs">Chọn sản phẩm từ Catalog bên trên rồi bấm "Đưa lên Live Stream" nhé!</p>
                    </div>

                    <div v-else class="table-responsive">
                        <table class="table table-hover align-middle text-light border-secondary border-opacity-10 mb-0">
                            <thead>
                                <tr class="text-muted border-secondary">
                                    <th>Sản Phẩm</th>
                                    <th>Giá Bán</th>
                                    <th style="width: 150px;">Số Lượng Trong Live</th>
                                    <th class="text-center">Đã bán</th>
                                    <th class="text-end">Hành động quản lý</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="p in liveProducts" :key="p.productId" class="border-secondary border-opacity-10">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img :src="p.imageUrl || 'https://via.placeholder.com/80'" class="rounded bg-secondary me-2" width="45" height="45">
                                            <div>
                                                <div class="fw-bold text-white text-truncate" style="max-width: 220px;" :title="p.name">
                                                    ${p.name}
                                                </div>
                                                <small class="text-muted text-xs">Mã: #${p.productId} | SKU: ${p.sku}</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <strong class="text-tiktok-teal">${formatCurrency(p.price)}</strong>
                                    </td>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input type="number" class="form-control form-control-tiktok text-center px-1" v-model.number="p.stock" min="0">
                                            <button class="btn btn-tiktok-secondary px-2" @@click="updateStock(p.productId, p.stock)" title="Lưu số lượng">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill fw-bold">
                                            ${p.salesCount || 0}
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <!-- PIN / UNPIN BUTTON -->
                                            <button v-if="!p.isPinned" class="btn btn-sm btn-outline-info" @@click="pinProduct(p.productId)">
                                                <i class="fa-solid fa-thumbtack me-1"></i>Ghim lên Live
                                            </button>
                                            <span v-else class="badge bg-tiktok-red bg-opacity-75 text-white py-2 px-2 rounded-2 animate-pulse me-1 d-flex align-items-center gap-1 cursor-pointer" @@click="unpinProduct(p.productId)">
                                                <i class="fa-solid fa-thumbtack animate-bounce"></i>Đang Ghim
                                            </span>

                                            <!-- TEST SIMULATED SALE -->
                                            <button class="btn btn-sm btn-tiktok-primary" @@click="quickSimulateBuy(p)" :disabled="p.stock <= 0" title="Giả lập một khách hàng đặt mua sản phẩm này ngay">
                                                <i class="fa-solid fa-magic me-1"></i>Giả lập bán 1
                                            </button>

                                            <!-- REMOVE BUTTON -->
                                            <button class="btn btn-sm btn-outline-danger" @@click="removeProduct(p.productId)">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- BUY MODAL (SIMULATED FOR CUSTOMER) -->
    <div class="modal fade" id="buyModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-tiktok-card text-light border border-secondary border-opacity-25 rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <i class="fa-solid fa-cart-shopping text-tiktok-red me-2"></i>
                        Đặt Mua Trực Tiếp Trên Live
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-3">
                    <div class="d-flex align-items-center p-3 mb-3 rounded bg-tiktok-dark border border-secondary border-opacity-10" v-if="modalProduct">
                        <img :src="modalProduct.imageUrl || 'https://via.placeholder.com/80'" class="rounded bg-secondary me-3" width="70" height="70">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold text-white mb-1 text-truncate" style="max-width: 280px;">${modalProduct.name}</h6>
                            <span class="text-tiktok-teal fw-bold">${formatCurrency(modalProduct.price)}</span>
                            <small class="text-muted d-block text-2xs mt-1">Số lượng tồn live: ${modalProduct.stock}</small>
                        </div>
                    </div>

                    <form @@submit.prevent="submitBuyOrder">
                        <div class="mb-3">
                            <label class="form-label text-muted text-xs fw-bold text-uppercase">Họ và Tên Khách Hàng <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-tiktok" v-model="buyForm.customerName" required placeholder="Ví dụ: Nguyễn Thị B">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted text-xs fw-bold text-uppercase">Số Điện Thoại <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-tiktok" v-model="buyForm.phone" required placeholder="09xxxxxxxx">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted text-xs fw-bold text-uppercase">Địa Chỉ Nhận Hàng <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-tiktok" v-model="buyForm.address" required placeholder="Số 10 Hai Bà Trưng, Hà Nội">
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label text-muted text-xs fw-bold text-uppercase">Số Lượng Mua</label>
                                <input type="number" class="form-control form-control-tiktok text-center" v-model.number="buyForm.quantity" min="1" :max="modalProduct ? modalProduct.stock : 99" required>
                            </div>
                            <div class="col-6 text-end d-flex flex-column justify-content-end">
                                <span class="text-muted-custom text-2xs d-block">Tổng giá trị:</span>
                                <h4 class="text-success fw-bold mb-0">${formatCurrency(calculateModalTotal())}</h4>
                            </div>
                        </div>

                        <div class="border-top border-secondary border-dashed pt-3 mt-3 d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-tiktok-dark py-2 px-3" data-bs-dismiss="modal">Hủy bỏ</button>
                            <button type="submit" class="btn btn-tiktok-primary py-2 px-4" :disabled="submittingOrder">
                                <span v-if="submittingOrder" class="spinner-border spinner-border-sm me-2"></span>
                                <i class="fa-solid fa-circle-check me-2"></i>Xác Nhận Đặt Mua
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for the Livestream Simulation Workspace */
    .bg-tiktok-navbar {
        background-color: #0d0e14;
        border-bottom: 1px solid #1f2230;
    }
    
    .text-muted-custom {
        color: #8c90a6;
    }

    .animate-pulse {
        animation: pulse-red 1.5s infinite;
    }
    @@keyframes pulse-red {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: .6; transform: scale(1.05); }
    }

    /* TikTok Mobile Frame */
    .tiktok-mobile-frame {
        width: 375px;
        height: 720px;
        background-color: #000;
        border-radius: 40px;
        border: 12px solid #232533;
        overflow: hidden;
        position: relative;
    }

    .tiktok-screen-inner {
        width: 100%;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

    .video-backdrop-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, #2b1025 0%, #0d0e15 100%);
        z-index: 1;
    }

    .webcam-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .neon-stream-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #1b091f 0%, #080d16 100%);
        position: relative;
        z-index: 2;
    }

    .pulse-ring {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(254, 44, 85, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px rgba(254, 44, 85, 0.4);
        animation: ring-ripple 2s infinite ease-out;
    }
    @@keyframes ring-ripple {
        0% { box-shadow: 0 0 0 0 rgba(254, 44, 85, 0.4), 0 0 0 0 rgba(37, 244, 238, 0.4); }
        100% { box-shadow: 0 0 0 20px rgba(254, 44, 85, 0), 0 0 0 35px rgba(37, 244, 238, 0); }
    }

    /* Live HUD layout */
    .live-hud {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 10;
        background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 25%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.65) 100%);
    }

    .text-2xs {
        font-size: 0.7rem;
    }
    .text-3xs {
        font-size: 0.6rem;
    }

    .viewer-bubble {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 0.65rem;
        margin-left: -6px;
        border: 1px solid #000;
    }
    .bg-purple { background-color: #9C27B0; }

    /* Live chat box */
    .live-chat-box {
        max-height: 160px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
        mask-image: linear-gradient(to top, black 85%, transparent 100%);
        -webkit-mask-image: linear-gradient(to top, black 85%, transparent 100%);
        padding-right: 5px;
    }
    .live-chat-box::-webkit-scrollbar {
        width: 3px;
    }
    .live-chat-box::-webkit-scrollbar-thumb {
