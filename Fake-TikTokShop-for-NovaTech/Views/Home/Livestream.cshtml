    }

    /* Custom form styling */
    .border-dashed {
        border-style: dashed !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        new Vue({
            el: '#livestream-app',
            delimiters: ['${', '}'],
            data: {
                isLive: false,
                cameraActive: false,
                mirrorCamera: true,
                captureInterval: null,
                liveDurationSeconds: 0,
                timerInterval: null,
                viewerCount: 0,
                likesCount: 0,
                
                catalogProducts: [],
                liveProducts: [],
                selectedCatalogProductId: '',
                syncingCatalog: false,

                // Chat Simulation
                chats: [
                    { username: 'Hệ thống', text: 'Chào mừng bạn đến với phòng Livestream Studio! Nhấn Bắt đầu phát sóng để live.', color: 'color-teal' }
                ],
                mockUsernames: ['quynh_anh99', 'tung_son_gaming', 'lan_huong_official', 'minh_quan_erp', 'linh_chi_cute', 'ha_anh_tuan', 'viet_anh_dev', 'kieu_trang_123', 'duy_manh_vip'],
                mockTexts: [
                    'Sản phẩm đẹp quá shop ơi!',
                    'Có mã giảm giá không ạ?',
                    'Laptop này dùng ổn định không shop?',
                    'Mới đặt 1 đơn rồi nha, shop giao nhanh giúp em',
                    'Uầy, giá hạt dẻ thế nhở!',
                    'Em xin giá dell xps 13 với',
                    'Chuột logitech kia có bảo hành không ạ?',
                    'Thích cái bàn phím cơ ghê',
                    'Đồng bộ đơn hàng TikTok siêu mượt luôn',
                    'Shop dễ thương ghê, thả tim nè!'
                ],
                chatInterval: null,

                // Shopping bag overlay
                showShoppingList: false,

                // Modal for buy order simulation
                modalProduct: null,
                buyForm: {
                    customerName: '',
                    phone: '',
                    address: '',
                    quantity: 1
                },
                submittingOrder: false,
                mediaRecorder: null,
                audioCaptureActive: false,
                audioTimeout: null
            },
            computed: {
                formattedDuration() {
                    const hrs = Math.floor(this.liveDurationSeconds / 3600);
                    const mins = Math.floor((this.liveDurationSeconds % 3600) / 60);
                    const secs = this.liveDurationSeconds % 60;
                    return [
                        hrs.toString().padStart(2, '0'),
                        mins.toString().padStart(2, '0'),
                        secs.toString().padStart(2, '0')
                    ].join(':');
                },
                pinnedProduct() {
                    return this.liveProducts.find(p => p.isPinned);
                },
                availableCatalogProducts() {
                    // Return catalog products that are not yet in liveProducts
                    return this.catalogProducts.filter(cp => !this.liveProducts.some(lp => lp.productId === cp.productId));
                }
            },
            mounted() {
                this.fetchCatalogProducts();
                this.fetchLiveProducts();
            },
            beforeDestroy() {
                this.stopTimer();
                this.stopChatSimulation();
            },
            methods: {
                formatCurrency(val) {
                    if (!val && val !== 0) return '0 ₫';
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
                },
                formatNumber(val) {
                    if (val >= 1000) {
                        return (val / 1000).toFixed(1) + 'K';
                    }
                    return val;
                },
                calculateModalTotal() {
                    if (!this.modalProduct) return 0;
                    return this.modalProduct.price * this.buyForm.quantity;
                },
                async fetchCatalogProducts() {
                    try {
                        const res = await axios.get('/api/tiktok/products-cache');
                        this.catalogProducts = res.data;
                    } catch (err) {
                        console.error('Lỗi tải sản phẩm catalog:', err);
                    }
                },
                async fetchLiveProducts() {
                    try {
                        const res = await axios.get('/api/tiktok/livestream/products');
                        this.liveProducts = res.data;
                    } catch (err) {
                        console.error('Lỗi tải sản phẩm live:', err);
                    }
                },
                async syncCatalogFromWarehouse() {
                    this.syncingCatalog = true;
                    try {
                        const res = await axios.post('/api/tiktok/sync-products');
                        await this.fetchCatalogProducts();
                        await this.fetchLiveProducts();
                        
                        const toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000,
                            background: '#12131a',
                            color: '#fff'
                        });
                        toast.fire({
                            icon: 'success',
                            title: res.data.message || 'Đồng bộ tồn kho gốc thành công!'
                        });
                    } catch (err) {
                        Swal.fire('Lỗi', err.response?.data?.message || 'Không thể đồng bộ với kho gốc NovaTech!', 'error');
                    } finally {
                        this.syncingCatalog = false;
                    }
                },
                async addCatalogProductToLive() {
                    if (!this.selectedCatalogProductId) return;
                    try {
                        await axios.post('/api/tiktok/livestream/products', {
                            productId: parseInt(this.selectedCatalogProductId)
                        });
                        this.selectedCatalogProductId = '';
                        await this.fetchLiveProducts();
                        const toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            background: '#12131a',
                            color: '#fff'
                        });
                        toast.fire({
                            icon: 'success',
                            title: 'Đã đưa sản phẩm lên Livestream!'
                        });
                    } catch (err) {
                        Swal.fire('Lỗi', err.response?.data?.message || 'Không thể thêm sản phẩm!', 'error');
                    }
                },
                async removeProduct(productId) {
                    try {
                        await axios.delete(`/api/tiktok/livestream/products/${productId}`);
                        await this.fetchLiveProducts();
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể xóa sản phẩm khỏi live!', 'error');
                    }
                },
                async pinProduct(productId) {
                    try {
                        await axios.post(`/api/tiktok/livestream/products/${productId}/pin`);
                        await this.fetchLiveProducts();
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể ghim sản phẩm!', 'error');
                    }
                },
                async unpinProduct(productId) {
                    try {
                        await axios.post(`/api/tiktok/livestream/products/${productId}/unpin`);
                        await this.fetchLiveProducts();
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể bỏ ghim sản phẩm!', 'error');
                    }
                },
                async updateStock(productId, stock) {
                    if (stock < 0 || isNaN(stock)) {
                        Swal.fire('Lỗi', 'Tồn kho không hợp lệ!', 'warning');
                        return;
                    }
                    try {
                        await axios.post(`/api/tiktok/livestream/products/${productId}/stock`, { stock });
                        await this.fetchLiveProducts();
                        await this.fetchCatalogProducts();
                        const toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            background: '#12131a',
                            color: '#fff'
                        });
                        toast.fire({
                            icon: 'success',
                            title: 'Đã cập nhật tồn kho live thành công!'
                        });
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể cập nhật tồn kho!', 'error');
                    }
                },
                toggleShoppingList() {
                    this.showShoppingList = !this.showShoppingList;
                },
                async toggleLive() {
                    this.isLive = !this.isLive;
                    if (this.isLive) {
                        // Notify server to broadcast live state
                        try {
                            await axios.post('/api/tiktok/livestream/state/start');
                        } catch (err) {
                            console.error('Lỗi gọi API start live:', err);
                        }
                        this.startTimer();
                        this.startChatSimulation();
                        this.initCamera();
                        this.viewerCount = Math.floor(Math.random() * 50) + 120;
                        this.likesCount = Math.floor(Math.random() * 500) + 1200;
                        
                        this.chats.push({
                            username: 'Hệ thống',
                            text: 'Phòng phát sóng bắt đầu. Trực tiếp từ NovaTech Shop!',
                            color: 'color-red'
                        });
                    } else {
                        // Notify server to stop live state
                        try {
                            await axios.post('/api/tiktok/livestream/state/stop');
                        } catch (err) {
                            console.error('Lỗi gọi API stop live:', err);
                        }
                        this.stopTimer();
                        this.stopChatSimulation();
                        this.stopCamera();
                        this.viewerCount = 0;
                        this.chats.push({
                            username: 'Hệ thống',
                            text: 'Đã kết thúc phiên Live Stream.',
                            color: 'color-teal'
                        });
                    }
                },
                startTimer() {
                    this.liveDurationSeconds = 0;
                    this.timerInterval = setInterval(() => {
                        this.liveDurationSeconds++;
                        // random shift view counts
                        if (this.liveDurationSeconds % 10 === 0) {
                            const delta = Math.floor(Math.random() * 15) - 7;
                            this.viewerCount = Math.max(10, this.viewerCount + delta);
                        }
                    }, 1000);
                },
                stopTimer() {
                    if (this.timerInterval) {
                        clearInterval(this.timerInterval);
                        this.timerInterval = null;
                    }
                },
                async initCamera() {
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                        if (this.$refs.videoPlayer) {
                            this.$refs.videoPlayer.srcObject = stream;
                            this.cameraActive = true;
                            this.startFrameCapture();
                            this.startAudioCapture(stream);
                        }
                    } catch (err) {
                        console.warn("Camera/Microphone không khả dụng hoặc bị từ chối quyền, sử dụng giả lập neon", err);
                        this.cameraActive = false;
                    }
                },
                stopCamera() {
                    if (this.$refs.videoPlayer && this.$refs.videoPlayer.srcObject) {
                        const tracks = this.$refs.videoPlayer.srcObject.getTracks();
                        tracks.forEach(track => track.stop());
                        this.$refs.videoPlayer.srcObject = null;
                    }
                    this.cameraActive = false;
                    this.stopFrameCapture();
                    this.stopAudioCapture();
                },
                 toggleMirror() {
                    this.mirrorCamera = !this.mirrorCamera;
                },
                startAudioCapture(stream) {
                    this.stopAudioCapture();
                    const audioTracks = stream.getAudioTracks();
                    if (audioTracks.length === 0) {
                        console.warn("Không tìm thấy micro.");
                        return;
                    }
                    const audioStream = new MediaStream(audioTracks);
                    let options = {};
                    if (typeof MediaRecorder !== 'undefined') {
                        if (MediaRecorder.isTypeSupported('audio/webm;codecs=opus')) {
                            options = { mimeType: 'audio/webm;codecs=opus' };
                        } else if (MediaRecorder.isTypeSupported('audio/ogg;codecs=opus')) {
                            options = { mimeType: 'audio/ogg;codecs=opus' };
                        } else if (MediaRecorder.isTypeSupported('audio/webm')) {
                            options = { mimeType: 'audio/webm' };
                        }
                    }

                    this.audioCaptureActive = true;

                    const recordChunk = () => {
                        if (!this.isLive || !this.audioCaptureActive) return;

                        try {
                            const chunkRecorder = new MediaRecorder(audioStream, options);
                            let chunks = [];

                            chunkRecorder.ondataavailable = (e) => {
                                if (e.data && e.data.size > 0) {
                                    chunks.push(e.data);
                                }
                            };

                            chunkRecorder.onstop = () => {
                                if (chunks.length > 0 && this.isLive && this.audioCaptureActive) {
                                    const blob = new Blob(chunks, { type: options.mimeType });
                                    const reader = new FileReader();
                                    reader.onloadend = () => {
                                        const base64Audio = reader.result;
                                        axios.post('/api/tiktok/livestream/audio', { audio: base64Audio })
                                            .catch(err => console.error("Lỗi gửi audio:", err));
                                    };
                                    reader.readAsDataURL(blob);
                                }

                                // Schedule next chunk recording
                                if (this.isLive && this.audioCaptureActive) {
                                    this.audioTimeout = setTimeout(recordChunk, 10);
                                }
                            };

                            chunkRecorder.start();

                            // Stop after 1 second to pack the chunk
                            this.audioTimeout = setTimeout(() => {
                                if (chunkRecorder && chunkRecorder.state === 'recording') {
                                    chunkRecorder.stop();
                                }
                            }, 1000);

                        } catch (err) {
                            console.error("Lỗi ghi âm chunk:", err);
                        }
                    };

                    recordChunk();
                },
                stopAudioCapture() {
                    this.audioCaptureActive = false;
                    if (this.audioTimeout) {
                        clearTimeout(this.audioTimeout);
                        this.audioTimeout = null;
                    }
                    axios.post('/api/tiktok/livestream/audio/clear').catch(err => {});
                },
                startFrameCapture() {
                    this.stopFrameCapture();
                    this.captureInterval = setInterval(() => {
                        if (!this.isLive || !this.cameraActive) {
                            this.stopFrameCapture();
                            return;
                        }
                        this.captureFrame();
                    }, 250);
                },
                stopFrameCapture() {
                    if (this.captureInterval) {
                        clearInterval(this.captureInterval);
                        this.captureInterval = null;
                    }
                    axios.post('/api/tiktok/livestream/frame', { frame: null }).catch(err => {});
                },
                captureFrame() {
                    const video = this.$refs.videoPlayer;
                    const canvas = this.$refs.captureCanvas;
                    if (!video || !canvas || video.paused || video.ended) return;
                    
                    const ctx = canvas.getContext('2d');
                    const width = 240;
                    const height = 320;
                    canvas.width = width;
                    canvas.height = height;
                    
                    const videoWidth = video.videoWidth;
                    const videoHeight = video.videoHeight;
                    if (videoWidth && videoHeight) {
                        let sx, sy, sWidth, sHeight;
                        const targetRatio = width / height;
                        const srcRatio = videoWidth / videoHeight;
                        
                        if (srcRatio > targetRatio) {
                            sHeight = videoHeight;
                            sWidth = videoHeight * targetRatio;
                            sx = (videoWidth - sWidth) / 2;
                            sy = 0;
                        } else {
                            sWidth = videoWidth;
                            sHeight = videoWidth / targetRatio;
                            sx = 0;
                            sy = (videoHeight - sHeight) / 2;
                        }
                        ctx.drawImage(video, sx, sy, sWidth, sHeight, 0, 0, width, height);
                    } else {
                        ctx.drawImage(video, 0, 0, width, height);
                    }
                    
                    const dataUrl = canvas.toDataURL('image/jpeg', 0.4);
                    axios.post('/api/tiktok/livestream/frame', { frame: dataUrl })
                        .catch(err => console.error("Lỗi gửi frame:", err));
                },
                startChatSimulation() {
                    this.chatInterval = setInterval(() => {
                        const randomUser = this.mockUsernames[Math.floor(Math.random() * this.mockUsernames.length)];
                        const randomText = this.mockTexts[Math.floor(Math.random() * this.mockTexts.length)];
                        const colors = ['color-teal', 'color-yellow', 'color-pink', 'color-green', 'color-red'];
                        const randomColor = colors[Math.floor(Math.random() * colors.length)];
                        
                        this.chats.push({
                            username: randomUser,
                            text: randomText,
                            color: randomColor
                        });

                        // Keep chat box small
                        if (this.chats.length > 25) {
                            this.chats.shift();
                        }

                        this.$nextTick(() => {
                            const chatEl = this.$refs.chatBox;
                            if (chatEl) {
                                chatEl.scrollTop = chatEl.scrollHeight;
                            }
                        });

                        // Occasionally simulate a random heart fly
                        if (Math.random() > 0.4) {
                            this.sendHeart();
                            this.likesCount += Math.floor(Math.random() * 5) + 1;
                        }
                    }, 4000);
                },
                stopChatSimulation() {
                    if (this.chatInterval) {
                        clearInterval(this.chatInterval);
                        this.chatInterval = null;
                    }
                },
                sendHeart() {
                    const hearts = ['❤️', '💖', '🔥', '✨', '🥰', '👍'];
                    const randomHeart = hearts[Math.floor(Math.random() * hearts.length)];
                    const heartEl = document.createElement('div');
                    heartEl.className = 'floating-heart';
                    heartEl.innerText = randomHeart;
                    
                    const driftX = (Math.random() * 100 - 50) + 'px';
                    const driftXEnd = (Math.random() * 140 - 70) + 'px';
                    heartEl.style.setProperty('--drift-x', driftX);
                    heartEl.style.setProperty('--drift-x-end', driftXEnd);
                    
                    const colors = ['#FE2C55', '#25F4EE', '#FFD700', '#FF69B4', '#00FF00'];
                    heartEl.style.color = colors[Math.floor(Math.random() * colors.length)];
                    
                    const container = this.$refs.heartsContainer;
                    if (container) {
                        container.appendChild(heartEl);
                        setTimeout(() => {
                            heartEl.remove();
                        }, 2500);
                    }
                    this.likesCount++;
                },
                triggerSimulatedComment() {
                    const user = this.mockUsernames[Math.floor(Math.random() * this.mockUsernames.length)];
                    const text = "Mua sản phẩm ghim thế nào vậy shop?";
                    this.chats.push({
                        username: user,
                        text: text,
                        color: 'color-yellow'
                    });
                    this.$nextTick(() => {
                        const chatEl = this.$refs.chatBox;
                        if (chatEl) chatEl.scrollTop = chatEl.scrollHeight;
                    });
                },
                openBuyModal(product) {
                    if (product.stock <= 0) {
                        Swal.fire('Hết hàng', 'Sản phẩm này đã hết hàng trong Livestream!', 'warning');
                        return;
                    }
                    this.modalProduct = product;
                    this.buyForm.customerName = '';
                    this.buyForm.phone = '';
                    this.buyForm.address = '';
                    this.buyForm.quantity = 1;
                    
                    // Show modal using Bootstrap
                    const modal = new bootstrap.Modal(document.getElementById('buyModal'));
                    modal.show();
                },
                async submitBuyOrder() {
                    if (this.buyForm.quantity > this.modalProduct.stock) {
                        Swal.fire('Lỗi', 'Không đủ số lượng trong kho Live!', 'warning');
                        return;
                    }
                    this.submittingOrder = true;
                    try {
                        const res = await axios.post('/api/tiktok/livestream/simulate-buy', {
                            productId: this.modalProduct.productId,
                            quantity: this.buyForm.quantity,
                            customerName: this.buyForm.customerName,
                            phone: this.buyForm.phone,
                            address: this.buyForm.address
                        });
                        
                        // Close modal
                        const modalEl = document.getElementById('buyModal');
                        const modalInstance = bootstrap.Modal.getInstance(modalEl);
                        if (modalInstance) modalInstance.hide();
                        
                        // Success notify
                        Swal.fire({
                            title: 'Đặt hàng thành công!',
                            html: `Đã tạo đơn Live: <strong>${res.data.orderId}</strong><br>Hệ thống đang đẩy webhook sang NovaTech ERP!`,
                            icon: 'success',
                            background: '#12131a',
                            color: '#fff',
                            confirmButtonColor: '#25F4EE'
                        });

                        // Show chat message about buyer
                        this.chats.push({
                            username: 'Hệ thống Live',
                            text: `🎉 Khách hàng ${this.buyForm.customerName} đã đặt mua thành công ${this.buyForm.quantity} x ${this.modalProduct.name}!`,
                            color: 'color-teal'
                        });

                        // Reload data
                        await this.fetchLiveProducts();
                        await this.fetchCatalogProducts();
                    } catch (err) {
                        Swal.fire('Lỗi', err.response?.data?.message || 'Không thể tạo đơn hàng live!', 'error');
                    } finally {
                        this.submittingOrder = false;
                    }
                },
                async quickSimulateBuy(product) {
                    if (product.stock <= 0) {
                        Swal.fire('Hết hàng', 'Sản phẩm đã hết hàng!', 'warning');
                        return;
                    }
                    
                    // Auto-generate some random buyers
                    const names = ['Nguyễn Văn Tài', 'Trần Thị Thuỷ', 'Lê Minh Hoàng', 'Phạm Hồng Nhung', 'Vũ Đức Huy'];
                    const phones = ['0912345678', '0988776655', '0909090909', '0977889900', '0944556677'];
                    const addresses = ['123 Nguyễn Trãi, Thanh Xuân, Hà Nội', '456 Lê Lợi, Quận 1, TP. HCM', '789 Trần Hưng Đạo, Đà Nẵng', '12 Đại Cồ Việt, Hà Nội'];
                    
                    const randIndex = Math.floor(Math.random() * names.length);
                    const customerName = names[randIndex];
                    const phone = phones[randIndex];
                    const address = addresses[randIndex];

                    try {
                        const res = await axios.post('/api/tiktok/livestream/simulate-buy', {
                            productId: product.productId,
                            quantity: 1,
                            customerName,
                            phone,
                            address
                        });

                        const toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000,
                            background: '#12131a',
                            color: '#fff'
                        });
                        toast.fire({
                            icon: 'success',
                            title: `Giả lập bán thành công cho ${customerName}!`
                        });

                        // Show chat comment
                        this.chats.push({
                            username: 'Hệ thống Live',
                            text: `🎉 Khách hàng ${customerName} đã đặt mua 1 x ${product.name}!`,
                            color: 'color-teal'
                        });

                        await this.fetchLiveProducts();
                        await this.fetchCatalogProducts();
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể giả lập đơn hàng!', 'error');
                    }
                }
            }
        });
    </script>
}
