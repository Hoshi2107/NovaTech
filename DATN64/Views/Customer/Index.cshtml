@model List<DATN64.Models.KhachHang>
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Quản lý khách hàng"; }
<div class="container my-5">
    <h2>Quản lý Khách Hàng</h2>
    <table class="table">
        <thead><tr><th>Mã KH</th><th>Họ Tên</th><th>Điện Thoại</th><th>Điểm Tích Lũy</th></tr></thead>
        <tbody>
            @foreach(var item in Model) {
                <tr><td>@item.MaKhachHang</td><td>@item.HoTen</td><td>@item.SoDienThoai</td><td>@item.DiemTichLuy</td></tr>
            }
        </tbody>
    </table>
</div>