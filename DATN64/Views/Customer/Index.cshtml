@model List<DATN64.Models.KhachHang>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Khách hàng";
    ViewData["BreadcrumbActive"] = "Khách hàng";

    var keyword = ViewBag.Keyword as string ?? "";
    var rankFilter = ViewBag.RankFilter as string ?? "";
    var statusFilter = ViewBag.StatusFilter as string ?? "";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 20;
    var totalItems = ViewBag.TotalItems as int? ?? 0;
    var totalPages = ViewBag.TotalPages as int? ?? 1;

    if (totalPages <= 0)
    {
        totalPages = 1;
    }

    var fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    var toItem = Math.Min(currentPage * pageSize, totalItems);

    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, currentPage + 2);
}

@functions {
    string GetRank(int points)
    {
        if (points >= 3000) return "Kim Cương";
        if (points >= 1500) return "Vàng";
        if (points >= 500) return "Bạc";
        return "Đồng";
    }

    string GetNextRankText(int points)
    {
        if (points < 500) return $"Còn {500 - points} điểm để lên Bạc";
        if (points < 1500) return $"Còn {1500 - points} điểm để lên Vàng";
        if (points < 3000) return $"Còn {3000 - points} điểm để lên Kim Cương";
        return "Đã đạt hạng cao nhất";
    }

    string GetRankBadgeClass(string rank)
    {
        return rank switch
        {
            "Kim Cương" => "bg-primary text-white",
            "Vàng" => "bg-warning text-dark",
            "Bạc" => "bg-secondary text-white",
            _ => "bg-info text-dark"
        };
    }

    string GetStatusBadgeClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status) || status == "Hoạt động")
        {
            return "bg-success text-white";
        }

        return "bg-danger text-white";
    }
}

<style>
    .nt-pagination-wrap {
        margin-top: 20px;
        padding: 14px 16px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
    }

    .nt-page-summary {
        display: flex;
        flex-direction: column;
        gap: 3px;
        color: #475569;
        font-size: 13px;
        font-weight: 600;
    }

    .nt-page-summary strong {
        color: #0f172a;
        font-size: 14px;
    }

    .nt-pagination {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .nt-page-btn,
    .nt-page-number,
    .nt-page-dots {
        min-width: 36px;
        height: 36px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid #dbeafe;
        background: #ffffff;
        color: #0369a1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.18s ease;
        box-shadow: 0 2px 6px rgba(2, 132, 199, 0.06);
    }

    .nt-page-btn:hover,
    .nt-page-number:hover {
        background: #e0f2fe;
        color: #075985;
        border-color: #7dd3fc;
        transform: translateY(-1px);
        text-decoration: none;
    }

    .nt-page-number.active {
        background: linear-gradient(135deg, #0284c7, #06b6d4);
        color: #ffffff;
        border-color: transparent;
        box-shadow: 0 8px 18px rgba(6, 182, 212, 0.28);
        pointer-events: none;
    }

    .nt-page-btn.disabled {
        background: #f1f5f9;
        color: #94a3b8;
        border-color: #e2e8f0;
        pointer-events: none;
        box-shadow: none;
    }

    .nt-page-dots {
        border: none;
        background: transparent;
        box-shadow: none;
        color: #94a3b8;
        min-width: 24px;
        padding: 0 4px;
    }

    .nt-page-size-pill {
        height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 13px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    @@media (max-width: 768px) {
        .nt-pagination-wrap {
            justify-content: center;
            text-align: center;
        }

        .nt-page-summary {
            width: 100%;
            align-items: center;
        }

        .nt-pagination {
            justify-content: center;
        }

        .nt-page-size-pill {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-glass p-4 mb-4">
            <h5 class="fw-bold mb-4 text-cyan">
                <i class="fa-solid fa-user-plus me-2"></i>
                Đăng ký khách hàng mới
            </h5>

            <form method="post" action="@Url.Action("Create", "Customer")">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label text-xs">Họ và tên</label>
                    <input type="text"
                           name="HoTen"
                           class="form-control"
                           required
                           placeholder="Nguyễn Văn A">
                </div>

                <div class="mb-3">
                    <label class="form-label text-xs">Số điện thoại</label>
                    <input type="text"
                           name="SoDienThoai"
                           class="form-control"
                           placeholder="09...">
                </div>

                <div class="mb-3">
                    <label class="form-label text-xs">Địa chỉ Email</label>
                    <input type="email"
                           name="Email"
                           class="form-control"
                           required
                           placeholder="khachhang@gmail.com">
                </div>

                <div class="mb-3">
                    <label class="form-label text-xs">Mật khẩu tạm thời</label>
                    <input type="password"
                           name="MatKhau"
                           class="form-control"
                           required
                           placeholder="Nhập mật khẩu cho khách hàng">

                    <div class="text-xxs text-muted mt-1">
                        Mật khẩu sẽ được lưu dưới dạng hash, không lưu mật khẩu thường.
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-xs">Địa chỉ</label>
                    <input type="text"
                           name="DiaChi"
                           class="form-control"
                           placeholder="TP. Hồ Chí Minh">
                </div>

                <button type="submit" class="btn btn-info rounded-pill px-4 w-100 fw-bold">
                    Tạo tài khoản thành viên
                </button>
            </form>
        </div>

        <div class="card card-glass p-4">
            <h5 class="fw-bold mb-3 text-cyan">
                <i class="fa-solid fa-ranking-star me-2"></i>
                Quy tắc tích điểm & thăng hạng
            </h5>

            <div class="text-sm text-dark">
                <div class="mb-2">
                    <b>+1 điểm</b> cho mỗi <b>10,000 đ</b> từ đơn hàng hoàn thành.
                </div>

                <div class="mb-2">
                    Đơn hàng bị hủy hoặc hoàn trả sẽ không được cộng điểm.
                </div>

                <hr />

                <div class="d-grid gap-2">
                    <div>
                        <span class="badge bg-info text-dark me-2">Đồng</span>
                        0 - 499 điểm
                    </div>

                    <div>
                        <span class="badge bg-secondary text-white me-2">Bạc</span>
                        500 - 1499 điểm
                    </div>

                    <div>
                        <span class="badge bg-warning text-dark me-2">Vàng</span>
                        1500 - 2999 điểm
                    </div>

                    <div>
                        <span class="badge bg-primary text-white me-2">Kim Cương</span>
                        từ 3000 điểm
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-glass p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h5 class="fw-bold mb-1 text-cyan">
                        <i class="fa-solid fa-user-group me-2"></i>
                        Thành viên mua sắm
                    </h5>

                    <div class="text-muted small">
                        Quản lý khách hàng theo phân trang, tìm kiếm, phân hạng và trạng thái.
                    </div>
                </div>

                <a href="@Url.Action("Index", "Customer")"
                   class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Đặt lại
                </a>
            </div>

            <form method="get" class="row g-2 mb-4">
                <input type="hidden" name="page" value="1" />

                <div class="col-md-4">
                    <input type="text"
                           name="keyword"
                           value="@keyword"
                           class="form-control"
                           placeholder="Tìm tên, SĐT, email...">
                </div>

                <div class="col-md-2">
                    <select name="rank" class="form-select">
                        <option value="">Tất cả hạng</option>
                        <option value="Đồng" selected="@(rankFilter == "Đồng")">Đồng</option>
                        <option value="Bạc" selected="@(rankFilter == "Bạc")">Bạc</option>
                        <option value="Vàng" selected="@(rankFilter == "Vàng")">Vàng</option>
                        <option value="Kim Cương" selected="@(rankFilter == "Kim Cương")">Kim Cương</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Hoạt động" selected="@(statusFilter == "Hoạt động")">Hoạt động</option>
                        <option value="Ngừng hoạt động" selected="@(statusFilter == "Ngừng hoạt động")">Ngừng hoạt động</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        <option value="10" selected="@(pageSize == 10)">10 dòng</option>
                        <option value="20" selected="@(pageSize == 20)">20 dòng</option>
                        <option value="50" selected="@(pageSize == 50)">50 dòng</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-info text-white rounded-pill">
                        <i class="fa-solid fa-magnifying-glass me-1"></i>
                        Lọc
                    </button>
                </div>
            </form>

            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div class="text-muted small">
                    Tổng số khách hàng: <strong>@totalItems</strong>
                </div>

                <div class="text-muted small">
                    Hiển thị <strong>@fromItem</strong> - <strong>@toItem</strong> / <strong>@totalItems</strong>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0 text-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Tích điểm</th>
                            <th>Phân hạng</th>
                            <th>Tiến độ</th>
                            <th>Ngày gia nhập</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Không tìm thấy khách hàng phù hợp.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                var rank = GetRank(item.DiemTichLuy);
                                var status = string.IsNullOrWhiteSpace(item.TrangThai) ? "Hoạt động" : item.TrangThai;

                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">
                                            @item.HoTen
                                        </div>

                                        <div class="text-xxs text-muted">
                                            Mã KH: @item.MaKhachHang
                                        </div>
                                    </td>

                                    <td>
                                        <div class="text-xs">
                                            @(string.IsNullOrWhiteSpace(item.SoDienThoai) ? "Chưa có SĐT" : item.SoDienThoai)
                                        </div>

                                        <div class="text-xxs text-muted">
                                            @(string.IsNullOrWhiteSpace(item.Email) ? "Chưa có email" : item.Email)
                                        </div>
                                    </td>

                                    <td class="fw-bold">
                                        @item.DiemTichLuy điểm
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill px-2 @GetRankBadgeClass(rank)">
                                            @rank
                                        </span>
                                    </td>

                                    <td>
                                        <span class="text-xs text-muted">
                                            @GetNextRankText(item.DiemTichLuy)
                                        </span>
                                    </td>

                                    <td>
                                        @item.NgayTao.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill px-2 @GetStatusBadgeClass(status)">
                                            @status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="nt-pagination-wrap">
                    <div class="nt-page-summary">
                        <strong>Trang @currentPage / @totalPages</strong>
                        <span>Hiển thị @fromItem - @toItem trong tổng @totalItems khách hàng</span>
                    </div>

                    <div class="nt-pagination">
                        <a class="nt-page-btn @(currentPage <= 1 ? "disabled" : "")"
                           href="@Url.Action("Index", new {
                               page = currentPage - 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               rank = rankFilter,
                               status = statusFilter
                           })"
                           title="Trang trước">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>

                        @if (startPage > 1)
                        {
                            <a class="nt-page-number"
                               href="@Url.Action("Index", new {
                                   page = 1,
                                   pageSize = pageSize,
                                   keyword = keyword,
                                   rank = rankFilter,
                                   status = statusFilter
                               })">
                                1
                            </a>

                            if (startPage > 2)
                            {
                                <span class="nt-page-dots">...</span>
                            }
                        }

                        @for (int p = startPage; p <= endPage; p++)
                        {
                            <a class="nt-page-number @(p == currentPage ? "active" : "")"
                               href="@Url.Action("Index", new {
                                   page = p,
                                   pageSize = pageSize,
                                   keyword = keyword,
                                   rank = rankFilter,
                                   status = statusFilter
                               })">
                                @p
                            </a>
                        }

                        @if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1)
                            {
                                <span class="nt-page-dots">...</span>
                            }

                            <a class="nt-page-number"
                               href="@Url.Action("Index", new {
                                   page = totalPages,
                                   pageSize = pageSize,
                                   keyword = keyword,
                                   rank = rankFilter,
                                   status = statusFilter
                               })">
                                @totalPages
                            </a>
                        }

                        <a class="nt-page-btn @(currentPage >= totalPages ? "disabled" : "")"
                           href="@Url.Action("Index", new {
                               page = currentPage + 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               rank = rankFilter,
                               status = statusFilter
                           })"
                           title="Trang sau">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </div>

                    <div class="nt-page-size-pill">
                        <i class="fa-solid fa-table-list"></i>
                        @pageSize dòng / trang
                    </div>
                </div>
            }
        </div>
    </div>
</div>