@model List<DATN64.Models.ChatMessage>
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "NovaTech AI"; }
<div class="container my-5">
    <h2>Tr? lı AI NovaTech</h2>
    <div class="chat-box border p-3 mb-3" style="height:400px; overflow-y:auto;">
        @foreach(var msg in Model) {
            <p><strong>@msg.Sender:</strong> @msg.Message <small class="text-muted">(@msg.Timestamp.ToString("HH:mm"))</small></p>
        }
    </div>
    <form asp-action="AskAi" method="post">
        <div class="input-group">
            <input type="text" name="question" class="form-control" placeholder="H?i tr? lı AI..." />
            <button class="btn btn-primary" type="submit">G?i</button>
        </div>
    </form>
</div>
