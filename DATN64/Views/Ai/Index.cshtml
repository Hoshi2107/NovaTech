@model List<DATN64.Models.MockDataService.ChatMessage>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Trợ lý ảo AI NovaTech";
    ViewData["BreadcrumbActive"] = "AI Assistant";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card card-glass p-4" style="height: 80vh; display: flex; flex-direction: column;">
            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom border-secondary border-opacity-25 pb-2">
                <h5 class="fw-bold m-0 text-cyan"><i class="fa-solid fa-robot me-2"></i>AI Assistant - Quản trị thông minh</h5>
                <span class="badge bg-success-subtle text-success px-3 py-1 text-xs">AI Online</span>
            </div>

            <!-- Chat screen box -->
            <div class="flex-grow-1 overflow-y-auto px-2 py-3 mb-3 d-flex flex-column gap-3" id="chatContainer">
                @foreach (var msg in Model)
                {
                    if (msg.Sender == "AI")
                    {
                        <div class="d-flex align-items-start gap-2.5 max-w-75">
                            <div class="bg-gradient-cyan text-white d-flex align-items-center justify-content-center rounded-circle shadow" style="width: 32px; height: 32px; flex-shrink: 0;"><i class="fa-solid fa-robot text-xs text-dark"></i></div>
                            <div class="bg-dark p-3 rounded-3 border border-secondary border-opacity-25">
                                <p class="text-xs mb-1 text-info fw-bold">NovaTech AI</p>
                                <p class="text-xs text-light mb-0" style="line-height: 1.5;">@msg.Message</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-start gap-2.5 justify-content-end max-w-75 ms-auto">
                            <div class="bg-info bg-opacity-10 p-3 rounded-3 border border-info border-opacity-20 text-end">
                                <p class="text-xs mb-1 text-warning fw-bold">Quản trị viên</p>
                                <p class="text-xs text-light mb-0" style="line-height: 1.5;">@msg.Message</p>
                            </div>
                            <div class="bg-gradient-purple text-white d-flex align-items-center justify-content-center rounded-circle shadow" style="width: 32px; height: 32px; flex-shrink: 0;"><i class="fa-solid fa-user-tie text-xs"></i></div>
                        </div>
                    }
                }
            </div>

            <!-- Question input area -->
            <form method="post" action="@Url.Action("AskAi", "Ai")" class="border-top border-secondary border-opacity-25 pt-3">
                <div class="input-group">
                    <input type="text" name="question" required class="form-control bg-dark border-secondary border-opacity-50 text-white rounded-start-pill py-2.5 px-4 text-xs" placeholder="Hỏi AI về doanh thu, tồn kho hoặc gợi ý chương trình bán hàng...">
                    <button type="submit" class="btn btn-info rounded-end-pill px-4"><i class="fa-solid fa-paper-plane text-dark"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto scroll chat screen to bottom
        window.addEventListener('load', function() {
            var container = document.getElementById('chatContainer');
            if(container) {
                container.scrollTop = container.scrollHeight;
            }
        });
    </script>
}
