@model DATN64.Models.ViewModels.InventoryReportViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Báo cáo kho";
}

@section Styles {
<style>
    .kpi-inv { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:18px 20px; box-shadow:0 2px 8px rgba(0,0,0,.04); height:100%; }
    .kpi-inv .val { font-size:1.5rem; font-weight:700; color:#1e293b; }
    .kpi-inv .lbl { font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; color:#64748b; }
    .inv-table th { background:#f8fafc; color:#475569; font-size:0.78rem; text-transform:uppercase; font-weight:700; letter-spacing:.05em; border-bottom:2px solid #e2e8f0; }
    .inv-table td { font-size:0.875rem; color:#1e293b; vertical-align:middle; border-bottom:1px solid #f1f5f9; }
    .inv-table tbody tr:hover td { background:#f8fafc; }
    .stock-progress { width:100%; height:7px; background:#f1f5f9; border-radius:9px; overflow:hidden; min-width:70px; }
    .stock-progress-fill { height:100%; border-radius:9px; }
    .section-card { background:#fff; border:1px solid #e2e8f0; border-radius:12px; padding:20px; box-shadow:0 2px 8px rgba(0,0,0,.04); }
    .import-row td { font-size:0.84rem; }
</style>
}

<!-- Header -->
<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h3 class="fw-bold mb-1" style="color:#1e293b">
                <i class="fa-solid fa-warehouse text-primary me-2"></i>Báo cáo Tồn kho
            </h3>
            <p class="text-muted text-xs mb-0">Giá trị tồn kho tính theo <strong>giá nhập</strong> (giá vốn thực tế).</p>
        </div>
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="fa-solid fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="kpi-inv">
            <div class="lbl mb-2"><i class="fa-solid fa-boxes-stacked me-1 text-primary"></i>Tổng SKU</div>
            <div class="val">@Model.TongSKU.ToString("N0")</div>
            <small class="text-muted">Sản phẩm trong DB</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-inv">
            <div class="lbl mb-2"><i class="fa-solid fa-circle-check me-1 text-success"></i>Đủ hàng</div>
            <div class="val text-success">@Model.SoLuongDuHang.ToString("N0")</div>
            <small class="text-muted">Tồn kho > 5</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-inv">
            <div class="lbl mb-2"><i class="fa-solid fa-triangle-exclamation me-1 text-warning"></i>Sắp hết</div>
            <div class="val text-warning">@Model.SoLuongSapHet.ToString("N0")</div>
            <small class="text-muted">Tồn kho 1–5</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-inv">
            <div class="lbl mb-2"><i class="fa-solid fa-circle-xmark me-1 text-danger"></i>Hết hàng</div>
            <div class="val text-danger">@Model.SoLuongHetHang.ToString("N0")</div>
            <small class="text-muted">Tồn kho = 0</small>
        </div>
    </div>
</div>

<!-- Giá trị tồn kho banner -->
<div class="mb-4 p-4 rounded-3 d-flex align-items-center gap-3"
     style="background:linear-gradient(135deg,#0284c7 0%,#0369a1 100%);color:#fff;">
    <i class="fa-solid fa-money-bill-trend-up fs-2 opacity-75"></i>
    <div>
        <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;opacity:.8">
            Tổng giá trị tồn kho (giá vốn = SoLuongTon × GiaNhap)
        </div>
        <div style="font-size:2rem;font-weight:700;line-height:1.2">
            @Model.TongGiaTriTonKho.ToString("N0")₫
        </div>
    </div>
</div>

<!-- Inventory Table -->
<div class="section-card mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <span class="fw-semibold text-sm" style="color:#475569">
            <i class="fa-solid fa-list me-1"></i>Danh sách tồn kho — <strong>@Model.TongSKU</strong> sản phẩm
        </span>
        <div class="d-flex gap-2 align-items-center">
            <input type="text" id="invSearch" class="form-control form-control-sm" placeholder="Tìm sản phẩm..." style="width:200px" onkeyup="filterInv()">
        </div>
    </div>
    <div class="table-responsive">
        <table class="table inv-table mb-0" id="invTable">
            <thead>
                <tr>
                    <th>Tên sản phẩm</th>
                    <th class="text-center">Tồn kho</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end">Giá nhập</th>
                    <th class="text-end">Giá bán</th>
                    <th class="text-end">Giá trị vốn</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var stockPct   = item.SoLuongTon == 0 ? 0 : Math.Min(100, item.SoLuongTon * 5);
                    var stockColor = item.SoLuongTon == 0 ? "#dc2626" : item.SoLuongTon <= 5 ? "#f59e0b" : "#16a34a";
                    var rowBg      = item.SoLuongTon == 0 ? "background:#fef2f2" : item.SoLuongTon <= 5 ? "background:#fffbeb" : "";
                    <tr style="@rowBg">
                        <td class="fw-semibold">@item.TenSanPham</td>
                        <td class="text-center">
                            <div class="d-flex align-items-center gap-2 justify-content-center">
                                <div class="stock-progress" style="max-width:70px">
                                    <div class="stock-progress-fill" style="width:@stockPct%;background:@stockColor"></div>
                                </div>
                                <span class="fw-bold" style="color:@stockColor;min-width:28px">@item.SoLuongTon</span>
                            </div>
                        </td>
                        <td class="text-center">
                            @{
                                var (sBg, sFg, sLabel) = item.SoLuongTon == 0
                                    ? ("#fef2f2", "#dc2626", "Hết hàng")
                                    : item.SoLuongTon <= 5
                                        ? ("#fffbeb", "#d97706", "Sắp hết")
                                        : ("#f0fdf4", "#16a34a", "Đủ hàng");
                            }
                            <span class="badge rounded-pill" style="background:@sBg;color:@sFg;border:1px solid @sFg;font-size:0.76rem">
                                @sLabel
                            </span>
                        </td>
                        <td class="text-end text-muted">@item.GiaNhap.ToString("N0")₫</td>
                        <td class="text-end">@item.GiaBan.ToString("N0")₫</td>
                        <td class="text-end fw-semibold text-primary">@item.GiaTriVon.ToString("N0")₫</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Recent Imports -->
<div class="section-card">
    <div class="fw-semibold text-sm mb-3" style="color:#475569">
        <i class="fa-solid fa-circle-down me-1 text-success"></i>10 Phiếu nhập gần nhất
    </div>
    @if (!Model.RecentImports.Any())
    {
        <div class="text-center text-muted py-4">
            <i class="fa-solid fa-inbox fs-3 mb-2 d-block"></i>Chưa có phiếu nhập
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table inv-table import-row mb-0">
                <thead>
                    <tr>
                        <th>Mã phiếu</th>
                        <th>Ngày nhập</th>
                        <th>Nhà cung cấp</th>
                        <th class="text-end">Tổng SL</th>
                        <th class="text-end">Tổng giá trị</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var imp in Model.RecentImports)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@imp.MaPhieuNhap</td>
                            <td>@(imp.NgayNhap?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td>@imp.NhaCungCap</td>
                            <td class="text-end">@imp.TongSoLuong.ToString("N0")</td>
                            <td class="text-end fw-semibold text-primary">@imp.TongGiaTri.ToString("N0")₫</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
function filterInv() {
    var kw = document.getElementById('invSearch').value.toLowerCase();
    document.querySelectorAll('#invTable tbody tr').forEach(function(tr) {
        tr.style.display = tr.cells[0].textContent.toLowerCase().includes(kw) ? '' : 'none';
    });
}
</script>
}
