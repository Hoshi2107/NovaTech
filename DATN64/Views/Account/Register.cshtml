@model DATN64.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - NovaTech Store</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f1f5f9 0%, #cbd5e1 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            color: #0f172a;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(226, 232, 240, 0.9);
            border-radius: 24px;
            padding: 2.5rem;
            width: 100%;
            max-width: 560px;
            box-shadow: 0 25px 50px rgba(15, 23, 42, 0.08);
        }
        .text-neon {
            background: linear-gradient(45deg, #0284c7, #0369a1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .form-control {
            background: rgba(255, 255, 255, 0.98) !important;
            border: 1px solid #cbd5e1 !important;
            color: #0f172a !important;
            border-radius: 14px;
            padding: 12px 16px;
        }
        .form-control:focus {
            background: #fff !important;
            border-color: #0284c7 !important;
            box-shadow: 0 0 15px rgba(2, 132, 199, 0.18) !important;
            color: #0f172a !important;
        }
        .btn-register,
        .btn-send-otp {
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 12px 16px;
            border-radius: 14px;
            transition: all 0.35s ease;
            background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        }
        .btn-register:hover,
        .btn-send-otp:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(2, 132, 199, 0.2);
        }
        .info-box {
            background: rgba(2, 132, 199, 0.08);
            border: 1px solid rgba(2, 132, 199, 0.18);
            border-radius: 14px;
            padding: 16px;
            color: #0f172a;
        }
        .otp-box {
            background: #eff6ff;
            border: 1px dashed rgba(2, 132, 199, 0.4);
            border-radius: 14px;
            padding: 14px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-neon"><i class="fa-solid fa-bolt-lightning me-2"></i>NovaTech</h2>
            <p class="text-muted text-sm">Đăng ký tài khoản khách hàng nhanh chóng bằng email hoặc số điện thoại.</p>
        </div>

        <form method="post" action="@Url.Action("Register", "Account")">
            @Html.ValidationSummary(true, "", new { @class = "text-danger text-sm mb-3" })
            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success py-2">@ViewBag.SuccessMessage</div>
            }
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label text-sm text-secondary">Họ và tên</label>
                    <input type="text" name="FullName" class="form-control" value="@Model.FullName" required placeholder="Nguyễn Văn A">
                </div>
                <div class="col-12">
                    <label class="form-label text-sm text-secondary">Email</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-envelope"></i></span>
                        <input type="email" name="Email" class="form-control border-start-0" value="@Model.Email" placeholder="email@domain.com">
                    </div>
                    <div class="text-xs text-muted mt-1">Nhập email nếu bạn muốn dùng email. Hoặc để trống và dùng số điện thoại.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-sm text-secondary">Số điện thoại</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-phone"></i></span>
                        <input type="text" name="Phone" class="form-control border-start-0" value="@Model.Phone" placeholder="0901234567">
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-sm text-secondary">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="Password" id="passwordInput" class="form-control border-start-0" required placeholder="••••••••">
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-sm text-secondary">Xác nhận mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="ConfirmPassword" id="confirmPasswordInput" class="form-control border-start-0" required placeholder="Nhập lại mật khẩu">
                    </div>
                </div>
                <div class="col-12">
                    <small class="text-muted">Bạn có thể đăng ký bằng email hoặc số điện thoại. Nếu không dùng email, chỉ cần nhập số điện thoại và mật khẩu.</small>
                </div>
            </div>

            <button type="submit" name="submitAction" value="register" class="btn btn-register w-100 mt-4">
                <i class="fa-solid fa-user-plus me-2"></i>Hoàn tất đăng ký
            </button>
        </form>

        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25 text-center">
            <p class="text-sm text-muted mb-2">Đã có tài khoản?</p>
            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary rounded-pill px-4 py-2 fw-bold">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập ngay
            </a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
