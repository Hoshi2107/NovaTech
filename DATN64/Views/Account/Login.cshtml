@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - NovaTech System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f1f5f9 0%, #cbd5e1 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            color: #0f172a;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.08);
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }
        .text-neon {
            background: linear-gradient(45deg, #0284c7, #0369a1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .form-control {
            background: rgba(255, 255, 255, 0.9) !important;
            border: 1px solid #cbd5e1 !important;
            color: #0f172a !important;
            border-radius: 10px;
            padding: 10px 15px;
        }
        .form-control:focus {
            background: #fff !important;
            border-color: #0284c7 !important;
            color: #0f172a !important;
            box-shadow: 0 0 10px rgba(2, 132, 199, 0.15) !important;
        }
        .btn-login {
            background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 10px;
            border-radius: 10px;
            transition: all 0.3s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(2, 132, 199, 0.3);
            color: #fff;
        }
        .input-group-text {
            background-color: #f8fafc !important;
            border: 1px solid #cbd5e1 !important;
            color: #64748b !important;
        }
        .badge {
            background-color: #e2e8f0 !important;
            color: #334155 !important;
            border: 1px solid #cbd5e1;
            transition: all 0.2s;
        }
        .badge:hover {
            background-color: #0284c7 !important;
            color: white !important;
            border-color: #0284c7;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-neon"><i class="fa-solid fa-bolt-lightning me-2"></i>NovaTech</h2>
            <p class="text-muted text-sm">Hệ thống quản lý bán hàng đa kênh</p>
        </div>

        <form method="post" action="@Url.Action("Login", "Account")">
            @Html.ValidationSummary(true, "", new { @class = "text-danger text-sm mb-3" })

            <div class="mb-3">
                <label class="form-label text-sm text-secondary">Email đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-envelope"></i></span>
                    <input type="email" name="email" class="form-control border-start-0" required placeholder="nhanvien@novatech.vn">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-sm text-secondary">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" id="passwordInput" class="form-control border-start-0 border-end-0" required placeholder="••••••••">
                    <button class="btn btn-outline-secondary" type="button" id="togglePasswordBtn">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 text-xs">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label text-muted" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <a href="@Url.Action("ForgotPassword", "Account")" class="text-info text-decoration-none">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn btn-login w-100">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập
            </button>
        </form>

        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25 text-center">
            <p class="text-xs text-muted mb-2">Tài khoản Demo hệ thống:</p>
            <div class="d-flex flex-wrap justify-content-center gap-1.5" style="gap: 5px;">
                <span class="badge bg-secondary text-xs cursor-pointer" onclick="fillDemo('admin@novatech.vn')">Super Admin</span>
                <span class="badge bg-secondary text-xs cursor-pointer" onclick="fillDemo('sale@novatech.vn')">Bán hàng</span>
                <span class="badge bg-secondary text-xs cursor-pointer" onclick="fillDemo('kho@novatech.vn')">Nhân viên kho</span>
                <span class="badge bg-secondary text-xs cursor-pointer" onclick="fillDemo('customer@gmail.com')">Khách hàng</span>
            </div>
            <div id="demoCredentialsInfo" class="mt-2 p-2 rounded bg-info bg-opacity-10 border border-info border-opacity-20 text-xs text-info" style="display: none; transition: all 0.3s;">
                <i class="fa-solid fa-circle-info me-1"></i>Đã chọn: <strong id="infoEmail"></strong> | Mật khẩu: <strong>123</strong>
            </div>
            <p class="text-xxs text-muted mt-2">(Mật khẩu mặc định là: 123)</p>
        </div>
    </div>

    <script>
        function fillDemo(email) {
            document.getElementsByName('email')[0].value = email;
            
            const pwdInput = document.getElementById('passwordInput');
            pwdInput.value = '123';
            pwdInput.type = 'text'; // Hiển thị mật khẩu rõ ràng để người dùng nhìn thấy
            
            // Cập nhật icon của nút ẩn/hiện mật khẩu thành "eye-slash" vì mật khẩu đang được hiện
            const toggleIcon = document.querySelector('#togglePasswordBtn i');
            if (toggleIcon) {
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            }

            // Hiển thị thông báo thông tin tài khoản demo đã chọn
            const infoDiv = document.getElementById('demoCredentialsInfo');
            const infoEmail = document.getElementById('infoEmail');
            if (infoDiv && infoEmail) {
                infoEmail.textContent = email;
                infoDiv.style.display = 'block';
            }
        }

        // Toggle password visibility
        document.getElementById('togglePasswordBtn').addEventListener('click', function() {
            const pwdInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                pwdInput.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });
    </script>
</body>
</html>

