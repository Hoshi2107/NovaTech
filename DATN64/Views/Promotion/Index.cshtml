@model List<DATN64.Models.MockDataService.Voucher>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý khuyến mãi";
    ViewData["BreadcrumbActive"] = "Khuyến mãi";
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-glass p-4">
            <h5 class="fw-bold mb-4 text-cyan">Tạo Voucher khuyến mãi</h5>
            <form method="post" action="@Url.Action("Create", "Promotion")">
                <div class="mb-3">
                    <label class="form-label text-xs">Mã giảm giá</label>
                    <input type="text" name="Code" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="SUMMER50">
                </div>
                <div class="mb-3">
                    <label class="form-label text-xs">Loại áp dụng</label>
                    <select name="Type" class="form-select bg-dark border-secondary border-opacity-50 text-white">
                        <option value="Giảm %">Giảm % hóa đơn</option>
                        <option value="Giảm tiền">Giảm số tiền trực tiếp</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label text-xs">Giá trị giảm</label>
                    <input type="number" name="Value" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="10 hoặc 500000">
                </div>
                <div class="mb-3">
                    <label class="form-label text-xs">Đơn tối thiểu</label>
                    <input type="number" name="MinOrderValue" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="500000">
                </div>
                <div class="mb-4">
                    <label class="form-label text-xs">Số lượng phát hành</label>
                    <input type="number" name="Quantity" class="form-control bg-dark border-secondary border-opacity-50 text-white" required value="50">
                </div>
                <button type="submit" class="btn btn-info rounded-pill px-4 w-100 fw-bold">Kích hoạt Voucher</button>
            </form>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-glass p-4">
            <h5 class="fw-bold mb-4 text-cyan"><i class="fa-solid fa-gift me-2"></i>Chiến dịch khuyến mãi & Voucher</h5>
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 text-sm align-middle">
                    <thead>
                        <tr>
                            <th>Mã Voucher</th>
                            <th>Hình thức</th>
                            <th>Mức Giảm</th>
                            <th>Đơn hàng tối thiểu</th>
                            <th>Số lượng</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model)
                        {
                            <tr>
                                <td><code class="fs-6 text-warning">@v.Code</code></td>
                                <td>@v.Type</td>
                                <td>
                                    @if (v.Type == "Giảm %")
                                    {
                                        <span>@v.Value %</span>
                                    }
                                    else
                                    {
                                        <span>@v.Value.ToString("N0") đ</span>
                                    }
                                </td>
                                <td>@v.MinOrderValue.ToString("N0") đ</td>
                                <td>@v.Quantity Voucher</td>
                                <td>
                                    <span class="badge bg-success">@v.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
