@model List<DATN64.Models.Voucher>
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Quản lý Khuyến Mãi"; }
<div class="container my-5">
    <h2>Quản lý Voucher Khuyến Mãi</h2>
    <table class="table">
        <thead><tr><th>Mã Voucher</th><th>Mã Code</th><th>Giá Trị</th><th>Số Lượng</th><th>Ngày Bắt Đầu</th><th>Ngày Kết Thúc</th></tr></thead>
        <tbody>
            @foreach(var item in Model) {
                <tr>
                    <td>@item.MaVoucher</td>
                    <td>@item.MaCode</td>
                    <td>@item.GiaTri?.ToString("N0") đ</td>
                    <td>@item.SoLuong</td>
                    <td>@item.NgayBatDau?.ToString("dd/MM/yyyy")</td>
                    <td>@item.NgayKetThuc?.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>