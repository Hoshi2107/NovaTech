        }
        body[data-theme="dark"] .border-light-custom {
            border-color: rgba(255, 255, 255, 0.08) !important;
        }
        body[data-theme="dark"] .border-bottom-custom {
            border-bottom-color: rgba(255, 255, 255, 0.08);
        }
        body[data-theme="dark"] .table-light-custom {
            background-color: rgba(255, 255, 255, 0.04);
            color: var(--nt-text);
        }
        body[data-theme="dark"] .text-secondary-custom {
            color: #cbd5e1;
        }
        body[data-theme="dark"] .text-primary-custom {
            color: #38bdf8;
        }
        body[data-theme="dark"] .text-muted-custom {
            color: #94a3b8;
        }
        body[data-theme="dark"] .nav-link-policy {
            color: #94a3b8;
        }
        body[data-theme="dark"] .nav-link-policy:hover {
            background-color: rgba(56, 189, 248, 0.08);
            color: #38bdf8;
        }
        body[data-theme="dark"] .nav-link-policy.active {
            background-color: #0284c7 !important;
            color: #ffffff !important;
        }
        body[data-theme="dark"] .bg-primary-subtle {
            background-color: rgba(2, 132, 199, 0.15) !important;
            color: #38bdf8 !important;
        }
        body[data-theme="dark"] .alert-info-custom {
            background-color: rgba(2, 132, 199, 0.05);
            border-color: rgba(2, 132, 199, 0.2);
            color: #38bdf8;
        }
        body[data-theme="dark"] .alert-warning-custom {
            background-color: rgba(217, 119, 6, 0.05);
            border-color: rgba(217, 119, 6, 0.2);
            color: #fbbf24;
        }
        body[data-theme="dark"] .alert-success-custom {
            background-color: rgba(22, 163, 74, 0.05);
            border-color: rgba(22, 163, 74, 0.2);
            color: #4ade80;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Add custom animation trigger on tab click
            const tabButtons = document.querySelectorAll('.nav-link-policy');
            tabButtons.forEach(button => {
                button.addEventListener('shown.bs.tab', function (event) {
                    const targetPane = document.querySelector(event.target.getAttribute('data-bs-target'));
                    if (targetPane) {
                        targetPane.classList.remove('animate-fade-in-policy');
                        // Trigger reflow to restart animation
                        void targetPane.offsetWidth;
                        targetPane.classList.add('animate-fade-in-policy');
                    }
                });
            });
        });
    </script>
}
