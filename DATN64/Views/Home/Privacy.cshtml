            font-size: 0.65rem;
            font-weight: bold;
        }

        /* Dark Mode support overrides */
        body[data-theme="dark"] .policy-hero {
            background-color: var(--nt-card);
            border-color: rgba(255, 255, 255, 0.08);
        }
        body[data-theme="dark"] .card-policy-menu,
        body[data-theme="dark"] .card-policy-content {
            background-color: var(--nt-card);
            border-color: rgba(255, 255, 255, 0.08);
        }
        body[data-theme="dark"] .bg-light-custom {
