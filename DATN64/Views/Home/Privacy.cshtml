@section Styles {
    <style>
        /* Modern Premium Style Design overrides */
        .text-gradient-policy {
            background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .policy-hero {
            background-color: var(--nt-card);
            border: 1px solid rgba(2, 132, 199, 0.08);
            box-shadow: 0 4px 20px rgba(0,0,0,0.02);
            transition: all 0.3s ease;
        }

        .policy-hero-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 100% 0%, rgba(2, 132, 199, 0.08) 0%, transparent 60%);
            z-index: 0;
        }

        .card-policy-menu {
            background-color: var(--nt-card);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 16px;
        }

        .card-policy-content {
            background-color: var(--nt-card);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 16px;
            color: var(--nt-text);
        }

        /* Tabs Menu Navigation */
        .nav-link-policy {
            background: transparent;
            border: none;
            color: var(--nt-muted);
            font-size: 0.9rem;
            font-weight: 600;
            padding: 12px 18px;
            border-radius: 12px;
            text-align: left;
            display: flex;
            align-items: center;
            width: 100%;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 6px;
        }

        .nav-link-policy:hover {
            background-color: rgba(2, 132, 199, 0.05);
            color: var(--nt-primary);
            padding-left: 22px;
        }

        .nav-link-policy.active {
            background-color: var(--nt-primary) !important;
            color: #ffffff !important;
            box-shadow: 0 8px 16px -4px rgba(2, 132, 199, 0.35);
        }

        .nav-link-policy i {
            font-size: 1.1rem;
            transition: transform 0.25s ease;
        }

        .nav-link-policy:hover i {
            transform: scale(1.1);
        }

        /* Light/Dark dynamic theme components */
        .border-bottom-custom {
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }
        .border-light-custom {
            border-color: rgba(0, 0, 0, 0.08) !important;
        }
        .bg-light-custom {
            background-color: #f8fafc;
        }
        .table-light-custom {
            background-color: #f1f5f9;
        }
        .text-secondary-custom {
            color: #334155;
        }
        .text-primary-custom {
            color: #0284c7;
        }
        .text-muted-custom {
            color: #64748b;
        }

        /* Alert blocks */
        .alert-policy {
            border: 1px solid transparent;
        }
        .alert-info-custom {
            background-color: #f0f9ff;
            border-color: #bae6fd;
            color: #0369a1;
        }
        .alert-warning-custom {
            background-color: #fffbeb;
            border-color: #fde68a;
            color: #b45309;
        }
        .alert-success-custom {
            background-color: #f0fdf4;
            border-color: #bbf7d0;
            color: #15803d;
        }

        .icon-shape {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            flex-shrink: 0;
        }
        .bg-primary-subtle {
            background-color: #e0f2fe !important;
        }

        /* Support Box Widget */
        .support-widget {
            background: linear-gradient(135deg, rgba(2, 132, 199, 0.03) 0%, rgba(3, 105, 161, 0.03) 100%);
            border: 1px dashed rgba(2, 132, 199, 0.25);
        }

        /* Animation */
        .animate-fade-in-policy {
            animation: fadeInPolicy 0.3s ease-out forwards;
        }
        @@keyframes fadeInPolicy {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Policy list items style */
        .policy-body ul {
            padding-left: 20px;
            margin-bottom: 24px;
        }
        .policy-body li {
            margin-bottom: 8px;
            position: relative;
            list-style-type: none;
            padding-left: 5px;
        }
        .policy-body li::before {
            content: "•";
            color: var(--nt-primary);
            font-weight: bold;
            display: inline-block;
            width: 1em;
