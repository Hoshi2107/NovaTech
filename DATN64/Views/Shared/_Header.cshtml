@using Microsoft.AspNetCore.Http
@using DATN64.Models
@inject IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var userName = session?.GetString("UserName") ?? "Khách";
    var userEmail = session?.GetString("UserEmail") ?? "";
    var userRolesStr = session?.GetString("UserRoles") ?? "";
    var notifications = MockDataService.Instance.Notifications.OrderByDescending(n => n.Timestamp).Take(5).ToList();
    var unreadCount = MockDataService.Instance.Notifications.Count(n => !n.IsRead);
}
<header class="header position-sticky top-0 z-2 bg-glass border-bottom border-secondary border-opacity-25 px-4 py-3 d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-icon d-lg-none text-dark fs-4" id="sidebarToggle">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="search-box position-relative d-none d-md-block" style="width: 300px;">
            <input type="text" class="form-control bg-white border border-light text-dark rounded-pill ps-4 pe-5" placeholder="Tìm kiếm nhanh..." style="border-color: #e2e8f0 !important; color: #0f172a !important;">
            <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y end-0 me-3 text-muted"></i>
        </div>
    </div>

    <div class="d-flex align-items-center gap-3">
        <!-- Dashboard Option Button (Nếu có Role nhân viên/admin) -->
        <a href="@Url.Action("Selection", "Portal")" class="btn btn-outline-info rounded-pill px-3 py-1 text-sm">
            <i class="fa-solid fa-network-wired me-2"></i>Cổng Portal
        </a>

        <!-- Notifications Dropdown -->
        <div class="dropdown">
            <button class="btn btn-icon text-dark position-relative" type="button" data-bs-toggle="dropdown">
                <i class="fa-solid fa-bell fs-5"></i>
                @if (unreadCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; padding: 0.25em 0.5em;">
                        @unreadCount
                    </span>
                }
            </button>
            <div class="dropdown-menu dropdown-menu-end bg-white border border-light shadow p-2" style="width: 320px; border-radius: 12px;">
                <div class="px-3 py-2 border-bottom border-light d-flex justify-content-between align-items-center text-dark">
                    <span class="fw-bold">Thông báo mới</span>
                    <a href="@Url.Action("MarkAllRead", "Dashboard")" class="text-xs text-info text-decoration-none">Đọc tất cả</a>
                </div>
                <div class="notification-list" style="max-height: 250px; overflow-y: auto;">
                    @foreach (var n in notifications)
                    {
                        var iconClass = "fa-circle-info text-info";
                        if (n.Type == "Đơn mới") iconClass = "fa-cart-shopping text-success";
                        else if (n.Type == "Hết hàng") iconClass = "fa-triangle-exclamation text-warning";
                        else if (n.Type == "Đồng bộ lỗi") iconClass = "fa-circle-xmark text-danger";

                        <div class="dropdown-item py-2.5 px-3 border-bottom border-light d-flex gap-3 align-items-start whitespace-normal text-dark">
                            <div class="fs-5 mt-1"><i class="fa-solid @iconClass"></i></div>
                            <div>
                                <div class="fw-semibold text-sm">@n.Title</div>
                                <div class="text-xs text-muted mt-0.5" style="line-height:1.3; color: #475569 !important;">@n.Message</div>
                                <div class="text-xxs text-muted mt-1">@n.Timestamp.ToString("HH:mm - dd/MM")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- User Profile Dropdown -->
        <div class="dropdown">
            <button class="btn d-flex align-items-center gap-2 text-dark border-0 bg-transparent" type="button" data-bs-toggle="dropdown">
                <div class="avatar bg-gradient-cyan text-white d-flex align-items-center justify-content-center rounded-circle shadow fw-bold" style="width: 36px; height: 36px;">
                    @userName.Substring(0, 1).ToUpper()
                </div>
                <span class="fw-semibold text-sm d-none d-sm-inline">@userName</span>
                <i class="fa-solid fa-chevron-down text-xs text-muted"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end bg-white border border-light shadow text-dark">
                <li>
                    <div class="px-3 py-2 border-bottom border-light text-dark">
                        <span class="d-block fw-semibold text-sm">@userName</span>
                        <span class="d-block text-xs text-muted" style="color: #64748b !important;">@userRolesStr</span>
                    </div>
                </li>
                <li>
                    <a class="dropdown-item py-2 text-dark" href="@Url.Action("Profile", "Account")">
                        <i class="fa-solid fa-id-card me-2 text-cyan"></i>Hồ sơ cá nhân
                    </a>
                </li>
                <li>
                    <a class="dropdown-item py-2 text-dark" href="@Url.Action("ChangePassword", "Account")">
                        <i class="fa-solid fa-key me-2 text-cyan"></i>Đổi mật khẩu
                    </a>
                </li>
                <li><hr class="dropdown-divider border-light"></li>
                <li>
                    <a class="dropdown-item py-2 text-danger" href="@Url.Action("Logout", "Account")">
                        <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                    </a>
                </li>
            </ul>
        </div>
    </div>
</header>
