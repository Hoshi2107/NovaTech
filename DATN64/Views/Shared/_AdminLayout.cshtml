<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NovaTech ERP</title>
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/admin_custom.css" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light text-dark">

    <!-- Loading Screen -->
    <div id="pageLoader">
        <div class="text-center">
            <div class="spinner-border text-info mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
            <h5 class="text-cyan tracking-widest fw-semibold">NOVATECH ERP</h5>
            <p class="text-muted-custom text-xs">Đang tải dữ liệu hệ thống...</p>
        </div>
    </div>

    <!-- Sidebar Layout -->
    @await Html.PartialAsync("_Sidebar")

    <!-- Content Area wrapper -->
    <div class="main-content d-flex flex-column animate-fade-in">
        <!-- Header -->
        @await Html.PartialAsync("_Header")

        <!-- Main Body -->
        <div class="container-fluid p-4 flex-grow-1">
            <!-- Breadcrumbs -->
            @{
                var breadcrumbActive = ViewData["BreadcrumbActive"]?.ToString();
                if (string.IsNullOrEmpty(breadcrumbActive))
                {
                    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
                    var actionName = ViewContext.RouteData.Values["action"]?.ToString();
                    
                    breadcrumbActive = controllerName switch
                    {
                        "Dashboard" => "Tổng quan",
                        "Product" => actionName switch {
                            "Index" => "Sản phẩm",
                            "Categories" => "Danh mục",
                            "Brands" => "Thương hiệu",
                            "Suppliers" => "Nhà cung cấp",
                            _ => "Hàng hóa"
                        },
                        "Inventory" => actionName switch {
                            "Index" => "Tồn kho",
                            "Import" => "Nhập kho",
                            "Export" => "Xuất kho",
                            _ => "Kho bãi"
                        },
                        "Order" => "Đơn hàng",
                        "Customer" => "Khách hàng",
                        "Promotion" => "Khuyến mãi",
                        "TikTok" => "TikTok Shop",
                        "Ai" => "AI Assistant",
                        "Employee" => "Nhân sự & RBAC",
                        "Report" => "Báo cáo",
                        "Setting" => "Cấu hình",
                        _ => controllerName
                    };
                }
            }
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb bg-transparent p-0 m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")" class="text-info text-decoration-none text-xs"><i class="fa-solid fa-house me-1"></i>Trang chủ</a></li>
                    @if (!string.IsNullOrEmpty(breadcrumbActive))
                    {
                        <li class="breadcrumb-item text-muted-custom text-xs" aria-current="page">@breadcrumbActive</li>
                    }
                </ol>
            </nav>

            <!-- Render Body -->
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="bg-glass border-top border-secondary border-opacity-10 py-3 text-center text-xs text-muted-custom">
            <span>© 2026 Cửa Hàng Công Nghệ NovaTech. Xây dựng bởi Antigravity. OS: Windows, Server: DESKTOP-MO3O9SP.</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Page loader delay simulation
        window.addEventListener('load', function () {
            const loader = document.getElementById('pageLoader');
            setTimeout(() => {
                if(loader) {
                    loader.classList.add('hidden');
                }
            }, 300);
        });
    </script>
    @await Html.PartialAsync("_ToastNotification")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
