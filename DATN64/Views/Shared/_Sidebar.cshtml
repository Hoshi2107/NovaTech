@using DATN64.Models
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var userRolesStr = session?.GetString("UserRoles") ?? "";
    var roles = userRolesStr.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var act = ViewContext.RouteData.Values["action"]?.ToString();
    var tab = HttpContextAccessor.HttpContext?.Request.Query["tab"].ToString() ?? "";

    bool canViewProduct    = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Product");
    bool canViewInventory  = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Inventory");
    bool canViewOrder      = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Order");
    bool canViewCustomer   = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Customer");
    bool canViewPromotion  = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Promotion");
    bool canViewAccounting = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Accounting");
    bool canViewTikTok     = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_TikTok");
    bool canViewEmployee   = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Employee");
    bool canViewReport     = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Report");
    bool canViewSetting    = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "View_Setting");
    bool canViewApproval   = AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "Approve_Order") ||
                             AuthHelper.HasPermission(HttpContextAccessor.HttpContext!, "Import_Inventory");
}
<aside class="sidebar position-fixed top-0 bottom-0 start-0 z-3 p-3">
    <div class="sidebar-brand d-flex align-items-center gap-2 mb-4 pb-3 border-bottom border-secondary border-opacity-25">
        <div class="logo-icon bg-gradient-cyan text-white d-flex align-items-center justify-content-center rounded-3 shadow" style="width: 40px; height: 40px;">
            <img src="/assets/images/NovaTech-Logo.png" alt="NovaTech Logo" class="img-fluid" style="width: 100%; height: 100%; border-radius: 10%;"/>
        </div>
        <div>
            <h5 class="m-0 fw-bold text-dark tracking-wider">NovaTech</h5>
            <span class="text-xs text-muted-custom">Hệ quản trị ERP v1.0</span>
        </div>
    </div>

    <div class="sidebar-menu overflow-y-auto" style="max-height: calc(100vh - 120px);">
        <ul class="nav flex-column gap-1">

            
            <li class="nav-item">
                <a href="@Url.Action("Index", "Dashboard")" class="nav-link-custom @(ctrl == "Dashboard" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                    <i class="fa-solid fa-chart-line text-cyan fs-5"></i>
                    <span>Tổng quan</span>
                </a>
            </li>

            
            @if (canViewProduct)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Hàng hóa</li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Product")" class="nav-link-custom @(ctrl == "Product" && act == "Index" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-box text-cyan fs-5"></i>
                        <span>Sản phẩm</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Categories", "Product")" class="nav-link-custom @(ctrl == "Product" && act == "Categories" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-tags text-cyan fs-5"></i>
                        <span>Danh mục</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Brands", "Product")" class="nav-link-custom @(ctrl == "Product" && act == "Brands" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-copyright text-cyan fs-5"></i>
                        <span>Thương hiệu</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Suppliers", "Product")" class="nav-link-custom @(ctrl == "Product" && act == "Suppliers" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-truck-field text-cyan fs-5"></i>
                        <span>Nhà cung cấp</span>
                    </a>
                </li>
            }

            
            @if (canViewInventory)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Kho bãi</li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Inventory")" class="nav-link-custom @(ctrl == "Inventory" && act == "Index" && tab != "import" && tab != "export" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-warehouse text-cyan fs-5"></i>
                        <span>Tồn kho</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Import", "Inventory")" class="nav-link-custom @(ctrl == "Inventory" && (act == "Import" || (act == "Index" && tab == "import")) ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-circle-down text-cyan fs-5"></i>
                        <span>Nhập kho</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Export", "Inventory")" class="nav-link-custom @(ctrl == "Inventory" && (act == "Export" || (act == "Index" && tab == "export")) ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-circle-up text-cyan fs-5"></i>
                        <span>Xuất kho</span>
                    </a>
                </li>
            }

            
            @if (canViewOrder || canViewCustomer || canViewPromotion)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Bán hàng & CSKH</li>
                @if (canViewOrder)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Order")" class="nav-link-custom @(ctrl == "Order" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-file-invoice-dollar text-cyan fs-5"></i>
                            <span>Đơn hàng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "SalesCSKH")" class="nav-link-custom @(ctrl == "SalesCSKH" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-headset text-cyan fs-5"></i>
                            <span>Chăm sóc khách hàng</span>
                        </a>
                    </li>
                }
                @if (canViewCustomer)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Customer")" class="nav-link-custom @(ctrl == "Customer" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-user-group text-cyan fs-5"></i>
                            <span>Khách hàng</span>
                        </a>
                    </li>
                }
                @if (canViewPromotion)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Promotion")" class="nav-link-custom @(ctrl == "Promotion" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-gift text-cyan fs-5"></i>
                            <span>Khuyến mãi</span>
                        </a>
                    </li>
                }
            }

            
            @if (canViewApproval)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Phê duyệt</li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Approval")" class="nav-link-custom @(ctrl == "Approval" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-clipboard-check text-cyan fs-5"></i>
                        <span>Trung tâm duyệt phiếu</span>
                    </a>
                </li>
            }

            
            @if (canViewAccounting || canViewReport)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Tài chính & Báo cáo</li>
                @if (canViewAccounting)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Accounting")" class="nav-link-custom @(ctrl == "Accounting" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-scale-balanced text-cyan fs-5"></i>
                            <span>Kế toán & Sổ quỹ</span>
                        </a>
                    </li>
                }
                @if (canViewReport)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Report")" class="nav-link-custom @(ctrl == "Report" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                            <i class="fa-solid fa-chart-pie text-cyan fs-5"></i>
                            <span>Báo cáo</span>
                        </a>
                    </li>
                }
            }

            
            @if (canViewTikTok)
            {
                <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Tích hợp</li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "TikTok")" class="nav-link-custom @(ctrl == "TikTok" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-brands fa-tiktok text-cyan fs-5"></i>
                        <span>TikTok Shop</span>
                    </a>
                </li>
            }

            
            <li class="nav-item-header text-xs text-uppercase tracking-widest text-muted-custom mt-3 mb-2 px-3">Quản trị & Hệ thống</li>
            @if (canViewEmployee)
            {
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Employee")" class="nav-link-custom @(ctrl == "Employee" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-users-gear text-cyan fs-5"></i>
                        <span>Nhân sự & RBAC</span>
                    </a>
                </li>
            }
            <li class="nav-item">
                <a href="@Url.Action("Index", "Ai")" class="nav-link-custom @(ctrl == "Ai" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                    <i class="fa-solid fa-robot text-cyan fs-5"></i>
                    <span>AI Assistant</span>
                </a>
            </li>
            @if (canViewSetting)
            {
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Setting")" class="nav-link-custom @(ctrl == "Setting" ? "active" : "") d-flex align-items-center gap-3 py-2.5 px-3 rounded-3">
                        <i class="fa-solid fa-gears text-cyan fs-5"></i>
                        <span>Cấu hình</span>
                    </a>
                </li>
            }

        </ul>
    </div>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var sidebarMenu = document.querySelector('.sidebar-menu');
        if (sidebarMenu) {
            // Restore scroll position
            var scrollPosition = localStorage.getItem('sidebarScrollPosition');
            if (scrollPosition !== null) {
                sidebarMenu.scrollTop = parseInt(scrollPosition, 10);
            } else {
                // Scroll active item into view if no saved position exists
                var activeItem = sidebarMenu.querySelector('.nav-link-custom.active');
                if (activeItem) {
                    activeItem.scrollIntoView({ block: 'nearest' });
                }
            }

            // Save scroll position when the user scrolls the sidebar menu
            sidebarMenu.addEventListener('scroll', function () {
                localStorage.setItem('sidebarScrollPosition', sidebarMenu.scrollTop);
            });
        }
    });
</script>
