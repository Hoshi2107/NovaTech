<!-- NovaTech Premium AI Consultation Widget -->
<div id="aiConsultantContainer" style="position: fixed; left: 24px; bottom: 24px; z-index: 9999; font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    
    <!-- Floating Chat Bubble -->
    <button id="aiConsultantToggle" type="button" style="display: flex; align-items: center; gap: 10px; border: none; border-radius: 999px; background: linear-gradient(135deg, #0f172a 0%, #0284c7 100%); color: white; padding: 12px 20px; cursor: pointer; box-shadow: 0 10px 30px rgba(2, 132, 199, 0.4); font-weight: 600; font-size: 14px; position: relative; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); outline: none;">
        <span class="ai-glow-pulse" style="position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px; border-radius: 999px; border: 2px solid #38bdf8; opacity: 0; animation: aiPulse 2s infinite;"></span>
        <i class="fas fa-robot" style="font-size: 18px; color: #38bdf8; animation: float 3s ease-in-out infinite;"></i>
        <span>Trợ lý AI tư vấn</span>
        <span style="background: rgba(56, 189, 248, 0.2); border: 1px solid rgba(56, 189, 248, 0.4); color: #38bdf8; font-size: 10px; padding: 2px 6px; border-radius: 999px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Beta</span>
    </button>

    <!-- Chat Box Window -->
    <div id="aiConsultantBox" style="display: none; width: 380px; height: 520px; background: rgba(255, 255, 255, 0.82); backdrop-filter: blur(25px) saturate(180%); -webkit-backdrop-filter: blur(25px) saturate(180%); border: 1px solid rgba(255, 255, 255, 0.45); border-radius: 24px; box-shadow: 0 20px 50px rgba(15, 23, 42, 0.22); overflow: hidden; flex-direction: column; margin-top: 12px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); opacity: 0; transform: translateY(20px);">
        <!-- Chat Header -->
        <div style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 18px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="position: relative; width: 40px; height: 40px; background: rgba(56, 189, 248, 0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(56, 189, 248, 0.3);">
                    <i class="fas fa-robot" style="font-size: 20px; color: #38bdf8;"></i>
                    <span style="position: absolute; bottom: -2px; right: -2px; width: 10px; height: 10px; background: #22c55e; border: 2px solid #0f172a; border-radius: 50%;"></span>
                </div>
                <div>
                    <h4 style="margin: 0; font-size: 15px; font-weight: 700; color: #f8fafc; letter-spacing: -0.3px;">NovaTech Assistant</h4>
                    <p style="margin: 0; font-size: 11px; color: #94a3b8; display: flex; align-items: center; gap: 4px;">
                        <span>AI tư vấn mua sắm 24/7</span>
                    </p>
                </div>
            </div>
            <div style="display: flex; gap: 8px;">
                <button id="aiConsultantClear" title="Xóa lịch sử chat" type="button" style="background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 14px; padding: 6px; border-radius: 8px; transition: all 0.2s;"><i class="fas fa-trash-alt"></i></button>
                <button id="aiConsultantClose" type="button" style="background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 18px; padding: 4px; border-radius: 8px; transition: all 0.2s;"><i class="fas fa-times"></i></button>
            </div>
        </div>

        <!-- Chat Messages Area -->
        <div id="aiConsultantMessages" style="flex: 1; padding: 18px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth;">
            <div style="align-self: flex-start; background: rgba(241, 245, 249, 0.9); color: #1e293b; padding: 12px 16px; border-radius: 18px 18px 18px 4px; max-width: 85%; font-size: 13.5px; line-height: 1.5; border: 1px solid rgba(226, 232, 240, 0.8);">
                👋 Xin chào! Em là trợ lý tư vấn thông minh của NovaTech. Em có thể tư vấn sản phẩm, so sánh giá cả hoặc gợi ý cấu hình phù hợp với nhu cầu của anh/chị. Anh/chị cần hỗ trợ gì ạ?
            </div>
        </div>

        <!-- Quick Suggestions Panel -->
        <div id="aiConsultantSuggestions" style="padding: 10px 18px; display: flex; gap: 8px; overflow-x: auto; white-space: nowrap; border-top: 1px solid rgba(0,0,0,0.03); scrollbar-width: none;">
            <button class="ai-suggest-btn" data-query="Sản phẩm bán chạy nhất?" style="background: #ffffff; border: 1px solid #e2e8f0; color: #0284c7; padding: 6px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 600; cursor: pointer; transition: all 0.2s; box-shadow: 0 2px 6px rgba(0,0,0,0.03);">🔥 Bán chạy</button>
            <button class="ai-suggest-btn" data-query="Có dòng iPhone nào mới không?" style="background: #ffffff; border: 1px solid #e2e8f0; color: #0284c7; padding: 6px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 600; cursor: pointer; transition: all 0.2s; box-shadow: 0 2px 6px rgba(0,0,0,0.03);">📱 iPhone mới nhất</button>
            <button class="ai-suggest-btn" data-query="Tư vấn laptop thiết kế đồ họa dưới 25 triệu" style="background: #ffffff; border: 1px solid #e2e8f0; color: #0284c7; padding: 6px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 600; cursor: pointer; transition: all 0.2s; box-shadow: 0 2px 6px rgba(0,0,0,0.03);">💻 Laptop đồ họa</button>
        </div>

        <!-- Input Area -->
        <div style="padding: 12px 18px 18px; border-top: 1px solid rgba(0,0,0,0.05); display: flex; gap: 10px; background: rgba(255, 255, 255, 0.5);">
            <input type="text" id="aiConsultantInput" placeholder="Nhập câu hỏi của anh/chị..." style="flex: 1; border: 1px solid rgba(203, 213, 225, 0.8); background: #ffffff; padding: 10px 18px; border-radius: 999px; outline: none; font-size: 13.5px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); transition: all 0.2s;" />
            <button id="aiConsultantSend" type="button" style="background: linear-gradient(135deg, #0284c7, #0369a1); border: none; width: 40px; height: 40px; border-radius: 50%; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3); transition: all 0.2s;"><i class="fas fa-paper-plane" style="font-size: 14px;"></i></button>
        </div>
    </div>
</div>

<style>
    @@keyframes aiPulse {
        0% { transform: scale(0.95); opacity: 0.5; }
        50% { transform: scale(1.08); opacity: 0; }
        100% { transform: scale(0.95); opacity: 0; }
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-4px); }
    }
    #aiConsultantToggle:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 12px 35px rgba(2, 132, 199, 0.5);
    }
    #aiConsultantToggle:hover .ai-glow-pulse {
        opacity: 1;
    }
    #aiConsultantSend:hover {
        transform: scale(1.08);
        background: linear-gradient(135deg, #0369a1, #075985);
    }
    #aiConsultantSend:active {
        transform: scale(0.95);
    }
    .ai-suggest-btn:hover {
        background: #0284c7 !important;
        color: white !important;
        border-color: #0284c7 !important;
        transform: translateY(-1px);
    }
    #aiConsultantClear:hover, #aiConsultantClose:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        color: #f1f5f9 !important;
    }
    .ai-user-msg {
        align-self: flex-end;
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        color: white;
        padding: 10px 15px;
        border-radius: 18px 18px 4px 18px;
        max-width: 80%;
        font-size: 13.5px;
        line-height: 1.5;
        box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
    }
    .ai-bot-msg {
        align-self: flex-start;
        background: rgba(241, 245, 249, 0.95);
        color: #0f172a;
        padding: 12px 16px;
        border-radius: 18px 18px 18px 4px;
        max-width: 85%;
        font-size: 13.5px;
        line-height: 1.55;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }
    .ai-bot-msg p {
        margin-bottom: 8px;
    }
    .ai-bot-msg p:last-child {
        margin-bottom: 0;
    }
    .ai-bot-msg ul, .ai-bot-msg ol {
        padding-left: 20px;
        margin-bottom: 8px;
    }
    .ai-bot-msg li {
        margin-bottom: 4px;
    }
    /* Typing Indicator */
    .ai-typing-indicator {
        display: flex;
        gap: 4px;
        padding: 8px 12px;
        align-self: flex-start;
        background: rgba(241, 245, 249, 0.95);
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.8);
    }
    .ai-typing-dot {
        width: 6px;
        height: 6px;
        background: #64748b;
        border-radius: 50%;
        animation: aiBounce 1.4s infinite ease-in-out both;
    }
    .ai-typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .ai-typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @@keyframes aiBounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1.0); }
    }
</style>

<script>
    (function () {
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('aiConsultantToggle');
            const chatBox = document.getElementById('aiConsultantBox');
            const closeBtn = document.getElementById('aiConsultantClose');
            const clearBtn = document.getElementById('aiConsultantClear');
            const sendBtn = document.getElementById('aiConsultantSend');
            const inputField = document.getElementById('aiConsultantInput');
            const messagesArea = document.getElementById('aiConsultantMessages');
            const suggestBtns = document.querySelectorAll('.ai-suggest-btn');

            let isOpening = false;

            // Toggle Open/Close chatbox
            toggleBtn.addEventListener('click', () => {
                if (chatBox.style.display === 'none' || !chatBox.style.display) {
                    chatBox.style.display = 'flex';
                    toggleBtn.style.transform = 'scale(0.9) rotate(-3deg)';
                    setTimeout(() => {
                        chatBox.style.opacity = '1';
                        chatBox.style.transform = 'translateY(0)';
                        inputField.focus();
                    }, 50);
                } else {
                    closeChat();
                }
            });

            closeBtn.addEventListener('click', closeChat);

            function closeChat() {
                chatBox.style.opacity = '0';
                chatBox.style.transform = 'translateY(20px)';
                toggleBtn.style.transform = '';
                setTimeout(() => {
                    chatBox.style.display = 'none';
                }, 300);
            }

            // Clear chat history
            clearBtn.addEventListener('click', async () => {
                if (confirm('Anh/chị có muốn xóa sạch lịch sử trò chuyện với trợ lý ảo không?')) {
                    try {
                        const response = await fetch('/Online/ClearConsultChatHistory', { method: 'POST' });
                        if (response.ok) {
                            messagesArea.innerHTML = `
                                <div style="align-self: flex-start; background: rgba(241, 245, 249, 0.9); color: #1e293b; padding: 12px 16px; border-radius: 18px 18px 18px 4px; max-width: 85%; font-size: 13.5px; line-height: 1.5; border: 1px solid rgba(226, 232, 240, 0.8);">
                                    🧹 Lịch sử đã được xóa sạch. Em đã sẵn sàng tư vấn mới cho anh/chị rồi ạ!
                                </div>
                            `;
                        }
                    } catch (err) {
                        console.error('Lỗi khi xóa lịch sử:', err);
                    }
                }
            });

            // Send message action
            sendBtn.addEventListener('click', sendMessage);
            inputField.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') sendMessage();
            });

            // Suggestion click
            suggestBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const text = btn.getAttribute('data-query');
                    inputField.value = text;
                    sendMessage();
                });
            });

            async function sendMessage() {
                const query = inputField.value.trim();
                if (!query) return;

                // Append user message
                appendMsg(query, 'user');
                inputField.value = '';

                // Show typing indicator
                const typingIndicator = document.createElement('div');
                typingIndicator.className = 'ai-typing-indicator';
                typingIndicator.innerHTML = `
                    <div class="ai-typing-dot"></div>
                    <div class="ai-typing-dot"></div>
                    <div class="ai-typing-dot"></div>
                `;
                messagesArea.appendChild(typingIndicator);
                scrollDown();

                try {
                    const response = await fetch('/Online/ChatConsult', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ message: query })
                    });

                    typingIndicator.remove();

                    if (response.ok) {
                        const data = await response.json();
                        appendMsg(data.response, 'bot');
                    } else {
                        appendMsg('⚠️ Rất tiếc, máy chủ gặp sự cố khi phản hồi. Anh/chị vui lòng thử lại sau nhé!', 'bot');
                    }
                } catch (err) {
                    typingIndicator.remove();
                    appendMsg('⚠️ Không thể kết nối với máy chủ AI. Vui lòng kiểm tra lại kết nối mạng.', 'bot');
                    console.error('Lỗi API:', err);
                }
            }

            function appendMsg(text, sender) {
                const msgDiv = document.createElement('div');
                if (sender === 'user') {
                    msgDiv.className = 'ai-user-msg';
                    msgDiv.textContent = text;
                } else {
                    msgDiv.className = 'ai-bot-msg';
                    msgDiv.innerHTML = formatMarkdown(text);
                }
                messagesArea.appendChild(msgDiv);
                scrollDown();
            }

            function scrollDown() {
                messagesArea.scrollTop = messagesArea.scrollHeight;
            }

            // Simple Markdown parser
            function formatMarkdown(text) {
                if (!text) return '';
                let html = text
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;");

                // Bold syntax: **text**
                html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

                // Code block (inline): `code`
                html = html.replace(/`(.*?)`/g, '<code style="background: rgba(0,0,0,0.06); padding: 2px 6px; border-radius: 4px; font-family: monospace;">$1</code>');

                // List items starting with "-" or "*"
                const lines = html.split('\n');
                let inList = false;
                for (let i = 0; i < lines.length; i++) {
                    let line = lines[i].trim();
                    if (line.startsWith('- ') || line.startsWith('* ')) {
                        let content = line.substring(2);
                        if (!inList) {
                            lines[i] = '<ul><li>' + content + '</li>';
                            inList = true;
                        } else {
                            lines[i] = '<li>' + content + '</li>';
                        }
                    } else {
                        if (inList) {
                            lines[i] = '</ul><p>' + line + '</p>';
                            inList = false;
                        } else {
                            if (line !== '') {
                                lines[i] = '<p>' + line + '</p>';
                            }
                        }
                    }
                }
                if (inList) {
                    lines[lines.length - 1] += '</ul>';
                }

                return lines.join('\n');
            }
        });
    })();
</script>
