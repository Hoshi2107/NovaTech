<!-- NovaTech Premium AI Consultation Widget -->
<div id="aiConsultantContainer" style="position: fixed; left: 24px; bottom: 24px; z-index: 9999; font-family: 'Inter', system-ui, -apple-system, sans-serif;">

    <!-- Floating Chat Bubble -->
    <button id="aiConsultantToggle" type="button" style="display: flex; align-items: center; gap: 10px; border: none; border-radius: 999px; background: linear-gradient(135deg, #0f172a 0%, #0284c7 100%); color: white; padding: 12px 20px; cursor: pointer; box-shadow: 0 10px 30px rgba(2, 132, 199, 0.4); font-weight: 600; font-size: 14px; position: relative; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); outline: none;">
        <span class="ai-glow-pulse" style="position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px; border-radius: 999px; border: 2px solid #38bdf8; opacity: 0; animation: aiPulse 2s infinite;"></span>
        <i class="fas fa-robot" style="font-size: 18px; color: #38bdf8; animation: float 3s ease-in-out infinite;"></i>
        <span>Trợ lý AI tư vấn</span>
        <span style="background: rgba(56, 189, 248, 0.2); border: 1px solid rgba(56, 189, 248, 0.4); color: #38bdf8; font-size: 10px; padding: 2px 6px; border-radius: 999px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">AI</span>
    </button>

    <!-- Chat Box Window -->
    <div id="aiConsultantBox" style="display: none; width: 420px; height: 620px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(25px) saturate(180%); -webkit-backdrop-filter: blur(25px) saturate(180%); border: 1px solid rgba(255, 255, 255, 0.45); border-radius: 24px; box-shadow: 0 20px 50px rgba(15, 23, 42, 0.22); overflow: hidden; flex-direction: column; margin-top: 12px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); opacity: 0; transform: translateY(20px);">

        <!-- Chat Header -->
        <div style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 18px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="position: relative; width: 40px; height: 40px; background: rgba(56, 189, 248, 0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(56, 189, 248, 0.3);">
                    <i class="fas fa-robot" style="font-size: 20px; color: #38bdf8;"></i>
                    <span style="position: absolute; bottom: -2px; right: -2px; width: 10px; height: 10px; background: #22c55e; border: 2px solid #0f172a; border-radius: 50%;"></span>
                </div>
                <div>
                    <h4 style="margin: 0; font-size: 15px; font-weight: 700; color: #f8fafc; letter-spacing: -0.3px;">NovaTech Assistant</h4>
                    <p style="margin: 0; font-size: 11px; color: #94a3b8; display: flex; align-items: center; gap: 4px;">
                        <span>AI tư vấn sản phẩm • Voucher • Giỏ hàng</span>
                    </p>
                </div>
            </div>

            <div style="display: flex; gap: 8px;">
                <button id="aiConsultantClear" title="Xóa lịch sử chat" type="button" style="background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 14px; padding: 6px; border-radius: 8px; transition: all 0.2s;">
                    <i class="fas fa-trash-alt"></i>
                </button>
                <button id="aiConsultantClose" type="button" style="background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 18px; padding: 4px; border-radius: 8px; transition: all 0.2s;">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Chat Messages Area -->
        <div id="aiConsultantMessages" style="flex: 1; padding: 18px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth; background: #f8fafc;">
            <div class="ai-bot-msg">
                👋 Xin chào! Em là trợ lý AI của NovaTech.
                <br><br>
                Em có thể tư vấn sản phẩm, gợi ý voucher và giúp anh/chị thêm sản phẩm vào giỏ hàng.
                <br><br>
                Anh/chị có thể hỏi:
                <br>
                <strong>“Tư vấn laptop tầm 15 triệu để học lập trình”</strong>
            </div>
        </div>

        <!-- Quick Suggestions Panel -->
        <div id="aiConsultantSuggestions" style="padding: 10px 18px; display: flex; gap: 8px; overflow-x: auto; white-space: nowrap; border-top: 1px solid rgba(0,0,0,0.05); background: white; scrollbar-width: none;">
            <button class="ai-suggest-btn" data-query="Tư vấn laptop tầm 15 triệu để học lập trình">💻 Laptop học lập trình</button>
            <button class="ai-suggest-btn" data-query="Có iPhone nào đang khuyến mãi không?">📱 iPhone khuyến mãi</button>
            <button class="ai-suggest-btn" data-query="Sản phẩm nào đang có voucher tốt nhất?">🎁 Voucher tốt nhất</button>
        </div>

        <!-- Input Area -->
        <div style="padding: 12px 18px 18px; border-top: 1px solid rgba(0,0,0,0.05); display: flex; gap: 10px; background: white;">
            <input type="text" id="aiConsultantInput" placeholder="Nhập nhu cầu mua hàng..." style="flex: 1; border: 1px solid rgba(203, 213, 225, 0.8); background: #ffffff; padding: 10px 18px; border-radius: 999px; outline: none; font-size: 13.5px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); transition: all 0.2s;" />
            <button id="aiConsultantSend" type="button" style="background: linear-gradient(135deg, #0284c7, #0369a1); border: none; width: 42px; height: 42px; border-radius: 50%; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3); transition: all 0.2s;">
                <i class="fas fa-paper-plane" style="font-size: 14px;"></i>
            </button>
        </div>
    </div>
</div>

<style>
    @@keyframes aiPulse {
        0% { transform: scale(0.95); opacity: 0.5; }
        50% { transform: scale(1.08); opacity: 0; }
        100% { transform: scale(0.95); opacity: 0; }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-4px); }
    }

    @@keyframes aiBounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1.0); }
    }

    #aiConsultantToggle:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 12px 35px rgba(2, 132, 199, 0.5);
    }

    #aiConsultantToggle:hover .ai-glow-pulse {
        opacity: 1;
    }

    #aiConsultantSend:hover {
        transform: scale(1.08);
        background: linear-gradient(135deg, #0369a1, #075985);
    }

    #aiConsultantSend:active {
        transform: scale(0.95);
    }

    .ai-suggest-btn {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #0284c7;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 11.5px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 6px rgba(0,0,0,0.03);
    }

    .ai-suggest-btn:hover {
        background: #0284c7 !important;
        color: white !important;
        border-color: #0284c7 !important;
        transform: translateY(-1px);
    }

    #aiConsultantClear:hover,
    #aiConsultantClose:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        color: #f1f5f9 !important;
    }

    .ai-user-msg {
        align-self: flex-end;
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        color: white;
        padding: 10px 15px;
        border-radius: 18px 18px 4px 18px;
        max-width: 82%;
        font-size: 13.5px;
        line-height: 1.5;
        box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
    }

    .ai-bot-msg {
        align-self: flex-start;
        background: #ffffff;
        color: #0f172a;
        padding: 12px 16px;
        border-radius: 18px 18px 18px 4px;
        max-width: 94%;
        font-size: 13.5px;
        line-height: 1.55;
        border: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .ai-bot-msg p {
        margin-bottom: 8px;
    }

    .ai-bot-msg p:last-child {
        margin-bottom: 0;
    }

    .ai-bot-msg ul,
    .ai-bot-msg ol {
        padding-left: 20px;
        margin-bottom: 8px;
    }

    .ai-bot-msg li {
        margin-bottom: 4px;
    }

    .ai-typing-indicator {
        display: flex;
        gap: 4px;
        padding: 10px 14px;
        align-self: flex-start;
        background: white;
        border-radius: 18px;
        border: 1px solid rgba(226, 232, 240, 0.9);
    }

    .ai-typing-dot {
        width: 6px;
        height: 6px;
        background: #64748b;
        border-radius: 50%;
        animation: aiBounce 1.4s infinite ease-in-out both;
    }

    .ai-typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .ai-typing-dot:nth-child(2) { animation-delay: -0.16s; }

    .ai-product-grid {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ai-product-card {
        display: grid;
        grid-template-columns: 74px 1fr;
        gap: 10px;
        padding: 10px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 15px;
    }

    .ai-product-card img {
        width: 74px;
        height: 74px;
        object-fit: cover;
        border-radius: 12px;
        background: white;
        border: 1px solid #e5e7eb;
    }

    .ai-product-name {
        font-weight: 800;
        font-size: 12.8px;
        color: #0f172a;
        line-height: 1.35;
    }

    .ai-product-price {
        color: #dc2626;
        font-weight: 900;
        font-size: 13px;
        margin-top: 4px;
    }

    .ai-product-meta {
        color: #64748b;
        font-size: 11px;
        margin: 4px 0 8px;
    }

    .ai-product-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .ai-product-actions a,
    .ai-product-actions button {
        border: none;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
    }

    .ai-view-detail {
        background: #e0f2fe;
        color: #0369a1;
    }

    .ai-view-detail:hover {
        background: #bae6fd;
        color: #075985;
    }

    .ai-add-to-cart {
        background: #16a34a;
        color: white;
    }

    .ai-add-to-cart:hover {
        background: #15803d;
    }

    .ai-voucher-card {
        margin-top: 10px;
        background: #fff7ed;
        border: 1px dashed #fb923c;
        border-radius: 13px;
        padding: 10px 12px;
        font-size: 12.5px;
        color: #9a3412;
    }

    .ai-voucher-code {
        font-weight: 900;
        color: #c2410c;
    }

    @@media (max-width: 576px) {
        #aiConsultantContainer {
            left: 12px !important;
            right: 12px !important;
            bottom: 12px !important;
        }

        #aiConsultantBox {
            width: calc(100vw - 24px) !important;
            height: 580px !important;
        }
    }
</style>

<script>
    (function () {
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('aiConsultantToggle');
            const chatBox = document.getElementById('aiConsultantBox');
            const closeBtn = document.getElementById('aiConsultantClose');
            const clearBtn = document.getElementById('aiConsultantClear');
            const sendBtn = document.getElementById('aiConsultantSend');
            const inputField = document.getElementById('aiConsultantInput');
            const messagesArea = document.getElementById('aiConsultantMessages');
            const suggestBtns = document.querySelectorAll('.ai-suggest-btn');

            let sending = false;

            toggleBtn.addEventListener('click', () => {
                if (chatBox.style.display === 'none' || !chatBox.style.display) {
                    chatBox.style.display = 'flex';
                    toggleBtn.style.transform = 'scale(0.9) rotate(-3deg)';

                    setTimeout(() => {
                        chatBox.style.opacity = '1';
                        chatBox.style.transform = 'translateY(0)';
                        inputField.focus();
                    }, 50);
                } else {
                    closeChat();
                }
            });

            closeBtn.addEventListener('click', closeChat);

            function closeChat() {
                chatBox.style.opacity = '0';
                chatBox.style.transform = 'translateY(20px)';
                toggleBtn.style.transform = '';

                setTimeout(() => {
                    chatBox.style.display = 'none';
                }, 300);
            }

            clearBtn.addEventListener('click', async () => {
                if (!confirm('Anh/chị có muốn xóa sạch lịch sử trò chuyện với trợ lý AI không?')) {
                    return;
                }

                try {
                    const response = await fetch('/Online/ClearConsultChatHistory', {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (response.ok) {
                        messagesArea.innerHTML = '';
                        appendMsg('🧹 Lịch sử đã được xóa. Em đã sẵn sàng tư vấn mới cho anh/chị rồi ạ!', 'bot');
                    }
                } catch (err) {
                    console.error('Lỗi khi xóa lịch sử:', err);
                }
            });

            sendBtn.addEventListener('click', sendMessage);

            inputField.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    sendMessage();
                }
            });

            suggestBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const text = btn.getAttribute('data-query') || '';
                    inputField.value = text;
                    sendMessage();
                });
            });

            async function sendMessage() {
                const query = inputField.value.trim();

                if (!query || sending) {
                    return;
                }

                sending = true;

                appendMsg(query, 'user');
                inputField.value = '';

                const typingIndicator = document.createElement('div');
                typingIndicator.className = 'ai-typing-indicator';
                typingIndicator.innerHTML = `
                    <div class="ai-typing-dot"></div>
                    <div class="ai-typing-dot"></div>
                    <div class="ai-typing-dot"></div>
                `;

                messagesArea.appendChild(typingIndicator);
                scrollDown();

                try {
                    const response = await fetch('/Online/ChatConsult', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ message: query })
                    });

                    typingIndicator.remove();

                    let data = null;

                    try {
                        data = await response.json();
                    } catch {
                        data = null;
                    }

                    if (response.ok && data) {
                        appendMsg(
                            data.response || 'Dạ hiện tại em chưa có câu trả lời phù hợp.',
                            'bot',
                            data.products || [],
                            data.vouchers || []
                        );

                        if (data.needsHumanSupport) {
                            appendMsg('Trường hợp này có thể cần nhân viên CSKH hỗ trợ thêm. Anh/chị vui lòng để lại thông tin hoặc tiếp tục nhắn trong hộp chat CSKH ạ.', 'bot');
                        }
                    } else {
                        appendMsg('⚠️ Rất tiếc, máy chủ gặp sự cố khi phản hồi. Anh/chị vui lòng thử lại sau nhé!', 'bot');
                    }
                } catch (err) {
                    typingIndicator.remove();
                    appendMsg('⚠️ Không thể kết nối với máy chủ AI. Vui lòng kiểm tra lại kết nối mạng.', 'bot');
                    console.error('Lỗi API:', err);
                } finally {
                    sending = false;
                    inputField.focus();
                }
            }

            function appendMsg(text, sender, products, vouchers) {
                const msgDiv = document.createElement('div');

                if (sender === 'user') {
                    msgDiv.className = 'ai-user-msg';
                    msgDiv.textContent = text;
                } else {
                    msgDiv.className = 'ai-bot-msg';
                    msgDiv.innerHTML = formatMarkdown(text || '');

                    if (products && products.length > 0) {
                        msgDiv.appendChild(renderProductCards(products));
                    }

                    if (vouchers && vouchers.length > 0) {
                        vouchers.forEach(voucher => {
                            msgDiv.appendChild(renderVoucherCard(voucher));
                        });
                    }
                }

                messagesArea.appendChild(msgDiv);
                scrollDown();
            }

            function renderProductCards(products) {
                const grid = document.createElement('div');
                grid.className = 'ai-product-grid';

                products.forEach(product => {
                    const card = document.createElement('div');
                    card.className = 'ai-product-card';

                    card.innerHTML = `
                        <img src="${escapeHtml(product.imageUrl || '')}" alt="${escapeHtml(product.name || 'Sản phẩm')}">
                        <div>
                            <div class="ai-product-name">${escapeHtml(product.name || 'Sản phẩm')}</div>
                            <div class="ai-product-price">${escapeHtml(product.priceText || formatCurrency(product.price || 0))}</div>
                            <div class="ai-product-meta">${escapeHtml(product.brand || '')} • Còn ${escapeHtml(String(product.stock ?? ''))} sản phẩm</div>
                            <div class="ai-product-actions">
                                <a class="ai-view-detail" href="${escapeHtml(product.detailUrl || '#')}">Xem chi tiết</a>
                                <button type="button" class="ai-add-to-cart" data-id="${escapeHtml(String(product.id || ''))}">Thêm vào giỏ</button>
                            </div>
                        </div>
                    `;

                    const addBtn = card.querySelector('.ai-add-to-cart');

                    addBtn.addEventListener('click', function () {
                        addProductToCart(product.id, product.name);
                    });

                    grid.appendChild(card);
                });

                return grid;
            }

            function renderVoucherCard(voucher) {
                const card = document.createElement('div');
                card.className = 'ai-voucher-card';
                card.innerHTML = `
                    🎁 Mã <span class="ai-voucher-code">${escapeHtml(voucher.code || '')}</span>
                    giảm <strong>${escapeHtml(voucher.valueText || formatCurrency(voucher.value || 0))}</strong>
                    <br>
                    <small>Còn: ${escapeHtml(voucher.quantityText || '')} • Hạn: ${escapeHtml(voucher.endDateText || '')}</small>
                `;
                return card;
            }

            async function addProductToCart(productId, productName) {
                if (!productId) {
                    appendMsg('⚠️ Không xác định được sản phẩm cần thêm vào giỏ.', 'bot');
                    return;
                }

                try {
                    const response = await fetch('/Online/AddToCart?id=' + encodeURIComponent(productId) + '&qty=1', {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    let data = null;

                    try {
                        data = await response.json();
                    } catch {
                        data = null;
                    }

                    if (response.ok && data && data.success) {
                        const badge = document.querySelector('.navbar .badge, .cart-count, #cartCount');

                        if (badge) {
                            badge.innerText = data.cartCount;
                        }

                        appendMsg('✅ Đã thêm **' + (productName || 'sản phẩm') + '** vào giỏ hàng. Anh/chị có thể vào giỏ hàng để thanh toán ạ.', 'bot');
                    } else {
                        appendMsg('⚠️ ' + ((data && data.message) ? data.message : 'Không thể thêm sản phẩm vào giỏ hàng.'), 'bot');
                    }
                } catch (err) {
                    appendMsg('⚠️ Không thể thêm sản phẩm vào giỏ hàng lúc này.', 'bot');
                    console.error('Lỗi thêm giỏ hàng:', err);
                }
            }

            function scrollDown() {
                messagesArea.scrollTop = messagesArea.scrollHeight;
            }

            function formatMarkdown(text) {
                if (!text) return '';

                let html = escapeHtml(text);

                html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                html = html.replace(/`(.*?)`/g, '<code style="background: rgba(0,0,0,0.06); padding: 2px 6px; border-radius: 4px; font-family: monospace;">$1</code>');

                const lines = html.split('\n');
                let output = '';
                let inList = false;

                lines.forEach(line => {
                    const trimmed = line.trim();

                    if (trimmed.startsWith('- ') || trimmed.startsWith('* ')) {
                        if (!inList) {
                            output += '<ul>';
                            inList = true;
                        }

                        output += '<li>' + trimmed.substring(2) + '</li>';
                    } else {
                        if (inList) {
                            output += '</ul>';
                            inList = false;
                        }

                        if (trimmed !== '') {
                            output += '<p>' + trimmed + '</p>';
                        }
                    }
                });

                if (inList) {
                    output += '</ul>';
                }

                return output;
            }

            function escapeHtml(value) {
                return String(value ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function formatCurrency(value) {
                return Number(value || 0).toLocaleString('vi-VN') + 'đ';
            }
        });
    })();
</script>