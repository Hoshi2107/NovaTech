@using Microsoft.AspNetCore.Http
@using DATN64.Models
@inject IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var userEmail = session?.GetString("UserEmail") ?? "";
    var isLogged = !string.IsNullOrEmpty(userEmail);
    
    // Fetch cart count from session
    var cartJson = session?.GetString("Cart");
    var cartItems = string.IsNullOrEmpty(cartJson) ? new List<DATN64.Controllers.OnlineController.CartItem>() : System.Text.Json.JsonSerializer.Deserialize<List<DATN64.Controllers.OnlineController.CartItem>>(cartJson) ?? new();
    var cartCount = cartItems.Sum(i => i.Quantity);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NovaTech Store</title>
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/admin_custom.css" rel="stylesheet">
    <style>
        :root {
            --nt-primary: #0284c7;
            --nt-secondary: #0369a1;
            --nt-dark: #ffffff;
            --nt-light: #f8fafc;
            --nt-card: #ffffff;
            --nt-text: #0f172a;
            --nt-muted: #64748b;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--nt-light);
            color: var(--nt-text);
        }
        .bg-gradient-nav {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
        }
        .text-neon {
            background: linear-gradient(45deg, #0284c7, #0369a1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .footer {
            background-color: #ffffff;
            border-top: 1px solid #e2e8f0;
            color: var(--nt-text);
        }
        .nav-link {
            color: #475569 !important;
            font-weight: 500;
            transition: color 0.3s;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--nt-primary) !important;
        }
        .card-product {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            color: var(--nt-text);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        .card-product:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(2, 132, 199, 0.1);
            border-color: rgba(2, 132, 199, 0.3);
        }
        .text-muted-custom {
            color: var(--nt-muted) !important;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-gradient-nav sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-extrabold fs-3 text-neon d-flex align-items-center gap-2" href="@Url.Action("Index", "Online")">
                <i class="fa-solid fa-bolt-lightning text-cyan animate-pulse"></i> NovaTech
            </a>

            <!-- Duchuymobile Category Mega Menu Button -->
            <div class="mega-menu-dropdown-toggle ms-2 d-none d-lg-block">
                <button class="btn btn-outline-primary rounded-pill px-3 py-2 text-xs fw-bold shadow-sm d-flex align-items-center gap-2">
                    <i class="fa-solid fa-table-cells"></i> Danh mục
                </button>
                <div class="mega-menu-wrapper">
                    <div class="mega-menu-left-sidebar">
                        <a href="/Online/ProductsList?category=Điện thoại" class="mega-menu-left-item active" data-target="panel-dt">
                            <span><i class="fa-solid fa-mobile-screen-button me-2 text-primary"></i>Điện thoại</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                        <a href="/Online/ProductsList?category=Laptop" class="mega-menu-left-item" data-target="panel-lt">
                            <span><i class="fa-solid fa-laptop me-2 text-primary"></i>Laptop</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                        <a href="/Online/ProductsList?category=Máy tính bảng" class="mega-menu-left-item" data-target="panel-mtb">
                            <span><i class="fa-solid fa-tablet-screen-button me-2 text-primary"></i>Máy tính bảng</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                        <a href="/Online/ProductsList?category=Tai nghe" class="mega-menu-left-item" data-target="panel-tn">
                            <span><i class="fa-solid fa-headphones me-2 text-primary"></i>Tai nghe</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                        <a href="/Online/ProductsList?category=Phụ kiện" class="mega-menu-left-item" data-target="panel-pk">
                            <span><i class="fa-solid fa-keyboard me-2 text-primary"></i>Phụ kiện</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                        <a href="/Online/ProductsList?category=Loa" class="mega-menu-left-item" data-target="panel-loa">
                            <span><i class="fa-solid fa-volume-high me-2 text-primary"></i>Loa & Âm thanh</span>
                            <i class="fa-solid fa-chevron-right text-xs"></i>
                        </a>
                    </div>
                    
                    <!-- Right Panels -->
                    <div class="mega-menu-right-panel active" id="panel-dt">
                        <div class="row">
                            <div class="col-md-7">
                                <h6 class="fw-bold text-dark mb-3">Hãng điện thoại</h6>
                                <div class="mega-menu-brand-grid">
