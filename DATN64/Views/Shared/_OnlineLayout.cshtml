@using Microsoft.AspNetCore.Http
@using DATN64.Models
@inject IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var userEmail = session?.GetString("UserEmail") ?? "";
    var userRoles = session?.GetString("UserRoles") ?? "";
    var isLogged = !string.IsNullOrEmpty(userEmail);
    var isCustomerRole = userRoles.Contains("Khách hàng");
    
    // Fetch cart count from session
    var cartJson = session?.GetString("Cart");
    var cartItems = string.IsNullOrEmpty(cartJson) ? new List<DATN64.Controllers.OnlineController.CartItem>() : System.Text.Json.JsonSerializer.Deserialize<List<DATN64.Controllers.OnlineController.CartItem>>(cartJson) ?? new();
    var cartCount = cartItems.Sum(i => i.Quantity);

    var onlineCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var onlineAct = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NovaTech Store</title>
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/admin_custom.css?v=@DateTime.Now.Ticks" rel="stylesheet">
    <script>
        (function () {
            const currentTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', currentTheme);
            document.addEventListener('DOMContentLoaded', () => {
                document.body.setAttribute('data-theme', currentTheme);
                const themeCheckbox = document.getElementById('themeCheckbox');
                if (themeCheckbox) {
                    themeCheckbox.checked = (currentTheme === 'dark');
                    themeCheckbox.addEventListener('change', function () {
                        if (this.checked) {
                            document.documentElement.setAttribute('data-theme', 'dark');
                            document.body.setAttribute('data-theme', 'dark');
                            localStorage.setItem('theme', 'dark');
                        } else {
                            document.documentElement.setAttribute('data-theme', 'light');
                            document.body.setAttribute('data-theme', 'light');
                            localStorage.setItem('theme', 'light');
                        }
                    });
                }
            });
        })();
    </script>
    <style>
        :root {
            --nt-primary: #0284c7;
            --nt-secondary: #0369a1;
            --nt-dark: #ffffff;
            --nt-light: #f8fafc;
            --nt-card: #ffffff;
            --nt-text: #0f172a;
            --nt-muted: #64748b;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--nt-light);
            color: var(--nt-text);
        }
        .bg-gradient-nav {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
        }
        .text-neon {
            background: linear-gradient(45deg, #0284c7, #0369a1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .footer {
            background-color: #ffffff;
            border-top: 1px solid #e2e8f0;
            color: var(--nt-text);
        }
        .nav-link,
        .nav-link * {
            white-space: nowrap !important;
            flex-shrink: 0 !important;
        }
        .nav-link {
            color: #475569 !important;
            font-weight: 600;
            font-size: 13.5px;
            padding: 8px 18px !important;
            border-radius: 50rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s ease;
        }
        .nav-link:hover {
            background-color: #f1f5f9;
            color: #0f172a !important;
        }
        .nav-link.active {
            background-color: #e0f2fe !important;
            color: #0284c7 !important;
        }
        .nav-link i {
            transition: transform 0.2s ease;
        }
        .nav-link:hover i {
            transform: scale(1.1);
        }
        .navbar-nav {
            margin: 0 auto !important;
            gap: 24px !important;
        }
        .navbar .btn,
        .navbar .btn *,
        .mega-menu-dropdown-toggle .btn,
        .mega-menu-dropdown-toggle .btn *,
        .nav-item {
            white-space: nowrap !important;
            flex-shrink: 0 !important;
        }
        .mega-menu-dropdown-toggle {
            margin-right: 20px !important;
            margin-left: 10px !important;
        }
        @@media (min-width: 1200px) and (max-width: 1600px) {
            .nav-link i {
                display: none !important;
            }
            .nav-link {
                padding: 6px 10px !important;
                font-size: 12.5px !important;
                gap: 0 !important;
            }
            .navbar-nav {
                margin: 0 auto !important;
                gap: 16px !important;
            }
            .mega-menu-dropdown-toggle {
                margin-left: 5px !important;
                margin-right: 15px !important;
            }
            .mega-menu-dropdown-toggle .btn {
                padding: 6px 10px !important;
                font-size: 12px !important;
            }
            .navbar .btn {
                padding: 6px 10px !important;
                font-size: 12px !important;
            }
            .navbar-brand {
                font-size: 1.2rem !important;
            }
            .navbar .container-fluid,
            .navbar .container {
                max-width: 100% !important;
                padding-left: 8px !important;
                padding-right: 8px !important;
            }
            .theme-switch-wrapper {
                margin-right: 4px !important;
            }
        }
        .card-product {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            color: var(--nt-text);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        .card-product:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(2, 132, 199, 0.15);
            border-color: rgba(2, 132, 199, 0.3);
        }
        .card-glass {
            background: rgba(255, 255, 255, 0.84);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(226, 232, 240, 0.7);
        }
        .animate-fade-in {
            animation: @@keyframes fadeInUp 0.5s ease forwards;
            opacity: 0;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hover-bg-light:hover {
            background-color: rgba(2, 132, 199, 0.08) !important;
        }
        .btn-icon {
            position: relative;
        }
        .text-muted-custom {
            color: var(--nt-muted) !important;
        }
        /* Fixed: Dark Mode Active & Hover state styles for navbar links to prevent invisible text */
        body[data-theme="dark"] .nav-link {
            color: #94a3b8 !important; /* Muted text for inactive tabs in dark mode */
            background-color: transparent !important;
        }
        body[data-theme="dark"] .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.08) !important;
            color: #ffffff !important;
        }
        body[data-theme="dark"] .nav-link.active {
            background-color: #0ea5e9 !important; /* Premium sky blue active background */
            color: #ffffff !important; /* Solid white text for perfect readability */
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
