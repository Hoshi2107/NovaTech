                                    <a href="/Online/ProductsList?category=Điện thoại&brand=Samsung" class="mega-menu-brand-badge">Samsung</a>
                                    <a href="/Online/ProductsList?category=Điện thoại&brand=Xiaomi" class="mega-menu-brand-badge">Xiaomi</a>
                                    <a href="/Online/ProductsList?category=Điện thoại&brand=Oppo" class="mega-menu-brand-badge">Oppo</a>
                                </div>
                                <h6 class="fw-bold text-dark mt-4 mb-2">Dòng sản phẩm HOT</h6>
                                <ul class="list-unstyled text-xs text-secondary d-grid gap-2">
                                    <li><a href="/Online/ProductsList?category=Điện thoại" class="text-decoration-none text-secondary">iPhone 15 Pro Max 256GB</a></li>
                                    <li><a href="/Online/ProductsList?category=Điện thoại" class="text-decoration-none text-secondary">Samsung Galaxy Tab S9 Ultra</a></li>
                                </ul>
                            </div>
                            <div class="col-md-5 border-start border-light ps-3">
