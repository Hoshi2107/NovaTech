@using DATN64.Models
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;
    var session = HttpContextAccessor.HttpContext?.Session;
    var userRolesStr = session?.GetString("UserRoles") ?? "";
    var roles = userRolesStr.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    var isSuperAdmin = roles.Contains("Super Admin");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>403 - Access Denied | NovaTech</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: radial-gradient(circle, #1a1a2e 0%, #161623 100%);
            color: #ffffff;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            overflow: hidden;
        }
        .error-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 3rem;
            max-width: 600px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            animation: fadeIn 0.8s ease-out;
        }
        .error-icon {
            font-size: 5rem;
            color: #ff3366;
            margin-bottom: 1.5rem;
            animation: bounce 2s infinite;
        }
        .error-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(45deg, #ff3366, #ff9933);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }
        .btn-home {
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            border: none;
            color: #fff;
            padding: 10px 25px;
            font-weight: 600;
            border-radius: 30px;
            transition: all 0.3s ease;
        }
        .btn-home:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 242, 254, 0.4);
            color: #fff;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-15px); }
            60% { transform: translateY(-7px); }
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div class="error-title">403 - TRUY CẬP BỊ TỪ CHỐI</div>
        <p class="text-muted-custom mb-4" style="color: #cbd5e1;">
            Bạn không có đủ quyền để truy cập tính năng này. Vui lòng liên hệ với Super Admin hoặc đổi tài khoản có quyền truy cập phù hợp.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-light rounded-pill px-4">
                <i class="fa-solid fa-sign-in-alt me-2"></i>Đăng nhập tài khoản khác
            </a>
            <a href="@Url.Action("Selection", "Portal")" class="btn btn-home">
                <i class="fa-solid fa-house me-2"></i>Về Trang Cổng Portal
            </a>
        </div>
    </div>
</body>
</html>
