                                        </div>
                                    </td>
                                    <td class="text-xs text-secondary">${ tx.creator }</td>
                                    <td class="text-xs text-muted-custom" style="max-width: 250px;">
                                        <div class="text-truncate" :title="tx.note">${ tx.note }</div>
                                        <div v-if="tx.lyDoTuChoi" class="text-danger mt-1" style="font-size: 0.75rem; border-top: 1px dashed #fee2e2; padding-top: 2px;">
                                            <strong>Lý do từ chối:</strong> ${ tx.lyDoTuChoi }
                                        </div>
                                    </td>
                                    <td class="text-end" v-if="isManager">
                                        <div class="d-flex gap-1 justify-content-end" v-if="tx.trangThai === 'Chờ duyệt'">
                                            <button class="btn btn-xs btn-success py-1 px-2 rounded text-xxs fw-bold" @@click="tx.type === 'Điều chỉnh' ? approveAdjust(tx) : approveTx(tx)" :disabled="submitting">
                                                <i class="fa-solid fa-check"></i> Duyệt
                                            </button>
                                            <button class="btn btn-xs btn-danger py-1 px-2 rounded text-xxs fw-bold" @@click="tx.type === 'Điều chỉnh' ? rejectAdjust(tx) : rejectTx(tx)" :disabled="submitting">
                                                <i class="fa-solid fa-xmark"></i> Từ chối
                                            </button>
                                        </div>
                                        <span class="text-muted text-xxs" v-else>---</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        [v-cloak] { display: none; }
        .text-gradient {
            background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .bg-glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        .group-hover:hover {
            background-color: rgba(2, 132, 199, 0.03) !important;
            transition: all 0.2s ease-in-out;
        }
        .badge.bg-success-subtle {
            background-color: #dcfce7 !important;
            color: #15803d !important;
        }
        .badge.bg-danger-subtle {
            background-color: #fee2e2 !important;
            color: #b91c1c !important;
        }
        .badge.bg-warning-subtle {
            background-color: #fef9c3 !important;
            color: #a16207 !important;
        }
        .badge.bg-info-subtle {
            background-color: #e0f2fe !important;
            color: #0369a1 !important;
        }
        .badge.bg-primary-subtle {
            background-color: #dbeafe !important;
            color: #1d4ed8 !important;
        }
        .badge.bg-purple-subtle {
            background-color: #f3e8ff !important;
            color: #6b21a8 !important;
        }
    </style>

    <script>
        var app = new Vue({
            el: '#app',
            delimiters: ['${', '}'],
            data: {
                activeTab: 'dashboard',
                lastUpdated: '',
                products: [],
                transactions: [],
                categories: [],
                brands: [],
                loading: false,
                submitting: false,
                isManager: @(isManager ? "true" : "false"),
                exportError: '',
                adjustError: '',
                filters: {
                    search: '',
                    category: '',
                    brand: '',
                    historySearch: '',
                    historyType: '',
                    historyTime: 'all'
                },
                forms: {
                    import: {
                        productId: '',
                        quantity: 10,
                        source: 'Nhà cung cấp',
                        note: ''
                    },
                    export: {
                        productId: '',
                        quantity: 1,
                        source: 'Xuất POS',
                        note: ''
                    },
                    audit: {
                        productId: '',
                        actualQuantity: '',
                        note: ''
                    },
                    adjust: {
                        productId: '',
                        direction: 'increase',
                        quantity: 1,
                        reason: '',
                        note: ''
                    }
                }
            },
            computed: {
                activeProducts() {
                    return this.products.filter(p => p.trangThai === 'Đang bán');
                },
                filteredProducts() {
                    let list = this.products;
                    if (this.filters.search) {
                        const s = this.filters.search.toLowerCase();
                        list = list.filter(p => p.tenSanPham.toLowerCase().includes(s) || p.maSanPham.toString().includes(s));
                    }
                    if (this.filters.category) {
                        list = list.filter(p => p.maDanhMuc === parseInt(this.filters.category));
                    }
                    if (this.filters.brand) {
                        list = list.filter(p => p.maThuongHieu === parseInt(this.filters.brand));
                    }
                    return list;
                },
                filteredTransactions() {
                    let list = this.transactions;
                    if (this.filters.historySearch) {
                        const s = this.filters.historySearch.toLowerCase();
                        list = list.filter(t => 
                            t.productName.toLowerCase().includes(s) || 
                            t.code.toLowerCase().includes(s) ||
                            t.creator.toLowerCase().includes(s)
                        );
                    }
                    if (this.filters.historyType) {
                        list = list.filter(t => t.type === this.filters.historyType);
                    }
                    if (this.filters.historyTime && this.filters.historyTime !== 'all') {
                        const now = new Date();
                        const todayStr = now.toISOString().slice(0, 10);
                        if (this.filters.historyTime === 'today') {
                            list = list.filter(t => t.date.startsWith(todayStr));
                        } else if (this.filters.historyTime === 'week') {
                            const limit = new Date();
                            limit.setDate(limit.getDate() - 7);
                            list = list.filter(t => new Date(t.date) >= limit);
                        }
                    }
                    return list;
                },
                stats() {
                    const totalProducts = this.products.length;
                    const totalStock = this.products.reduce((acc, p) => acc + p.soLuongTon, 0);
                    
                    const nowStr = new Date().toISOString().slice(0, 10);
                    const importsToday = this.transactions
                        .filter(t => t.type === 'Nhập kho' && t.date.startsWith(nowStr))
                        .reduce((acc, t) => acc + t.quantityChange, 0);
                    
                    const exportsToday = this.transactions
                        .filter(t => t.type === 'Xuất kho' && t.date.startsWith(nowStr))
                        .reduce((acc, t) => acc + Math.abs(t.quantityChange), 0);

                    const lowStockProducts = this.products.filter(p => p.soLuongTon <= 10).length;

                    return {
                        totalProducts,
                        totalStock,
                        importsToday,
                        exportsToday,
                        lowStockProducts
                    };
                },
                lowStockItems() {
                    return this.products.filter(p => p.soLuongTon <= 10).sort((a, b) => a.soLuongTon - b.soLuongTon);
                },
                selectedImportProduct() {
                    return this.products.find(p => p.maSanPham === this.forms.import.productId) || {};
                },
                selectedExportProduct() {
                    return this.products.find(p => p.maSanPham === this.forms.export.productId) || {};
                },
                selectedAuditProduct() {
                    return this.products.find(p => p.maSanPham === this.forms.audit.productId) || {};
                },
                selectedAdjustProduct() {
                    return this.products.find(p => p.maSanPham === this.forms.adjust.productId) || {};
                },
                auditDiff() {
                    if (!this.forms.audit.productId || this.forms.audit.actualQuantity === '') return 0;
                    return this.forms.audit.actualQuantity - this.selectedAuditProduct.soLuongTon;
                },
                auditDiffText() {
                    const diff = this.auditDiff;
                    if (diff === 0) return 'Khớp tồn (0)';
                    return `${diff >= 0 ? '+' : ''}${diff} cái`;
                },
                auditDiffClass() {
                    const diff = this.auditDiff;
                    if (diff === 0) return 'bg-secondary bg-opacity-10 text-secondary';
                    return diff > 0 ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger';
                },
                pendingTransactions() {
                    return this.transactions.filter(t => t.trangThai === 'Chờ duyệt' && t.type !== 'Điều chỉnh');
                },
                pendingAdjustments() {
                    return this.transactions.filter(t => t.type === 'Điều chỉnh' && t.trangThai === 'Chờ duyệt');
                }
            },
            mounted() {
                this.updateTime();
                this.fetchData();
                
                // Parse initial tab
                const params = new URLSearchParams(window.location.search);
                const tab = params.get('tab');
                if (tab) {
                    this.activeTab = tab;
                }
            },
            methods: {
                updateTime() {
                    const now = new Date();
                    this.lastUpdated = now.toLocaleTimeString('vi-VN') + ' ' + now.toLocaleDateString('vi-VN');
                },
                formatCurrency(val) {
                    if (!val && val !== 0) return '0 ₫';
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
                },
                async fetchData() {
                    this.loading = true;
                    try {
                        const [prodRes, txRes, optRes] = await Promise.all([
                            axios.get('/api/inventory'),
                            axios.get('/api/inventory/transactions'),
                            axios.get('/api/product/options')
                        ]);

                        this.products = prodRes.data;
                        this.transactions = txRes.data;
                        this.categories = optRes.data.categories;
                        this.brands = optRes.data.brands;
                    } catch (err) {
                        console.error('Lỗi khi tải dữ liệu:', err);
                        Swal.fire('Lỗi', 'Không thể tải dữ liệu kho hàng.', 'error');
                    } finally {
                        this.loading = false;
                        this.updateTime();
                    }
                },
                setTab(tab) {
                    this.activeTab = tab;
                    // Reset errors on tab change
                    this.exportError = '';
                    this.adjustError = '';
                },
                resetFilters() {
                    this.filters.search = '';
                    this.filters.category = '';
                    this.filters.brand = '';
                },
                resetHistoryFilters() {
                    this.filters.historySearch = '';
                    this.filters.historyType = '';
                    this.filters.historyTime = 'all';
                },
                selectAuditProductQuick(p) {
                    this.forms.audit.productId = p.maSanPham;
                    this.forms.audit.actualQuantity = p.soLuongTon;
                    this.forms.audit.note = '';
                    this.setTab('audit');
                },

                // Validation previews
                updateImportPreview() {
                    // No validation logic needed
                },
                updateExportPreview() {
                    this.exportError = '';
                    if (this.forms.export.productId && this.forms.export.quantity) {
                        if (this.forms.export.quantity > this.selectedExportProduct.soLuongTon) {
                            this.exportError = `Số lượng xuất vượt quá tồn kho khả dụng (${this.selectedExportProduct.soLuongTon} cái)!`;
                        }
                    }
                },
                updateAuditPreview() {
                    if (this.forms.audit.productId) {
                        this.forms.audit.actualQuantity = this.selectedAuditProduct.soLuongTon;
                    }
                },
                updateAdjustPreview() {
                    this.adjustError = '';
                    if (this.forms.adjust.productId && this.forms.adjust.quantity) {
                        if (this.forms.adjust.direction === 'decrease' && this.forms.adjust.quantity > this.selectedAdjustProduct.soLuongTon) {
                            this.adjustError = `Số lượng điều chỉnh giảm vượt quá tồn kho hiện tại (${this.selectedAdjustProduct.soLuongTon} cái)!`;
                        }
                    }
                },
                getAdjustedPreviewQty() {
                    if (!this.forms.adjust.productId || !this.forms.adjust.quantity) return 0;
                    if (this.forms.adjust.direction === 'increase') {
                        return this.selectedAdjustProduct.soLuongTon + this.forms.adjust.quantity;
                    } else {
                        return this.selectedAdjustProduct.soLuongTon - this.forms.adjust.quantity;
                    }
                },

                // Forms submissions
                async submitImport() {
                    this.submitting = true;
                    try {
                        const payload = {
                            productId: this.forms.import.productId,
                            quantity: this.forms.import.quantity,
                            source: this.forms.import.source,
                            note: this.forms.import.note
                        };

                        const res = await axios.post('/api/inventory/import', payload);
                        
                        await Swal.fire({
                            title: 'Đã gửi yêu cầu!',
                            text: res.data.message || 'Phiếu nhập kho đã được tạo và đang chờ quản lý duyệt.',
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });

                        // Reset form
                        this.forms.import.productId = '';
                        this.forms.import.quantity = 10;
                        this.forms.import.note = '';

                        // Refresh and redirect to Stock
                        await this.fetchData();
                        this.setTab('stock');
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi nhập kho.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },
                async submitExport() {
                    if (this.exportError) return;
                    this.submitting = true;
                    try {
                        const payload = {
                            productId: this.forms.export.productId,
                            quantity: this.forms.export.quantity,
                            source: this.forms.export.source,
                            note: this.forms.export.note
                        };

                        const res = await axios.post('/api/inventory/export', payload);

                        await Swal.fire({
                            title: 'Đã gửi yêu cầu!',
                            text: res.data.message || 'Phiếu xuất kho đã được tạo và đang chờ quản lý duyệt.',
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });

                        // Reset form
                        this.forms.export.productId = '';
                        this.forms.export.quantity = 1;
                        this.forms.export.note = '';

                        await this.fetchData();
                        this.setTab('stock');
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi xuất kho.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },
                async submitAudit() {
                    this.submitting = true;
                    try {
                        const payload = {
                            productId: this.forms.audit.productId,
                            actualQuantity: this.forms.audit.actualQuantity,
                            note: this.forms.audit.note
                        };

                        const res = await axios.post('/api/inventory/audit', payload);

                        await Swal.fire({
                            title: 'Đã tạo phiếu kiểm kê!',
                            html: `<div class="text-start"><p>${res.data.message}</p><p class="mb-0 text-muted"><small>Phiếu đang chờ Quản lý/Admin phê duyệt.</small></p></div>`,
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });

                        // Reset form
                        this.forms.audit.productId = '';
                        this.forms.audit.actualQuantity = '';
                        this.forms.audit.note = '';

                        await this.fetchData();
                        this.setTab('history');
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi kiểm kê kho.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },
                async submitAdjust() {
                    if (this.adjustError) return;
                    this.submitting = true;
                    try {
                        const qtyChange = this.forms.adjust.direction === 'increase' 
                            ? this.forms.adjust.quantity 
                            : -this.forms.adjust.quantity;

                        const payload = {
                            productId: this.forms.adjust.productId,
                            quantityChange: qtyChange,
                            reason: this.forms.adjust.reason,
                            note: this.forms.adjust.note
                        };

                        const res = await axios.post('/api/inventory/adjust', payload);

                        await Swal.fire({
                            title: 'Đã tạo phiếu điều chỉnh!',
                            html: `<div class="text-start"><p>${res.data.message}</p><p class="mb-0 text-muted"><small>Phiếu đang chờ Quản lý/Admin phê duyệt.</small></p></div>`,
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });

                        // Reset form
                        this.forms.adjust.productId = '';
                        this.forms.adjust.quantity = 1;
                        this.forms.adjust.reason = '';
                        this.forms.adjust.note = '';

                        await this.fetchData();
                        this.setTab('history');
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi điều chỉnh kho.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },

                // Approval workflow
                async approveTx(tx) {
                    const confirm = await Swal.fire({
                        title: 'Xác nhận duyệt?',
                        html: `Bạn có chắc muốn <b>duyệt</b> phiếu <b>${tx.code}</b>?<br>Sản phẩm: <b>${tx.productName}</b><br>Số lượng: <b>${tx.quantityChange > 0 ? '+' : ''}${tx.quantityChange} cái</b>`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Duyệt',
                        cancelButtonText: 'Huỷ',
                        confirmButtonColor: '#198754'
                    });
                    if (!confirm.isConfirmed) return;

                    this.submitting = true;
                    try {
                        const res = await axios.post(`/api/inventory/approve/${tx.id}`);
                        await Swal.fire({
                            title: 'Đã duyệt!',
                            text: res.data.message || 'Phiếu đã được duyệt và tồn kho đã được cập nhật.',
                            icon: 'success',
                            confirmButtonText: 'Đồng ý'
                        });
                        await this.fetchData();
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi duyệt phiếu.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },
                async rejectTx(tx) {
                    const confirm = await Swal.fire({
                        title: 'Xác nhận từ chối?',
                        html: `Bạn có chắc muốn <b>từ chối</b> phiếu <b>${tx.code}</b>?<br>Sản phẩm: <b>${tx.productName}</b>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Từ chối',
                        cancelButtonText: 'Huỷ',
                        confirmButtonColor: '#dc3545'
                    });
                    if (!confirm.isConfirmed) return;

                    this.submitting = true;
                    try {
                        const res = await axios.post(`/api/inventory/reject/${tx.id}`);
                        await Swal.fire({
                            title: 'Đã từ chối!',
                            text: res.data.message || 'Phiếu đã bị từ chối. Tồn kho không thay đổi.',
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });
                        await this.fetchData();
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi từ chối phiếu.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },

                // Adjustment approval workflow
                async approveAdjust(tx) {
                    const confirm = await Swal.fire({
                        title: 'Xác nhận duyệt phiếu điều chỉnh?',
                        html: `Bạn có chắc muốn <b>duyệt</b> phiếu <b>${tx.code}</b>?<br>Sản phẩm: <b>${tx.productName}</b><br>Thay đổi: <b>${tx.quantityChange > 0 ? '+' : ''}${tx.quantityChange} cái</b>`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: '<i class="fa-solid fa-check me-1"></i>Duyệt phiếu',
                        cancelButtonText: 'Huỷ',
                        confirmButtonColor: '#198754'
                    });
                    if (!confirm.isConfirmed) return;

                    this.submitting = true;
                    try {
                        const res = await axios.post(`/api/inventory/adjust/approve/${tx.id}`);
                        await Swal.fire({
                            title: 'Đã duyệt!',
                            text: res.data.message || 'Phiếu điều chỉnh đã được duyệt và tồn kho đã được cập nhật.',
                            icon: 'success',
                            confirmButtonText: 'Đồng ý'
                        });
                        await this.fetchData();
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi duyệt phiếu điều chỉnh.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                },
                async rejectAdjust(tx) {
                    const { value: lyDo } = await Swal.fire({
                        title: 'Từ chối phiếu điều chỉnh',
                        html: `Phiếu: <b>${tx.code}</b><br>Sản phẩm: <b>${tx.productName}</b><br>Thay đổi: <b>${tx.quantityChange > 0 ? '+' : ''}${tx.quantityChange} cái</b>`,
                        input: 'textarea',
                        inputLabel: 'Lý do từ chối (bắt buộc)',
                        inputPlaceholder: 'Nhập lý do từ chối...',
                        inputAttributes: { required: true },
                        inputValidator: (value) => {
                            if (!value || !value.trim()) return 'Vui lòng nhập lý do từ chối!';
                        },
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: '<i class="fa-solid fa-xmark me-1"></i>Xác nhận từ chối',
                        cancelButtonText: 'Huỷ',
                        confirmButtonColor: '#dc3545'
                    });
                    if (!lyDo) return;

                    this.submitting = true;
                    try {
                        const res = await axios.post(`/api/inventory/adjust/reject/${tx.id}`, { lyDoTuChoi: lyDo });
                        await Swal.fire({
                            title: 'Đã từ chối!',
                            text: res.data.message || 'Phiếu điều chỉnh đã bị từ chối. Tồn kho không thay đổi.',
                            icon: 'info',
                            confirmButtonText: 'Đồng ý'
                        });
                        await this.fetchData();
                    } catch (err) {
                        const msg = err.response?.data?.message || 'Có lỗi xảy ra khi từ chối phiếu điều chỉnh.';
                        Swal.fire('Lỗi', msg, 'error');
                    } finally {
                        this.submitting = false;
                    }
                }
            }
        });
    </script>
}
