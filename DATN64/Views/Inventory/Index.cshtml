@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Kho bãi";

    var session = Context.Session;
    var userRolesStr = session?.GetString("UserRoles") ?? "";
    var roles = userRolesStr.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    var isManager = roles.Contains("Admin") || roles.Contains("Super Admin") || roles.Contains("Quản lý") || roles.Contains("Quản lý cửa hàng");
}

<div id="app" class="container-fluid animate-fade-in" v-cloak>
    <!-- Header Page -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-gradient mb-0"><i class="fa-solid fa-warehouse me-2"></i>Quản lý Kho bãi</h2>
            <p class="text-muted-custom text-sm mb-0">Hệ thống quản lý tồn kho và giao dịch kho tổng hợp</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <span class="badge bg-info-subtle text-info p-2 rounded-pill px-3">
                <i class="fa-solid fa-clock me-1"></i> Cập nhật: ${ lastUpdated }
            </span>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-glass">
        <div class="card-body p-2">
            <ul class="nav nav-pills nav-fill gap-1" id="inventoryTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'dashboard' }" @@click="setTab('dashboard')">
                        <i class="fa-solid fa-chart-pie me-2"></i>Thống kê
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'stock' }" @@click="setTab('stock')">
                        <i class="fa-solid fa-boxes-stacked me-2"></i>Tồn kho
                    </button>
                </li>

                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'audit' }" @@click="setTab('audit')">
                        <i class="fa-solid fa-clipboard-check me-2 text-warning"></i>Kiểm kê
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'adjust' }" @@click="setTab('adjust')">
                        <i class="fa-solid fa-sliders me-2 text-primary"></i>Điều chỉnh
                    </button>
                </li>
                <li class="nav-item" role="presentation" v-if="isManager">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'approval' }" @@click="setTab('approval')">
                        <i class="fa-solid fa-clipboard-check me-2 text-warning"></i>Phê duyệt điều chỉnh
                        <span v-if="pendingAdjustments.length > 0" class="badge bg-danger rounded-pill ms-1">${ pendingAdjustments.length }</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-3 py-2.5" :class="{ active: activeTab === 'history' }" @@click="setTab('history')">
                        <i class="fa-solid fa-history me-2"></i>Lịch sử
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="tab-content" id="inventoryTabContent">
        
        <!-- 1. DASHBOARD TAB -->
        <div class="tab-pane show active" v-if="activeTab === 'dashboard'">
            <!-- Stats Grid -->
            <div class="row g-4 mb-4">
                <div class="col-md-4 col-lg">
                    <div class="card border-0 shadow-sm rounded-4 card-glass text-center p-3 h-100">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-circle mb-3 mx-auto" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-box fs-5"></i>
                        </div>
                        <h6 class="text-muted-custom text-xs fw-bold text-uppercase mb-1">Tổng sản phẩm</h6>
                        <h3 class="fw-extrabold text-primary mb-0">${ stats.totalProducts }</h3>
                    </div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="card border-0 shadow-sm rounded-4 card-glass text-center p-3 h-100">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-circle mb-3 mx-auto" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-boxes-stacked fs-5"></i>
                        </div>
                        <h6 class="text-muted-custom text-xs fw-bold text-uppercase mb-1">Tổng tồn kho</h6>
                        <h3 class="fw-extrabold text-success mb-0">${ stats.totalStock }</h3>
                    </div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="card border-0 shadow-sm rounded-4 card-glass text-center p-3 h-100">
                        <div class="d-inline-flex align-items-center justify-content-center bg-info-subtle text-info rounded-circle mb-3 mx-auto" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-circle-down fs-5"></i>
                        </div>
                        <h6 class="text-muted-custom text-xs fw-bold text-uppercase mb-1">Nhập hôm nay</h6>
                        <h3 class="fw-extrabold text-info mb-0">${ stats.importsToday }</h3>
                    </div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="card border-0 shadow-sm rounded-4 card-glass text-center p-3 h-100">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle mb-3 mx-auto" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-circle-up fs-5"></i>
                        </div>
                        <h6 class="text-muted-custom text-xs fw-bold text-uppercase mb-1">Xuất hôm nay</h6>
                        <h3 class="fw-extrabold text-danger mb-0">${ stats.exportsToday }</h3>
                    </div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="card border-0 shadow-sm rounded-4 card-glass text-center p-3 h-100">
                        <div class="d-inline-flex align-items-center justify-content-center bg-warning-subtle text-warning rounded-circle mb-3 mx-auto" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-triangle-exclamation fs-5"></i>
                        </div>
                        <h6 class="text-muted-custom text-xs fw-bold text-uppercase mb-1">Sắp hết hàng</h6>
                        <h3 class="fw-extrabold text-warning mb-0">${ stats.lowStockProducts }</h3>
                    </div>
                </div>
            </div>

            <!-- Double Column: Recent activity and Low stock products -->
            <div class="row g-4">
                <!-- Low Stock Products List -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 card-glass h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0 text-gradient"><i class="fa-solid fa-triangle-exclamation text-warning me-2"></i>Sản phẩm sắp hết hàng</h5>
                            <button class="btn btn-sm btn-link text-decoration-none" @@click="setTab('stock')">Xem tất cả</button>
                        </div>
                        <div class="card-body p-4">
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                        <tr>
                                            <th>Sản phẩm</th>
                                            <th>Tồn kho</th>
                                            <th>Giá bán</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr v-if="lowStockItems.length === 0">
                                            <td colspan="3" class="text-center py-4 text-muted">Không có sản phẩm nào sắp hết hàng!</td>
                                        </tr>
                                        <tr v-for="item in lowStockItems.slice(0, 5)" :key="item.maSanPham">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img :src="item.hinhAnh || 'https://via.placeholder.com/40'" class="rounded shadow-sm me-2" width="36" height="36">
                                                    <div>
                                                        <span class="fw-bold d-block text-xs text-truncate" style="max-width: 200px;">${ item.tenSanPham }</span>
                                                        <small class="text-muted text-xxs">Mã SP: #${ item.maSanPham }</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-danger-subtle text-danger" v-if="item.soLuongTon === 0">Hết hàng</span>
                                                <span class="badge bg-warning-subtle text-warning" v-else>${ item.soLuongTon } cái</span>
                                            </td>
                                            <td class="fw-bold text-success text-xs">${ formatCurrency(item.giaBan) }</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Transactions -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 card-glass h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0 text-gradient"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Giao dịch kho gần đây</h5>
                            <button class="btn btn-sm btn-link text-decoration-none" @@click="setTab('history')">Xem lịch sử</button>
                        </div>
                        <div class="card-body p-4">
                            <div class="timeline" v-if="transactions.length > 0">
                                <div class="d-flex mb-3 align-items-start pb-2 border-bottom border-secondary border-opacity-10" v-for="tx in transactions.slice(0, 5)" :key="tx.id">
                                    <div class="me-3">
                                        <span class="badge rounded-pill p-2" :class="{
                                            'bg-success-subtle text-success': tx.type === 'Nhập kho',
                                            'bg-danger-subtle text-danger': tx.type === 'Xuất kho',
                                            'bg-warning-subtle text-warning': tx.type === 'Kiểm kê',
                                            'bg-primary-subtle text-primary': tx.type === 'Điều chỉnh'
                                        }">
                                            <i class="fa-solid" :class="{
                                                'fa-circle-down': tx.type === 'Nhập kho',
                                                'fa-circle-up': tx.type === 'Xuất kho',
                                                'fa-clipboard-check': tx.type === 'Kiểm kê',
                                                'fa-sliders': tx.type === 'Điều chỉnh'
                                            }"></i>
                                        </span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-bold text-xs">${ tx.productName }</span>
                                            <small class="text-muted text-xxs">${ tx.date }</small>
                                        </div>
                                        <p class="mb-0 text-xs text-muted-custom">
                                            <span class="fw-semibold text-dark">${ tx.type }</span>: 
                                            <span :class="tx.quantityChange >= 0 ? 'text-success fw-bold' : 'text-danger fw-bold'">
                                                ${ tx.quantityChange >= 0 ? '+' : '' }${ tx.quantityChange } cái
                                            </span>
                                        </p>
                                        <small class="text-muted text-xxs d-block mt-0.5"><i class="fa-solid fa-user me-1"></i>${ tx.creator } &bull; Lý do/Ghi chú: ${ tx.note }</small>
                                    </div>
                                </div>
                            </div>
                            <div v-else class="text-center py-5 text-muted">
                                Chưa có giao dịch nào được ghi nhận.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. STOCK TAB -->
        <div class="tab-pane show active" v-if="activeTab === 'stock'">
            <div class="card border-0 shadow-sm rounded-4 bg-glass">
                <div class="card-body p-4">
                    <!-- Filters Grid -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label text-muted-custom text-xs fw-bold text-uppercase">Tìm kiếm sản phẩm</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0 ps-0" v-model="filters.search" placeholder="Nhập tên hoặc mã sản phẩm...">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted-custom text-xs fw-bold text-uppercase">Danh mục</label>
                            <select class="form-select" v-model="filters.category">
                                <option value="">Tất cả danh mục</option>
                                <option v-for="cat in categories" :value="cat.maDanhMuc">${ cat.tenDanhMuc }</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted-custom text-xs fw-bold text-uppercase">Thương hiệu</label>
                            <select class="form-select" v-model="filters.brand">
                                <option value="">Tất cả thương hiệu</option>
                                <option v-for="b in brands" :value="b.maThuongHieu">${ b.tenThuongHieu }</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-outline-secondary w-100 rounded-3" @@click="resetFilters">
                                <i class="fa-solid fa-rotate-left me-1"></i>Xóa lọc
                            </button>
                        </div>
                    </div>

                    <!-- Products Table -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã SP</th>
                                    <th>Sản phẩm</th>
                                    <th>Danh mục</th>
                                    <th>Thương hiệu</th>
                                    <th class="text-end">Giá vốn (Giá nhập)</th>
                                    <th class="text-end">Giá bán</th>
                                    <th class="text-center">Số lượng tồn</th>
                                    <th class="text-center">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-if="filteredProducts.length === 0">
                                    <td colspan="8" class="text-center py-5 text-muted">
                                        <i class="fa-solid fa-box-open fs-2 mb-2 d-block"></i>
                                        Không tìm thấy sản phẩm nào!
                                    </td>
                                </tr>
                                <tr v-for="item in filteredProducts" :key="item.maSanPham" class="group-hover">
                                    <td class="fw-medium text-secondary">#${ item.maSanPham }</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img :src="item.hinhAnh || 'https://via.placeholder.com/40'" class="rounded shadow-sm me-3" width="40" height="40" alt="Ảnh SP">
                                            <div>
                                                <h6 class="mb-0 fw-bold">${ item.tenSanPham }</h6>
                                                <small class="text-muted-custom text-xs">NCC: ${ item.nhaCungCapTen }</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>${ item.danhMucTen }</td>
                                    <td>${ item.thuongHieuTen }</td>
                                    <td class="text-end fw-bold text-secondary">${ formatCurrency(item.giaNhap) }</td>
                                    <td class="text-end fw-bold text-success">${ formatCurrency(item.giaBan) }</td>
                                    <td class="text-center">
                                        <span class="badge fs-7 px-3 py-1.5 rounded-pill" :class="{
                                            'bg-danger-subtle text-danger': item.soLuongTon === 0,
                                            'bg-warning-subtle text-warning': item.soLuongTon > 0 && item.soLuongTon <= 10,
                                            'bg-success-subtle text-success': item.soLuongTon > 10
                                        }">
                                            ${ item.soLuongTon } cái
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill" :class="item.trangThai === 'Đang bán' ? 'bg-success' : 'bg-secondary'">
                                            ${ item.trangThai }
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. IMPORT TAB -->
        <div class="tab-pane show active" v-if="activeTab === 'import'">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 card-glass p-4">
                        <div class="card-title mb-4 d-flex align-items-center">
                            <h4 class="fw-bold mb-0 text-success"><i class="fa-solid fa-circle-down me-2"></i>Tạo Phiếu Nhập Kho</h4>
                        </div>
                        <form @@submit.prevent="submitImport">
                            <!-- Product Select -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Chọn sản phẩm</label>
                                <select class="form-select" v-model="forms.import.productId" required @@change="updateImportPreview">
                                    <option value="" disabled>--- Chọn sản phẩm cần nhập ---</option>
                                    <option v-for="p in activeProducts" :value="p.maSanPham">
                                        ${ p.tenSanPham } (Mã: #${ p.maSanPham }) - Hiện có: ${ p.soLuongTon } cái
                                    </option>
                                </select>
                            </div>

                            <!-- Source Select -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Nguồn nhập kho</label>
                                <select class="form-select" v-model="forms.import.source" required>
                                    <option value="Nhà cung cấp">Nhà cung cấp</option>
                                    <option value="Nhập trả">Nhập trả (Khách trả hàng)</option>
                                    <option value="Điều chỉnh tăng">Điều chỉnh tăng</option>
                                </select>
                            </div>

                            <!-- Quantity -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Số lượng nhập</label>
                                <input type="number" class="form-control" v-model.number="forms.import.quantity" min="1" required @@input="updateImportPreview">
                            </div>

                            <!-- Preview Diff Stock -->
                            <div class="p-3 bg-light rounded-3 mb-4 d-flex align-items-center justify-content-between" v-if="forms.import.productId && forms.import.quantity > 0">
                                <div>
                                    <span class="text-xs text-muted d-block">Xem trước thay đổi tồn kho:</span>
                                    <span class="fw-bold">${ selectedImportProduct.tenSanPham }</span>
                                </div>
                                <div class="text-end">
                                    <span class="fs-5 text-secondary fw-semibold">${ selectedImportProduct.soLuongTon } cái</span>
                                    <i class="fa-solid fa-arrow-right mx-2 text-muted"></i>
                                    <span class="fs-5 text-success fw-bold">${ selectedImportProduct.soLuongTon + forms.import.quantity } cái (+${ forms.import.quantity })</span>
                                </div>
                            </div>

                            <!-- Note -->
                            <div class="mb-4">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Ghi chú nhập kho</label>
                                <textarea class="form-control" v-model="forms.import.note" placeholder="Nhập ghi chú hoặc lý do nhập kho..." rows="3"></textarea>
                            </div>

                            <!-- Action -->
                            <button type="submit" class="btn btn-success rounded-3 w-100 fw-bold py-2.5 shadow-sm" :disabled="submitting">
                                <span v-if="submitting" class="spinner-border spinner-border-sm me-2"></span>
                                <i class="fa-solid fa-circle-check me-2" v-else></i> Xác nhận nhập kho
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. EXPORT TAB -->
        <div class="tab-pane show active" v-if="activeTab === 'export'">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 card-glass p-4">
                        <div class="card-title mb-4 d-flex align-items-center">
                            <h4 class="fw-bold mb-0 text-danger"><i class="fa-solid fa-circle-up me-2"></i>Tạo Phiếu Xuất Kho</h4>
                        </div>
                        <form @@submit.prevent="submitExport">
                            <!-- Product Select -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Chọn sản phẩm</label>
                                <select class="form-select" v-model="forms.export.productId" required @@change="updateExportPreview">
                                    <option value="" disabled>--- Chọn sản phẩm cần xuất ---</option>
                                    <option v-for="p in activeProducts" :value="p.maSanPham">
                                        ${ p.tenSanPham } (Mã: #${ p.maSanPham }) - Hiện có: ${ p.soLuongTon } cái
                                    </option>
                                </select>
                            </div>

                            <!-- Source Select -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Nguồn xuất kho</label>
                                <select class="form-select" v-model="forms.export.source" required>
                                    <option value="Xuất POS">Xuất cho POS (Bán hàng lẻ)</option>
                                    <option value="Xuất Website Online">Xuất bán Online (Đơn hàng Website)</option>
                                    <option value="Hàng hỏng">Hàng hỏng / Lỗi kỹ thuật</option>
                                    <option value="Trả nhà cung cấp">Trả hàng nhà cung cấp (Trả NCC)</option>
                                </select>
                            </div>

                            <!-- Quantity -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Số lượng xuất</label>
                                <input type="number" class="form-control" v-model.number="forms.export.quantity" min="1" required @@input="updateExportPreview">
                                <div class="form-text text-danger fw-bold text-xs" v-if="exportError">
                                    <i class="fa-solid fa-triangle-exclamation"></i> ${ exportError }
                                </div>
                            </div>

                            <!-- Preview Diff Stock -->
                            <div class="p-3 bg-light rounded-3 mb-4 d-flex align-items-center justify-content-between" v-if="forms.export.productId && forms.export.quantity > 0 && !exportError">
                                <div>
                                    <span class="text-xs text-muted d-block">Xem trước thay đổi tồn kho:</span>
                                    <span class="fw-bold">${ selectedExportProduct.tenSanPham }</span>
                                </div>
                                <div class="text-end">
                                    <span class="fs-5 text-secondary fw-semibold">${ selectedExportProduct.soLuongTon } cái</span>
                                    <i class="fa-solid fa-arrow-right mx-2 text-muted"></i>
                                    <span class="fs-5 text-danger fw-bold">${ selectedExportProduct.soLuongTon - forms.export.quantity } cái (-${ forms.export.quantity })</span>
                                </div>
                            </div>

                            <!-- Note -->
                            <div class="mb-4">
                                <label class="form-label fw-bold text-xs text-uppercase text-muted-custom">Lý do / Ghi chú xuất kho</label>
                                <textarea class="form-control" v-model="forms.export.note" placeholder="Nhập ghi chú hoặc lý do xuất kho..." rows="3"></textarea>
                            </div>

                            <!-- Action -->
