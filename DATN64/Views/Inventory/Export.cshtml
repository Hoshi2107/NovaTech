@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xuất kho sản phẩm";
    ViewData["BreadcrumbActive"] = "Xuất kho";
    var products = ViewBag.Products as List<DATN64.Models.SanPham> ?? new();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-glass p-4">
            <h5 class="fw-bold mb-4 text-danger"><i class="fa-solid fa-circle-up me-2"></i>Tạo phiếu xuất kho</h5>
            <form method="post" action="@Url.Action("SubmitExport", "Inventory")">
                <div class="mb-3">
                    <label class="form-label text-sm">Chọn sản phẩm cần xuất</label>
                    <select name="productId" class="form-select bg-dark border-secondary border-opacity-50 text-white" required>
                        @foreach (var p in products)
                        {
                            <option value="@p.MaSanPham">@p.TenSanPham (Mã: @p.MaSanPham) - Tồn hiện tại: @p.SoLuongTon</option>
                        }
                    </select>
                </div>
                
                <div class="mb-3">
                    <label class="form-label text-sm">Số lượng xuất</label>
                    <input type="number" name="quantity" class="form-control bg-dark border-secondary border-opacity-50 text-white" required min="1" value="1">
                </div>

                <div class="mb-4">
                    <label class="form-label text-sm">Lý do xuất kho</label>
                    <input type="text" name="note" class="form-control bg-dark border-secondary border-opacity-50 text-white" placeholder="Chuyển kho chi nhánh, xuất thanh lý, v.v.">
                </div>

                <button type="submit" class="btn btn-danger rounded-pill px-4 w-100 fw-bold">Xác nhận xuất kho</button>
            </form>
        </div>
    </div>
</div>


