@model DATN64.Models.TikTokShopConfig
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "TikTok Sync"; }
<div class="container my-5">
    <h2>Cấu hình TikTok Shop</h2>
    <p>Trạng thái: @(Model?.IsConnected == true ? "Đã kết nối" : "Chưa kết nối")</p>
    <p>Shop ID: @Model?.ShopId</p>
    <p>Đồng bộ cuối: @Model?.LastSyncTime.ToString("dd/MM/yyyy HH:mm:ss")</p>
    <form asp-action="TriggerSync" method="post">
        <select name="syncType" class="form-control mb-2 w-25">
            <option value="Đơn hàng">Đồng bộ Đơn hàng</option>
            <option value="Sản phẩm">Đồng bộ Sản phẩm</option>
        </select>
        <button type="submit" class="btn btn-primary">Đồng bộ ngay</button>
    </form>
</div>