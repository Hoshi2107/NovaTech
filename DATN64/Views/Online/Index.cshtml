@model List<DATN64.Models.SanPham>
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = "Trang chủ NovaTech";
    // Simplified for DB schema
    var flashSaleProducts = Model.Take(4).ToList();
    var bestSellers = Model.Skip(4).Take(4).ToList();
}

<!-- Hero Banner Section -->
<div class="p-5 mb-5 rounded-4 shadow-sm" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(241, 245, 249, 0.9) 100%), url('https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=1200&auto=format&fit=crop'); background-blend-mode: overlay; background-size: cover; border: 1px solid #e2e8f0;">
    <div class="container-fluid py-5">
        <h1 class="display-4 fw-extrabold text-neon">Siêu Thị Công Nghệ NovaTech</h1>
        <p class="col-md-8 fs-5 text-dark" style="line-height: 1.6;">Chào mừng đến với cửa hàng bán lẻ thiết bị công nghệ uy tín. Tận hưởng ưu đãi độc quyền tại cửa hàng trực tuyến tích hợp của chúng tôi.</p>
        <div class="d-flex gap-3 mt-4">
            <a href="@Url.Action("ProductsList", "Online")" class="btn btn-info rounded-pill px-4 text-white fw-bold shadow-sm">Mua Sắm Ngay <i class="fa-solid fa-arrow-right ms-2"></i></a>
            <a href="#" class="btn btn-outline-secondary rounded-pill px-4">Tìm hiểu thêm</a>
        </div>
    </div>
</div>

<!-- Category Navigation Row -->
<div class="container my-5 animate-fade-in">
    <h5 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-layer-group text-primary me-2"></i>Danh mục sản phẩm</h5>
    <div class="d-flex flex-wrap justify-content-center justify-content-md-between gap-3">
        <a href="@Url.Action("ProductsList", "Online", new { category = "Điện thoại" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon"><i class="fa-solid fa-mobile-screen-button"></i></div>
                <div class="chotot-cat-title">Điện thoại</div>
            </div>
        </a>
        <a href="@Url.Action("ProductsList", "Online", new { category = "Laptop" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon"><i class="fa-solid fa-laptop"></i></div>
                <div class="chotot-cat-title">Laptop</div>
            </div>
        </a>
        <a href="@Url.Action("ProductsList", "Online", new { category = "Phụ kiện" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon"><i class="fa-solid fa-keyboard"></i></div>
                <div class="chotot-cat-title">Phụ kiện</div>
            </div>
        </a>
    </div>
</div>

<!-- PRODUCTS SECTION -->
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-crown text-warning me-2"></i>Sản phẩm nổi bật</h3>
        <a href="@Url.Action("ProductsList", "Online")" class="text-primary text-decoration-none fw-semibold">Xem tất cả <i class="fa-solid fa-angles-right ms-1"></i></a>
    </div>
    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card card-product h-100 p-3 shadow-sm border border-light bg-white">
                    <img src="@p.HinhAnh" class="card-img-top rounded-3 mb-3" alt="@p.TenSanPham" style="height: 180px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=300'">
                    <div class="card-body p-0 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge bg-light text-primary border border-info border-opacity-25 mb-2 text-xxs">@(p.DanhMuc?.TenDanhMuc ?? "Khác")</span>
                            <h5 class="card-title fw-bold text-dark fs-6 mb-1">
                                <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="text-decoration-none text-dark">@p.TenSanPham</a>
                            </h5>
                            <p class="text-xxs text-muted mb-2">Thương hiệu: @(p.ThuongHieu?.TenThuongHieu ?? "Khác")</p>
                            
                            <div class="mb-3">
                                <span class="card-text text-danger fw-bold fs-5">@p.GiaBan.ToString("N0") đ</span>
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="btn btn-outline-danger rounded-pill text-xs py-2 fw-semibold">
                                Xem Chi Tiết
                            </a>
                            <button class="btn btn-danger rounded-pill text-xs py-2 fw-semibold text-white shadow-sm" type="button" onclick="addToCart(@p.MaSanPham)">
                                <i class="fa-solid fa-cart-plus me-1"></i>Thêm Vào Giỏ
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId + '&qty=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const badge = document.querySelector('.navbar .badge');
                    if (badge) {
                        badge.innerText = data.cartCount;
                    }
                    alert('Đã thêm sản phẩm vào giỏ hàng!');
                }
            });
        }
    </script>
}
