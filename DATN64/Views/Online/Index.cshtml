@model List<DATN64.Models.SanPham>
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = "Trang chủ NovaTech";
    // Simplified for DB schema
    var flashSaleProducts = Model.Take(4).ToList();
    var bestSellers = Model.Skip(4).Take(4).ToList();
}
<!-- Hero Banner Section (Carousel) -->
<div id="heroBannerCarousel" class="carousel slide carousel-fade mb-5 rounded-4 overflow-hidden shadow-sm animate-fade-in" data-bs-ride="carousel" data-bs-interval="4000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active" style="height: 380px;">
            <div class="w-100 h-100" style="background: linear-gradient(rgba(15, 23, 42, 0.55), rgba(15, 23, 42, 0.65)), url('https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat;">
                <div class="container h-100 d-flex align-items-center">
                    <div class="text-white py-5 px-3 px-md-5">
                        <span class="badge bg-info text-dark text-xxs fw-bold px-3 py-1.5 rounded-pill mb-3 text-uppercase">Công nghệ đỉnh cao</span>
                        <h1 class="display-5 fw-extrabold mb-3">Siêu Thị Công Nghệ NovaTech</h1>
                        <p class="fs-6 opacity-90 col-lg-8 mb-4">Chào mừng đến với cửa hàng bán lẻ thiết bị công nghệ uy tín. Tận hưởng ưu đãi độc quyền tại cửa hàng trực tuyến tích hợp của chúng tôi.</p>
                        <div class="d-flex gap-3">
                            <a href="@Url.Action("ProductsList", "Online")" class="btn btn-info rounded-pill px-4 py-2.5 text-white fw-bold shadow-sm">Mua Sắm Ngay <i class="fa-solid fa-arrow-right ms-2"></i></a>
                            <a href="#" class="btn btn-outline-light rounded-pill px-4 py-2.5 fw-bold">Tìm hiểu thêm</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Slide 2 -->
        <div class="carousel-item" style="height: 380px;">
            <div class="w-100 h-100" style="background: linear-gradient(rgba(15, 23, 42, 0.55), rgba(15, 23, 42, 0.65)), url('https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat;">
                <div class="container h-100 d-flex align-items-center">
                    <div class="text-white py-5 px-3 px-md-5">
                        <span class="badge bg-warning text-dark text-xxs fw-bold px-3 py-1.5 rounded-pill mb-3 text-uppercase">Hot Trend 2026</span>
                        <h1 class="display-5 fw-extrabold mb-3">Trải Nghiệm Smartphone Mới</h1>
                        <p class="fs-6 opacity-90 col-lg-8 mb-4">Khám phá các dòng điện thoại thông minh, máy tính bảng hàng đầu thế giới với chương trình trợ giá tốt nhất hiện nay.</p>
                        <div class="d-flex gap-3">
                            <a href="@Url.Action("ProductsList", "Online", new { category = "Điện thoại" })" class="btn btn-warning rounded-pill px-4 py-2.5 text-dark fw-bold shadow-sm">Xem Ngay <i class="fa-solid fa-arrow-right ms-2"></i></a>
                            <a href="#" class="btn btn-outline-light rounded-pill px-4 py-2.5 fw-bold">Tìm hiểu thêm</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Slide 3 -->
        <div class="carousel-item" style="height: 380px;">
            <div class="w-100 h-100" style="background: linear-gradient(rgba(15, 23, 42, 0.55), rgba(15, 23, 42, 0.65)), url('https://images.unsplash.com/photo-1484704849700-f032a568e944?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat;">
                <div class="container h-100 d-flex align-items-center">
                    <div class="text-white py-5 px-3 px-md-5">
                        <span class="badge bg-danger text-white text-xxs fw-bold px-3 py-1.5 rounded-pill mb-3 text-uppercase">Âm Thanh Sống Động</span>
                        <h1 class="display-5 fw-extrabold mb-3">Thế Giới Âm Nhạc Cực Chất</h1>
                        <p class="fs-6 opacity-90 col-lg-8 mb-4">Các sản phẩm Tai nghe, Loa Bluetooth chính hãng mang đến chất lượng âm thanh đỉnh cao, chân thực đến từng chi tiết.</p>
                        <div class="d-flex gap-3">
                            <a href="@Url.Action("ProductsList", "Online", new { category = "Tai nghe" })" class="btn btn-danger rounded-pill px-4 py-2.5 text-white fw-bold shadow-sm">Khám Phá <i class="fa-solid fa-arrow-right ms-2"></i></a>
                            <a href="#" class="btn btn-outline-light rounded-pill px-4 py-2.5 fw-bold">Tìm hiểu thêm</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroBannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroBannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Category Navigation Row -->
<div class="container my-5 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0 text-dark">
            <i class="fa-solid fa-layer-group text-primary me-2"></i>Danh mục sản phẩm
        </h5>
        <!-- Expandable Arrow Button -->
        <button id="toggleCategoryBtn" class="btn btn-outline-info rounded-pill px-3 py-1.5 btn-sm fw-bold transition-all d-flex align-items-center gap-1">
            <span id="toggleText">Xem tất cả</span>
            <i id="toggleIcon" class="fa-solid fa-chevron-down"></i>
        </button>
    </div>

    <div id="categoryContainer" class="scroll-category-container">
        <a href="@Url.Action("ProductsList", "Online", new { category = "Điện thoại" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                </div>
                <div class="chotot-cat-title">Điện thoại</div>
            </div>
        </a>

        <a href="@Url.Action("ProductsList", "Online", new { category = "Laptop" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-laptop"></i>
                </div>
                <div class="chotot-cat-title">Laptop</div>
            </div>
        </a>

        <a href="@Url.Action("ProductsList", "Online", new { category = "Máy tính bảng" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-tablet-screen-button"></i>
                </div>
                <div class="chotot-cat-title">Máy tính bảng</div>
            </div>
        </a>

        <a href="@Url.Action("ProductsList", "Online", new { category = "Tai nghe" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-headphones"></i>
                </div>
                <div class="chotot-cat-title">Tai nghe</div>
            </div>
        </a>

        <a href="@Url.Action("ProductsList", "Online", new { category = "Phụ kiện" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-keyboard"></i>
                </div>
                <div class="chotot-cat-title">Phụ kiện</div>
            </div>
        </a>

        <a href="@Url.Action("ProductsList", "Online", new { category = "Loa" })" class="text-decoration-none">
            <div class="chotot-cat-card">
                <div class="chotot-cat-icon">
                    <i class="fa-solid fa-volume-high"></i>
                </div>
                <div class="chotot-cat-title">Loa & Âm thanh</div>
            </div>
        </a>
    </div>
</div>

<!-- Advertising Carousel Panels -->
<div class="container my-5">
    <div class="row gy-4 align-items-stretch">
        <!-- Left Banner Carousel -->
        <div class="col-lg-3 d-flex">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden w-100 h-100">
                <div class="card-body p-0 h-100">
                    <div id="leftAdCarousel" class="carousel slide h-100" data-bs-ride="carousel">
                        <div class="carousel-inner h-100">
                            @if (ViewBag.LeftCarouselProducts is List<DATN64.Models.SanPham> leftAds && leftAds.Any())
                            {
                                var index = 0;
                                foreach (var ad in leftAds)
                                {
                                    <div class="carousel-item h-100 @(index == 0 ? "active" : "")">
                                        <img src="@(ad.HinhAnh != null ? ImageHelper.AppendVersion(ad.HinhAnh) : "https://images.unsplash.com/photo-1598327105666-5b89351aff97?q=80&w=500")" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="@ad.TenSanPham">
                                        <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                            <span class="badge bg-info text-dark text-xxs fw-bold px-2.5 py-1 mb-2">HOT DEAL</span>
                                            <h6 class="fw-bold text-white mb-1">@ad.TenSanPham</h6>
                                            <p class="mb-0 text-warning fw-bold">@ad.GiaBan.ToString("N0") đ</p>
                                        </div>
                                    </div>
                                    index++;
                                }
                            }
                            else
                            {
                                <!-- Slide 1 (iPhone 15) -->
                                <div class="carousel-item active h-100">
                                    <img src="https://images.unsplash.com/photo-1510557880182-3f8ed9f4a7b6?q=80&w=800" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="iPhone 15">
                                    <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                        <span class="badge bg-info text-dark text-xxs fw-bold px-2.5 py-1 mb-2">HOT DEAL</span>
                                        <h6 class="fw-bold text-white mb-1">iPhone 15</h6>
                                        <p class="mb-0 text-warning fw-bold">22,000,000 đ</p>
                                    </div>
                                </div>
                                <!-- Slide 2 (Asus Vivobook 15) -->
                                <div class="carousel-item h-100">
                                    <img src="https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?q=80&w=800" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="Asus Vivobook 15">
                                    <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                        <span class="badge bg-info text-dark text-xxs fw-bold px-2.5 py-1 mb-2">MỚI VỀ</span>
                                        <h6 class="fw-bold text-white mb-1">Asus Vivobook 15</h6>
                                        <p class="mb-0 text-warning fw-bold">15,000,000 đ</p>
                                    </div>
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#leftAdCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#leftAdCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Middle Product List -->
        <div class="col-lg-6 d-flex">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white w-100 h-100">
                <div class="d-flex flex-column justify-content-between h-100">
                    <div>
                        <h5 class="text-info fw-bold mb-1">Ưu đãi hôm nay</h5>
                        <p class="text-muted text-sm mb-4">Xem nhanh các sản phẩm bán chạy và chương trình khuyến mãi đang được ưa chuộng.</p>
                    </div>
                    <div class="row gy-3">
                        @if (ViewBag.HeroBannerProducts is List<DATN64.Models.SanPham> heroAds && heroAds.Any())
                        {
                            foreach (var hero in heroAds)
                            {
                                <div class="col-12">
                                    <div class="d-flex align-items-center gap-3 border rounded-4 p-3 bg-light transition-all hover-shadow-sm">
                                        <img src="@(hero.HinhAnh != null ? ImageHelper.AppendVersion(hero.HinhAnh) : "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?q=80&w=150")" class="rounded-4" style="width: 70px; height: 70px; object-fit: cover;" alt="@hero.TenSanPham">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1 fw-bold text-dark text-sm">@hero.TenSanPham</h6>
                                            <p class="text-secondary mb-0 text-xxs text-truncate" style="max-width: 250px;" title="@(hero.MoTa ?? "")">
                                                <strong class="text-info">@(hero.ThuongHieu?.TenThuongHieu ?? "NovaTech")</strong> • @(string.IsNullOrEmpty(hero.MoTa) ? "Sản phẩm chính hãng chất lượng cao" : hero.MoTa)
                                            </p>
                                        </div>
                                        <div class="text-end">
                                            <span class="text-primary fw-bold text-sm">@hero.GiaBan.ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="border rounded-4 p-4 bg-light text-center">
                                    <h6 class="fw-bold text-dark">Chưa có thông tin quảng cáo</h6>
                                    <p class="text-muted text-xs">Hệ thống sẽ hiển thị ưu đãi khi có sản phẩm hợp lệ.</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Banner Carousel -->
        <div class="col-lg-3 d-flex">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden w-100 h-100">
                <div class="card-body p-0 h-100">
                    <div id="rightAdCarousel" class="carousel slide h-100" data-bs-ride="carousel">
                        <div class="carousel-inner h-100">
                            @if (ViewBag.RightCarouselProducts is List<DATN64.Models.SanPham> rightAds && rightAds.Any())
                            {
                                var index = 0;
                                foreach (var ad in rightAds)
                                {
                                    <div class="carousel-item h-100 @(index == 0 ? "active" : "")">
                                        <img src="@(ad.HinhAnh != null ? ImageHelper.AppendVersion(ad.HinhAnh) : "https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?q=80&w=500")" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="@ad.TenSanPham">
                                        <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                            <span class="badge bg-warning text-dark text-xxs fw-bold px-2.5 py-1 mb-2">KHUYẾN MÃI</span>
                                            <h6 class="fw-bold text-white mb-1">@ad.TenSanPham</h6>
                                            <p class="mb-0 text-warning fw-bold">@ad.GiaBan.ToString("N0") đ</p>
                                        </div>
                                    </div>
                                    index++;
                                }
                            }
                            else
                            {
                                <!-- Slide 1 (Samsung Galaxy S24) -->
                                <div class="carousel-item active h-100">
                                    <img src="https://images.unsplash.com/photo-1610945265064-0e34e5519bbf?q=80&w=800" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="Samsung Galaxy S24">
                                    <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                        <span class="badge bg-warning text-dark text-xxs fw-bold px-2.5 py-1 mb-2">KHUYẾN MÃI</span>
                                        <h6 class="fw-bold text-white mb-1">Samsung Galaxy S24</h6>
                                        <p class="mb-0 text-warning fw-bold">19,000,000 đ</p>
                                    </div>
                                </div>
                                <!-- Slide 2 (Chuột Logitech G102) -->
                                <div class="carousel-item h-100">
                                    <img src="https://images.unsplash.com/photo-1615663245857-ac93bb7c39e7?q=80&w=800" class="d-block w-100 h-100" style="height: 535px !important; object-fit: cover;" alt="Chuột Logitech G102">
                                    <div class="carousel-caption d-block text-start p-3 rounded-4" style="background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); left: 15px; right: 15px; bottom: 15px; border: 1px solid rgba(255,255,255,0.1);">
                                        <span class="badge bg-warning text-dark text-xxs fw-bold px-2.5 py-1 mb-2">BEST SELLER</span>
                                        <h6 class="fw-bold text-white mb-1">Chuột Logitech G102</h6>
                                        <p class="mb-0 text-warning fw-bold">350,000 đ</p>
                                    </div>
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#rightAdCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#rightAdCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- PRODUCTS SECTION -->
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-crown text-warning me-2"></i>Sản phẩm nổi bật</h3>
        <a href="@Url.Action("ProductsList", "Online")" class="text-primary text-decoration-none fw-semibold">Xem tất cả <i class="fa-solid fa-angles-right ms-1"></i></a>
    </div>
    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card card-product h-100 p-3 shadow-sm border border-light bg-white">
                    <img src="@ImageHelper.AppendVersion(p.HinhAnh)" class="card-img-top rounded-3 mb-3" alt="@p.TenSanPham" style="height: 180px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=300'">
                    <div class="card-body p-0 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge bg-light text-primary border border-info border-opacity-25 mb-2 text-xxs">@(p.DanhMuc?.TenDanhMuc ?? "Khác")</span>
                            <h5 class="card-title fw-bold text-dark fs-6 mb-1">
                                <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="text-decoration-none text-dark">@p.TenSanPham</a>
                            </h5>
                            <p class="text-xxs text-muted mb-2">Thương hiệu: @(p.ThuongHieu?.TenThuongHieu ?? "Khác")</p>
                            
                            <div class="mb-3">
                                <span class="card-text text-danger fw-bold fs-5">@p.GiaBan.ToString("N0") đ</span>
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="btn btn-outline-danger rounded-pill text-xs py-2 fw-semibold">
                                Xem Chi Tiết
                            </a>
                            @if (p.SoLuongTon <= 0)
                            {
                                <button class="btn btn-secondary rounded-pill text-xs py-2 fw-semibold text-white shadow-sm" type="button" disabled>
                                    <i class="fa-solid fa-ban me-1"></i>Hết Hàng
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-danger rounded-pill text-xs py-2 fw-semibold text-white shadow-sm" type="button" onclick="addToCart(@p.MaSanPham)">
                                    <i class="fa-solid fa-cart-plus me-1"></i>Thêm Vào Giỏ
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId + '&qty=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const badge = document.querySelector('.navbar .badge');
                    if (badge) {
                        badge.innerText = data.cartCount;
                    }
                    alert('Đã thêm sản phẩm vào giỏ hàng!');
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng!');
                }
            });
        }

        function addToFavorites(productId) {
            fetch('@Url.Action("AddToFavorites", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Đã thêm vào danh sách yêu thích!');
                }
            });
        }

        // Category arrow expand toggle logic
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('toggleCategoryBtn');
            const container = document.getElementById('categoryContainer');
            const toggleIcon = document.getElementById('toggleIcon');
            const toggleText = document.getElementById('toggleText');

            if (toggleBtn && container && toggleIcon && toggleText) {
                toggleBtn.addEventListener('click', () => {
                    container.classList.toggle('expanded');
                    if (container.classList.contains('expanded')) {
                        toggleIcon.className = 'fa-solid fa-chevron-up';
                        toggleText.innerText = 'Thu gọn';
                    } else {
                        toggleIcon.className = 'fa-solid fa-chevron-down';
                        toggleText.innerText = 'Xem tất cả';
                    }
                });
            }
        });
    </script>
}
