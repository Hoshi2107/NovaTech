@model List<DATN64.Controllers.OnlineController.CartItem>

@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = "Giỏ hàng & Thanh toán";

    decimal subtotal = Model.Sum(i => i.Total);
    var vouchers = ViewBag.Vouchers as List<DATN64.Models.Voucher> ?? new();

    var customerName = ViewBag.CustomerName as string ?? "";
    var customerEmail = ViewBag.CustomerEmail as string ?? "";
    var customerPhone = ViewBag.CustomerPhone as string ?? "";
    var customerAddress = ViewBag.CustomerAddress as string ?? "";
}

<div class="container my-5 animate-fade-in">
    <h3 class="fw-bold mb-4 text-dark">
        <i class="fa-solid fa-cart-shopping text-primary me-2"></i>Giỏ hàng của bạn
    </h3>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light">
            <div class="fs-1 text-muted mb-3">
                <i class="fa-solid fa-basket-shopping"></i>
            </div>
            <h4 class="text-secondary fw-semibold">Giỏ hàng đang trống</h4>
            <p class="text-xs text-muted mb-4">Vui lòng quay lại cửa hàng để chọn sản phẩm.</p>
            <a href="@Url.Action("ProductsList", "Online")"
               class="btn btn-primary rounded-pill px-5 py-2.5 text-xs fw-bold">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-7 col-xl-8">
                <div class="card border border-light shadow-sm p-4 bg-white rounded-4 mb-4">
                    <h5 class="fw-bold text-dark mb-4">
                        Danh sách sản phẩm (@Model.Sum(i => i.Quantity))
                    </h5>

                    <div class="table-responsive">
                        <table class="table align-middle table-borderless">
                            <thead>
                                <tr class="border-bottom border-light" style="font-size: 13px; color: #64748b;">
                                    <th colspan="2">Sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th class="text-end">Tổng</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="border-bottom border-light">
                                        <td style="width: 70px;">
                                            <img src="@ImageHelper.AppendVersion(item.Image)"
                                                 class="rounded-3 border"
                                                 style="width: 60px; height: 60px; object-fit: cover;">
                                        </td>

                                        <td>
                                            <div class="fw-bold text-dark text-sm">@item.Name</div>

                                            @if (item.IsDiscounted)
                                            {
                                                <span class="badge bg-danger-subtle text-danger text-xxs border border-danger border-opacity-10 mt-1">
                                                    <i class="fa-solid fa-bolt me-1"></i>Flash Sale
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <div class="text-sm fw-bold">
                                                @item.Price.ToString("N0") đ
                                            </div>

                                            @if (item.IsDiscounted)
                                            {
                                                <div class="text-xxs text-muted text-decoration-line-through">
                                                    @item.OriginalPrice.ToString("N0") đ
                                                </div>
                                            }
                                        </td>

                                        <td>
                                            <div class="quantity-picker">
                                                <button type="button" onclick="changeQty(@item.ProductId, -1)">-</button>
                                                <input type="text" id="qty-@item.ProductId" value="@item.Quantity" readonly>
                                                <button type="button" onclick="changeQty(@item.ProductId, 1)">+</button>
                                            </div>
                                        </td>

                                        <td class="text-end fw-bold text-dark text-sm">
                                            <span id="total-@item.ProductId">@item.Total.ToString("N0")</span> đ

                                            <form method="post"
                                                  action="@Url.Action("RemoveFromCart", "Online")"
                                                  class="d-inline ms-3">
                                                <input type="hidden" name="id" value="@item.ProductId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-link text-danger p-0"
                                                        title="Xóa">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("ProductsList", "Online")"
                       class="btn btn-outline-secondary rounded-pill px-4 text-xs">
                        <i class="fa-solid fa-arrow-left me-2"></i>Tiếp tục mua hàng
                    </a>
                </div>
            </div>

            <div class="col-lg-5 col-xl-4">
                <div class="card border border-light shadow-sm p-4 bg-white rounded-4">
                    <h5 class="fw-bold text-dark mb-4">Thông tin thanh toán</h5>

                    <div class="p-3 bg-light rounded-3 mb-4 text-xs">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Tạm tính:</span>
                            <span class="fw-bold text-dark" id="summarySubtotal">@subtotal.ToString("N0") đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>Giảm giá Voucher:</span>
                            <span class="fw-bold" id="summaryDiscount">- 0 đ</span>
                        </div>

                        <hr class="border-secondary border-opacity-10 my-2">

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark text-sm">Tổng cộng:</span>
                            <span class="fw-extrabold text-primary text-base" id="summaryTotal">
                                @subtotal.ToString("N0") đ
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary text-xs text-uppercase mb-2">
                            Mã giảm giá
                        </label>

                        <div class="input-group">
                            <input type="text"
                                   id="voucherInput"
                                   class="form-control"
                                   placeholder="Nhập mã (Ví dụ: NOVATECH10)...">

                            <button class="btn btn-outline-primary text-xs px-3"
                                    type="button"
                                    onclick="applyVoucher()">
                                Áp dụng
                            </button>
                        </div>

                        <div class="text-xxs text-muted mt-2" style="line-height: 1.4;">
                            <i class="fa-solid fa-circle-info me-1 text-info"></i>
                            Mã giảm giá chỉ tính trên sản phẩm giá thường,
                            <strong>không áp dụng cho Flash Sale</strong>.
                        </div>

                        <div id="voucherMsg" class="text-xxs mt-2 d-none"></div>

                        @if (vouchers.Count > 0)
                        {
                            <div class="mt-3">
                                <span class="text-xxs fw-bold text-secondary">MÃ GIẢM GIÁ ĐANG CÓ:</span>

                                <div class="d-flex flex-wrap gap-2 mt-1">
                                    @foreach (var v in vouchers)
                                    {
                                        <span class="badge bg-light text-primary border border-info border-opacity-25 cursor-pointer text-xxs py-1 px-2"
                                              onclick="useVoucherCode('@v.MaCode')"
                                              style="cursor:pointer;"
                                              title="Click để áp dụng">
                                            <i class="fa-solid fa-tag me-1"></i>@v.MaCode
                                            <span class="text-danger fw-bold ms-1">
                                                -@((v.GiaTri ?? 0).ToString("N0"))đ
                                            </span>
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @{
                        var canCheckout = ViewBag.CanCheckout as bool? ?? false;
                    }

                    @if (canCheckout)
                    {
                        <form method="post" action="@Url.Action("Checkout", "Online")">
                            <input type="hidden" name="voucherCode" id="formVoucherCode" value="">
                            <input type="hidden" name="discountVal" id="formDiscountVal" value="0">

                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary text-xs">
                                    Họ và tên người nhận
                                </label>

                                <input type="text"
                                       name="customerName"
                                       class="form-control bg-light"
                                       value="@customerName"
                                       readonly
                                       required>

                                <div class="text-xxs text-muted mt-1">
                                    Tên người nhận được lấy tự động từ tài khoản đăng nhập.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary text-xs">
                                    Email tài khoản
                                </label>

                                <input type="email"
                                       name="customerEmail"
                                       class="form-control bg-light"
                                       value="@customerEmail"
                                       readonly>

                                <div class="text-xxs text-muted mt-1">
                                    Email được lấy từ tài khoản đang đăng nhập.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary text-xs">
                                    Số điện thoại liên hệ
                                </label>

                                <input type="tel"
                                       name="customerPhone"
                                       class="form-control"
                                       required
                                       value="@customerPhone"
                                       placeholder="0901234567..."
                                       pattern="^(0|\+84)\d{9,10}$"
                                       title="Nhập số điện thoại bắt đầu 0 hoặc +84, đủ 10-12 chữ số.">
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary text-xs">
                                    Địa chỉ giao hàng
                                </label>

                                <textarea name="customerAddress"
                                          class="form-control"
                                          rows="2"
                                          required
                                          placeholder="Số nhà, tên đường, phường/xã, quận/huyện..."
                                          minlength="10"
                                          maxlength="250">@customerAddress</textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary text-xs">
                                    Phương thức thanh toán
                                </label>

                                <select name="paymentMethod" class="form-select">
                                    <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                                    <option value="Chuyển khoản">Chuyển khoản Ngân hàng</option>
                                    <option value="Tiền mặt">Đến nhận tại cửa hàng (Tiền mặt)</option>
                                </select>
                            </div>

                            <button type="submit"
                                    class="btn btn-primary rounded-pill w-100 py-3 text-xs fw-bold shadow-sm">
                                <i class="fa-solid fa-credit-card me-2"></i>ĐẶT HÀNG NGAY
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info rounded-4 p-4 mb-0">
                            <h6 class="fw-bold mb-2">Bạn cần đăng nhập để đặt hàng</h6>

                            <p class="mb-3 text-sm text-muted">
                                Hiện tại bạn đang xem web dưới tư cách khách.
                                Đăng nhập bằng tài khoản khách hàng để lưu giỏ hàng và xem lịch sử đơn hàng.
                            </p>

                            <a href="@Url.Action("Login", "Account")"
                               class="btn btn-info rounded-pill px-4 py-3 text-xs fw-bold">
                                <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập ngay
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        var currentSubtotalVal = @subtotal;
        var discountVal = 0;

        function changeQty(productId, delta) {
            const input = document.getElementById('qty-' + productId);
            let val = parseInt(input.value) + delta;

            if (val <= 0) {
                if (confirm('Bạn muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                    var form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '@Url.Action("RemoveFromCart", "Online")';

                    var inputId = document.createElement('input');
                    inputId.type = 'hidden';
                    inputId.name = 'id';
                    inputId.value = productId;

                    form.appendChild(inputId);
                    document.body.appendChild(form);
                    form.submit();
                }

                return;
            }

            fetch('@Url.Action("UpdateCart", "Online")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'id=' + productId + '&qty=' + val
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    input.value = val;
                    document.getElementById('total-' + productId).innerText = data.itemTotal;
                    location.reload();
                }
            });
        }

        function useVoucherCode(code) {
            document.getElementById('voucherInput').value = code;
            applyVoucher();
        }

        function applyVoucher() {
            const code = document.getElementById('voucherInput').value.trim();
            const msgEl = document.getElementById('voucherMsg');

            if (code === '') {
                return;
            }

            fetch('@Url.Action("ApplyVoucher", "Online")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'code=' + encodeURIComponent(code) + '&currentSubtotal=' + currentSubtotalVal
            })
            .then(res => res.json())
            .then(data => {
                msgEl.classList.remove('d-none');

                if (data.success) {
                    discountVal = data.discount;

                    msgEl.className = 'text-xxs mt-2 text-success fw-bold';
                    msgEl.innerHTML = data.message;

                    document.getElementById('summaryDiscount').innerText =
                        '- ' + discountVal.toLocaleString('vi-VN') + ' đ';

                    var totalVal = Math.max(0, currentSubtotalVal - discountVal);

                    document.getElementById('summaryTotal').innerText =
                        totalVal.toLocaleString('vi-VN') + ' đ';

                    document.getElementById('formVoucherCode').value = code;
                    document.getElementById('formDiscountVal').value = discountVal;
                } else {
                    discountVal = 0;

                    msgEl.className = 'text-xxs mt-2 text-danger fw-bold';
                    msgEl.innerHTML = data.message;

                    document.getElementById('summaryDiscount').innerText = '- 0 đ';

                    document.getElementById('summaryTotal').innerText =
                        currentSubtotalVal.toLocaleString('vi-VN') + ' đ';

                    document.getElementById('formVoucherCode').value = '';
                    document.getElementById('formDiscountVal').value = '0';
                }
            });
        }
    </script>
}