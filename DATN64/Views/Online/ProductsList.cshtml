@model List<DATN64.Models.SanPham>
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = "Tất cả sản phẩm";
    var currentCat = Context.Request.Query["category"].ToString();
    var currentBrand = Context.Request.Query["brand"].ToString();
    var brands = Model.Select(p => p.ThuongHieu?.TenThuongHieu).Where(b => b != null).Distinct().ToList();
}

<div class="container my-5 animate-fade-in">
    <div class="row g-4">
        <!-- Sidebar Bộ lọc bên trái -->
        <div class="col-lg-3">
            <div class="card shadow-sm p-4 border border-light bg-white rounded-4 sticky-lg-top" style="top: 90px; z-index: 10;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0 text-dark"><i class="fa-solid fa-filter text-primary me-2"></i>Bộ lọc tìm kiếm</h5>
                    <button type="button" class="btn btn-sm btn-link text-decoration-none text-xs p-0" onclick="resetAllFilters()">Xóa bộ lọc</button>
                </div>
                
                <!-- 1. Search Box -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary text-xs text-uppercase mb-2">Tìm kiếm nhanh</label>
                    <div class="position-relative">
                        <input type="text" id="liveSearchInput" class="form-control text-sm ps-3 pe-5" placeholder="Nhập tên sản phẩm..." oninput="filterProducts()">
                        <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y end-0 me-3 text-muted"></i>
                    </div>
                </div>

                <!-- 2. Nhóm danh mục -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary text-xs text-uppercase mb-2">Danh mục sản phẩm</label>
                    <div class="filter-sidebar-list d-flex flex-column">
                        <button type="button" class="filter-sidebar-item @(string.IsNullOrEmpty(currentCat) ? "active" : "")" data-category="" onclick="filterCategory('', this)">
                            <i class="fa-solid fa-layer-group me-2"></i> Tất cả sản phẩm
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Điện thoại" ? "active" : "")" data-category="Điện thoại" onclick="filterCategory('Điện thoại', this)">
                            <i class="fa-solid fa-mobile-screen-button me-2"></i> Điện thoại
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Laptop" ? "active" : "")" data-category="Laptop" onclick="filterCategory('Laptop', this)">
                            <i class="fa-solid fa-laptop me-2"></i> Laptop
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Máy tính bảng" ? "active" : "")" data-category="Máy tính bảng" onclick="filterCategory('Máy tính bảng', this)">
                            <i class="fa-solid fa-tablet-screen-button me-2"></i> Máy tính bảng
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Tai nghe" ? "active" : "")" data-category="Tai nghe" onclick="filterCategory('Tai nghe', this)">
                            <i class="fa-solid fa-headphones me-2"></i> Tai nghe
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Phụ kiện" ? "active" : "")" data-category="Phụ kiện" onclick="filterCategory('Phụ kiện', this)">
                            <i class="fa-solid fa-keyboard me-2"></i> Phụ kiện
                        </button>
                        <button type="button" class="filter-sidebar-item @(currentCat == "Loa" ? "active" : "")" data-category="Loa" onclick="filterCategory('Loa', this)">
                            <i class="fa-solid fa-volume-high me-2"></i> Loa & Âm thanh
                        </button>
                    </div>
                </div>

                <!-- 3. Nhóm thương hiệu -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary text-xs text-uppercase mb-2">Thương hiệu</label>
                    <input type="text" id="brandSearchInput" class="form-control text-xs mb-2 py-1 px-2.5" placeholder="Tìm nhanh hãng..." oninput="filterBrandCheckboxes()">
                    
                    <div class="brand-checkbox-list" id="brandChecklist">
                        @foreach (var b in brands)
                        {
                            var isChecked = !string.IsNullOrEmpty(currentBrand) && currentBrand.Equals(b, StringComparison.OrdinalIgnoreCase);
                            <div class="form-check mb-1.5 brand-item-row" data-brand-name="@b?.ToLower()">
                                <input class="form-check-input brand-filter-checkbox" type="checkbox" value="@b" id="brand-@b" onchange="filterProducts()" @(isChecked ? "checked" : "")>
                                <label class="form-check-label text-xs cursor-pointer" for="brand-@b">@b</label>
                            </div>
                        }
                    </div>
                </div>

                <!-- 4. Nhóm giá -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary text-xs text-uppercase mb-2">Khoảng giá</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input price-filter-checkbox" type="checkbox" value="under-5" id="price-under-5" onchange="filterProducts()">
                        <label class="form-check-label text-xs" for="price-under-5">Dưới 5 triệu</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input price-filter-checkbox" type="checkbox" value="5-15" id="price-5-15" onchange="filterProducts()">
                        <label class="form-check-label text-xs" for="price-5-15">5 - 15 triệu</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input price-filter-checkbox" type="checkbox" value="15-30" id="price-15-30" onchange="filterProducts()">
                        <label class="form-check-label text-xs" for="price-15-30">15 - 30 triệu</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input price-filter-checkbox" type="checkbox" value="over-30" id="price-over-30" onchange="filterProducts()">
                        <label class="form-check-label text-xs" for="price-over-30">Trên 30 triệu</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lưới sản phẩm bên phải -->
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
                <div>
                    <h4 class="fw-bold text-dark m-0" id="currentCatTitle">
                        @(string.IsNullOrEmpty(currentCat) ? "Tất cả sản phẩm NovaTech" : "Thiết bị: " + currentCat + (string.IsNullOrEmpty(currentBrand) ? "" : " - " + currentBrand))
                    </h4>
                    <span class="text-xs text-muted">Tìm thấy <strong id="filterCount">@Model.Count</strong> sản phẩm</span>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <span class="text-xs text-muted whitespace-nowrap">Sắp xếp:</span>
                    <select id="sortSelect" class="form-select text-xs py-1.5 px-3 rounded-pill bg-white border" style="width: 160px;" onchange="filterProducts()">
                        <option value="default">Mới nhất</option>
                        <option value="price-asc">Giá tăng dần</option>
                        <option value="price-desc">Giá giảm dần</option>
                        <option value="name-asc">Tên A-Z</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <div class="horizontal-tabs-container">
                    <button type="button" class="tab-btn @(string.IsNullOrEmpty(currentCat) ? "active" : "")" data-category="" onclick="filterCategory('', this)">
                        <i class="fa-solid fa-layer-group me-1.5"></i> Tất cả sản phẩm
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Điện thoại" ? "active" : "")" data-category="Điện thoại" onclick="filterCategory('Điện thoại', this)">
                        <i class="fa-solid fa-mobile-screen-button me-1.5"></i> Điện thoại
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Laptop" ? "active" : "")" data-category="Laptop" onclick="filterCategory('Laptop', this)">
                        <i class="fa-solid fa-laptop me-1.5"></i> Laptop
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Máy tính bảng" ? "active" : "")" data-category="Máy tính bảng" onclick="filterCategory('Máy tính bảng', this)">
                        <i class="fa-solid fa-tablet-screen-button me-1.5"></i> Máy tính bảng
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Tai nghe" ? "active" : "")" data-category="Tai nghe" onclick="filterCategory('Tai nghe', this)">
                        <i class="fa-solid fa-headphones me-1.5"></i> Tai nghe
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Phụ kiện" ? "active" : "")" data-category="Phụ kiện" onclick="filterCategory('Phụ kiện', this)">
                        <i class="fa-solid fa-keyboard me-1.5"></i> Phụ kiện
                    </button>
                    <button type="button" class="tab-btn @(currentCat == "Loa" ? "active" : "")" data-category="Loa" onclick="filterCategory('Loa', this)">
                        <i class="fa-solid fa-volume-high me-1.5"></i> Loa & Âm thanh
                    </button>
                </div>
            </div>

            <!-- Empty state -->
            <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light d-none" id="emptyState">
                <div class="fs-1 text-muted mb-3"><i class="fa-regular fa-folder-open"></i></div>
                <h5 class="text-secondary fw-semibold">Không tìm thấy sản phẩm nào</h5>
                <p class="text-xs text-muted-custom">Vui lòng điều chỉnh hoặc xóa bộ lọc hiện tại.</p>
            </div>

            <!-- Product Grid -->
            <div class="row row-cols-1 row-cols-md-3 g-4" id="productGrid">
                @foreach (var p in Model)
                {
                    <div class="col product-card-col" 
                         data-id="@p.MaSanPham"
                         data-name="@p.TenSanPham.ToLower()" 
                         data-brand="@(p.ThuongHieu?.TenThuongHieu)" 
                         data-category="@(p.DanhMuc?.TenDanhMuc)" 
                         data-price="@p.GiaBan">
                        
                        <div class="card card-product h-100 p-3 shadow-sm border border-light">
                            <img src="@p.HinhAnh" class="card-img-top rounded-3 mb-3" alt="@p.TenSanPham" style="height: 180px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=300'">
                            
                            <div class="card-body p-0 d-flex flex-column justify-content-between">
                                <div>
                                    <span class="badge bg-light text-primary border border-info border-opacity-25 mb-2 text-xxs">@(p.DanhMuc?.TenDanhMuc ?? "Khác")</span>
                                    <h5 class="card-title fw-bold text-dark fs-6 mb-1">
                                        <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="text-decoration-none text-dark">@p.TenSanPham</a>
                                    </h5>
                                    <p class="text-xxs text-muted mb-2">Thương hiệu: @(p.ThuongHieu?.TenThuongHieu ?? "Khác")</p>
                                    
                                    <div class="mb-3">
                                        <span class="card-text text-danger fw-bold fs-5">@p.GiaBan.ToString("N0") đ</span>
                                    </div>
                                </div>
                                
                                <div class="d-grid gap-2">
                                    <a href="@Url.Action("Detail", "Online", new { id = p.MaSanPham })" class="btn btn-outline-primary rounded-pill text-xs py-2 fw-semibold">
                                        Xem Chi Tiết
                                    </a>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-primary rounded-pill text-xs py-2 fw-semibold text-white shadow-sm flex-grow-1" type="button" onclick="addToCart(@p.MaSanPham)">
                                            <i class="fa-solid fa-cart-plus me-1"></i>Thêm
                                        </button>
                                        <button class="btn btn-outline-secondary rounded-pill text-xs py-2 fw-semibold flex-shrink-0" type="button" onclick="addToFavorites(@p.MaSanPham)">
                                            <i class="fa-regular fa-heart text-danger"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var selectedCategory = '@currentCat';

        function filterCategory(cat, btn) {
            selectedCategory = cat;
            
            // Sync horizontal tab active state
            document.querySelectorAll('.tab-btn').forEach(b => {
                if (b.getAttribute('data-category') === cat) {
                    b.classList.add('active');
                } else {
                    b.classList.remove('active');
                }
            });

            // Sync sidebar list active state
            document.querySelectorAll('.filter-sidebar-item').forEach(b => {
                if (b.getAttribute('data-category') === cat) {
                    b.classList.add('active');
                } else {
                    b.classList.remove('active');
                }
            });

            document.getElementById('currentCatTitle').innerText = cat === '' ? "Tất cả sản phẩm NovaTech" : "Thiết bị: " + cat;
            filterProducts();
        }

        function filterBrandCheckboxes() {
            const query = document.getElementById('brandSearchInput').value.toLowerCase().trim();
            document.querySelectorAll('.brand-item-row').forEach(row => {
                const brand = row.getAttribute('data-brand-name');
                if (brand && brand.includes(query)) {
                    row.classList.remove('d-none');
                } else {
                    row.classList.add('d-none');
                }
            });
        }

        function filterProducts() {
            const searchQuery = document.getElementById('liveSearchInput').value.toLowerCase().trim();
            const checkedBrands = [];
            document.querySelectorAll('.brand-filter-checkbox:checked').forEach(cb => {
                checkedBrands.push(cb.value);
            });
            const checkedPrices = [];
            document.querySelectorAll('.price-filter-checkbox:checked').forEach(cb => {
                checkedPrices.push(cb.value);
            });

            let visibleCount = 0;
            const cards = Array.from(document.querySelectorAll('.product-card-col'));

            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                const brand = card.getAttribute('data-brand');
                const category = card.getAttribute('data-category');
                const price = parseFloat(card.getAttribute('data-price'));

                let matchCat = (selectedCategory === '' || category === selectedCategory);
                let matchSearch = (searchQuery === '' || name.includes(searchQuery));
                let matchBrand = (checkedBrands.length === 0 || checkedBrands.includes(brand));
                let matchPrice = true;
                if (checkedPrices.length > 0) {
                    matchPrice = false;
                    for (let p of checkedPrices) {
                        if (p === 'under-5' && price < 5000000) matchPrice = true;
                        else if (p === '5-15' && price >= 5000000 && price <= 15000000) matchPrice = true;
                        else if (p === '15-30' && price >= 15000000 && price <= 30000000) matchPrice = true;
                        else if (p === 'over-30' && price > 30000000) matchPrice = true;
                    }
                }

                if (matchCat && matchSearch && matchBrand && matchPrice) {
                    card.style.display = 'block';
                    card.style.opacity = '0';
                    setTimeout(() => { card.style.opacity = '1'; card.style.transition = 'opacity 0.2s ease-in-out'; }, 50);
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            const sortVal = document.getElementById('sortSelect').value;
            const grid = document.getElementById('productGrid');
            if (sortVal !== 'default') {
                cards.sort((a, b) => {
                    const priceA = parseFloat(a.getAttribute('data-price'));
                    const priceB = parseFloat(b.getAttribute('data-price'));
                    const nameA = a.getAttribute('data-name');
                    const nameB = b.getAttribute('data-name');

                    if (sortVal === 'price-asc') return priceA - priceB;
                    if (sortVal === 'price-desc') return priceB - priceA;
                    if (sortVal === 'name-asc') return nameA.localeCompare(nameB);
                    return 0;
                }).forEach(c => grid.appendChild(c));
            }

            document.getElementById('filterCount').innerText = visibleCount;
            if (visibleCount === 0) {
                document.getElementById('emptyState').classList.remove('d-none');
            } else {
                document.getElementById('emptyState').classList.add('d-none');
            }
        }

        function resetAllFilters() {
            document.getElementById('liveSearchInput').value = '';
            document.getElementById('brandSearchInput').value = '';
            document.querySelectorAll('.brand-filter-checkbox').forEach(cb => cb.checked = false);
            document.querySelectorAll('.price-filter-checkbox').forEach(cb => cb.checked = false);
            document.getElementById('sortSelect').value = 'default';
            filterBrandCheckboxes();
            filterCategory('');
        }

        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId + '&qty=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const badge = document.querySelector('.navbar .badge');
                    if (badge) {
                        badge.innerText = data.cartCount;
                    }
                    alert('Đã thêm sản phẩm vào giỏ hàng!');
                }
            });
        }

        function addToFavorites(productId) {
            fetch('@Url.Action("AddToFavorites", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Đã thêm vào danh sách yêu thích!');
                }
            });
        }
    </script>
}
