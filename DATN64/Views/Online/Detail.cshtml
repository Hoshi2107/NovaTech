@model DATN64.Models.SanPham
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = Model.TenSanPham;
}

<div class="container my-5 animate-fade-in">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Online")" class="text-decoration-none text-danger"><i class="fa-solid fa-house me-1"></i>Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">@(Model.DanhMuc?.TenDanhMuc ?? "Khác")</a></li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">@Model.TenSanPham</li>
        </ol>
    </nav>

    <div class="row gx-5">
        <!-- L: Image Gallery (CellphoneS Style) -->
        <div class="col-md-5 mb-4 mb-md-0">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3 p-3 text-center" style="background: white;">
                <img src="@Model.HinhAnh" class="img-fluid rounded-3" alt="@Model.TenSanPham" style="max-height: 400px; object-fit: contain;" onerror="this.src='https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=500'">
            </div>
            
            <!-- Features Block -->
            <div class="d-flex justify-content-center gap-3 mt-4 text-center text-muted">
                <div>
                    <i class="fa-solid fa-shield-halved fs-4 mb-2 text-danger"></i>
                    <div class="text-xxs">Bảo hành 12 tháng</div>
                </div>
                <div>
                    <i class="fa-solid fa-rotate-left fs-4 mb-2 text-danger"></i>
                    <div class="text-xxs">Đổi trả trong 30 ngày</div>
                </div>
                <div>
                    <i class="fa-solid fa-truck-fast fs-4 mb-2 text-danger"></i>
                    <div class="text-xxs">Giao hàng miễn phí</div>
                </div>
            </div>
        </div>

        <!-- R: Product Info (CellphoneS Style) -->
        <div class="col-md-7">
            <h1 class="fw-bold mb-2 text-dark fs-3">@Model.TenSanPham</h1>
            <div class="d-flex align-items-center mb-4 text-sm">
                <span class="text-warning me-2">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                </span>
                <span class="text-primary me-3">(24 đánh giá)</span>
                <span class="text-muted">Thương hiệu: <span class="fw-bold text-dark">@(Model.ThuongHieu?.TenThuongHieu ?? "Khác")</span></span>
            </div>

            <!-- Price Block -->
            <div class="p-3 rounded-3 mb-4" style="background: #D70018; color: white;">
                <div class="d-flex align-items-end gap-3 mb-1">
                    <span class="fw-bold fs-2" style="line-height: 1;">@Model.GiaBan.ToString("N0") ₫</span>
                    <span class="text-decoration-line-through text-white-50 fs-6">@((Model.GiaBan * 1.1m).ToString("N0")) ₫</span>
                </div>
            </div>

            <!-- Options (Mock) -->
            <div class="mb-4">
                <p class="fw-bold mb-2">Chọn màu sắc:</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary text-dark active border-danger" style="width: 100px;">
                        Titan Tự Nhiên
                    </button>
                    <button class="btn btn-outline-secondary text-dark" style="width: 100px;">
                        Titan Xanh
                    </button>
                    <button class="btn btn-outline-secondary text-dark" style="width: 100px;">
                        Titan Đen
                    </button>
                </div>
            </div>

            <!-- Promo Box -->
            <div class="card border border-danger mb-4 shadow-sm">
                <div class="card-header bg-danger text-white fw-bold py-2">
                    <i class="fa-solid fa-gift me-2"></i>Khuyến mãi ưu đãi
                </div>
                <div class="card-body p-3 text-sm bg-light">
                    <ul class="mb-0 text-dark" style="padding-left: 20px;">
                        <li class="mb-2">Giảm thêm 500.000đ khi thanh toán qua thẻ tín dụng ngân hàng đối tác.</li>
                        <li class="mb-2">Tặng ốp lưng bảo vệ chính hãng trị giá 300.000đ.</li>
                        <li>Thu cũ đổi mới trợ giá thêm lên đến 1.000.000đ.</li>
                    </ul>
                </div>
            </div>

            <!-- Actions -->
            <div class="mb-4">
                @if (Model.SoLuongTon <= 0)
                {
                    <button class="btn btn-secondary w-100 py-3 fw-bold fs-5 text-white rounded-3 shadow-sm" disabled style="background: #6c757d;">
                        HẾT HÀNG
                        <div class="fw-normal" style="font-size: 0.85rem;">Sản phẩm tạm thời hết hàng</div>
                    </button>
                }
                else
                {
                    <button class="btn btn-danger w-100 py-3 fw-bold fs-5 text-white rounded-3 shadow-sm" style="background: #D70018;" onclick="addToCart(@Model.MaSanPham)">
                        MUA NGAY
                        <div class="fw-normal" style="font-size: 0.85rem;">Giao tận nơi hoặc nhận tại cửa hàng</div>
                    </button>
                }
            </div>

            <!-- Specs Info -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom fw-bold fs-5 py-3">
                    Thông số kỹ thuật
                </div>
                <div class="card-body p-4 text-dark text-sm bg-light" style="white-space: pre-line;">
                    @(Model.MoTa ?? "Đang cập nhật thông tin chi tiết về sản phẩm này.")
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId + '&qty=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Đã thêm sản phẩm vào giỏ hàng!');
                    window.location.href = '@Url.Action("Cart", "Online")';
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng!');
                }
            });
        }

        function toggleFavorite(productId) {
            var isFav = document.getElementById('favoriteText').innerText.trim() !== 'Yêu thích';
            var action = isFav ? 'RemoveFromFavorites' : 'AddToFavorites';
            fetch('@Url.Action("AddToFavorites", "Online")'.replace('AddToFavorites', action), {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                }
            });
        }
    </script>
}
