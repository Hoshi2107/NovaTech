@section Scripts {
    <script>
        var variantMap = [
            @foreach(var item in relatedVariants) {
                <text>{ id: @item.MaSanPham, model: "@Html.Raw(GetModelVersion(item.TenSanPham))", storage: "@Html.Raw(GetStorage(item.TenSanPham))", color: "@Html.Raw(GetColor(item.TenSanPham))", price: @item.GiaBan, sku: "@Html.Raw(item.SKU ?? "")" },</text>
            }
        ];

        var selectedModel = "@Html.Raw(currentModelVal)";
        var selectedStorage = "@Html.Raw(currentStorageVal)";
        var selectedColor = "@Html.Raw(currentColorVal)";

        function selectModel(model) {
            selectedModel = model;
            updateVariantSelection();
        }

        function selectStorage(storage) {
            selectedStorage = storage;
            updateVariantSelection();
        }

        function selectColor(color) {
            selectedColor = color;
            updateVariantSelection();
        }

        function updateVariantSelection() {
            // Find exact match
            var match = variantMap.find(v => v.model === selectedModel && v.storage === selectedStorage && v.color === selectedColor);
            
            // If exact match not found, find one matching same model and storage
            if (!match) {
                match = variantMap.find(v => v.model === selectedModel && v.storage === selectedStorage);
            }
            
            // If still not found, find one matching same model
            if (!match) {
                match = variantMap.find(v => v.model === selectedModel);
            }

            if (match) {
                // Instantly update price display
                var priceEl = document.querySelector('.product-live-price');
                if (priceEl) {
                    priceEl.textContent = new Intl.NumberFormat('vi-VN').format(match.price) + ' ₫';
                }
                // Instantly update SKU badge before navigation
                var skuEl = document.getElementById('sku-badge-text');
                if (skuEl && match.sku) {
                    skuEl.textContent = 'SKU: ' + match.sku;
                    skuEl.closest('.badge').style.display = '';
                }
                // Navigate to variant page
                window.location.href = '/Online/Detail/' + match.id;
            }
        }

        function checkAvailableOptions() {
            var availableStorages = variantMap.filter(v => v.model === selectedModel).map(v => v.storage);
            var availableColors = variantMap.filter(v => v.model === selectedModel && v.storage === selectedStorage).map(v => v.color);

            document.querySelectorAll('.variant-storage').forEach(btn => {
                var s = btn.getAttribute('data-storage');
                if (availableStorages.includes(s)) {
                    btn.classList.remove('disabled');
                    btn.style.opacity = '1';
                    btn.style.pointerEvents = 'auto';
                } else {
                    btn.classList.add('disabled');
                    btn.style.opacity = '0.4';
                    btn.style.pointerEvents = 'none';
                }
            });

            document.querySelectorAll('.variant-color').forEach(btn => {
                var c = btn.getAttribute('data-color');
                if (availableColors.includes(c)) {
                    btn.classList.remove('disabled');
                    btn.style.opacity = '1';
                    btn.style.pointerEvents = 'auto';
                } else {
                    btn.classList.add('disabled');
                    btn.style.opacity = '0.4';
                    btn.style.pointerEvents = 'none';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            checkAvailableOptions();
        });

        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Online")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + productId + '&qty=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Đã thêm sản phẩm vào giỏ hàng!');
                    window.location.href = '@Url.Action("Cart", "Online")';
                } else {
                    alert(data.message || 'Không thể thêm sản phẩm vào giỏ hàng!');
                }
            });
        }
    </script>
}
