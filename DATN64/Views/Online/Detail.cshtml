@model DATN64.Models.SanPham
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = Model.TenSanPham;

    var relatedVariants = ViewBag.RelatedVariants as List<DATN64.Models.SanPham> ?? new List<DATN64.Models.SanPham>();
    
    string currentName = Model.TenSanPham;
    bool isIPhone15 = currentName.Contains("iPhone 15", StringComparison.OrdinalIgnoreCase);
    bool isSamsungS24 = currentName.Contains("Samsung Galaxy S24", StringComparison.OrdinalIgnoreCase);
    
    var modelsList = new List<string>();
    var storagesList = new List<string>();
    var colorsList = new List<string>();
    
    string GetModelVersion(string name) {
        if (name.Contains("Pro Max", StringComparison.OrdinalIgnoreCase)) return isIPhone15 ? "iPhone 15 Pro Max" : "Pro Max";
        if (name.Contains("Pro", StringComparison.OrdinalIgnoreCase)) return isIPhone15 ? "iPhone 15 Pro" : "Pro";
        if (name.Contains("Ultra", StringComparison.OrdinalIgnoreCase)) return isSamsungS24 ? "Samsung Galaxy S24 Ultra" : "Ultra";
        return isIPhone15 ? "iPhone 15 Thường" : (isSamsungS24 ? "Samsung Galaxy S24 Thường" : name);
    }
    
    string GetStorage(string name) {
        if (name.Contains("128GB", StringComparison.OrdinalIgnoreCase)) return "128GB";
        if (name.Contains("256GB", StringComparison.OrdinalIgnoreCase)) return "256GB";
        if (name.Contains("512GB", StringComparison.OrdinalIgnoreCase)) return "512GB";
        if (name.Contains("1TB", StringComparison.OrdinalIgnoreCase)) return "1TB";
        
        // Base model fallbacks
        if (name.Equals("iPhone 15 Thường", StringComparison.OrdinalIgnoreCase)) return "128GB";
        if (name.Equals("iPhone 15 Pro", StringComparison.OrdinalIgnoreCase)) return "128GB";
        if (name.Equals("iPhone 15 Pro Max", StringComparison.OrdinalIgnoreCase)) return "256GB";
        if (name.Equals("Samsung Galaxy S24", StringComparison.OrdinalIgnoreCase)) return "256GB";
        if (name.Equals("Samsung Galaxy S24 Ultra", StringComparison.OrdinalIgnoreCase)) return "256GB";
        return "";
    }
    
    string GetColor(string name) {
        var colors = new[] { "Titan Tự Nhiên", "Titan Xanh", "Titan Trắng", "Titan Đen", "Titan Vàng", "Titan Tím", "Titan Xám", "Hồng", "Vàng", "Xanh Lá", "Xanh Dương", "Đen", "Tím", "Xám" };
        foreach(var c in colors) {
            if (name.Contains(c, StringComparison.OrdinalIgnoreCase)) return c;
        }
        
        // Base model fallbacks
        if (name.Equals("iPhone 15 Thường", StringComparison.OrdinalIgnoreCase)) return "Đen";
        if (name.Equals("iPhone 15 Pro", StringComparison.OrdinalIgnoreCase)) return "Titan Tự Nhiên";
        if (name.Equals("iPhone 15 Pro Max", StringComparison.OrdinalIgnoreCase)) return "Titan Tự Nhiên";
        if (name.Equals("Samsung Galaxy S24", StringComparison.OrdinalIgnoreCase)) return "Đen";
        if (name.Equals("Samsung Galaxy S24 Ultra", StringComparison.OrdinalIgnoreCase)) return "Titan Xám";
        return "Mặc định";
    }

    foreach(var item in relatedVariants) {
        var m = GetModelVersion(item.TenSanPham);
        if (!modelsList.Contains(m) && !string.IsNullOrEmpty(m)) modelsList.Add(m);
        
        var s = GetStorage(item.TenSanPham);
        if (!storagesList.Contains(s) && !string.IsNullOrEmpty(s)) storagesList.Add(s);
        
        var c = GetColor(item.TenSanPham);
        if (!colorsList.Contains(c) && !string.IsNullOrEmpty(c)) colorsList.Add(c);
    }
    
    modelsList = modelsList.OrderBy(m => m.Contains("Max") || m.Contains("Ultra") ? 2 : (m.Contains("Pro") ? 1 : 0)).ToList();
    
    var storageOrder = new List<string> { "128GB", "256GB", "512GB", "1TB" };
    storagesList = storagesList.OrderBy(s => storageOrder.IndexOf(s)).ToList();
    colorsList = colorsList.OrderBy(c => c).ToList();

    string currentModelVal = GetModelVersion(Model.TenSanPham);
    string currentStorageVal = GetStorage(Model.TenSanPham);
    string currentColorVal = GetColor(Model.TenSanPham);
}


<div class="container my-5 animate-fade-in">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-white p-3 rounded-3 shadow-xs border border-light">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Online")" class="text-decoration-none text-primary fw-medium">
                    <i class="fa-solid fa-house me-1"></i>Trang chủ
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Online/ProductsList?category=@Model.DanhMuc?.TenDanhMuc" class="text-decoration-none text-muted">
                    @(Model.DanhMuc?.TenDanhMuc ?? "Khác")
                </a>
            </li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">@Model.TenSanPham</li>
        </ol>
    </nav>

    <div class="row gx-lg-5">
        <!-- L: Image Gallery (Premium Glowing Card) -->
        <div class="col-md-5 mb-5 mb-md-0">
            <div class="product-image-container card border-0 shadow-sm rounded-4 overflow-hidden mb-4 p-4 text-center bg-white position-relative">
                <div class="position-absolute top-0 start-0 m-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2.5 py-1.5 rounded-pill text-xxs fw-bold text-uppercase">
                        <i class="fa-solid fa-certificate me-1"></i>Chính hãng
                    </span>
                </div>
                <img src="@Model.HinhAnh?v=2" class="img-fluid rounded-3 product-main-image" alt="@Model.TenSanPham" style="max-height: 380px; object-fit: contain; transition: transform 0.4s ease;" onerror="this.src='https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=500'">
            </div>
            
            <!-- Features Block (Premium Grid) -->
            <div class="row g-3 text-center text-muted">
                <div class="col-4">
                    <div class="p-3 bg-white rounded-3 border border-light shadow-xs h-100 d-flex flex-column align-items-center justify-content-center">
                        <i class="fa-solid fa-shield-halved fs-4 mb-2 text-primary"></i>
                        <div class="text-xxs fw-bold text-dark mb-0.5">Bảo hành 12T</div>
                        <div class="text-xxxs text-muted">Chính hãng Việt Nam</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 bg-white rounded-3 border border-light shadow-xs h-100 d-flex flex-column align-items-center justify-content-center">
                        <i class="fa-solid fa-rotate-left fs-4 mb-2 text-primary"></i>
                        <div class="text-xxs fw-bold text-dark mb-0.5">Đổi trả 30 ngày</div>
                        <div class="text-xxxs text-muted">Lỗi 1 đổi 1 nhanh chóng</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 bg-white rounded-3 border border-light shadow-xs h-100 d-flex flex-column align-items-center justify-content-center">
                        <i class="fa-solid fa-truck-fast fs-4 mb-2 text-primary"></i>
                        <div class="text-xxs fw-bold text-dark mb-0.5">Giao miễn phí</div>
                        <div class="text-xxxs text-muted">Giao siêu tốc toàn quốc</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- R: Product Info (Premium Tech Theme) -->
        <div class="col-md-7">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2.5 py-1 rounded-pill text-xxs fw-bold">
                    @(Model.ThuongHieu?.TenThuongHieu ?? "NovaTech")
                </span>
                @if (!string.IsNullOrEmpty(Model.SKU))
                {
                    <span id="sku-badge-text" class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2.5 py-1 rounded-pill text-xxs fw-bold" style="letter-spacing: 0.5px;">
                        SKU: @Model.SKU
                    </span>
                }
                else
                {
                    <span id="sku-badge-text" class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2.5 py-1 rounded-pill text-xxs fw-bold" style="letter-spacing: 0.5px; display: none;">
                        SKU:
                    </span>
                }
            </div>
            <h1 class="fw-extrabold mb-2 text-dark fs-2 text-gradient-title">@Model.TenSanPham</h1>
            
            <div class="d-flex align-items-center mb-4 text-xs bg-white p-2.5 rounded-3 border border-light shadow-xs d-inline-flex gap-3">
                <span class="text-warning d-flex align-items-center gap-0.5">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <span class="text-dark fw-bold ms-1 text-xs">5.0</span>
                </span>
                <span class="text-muted">|</span>
                <span class="text-primary fw-medium cursor-pointer"><i class="fa-regular fa-comment-dots me-1"></i>24 đánh giá</span>
                <span class="text-muted">|</span>
                <span class="text-muted">Lượt xem: <span class="fw-bold text-dark">1,248</span></span>
            </div>

            <!-- Price Block (Premium Tech Gradient) -->
            <div class="p-4 rounded-4 mb-4 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(135deg, #0284c7, #0369a1); color: white;">
                <div class="position-absolute end-0 bottom-0 opacity-10 m-n3">
                    <i class="fa-solid fa-bolt-lightning text-white" style="font-size: 8rem;"></i>
                </div>
                <div class="text-white-50 text-xs text-uppercase fw-bold mb-1">Giá bán ưu đãi độc quyền</div>
                <div class="d-flex align-items-baseline gap-3">
                    <span class="fw-extrabold fs-1" style="letter-spacing: -0.5px;">@Model.GiaBan.ToString("N0") ₫</span>
                    <span class="text-decoration-line-through text-white-50 fs-6">@((Model.GiaBan * 1.15m).ToString("N0")) ₫</span>
                    <span class="badge bg-danger text-white rounded-2 text-xxs px-2 py-1 fw-bold">-15%</span>
                </div>
            </div>

            <!-- Options (Premium Styled Selection) -->
            @if (relatedVariants.Count > 1)
            {
                <div class="d-flex flex-column gap-3 mb-4">
                    <!-- Version/Model Selector -->
                    @if (modelsList.Count > 1)
                    {
                        <div class="bg-white p-3 rounded-4 border border-light shadow-xs">
                            <p class="fw-bold mb-2 text-sm text-dark"><i class="fa-solid fa-layer-group text-primary me-2"></i>Chọn phiên bản:</p>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var m in modelsList)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-option-custom variant-model @(m == currentModelVal ? "active" : "")" data-model="@m" onclick="selectModel('@m')">
                                        <div class="text-xxs fw-bold">@m</div>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Storage Selector -->
                    @if (storagesList.Count > 1)
                    {
                        <div class="bg-white p-3 rounded-4 border border-light shadow-xs">
                            <p class="fw-bold mb-2 text-sm text-dark"><i class="fa-solid fa-hard-drive text-primary me-2"></i>Chọn dung lượng:</p>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var s in storagesList)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-option-custom variant-storage @(s == currentStorageVal ? "active" : "")" data-storage="@s" onclick="selectStorage('@s')">
                                        <div class="text-xxs fw-bold">@s</div>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Color Selector -->
                    @if (colorsList.Count > 1)
                    {
                        <div class="bg-white p-3 rounded-4 border border-light shadow-xs">
                            <p class="fw-bold mb-2 text-sm text-dark"><i class="fa-solid fa-palette text-primary me-2"></i>Chọn màu sắc:</p>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var c in colorsList)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-option-custom variant-color @(c == currentColorVal ? "active" : "")" data-color="@c" onclick="selectColor('@c')">
                                        <div class="text-xxs fw-bold">@c</div>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="mb-4 bg-white p-3 rounded-4 border border-light shadow-xs">
                    <p class="fw-bold mb-2 text-sm text-dark"><i class="fa-solid fa-circle-info text-primary me-2"></i>Phiên bản:</p>
                    <button class="btn btn-outline-primary btn-option-custom active" style="min-width: 120px;" disabled>
                        <div class="text-xxs fw-bold">@Model.TenSanPham</div>
                        <div class="text-xxxs text-muted">@Model.GiaBan.ToString("N0") ₫</div>
                    </button>
                </div>
            }

            <!-- Promo Box (Stunning Clean Design) -->
            <div class="card border border-primary border-opacity-25 mb-4 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-nav text-primary fw-extrabold py-3 border-bottom border-primary border-opacity-10 d-flex align-items-center gap-2" style="background: rgba(2, 132, 199, 0.04) !important;">
                    <i class="fa-solid fa-gift text-cyan"></i>Khuyến mãi & ưu đãi đặc biệt
                </div>
                <div class="card-body p-3.5 text-sm bg-white">
                    <div class="d-flex flex-column gap-3 text-secondary">
                        <div class="d-flex align-items-start gap-2.5">
                            <div class="badge bg-primary bg-opacity-10 text-primary rounded-circle p-1.5 d-flex align-items-center justify-content-center" style="width: 22px; height: 22px;">1</div>
                            <div>Giảm thêm <span class="fw-bold text-dark">500.000đ</span> khi thanh toán qua chuyển khoản ngân hàng trực tuyến.</div>
                        </div>
                        <div class="d-flex align-items-start gap-2.5">
                            <div class="badge bg-primary bg-opacity-10 text-primary rounded-circle p-1.5 d-flex align-items-center justify-content-center" style="width: 22px; height: 22px;">2</div>
                            <div>Tặng gói bảo hành vàng <span class="fw-bold text-dark">1 đổi 1 trong 12 tháng</span> trị giá 990.000đ.</div>
                        </div>
                        <div class="d-flex align-items-start gap-2.5">
                            <div class="badge bg-primary bg-opacity-10 text-primary rounded-circle p-1.5 d-flex align-items-center justify-content-center" style="width: 22px; height: 22px;">3</div>
                            <div>Hỗ trợ thu cũ đổi mới - Trợ giá trực tiếp lên đến <span class="fw-bold text-dark">1.000.000đ</span>.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions (Stunning Action Button) -->
            <div class="mb-5">
                @if (Model.SoLuongTon <= 0)
                {
                    <button class="btn btn-secondary w-100 py-3.5 fw-bold fs-5 text-white rounded-3 shadow-sm border-0 cursor-not-allowed" disabled style="background: #94a3b8 !important;">
                        HẾT HÀNG
                        <div class="fw-normal" style="font-size: 0.8rem; opacity: 0.8;">Sản phẩm tạm thời hết hàng</div>
                    </button>
                }
                else
                {
                    <button class="btn btn-primary-gradient w-100 py-3 fw-bold fs-5 text-white rounded-3 shadow-md border-0 position-relative overflow-hidden btn-hover-effect" onclick="addToCart(@Model.MaSanPham)">
                        MUA NGAY
                        <div class="fw-normal" style="font-size: 0.8rem; opacity: 0.9;">Giao hàng siêu tốc tận nơi hoặc nhận tại cửa hàng</div>
                    </button>
                }
            </div>

            <!-- Specs Info (Stunning Modern Layout) -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white border-bottom fw-extrabold fs-5 py-3.5 text-dark d-flex align-items-center gap-2">
                    <i class="fa-solid fa-list-check text-primary"></i>Thông số kỹ thuật chi tiết
                </div>
                <div class="card-body p-4 text-sm bg-light bg-opacity-50" style="line-height: 1.7; font-family: system-ui, -apple-system, sans-serif;">
                    @if (isIPhone15)
                    {
                        string modelType = "Thường";
                        if (currentName.Contains("Pro Max", StringComparison.OrdinalIgnoreCase)) modelType = "Pro Max";
                        else if (currentName.Contains("Pro", StringComparison.OrdinalIgnoreCase)) modelType = "Pro";

                        <h5 class="fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                            <span class="badge bg-primary rounded-pill px-3.5 py-2 fs-6">iPhone 15 @modelType</span>
                            Cấu hình chi tiết sản phẩm
                        </h5>
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-mobile-screen fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Màn hình chính</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Pro Max") { <text>6.7" Super Retina XDR OLED, Dynamic Island, 120Hz ProMotion</text> }
                                            else if (modelType == "Pro") { <text>6.1" Super Retina XDR OLED, Dynamic Island, 120Hz ProMotion</text> }
                                            else { <text>6.1" Super Retina XDR OLED, Dynamic Island, 60Hz</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-info bg-opacity-10 text-info rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-microchip fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Vi xử lý (CPU)</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Thường") { <text>Apple A16 Bionic (4 nm) 6 nhân</text> }
                                            else { <text>Apple A17 Pro (3 nm) 6 nhân mạnh mẽ</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-success bg-opacity-10 text-success rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-memory fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Bộ nhớ RAM</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Thường") { <text>6 GB LPDDR5</text> }
                                            else { <text>8 GB LPDDR5X siêu tốc</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-danger bg-opacity-10 text-danger rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-camera fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Camera chính</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Pro Max") { <text>48MP + 12MP + 12MP (Zoom quang 5x)</text> }
                                            else if (modelType == "Pro") { <text>48MP + 12MP + 12MP (Zoom quang 3x)</text> }
                                            else { <text>48MP + 12MP Ultra-wide</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-warning bg-opacity-10 text-warning rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-video fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Camera selfie</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">12 MP, f/1.9, hỗ trợ FaceID</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-secondary bg-opacity-10 text-secondary rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-bolt fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Kết nối & Sạc</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Thường") { <text>USB-C (tốc độ USB 2.0)</text> }
                                            else { <text>USB-C (tốc độ USB 3.0 lên tới 10Gb/s)</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-info bg-opacity-10 text-info rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-shield-halved fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="text-xxs text-muted fw-bold text-uppercase tracking-wider">Chất liệu thiết kế</div>
                                        <div class="text-xs fw-semibold text-dark mt-0.5">
                                            @if (modelType == "Thường") { <text>Khung nhôm tái chế, mặt sau kính pha màu</text> }
                                            else { <text>Khung Titanium chuẩn hàng không, lưng kính nhám</text> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3.5 bg-white rounded-4 border border-light shadow-xs d-flex align-items-center gap-3 spec-item-card">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center" style="width: 46px; height: 46px; min-width: 46px;">
                                        <i class="fa-solid fa-weight-hanging fs-5"></i>
