@model List<DATN64.Models.DonHang>
@{
    Layout = "~/Views/Shared/_OnlineLayout.cshtml";
    ViewData["Title"] = "Lịch sử đặt hàng";
}

<div class="container my-5 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark">Lịch sử đặt hàng</h3>
            <p class="text-muted-custom text-sm mb-0">Xem lại các đơn đã đặt và thông tin trạng thái.</p>
        </div>
        <a href="@Url.Action("Index", "Online")" class="btn btn-outline-primary rounded-pill px-4">Trở về trang chủ</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card card-glass p-5 text-center">
            <div class="fs-1 text-muted mb-3"><i class="fa-regular fa-clock"></i></div>
            <h5 class="fw-bold text-dark">Bạn chưa có đơn hàng nào</h5>
            <p class="text-muted-custom">Hoàn thành đơn hàng đầu tiên để lưu lịch sử tại đây.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card card-glass p-4 shadow-sm border-light">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <div>
                                <div class="text-xxs text-muted mb-1">Mã đơn hàng</div>
                                <h5 class="fw-bold">#@order.MaDonHang</h5>
                            </div>
                            <div>
                                <div class="text-xxs text-muted mb-1">Ngày đặt</div>
                                <div>@order.NgayDat?.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                            <div>
                                <div class="text-xxs text-muted mb-1">Tổng tiền</div>
                                <div class="fw-bold text-danger">@order.TongTien?.ToString("N0") đ</div>
                            </div>
                            <div>
                                <span class="badge bg-gradient-cyan text-white py-2 px-3">@order.TrangThai</span>
                            </div>
                            <div>
                                <a href="@Url.Action("OrderDetail", "Online", new { id = order.MaDonHang })" class="btn btn-primary rounded-pill px-4 py-2">Xem chi tiết</a>
                            </div>
                        </div>
                        <div class="mt-3 text-sm text-muted">
                            @if (order.ChiTietDonHangs != null && order.ChiTietDonHangs.Any())
                            {
                                var firstProduct = order.ChiTietDonHangs.First().SanPham?.TenSanPham ?? "Sản phẩm";
                                var count = order.ChiTietDonHangs.Count();
                                <span>@firstProduct</span>
                                @if (count > 1)
                                {
                                    <span class="text-muted"> và @((count - 1).ToString()) sản phẩm khác</span>
                                }
                            }
                            else
                            {
                                <span>Không có dữ liệu chi tiết sản phẩm</span>
                            }
                        </div>
                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <span class="badge bg-light text-dark border">@order.PhuongThucThanhToan</span>
                            <span class="badge @(order.TrangThai == "Đang vận chuyển" ? "bg-warning text-dark" : order.TrangThai == "Hoàn tất" ? "bg-success" : order.TrangThai == "Đã duyệt" ? "bg-info text-dark" : "bg-secondary text-white")">@order.TrangThai</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
