@using System.Text.Json
@model List<DATN64.Models.SanPham>

@{
    Layout = "~/Views/Shared/_POSLayout.cshtml";
    ViewData["Title"] = "Bán hàng tại quầy (POS)";
    var seller = ViewBag.CurrentSeller as DATN64.Models.NhanVien;
    var todayChamCong = ViewBag.TodayChamCong as DATN64.Models.ChamCong;
    bool daCheckIn = todayChamCong != null;
}

<div id="app" class="pos-wrapper min-vh-100 w-100 d-flex flex-column" :class="{ 'light-mode': !isDarkMode }" v-cloak>
    <!-- POS Header -->
    <header class="pos-header d-flex justify-content-between align-items-center px-4 py-3">
      <!-- Left side logo & Cashier Info -->
      <div class="d-flex align-items-center gap-3 flex-shrink-0 header-left-brand">
        <h4 class="fw-bold m-0 text-cyan d-flex align-items-center gap-2 text-nowrap">
          <i class="fa-solid fa-cash-register animate-pulse text-cyan"></i>
          <span class="d-none d-sm-inline text-nowrap">NovaTech POS</span>
          <span class="d-inline d-sm-none text-nowrap">POS</span>
        </h4>
        <div style="width: 1px; height: 20px; background-color: var(--border-color); flex-shrink: 0;"></div>
        <div class="d-flex align-items-center gap-2 text-xs header-cashier-info text-nowrap">
          <i class="fa-solid fa-circle-user text-cyan flex-shrink-0"></i>
          <span class="text-nowrap"><span class="d-none d-sm-inline text-nowrap">Thu ngân: </span><strong class="cashier-name text-nowrap" v-if="user">${ user.fullName }</strong></span>
        </div>
      </div>

      <!-- Mobile Tabs Navigation (Visible under 992px) -->
      <div class="pos-mobile-tabs d-lg-none d-flex rounded-pill p-1 mx-auto">
        <button type="button" class="btn btn-sm rounded-pill px-4 text-xs fw-semibold" :class="activeTab === 'products' ? 'btn-info text-white' : 'text-slate-400'" @@click="activeTab = 'products'">
          Sản phẩm
        </button>
        <button type="button" class="btn btn-sm rounded-pill px-4 text-xs fw-semibold position-relative" :class="activeTab === 'cart' ? 'btn-info text-white' : 'text-slate-400'" @@click="activeTab = 'cart'">
          Giỏ hàng
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;" v-if="cart.length > 0">
            ${ cart.reduce((sum, item) => sum + item.quantity, 0) }
          </span>
        </button>
      </div>

      <!-- Right side Cashier and Toggle switch -->
      <div class="d-flex align-items-center gap-3 flex-shrink-0 header-right-actions" style="justify-content: flex-end;">
        
        <!-- Check In / Out Button -->
        @if (seller != null)
        {
            @if (!daCheckIn)
            {
                <form asp-action="QuickToggleChamCong" asp-controller="Portal" method="post" class="m-0">
                    <button type="submit" class="btn btn-sm btn-warning rounded-pill px-3 text-xs fw-bold text-dark">
                        <i class="fa-solid fa-fingerprint me-1"></i> Check In
                    </button>
                </form>
            }
            else
            {
                <form asp-action="QuickToggleChamCong" asp-controller="Portal" method="post" class="m-0">
                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3 text-xs fw-bold" onclick="return confirm('Kết thúc ca làm việc?')">
                        <i class="fa-solid fa-right-from-bracket me-1"></i> Check Out
                    </button>
                </form>
            }
        }
        
        <!-- Theme Toggle Switch -->
        <div class="theme-switch-wrapper">
          <label class="theme-switch" for="themeCheckbox">
            <input type="checkbox" id="themeCheckbox" v-model="isDarkMode" />
            <div class="slider round">
              <i class="fa-solid fa-sun"></i>
              <i class="fa-solid fa-moon"></i>
            </div>
          </label>
        </div>

        <a href="/Portal/Selection" class="btn btn-back rounded-pill px-2.5 px-sm-3.5 text-xs d-flex align-items-center gap-1.5">
          <i class="fa-solid fa-arrow-left"></i> <span class="d-none d-sm-inline">Trở lại</span>
        </a>
      </div>
    </header>

    <!-- Main Dashboard -->
    <div class="pos-main-container flex-grow-1 row g-0 overflow-hidden">
      
      <!-- Left Panel: Product Catalog -->
      <div class="col-lg-8 d-flex flex-column h-100 p-4 border-end border-slate-800 overflow-hidden" :class="{ 'd-none d-lg-flex': activeTab !== 'products' }">
        
        <!-- Search and Catalog Filter -->
        <div class="d-flex flex-row flex-wrap gap-2 mb-4 flex-shrink-0 align-items-center justify-content-start">

          <!-- Spacious Search Bar with Search Button -->
          <div class="search-box-pos d-flex align-items-center" style="min-width: 300px; max-width: 520px; flex: 1 1 360px;">
            <div class="input-group position-relative">
              <input type="text" v-model="searchQuery" class="form-control" style="border-radius: 22px 0 0 22px; border-right: none; font-size: 0.8rem; padding: 0.45rem 1rem 0.45rem 2.2rem;" placeholder="Tìm tên sản phẩm hoặc mã SKU...">
              <span class="position-absolute start-0 top-50 translate-middle-y ms-3 text-muted-custom text-xs pointer-events-none" style="z-index: 5;">
                <i class="fa-solid fa-magnifying-glass text-slate-500"></i>
              </span>
              <!-- Nút kính lúp / xóa: khi có text thì hiện × để xóa, khi trống hiện kính lúp -->
              <button class="btn btn-search-pos d-flex align-items-center justify-content-center" type="button"
                      @@click="searchQuery ? searchQuery = '' : null"
                      style="border-radius: 0 22px 22px 0; min-width: 44px; font-size: 0.9rem;"
                      :title="searchQuery ? 'Xóa tìm kiếm' : 'Tìm kiếm'">
                <i v-if="!searchQuery" class="fa-solid fa-magnifying-glass"></i>
                <i v-else class="fa-solid fa-xmark"></i>
              </button>
            </div>
          </div>

          <!-- Divider -->
          <div class="vr opacity-25 d-none d-md-block" style="height: 24px;"></div>

          <!-- Compact Dropdown Filter -->
          <div class="dropdown flex-shrink-0">
            <button class="btn btn-outline-slate rounded-pill px-3 py-1.5 text-xs fw-bold dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fa-solid fa-filter text-cyan"></i> ${ activeCategory }
            </button>
            <ul class="dropdown-menu shadow">
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="activeCategory = 'Tất cả'">Tất cả</a></li>
              <li v-for="cat in categories" :key="cat">
                <a class="dropdown-item text-xs" href="#" @@click.prevent="activeCategory = cat">${ cat }</a>
              </li>
            </ul>
          </div>

          <!-- Brand Dropdown Filter -->
          <div class="dropdown flex-shrink-0">
            <button class="btn btn-outline-slate rounded-pill px-3 py-1.5 text-xs fw-bold dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fa-solid fa-tag text-cyan"></i> ${ activeBrand }
            </button>
            <ul class="dropdown-menu shadow">
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="activeBrand = 'Tất cả'">Tất cả</a></li>
              <li v-for="brand in brands" :key="brand">
                <a class="dropdown-item text-xs" href="#" @@click.prevent="activeBrand = brand">${ brand }</a>
              </li>
            </ul>
          </div>

          <!-- Sort Dropdown Filter -->
          <div class="dropdown flex-shrink-0">
            <button class="btn btn-outline-slate rounded-pill px-3 py-1.5 text-xs fw-bold dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fa-solid fa-arrow-down-wide-narrow text-cyan"></i> ${ getSortLabel() }
            </button>
            <ul class="dropdown-menu shadow">
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="sortBy = 'default'">Mặc định</a></li>
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="sortBy = 'priceAsc'">Giá: Thấp → Cao</a></li>
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="sortBy = 'priceDesc'">Giá: Cao → Thấp</a></li>
              <li><a class="dropdown-item text-xs" href="#" @@click.prevent="sortBy = 'nameAsc'">Tên: A → Z</a></li>
            </ul>
          </div>

          <!-- Toggle Advanced Filter Button -->
          <button type="button" class="btn btn-outline-slate rounded-pill px-3 py-1.5 text-xs fw-bold d-flex align-items-center gap-2" :class="{ 'btn-info-active text-white': showAdvancedFilter }" @@click="showAdvancedFilter = !showAdvancedFilter">
            <i class="fa-solid fa-sliders text-cyan" :class="{ 'text-white': showAdvancedFilter }"></i> Lọc nâng cao
          </button>

        </div>

          <!-- Row 3: Collapsible Advanced Filter Panel -->
          <div v-if="showAdvancedFilter" class="advanced-filter-panel p-3 rounded-3" style="transition: all 0.3s ease;">
            <div class="row g-3">
              <!-- Brand Checkboxes -->
              <div class="col-md-5">
                <h6 class="text-xs fw-bold mb-2 text-cyan"><i class="fa-solid fa-tag me-1"></i> Thương hiệu</h6>
                <div class="d-flex flex-wrap gap-3">
                  <div v-for="b in brands" :key="b" class="form-check m-0">
                    <input class="form-check-input text-xs" type="checkbox" :id="'brand-' + b" :value="b" v-model="selectedBrands" @@change="currentPage = 1">
                    <label class="form-check-label text-xs cursor-pointer text-slate-300" :for="'brand-' + b">${ b }</label>
                  </div>
                </div>
              </div>

              <!-- Price ranges Checkboxes -->
              <div class="col-md-5">
                <h6 class="text-xs fw-bold mb-2 text-cyan"><i class="fa-solid fa-coins me-1"></i> Khoảng giá</h6>
                <div class="d-flex flex-wrap gap-3">
                  <div class="form-check m-0">
                    <input class="form-check-input text-xs" type="checkbox" id="price-under-5" value="under-5" v-model="selectedPriceRanges" @@change="currentPage = 1">
                    <label class="form-check-label text-xs cursor-pointer text-slate-300" for="price-under-5">Dưới 5tr</label>
                  </div>
                  <div class="form-check m-0">
                    <input class="form-check-input text-xs" type="checkbox" id="price-5-15" value="5-15" v-model="selectedPriceRanges" @@change="currentPage = 1">
                    <label class="form-check-label text-xs cursor-pointer text-slate-300" for="price-5-15">5 - 15tr</label>
                  </div>
                  <div class="form-check m-0">
                    <input class="form-check-input text-xs" type="checkbox" id="price-over-15" value="over-15" v-model="selectedPriceRanges" @@change="currentPage = 1">
                    <label class="form-check-label text-xs cursor-pointer text-slate-300" for="price-over-15">Trên 15tr</label>
                  </div>
                </div>
              </div>

              <!-- Stock status -->
              <div class="col-md-2">
                <h6 class="text-xs fw-bold mb-2 text-cyan"><i class="fa-solid fa-warehouse me-1"></i> Trạng thái</h6>
                <div class="form-check form-switch m-0">
                  <input class="form-check-input text-xs" type="checkbox" id="stock-switch" v-model="onlyInStock" @@change="currentPage = 1">
                  <label class="form-check-label text-xs cursor-pointer text-slate-300" for="stock-switch">Còn hàng</label>
                </div>
              </div>
            </div>

            <!-- Reset All button -->
            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top border-secondary border-opacity-10" style="gap: 15px;">
              <div class="d-flex flex-wrap gap-1.5 align-items-center">
                <span class="text-xxs text-muted me-1">Đang lọc theo:</span>
                <span v-for="b in selectedBrands" :key="b" class="badge bg-info bg-opacity-10 border border-info border-opacity-35 text-info text-xxs cursor-pointer" @@click="selectedBrands = selectedBrands.filter(x => x !== b)">
                  ${ b } &times;
                </span>
                <span v-for="p in selectedPriceRanges" :key="p" class="badge bg-info bg-opacity-10 border border-info border-opacity-35 text-info text-xxs cursor-pointer" @@click="selectedPriceRanges = selectedPriceRanges.filter(x => x !== p)">
                  ${ p === 'under-5' ? 'Dưới 5tr' : p === '5-15' ? '5 - 15tr' : 'Trên 15tr' } &times;
                </span>
                <span v-if="onlyInStock" class="badge bg-info bg-opacity-10 border border-info border-opacity-35 text-info text-xxs cursor-pointer" @@click="onlyInStock = false">
                  Còn hàng &times;
                </span>
              </div>
              <button type="button" class="btn btn-xxs btn-outline-danger rounded-pill px-3 py-1" @@click="resetFilters">
                Reset
              </button>
            </div>
          </div>

        <div v-if="loading" class="d-flex align-items-center justify-content-center flex-grow-1">
          <div class="spinner-border text-info" role="status"></div>
        </div>

        <!-- Products Grid with Pagination -->
        <div class="flex-grow-1 d-flex flex-column overflow-hidden products-grid-container" v-else>

          <!-- Scrollable grid area -->
          <div class="flex-grow-1 overflow-y-auto pe-2">
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3" v-if="filteredProducts.length > 0">
              <div class="col" v-for="p in filteredProducts" :key="p.id">
                <div class="card product-card h-100 cursor-pointer" @@click="addToCart(p)">
                  <div class="position-relative overflow-hidden rounded-top-3 p-2 bg-white d-flex align-items-center justify-content-center" style="height: 120px;">
                    <img :src="p.image" class="card-img-top h-100 w-auto object-fit-contain" :alt="p.name">
                    <span class="position-absolute top-0 start-0 m-2 badge bg-success" v-if="p.stock > 0 && !p.hasVariants">
                      Tồn: ${ p.stock }
                    </span>
                    <span class="position-absolute top-0 start-0 m-2 badge bg-danger" v-else-if="p.stock <= 0 && !p.hasVariants">
                      Hết hàng
                    </span>
                    <span class="position-absolute top-0 start-0 m-2 badge variant-badge" v-if="p.hasVariants">
                      <i class="fa-solid fa-layer-group me-1" style="font-size:0.6rem;"></i>Biến thể
                    </span>
                    <span class="position-absolute top-0 end-0 m-2" v-if="p.hasVariants">
                      <i class="fa-solid fa-chevron-right text-white" style="font-size:0.65rem; opacity:0.7;"></i>
                    </span>
                  </div>
                  <div class="card-body p-2.5 d-flex flex-column">
                    <div class="text-xxs text-uppercase fw-bold text-muted mb-1" style="font-size: 0.65rem;">${ p.category }</div>
                    <h6 class="text-xs text-truncate mb-1 fw-bold product-name-highlight" :title="p.name">${ p.name }</h6>
                    <div class="mb-1"><span class="sku-badge"><i class="fa-solid fa-barcode me-1" style="font-size:0.55rem;"></i>${ p.sku }</span></div>

                    <div class="d-flex align-items-center justify-content-between mt-auto">
                      <div class="text-xs text-emerald fw-extrabold" style="font-size: 0.85rem;">${ formatMoney(p.price) }</div>
                      <button type="button" class="btn-add-to-cart-quick" @@click.stop="addToCart(p)">
                        <i class="fa-solid fa-basket-shopping text-xxs"></i>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="d-flex flex-column align-items-center justify-content-center text-muted-custom py-5" v-else>
              <i class="fa-solid fa-box-open fs-1 mb-3 text-slate-600"></i>
              <p class="text-xs text-slate-400">Không tìm thấy sản phẩm nào phù hợp</p>
            </div>
          </div>

          <!-- Pagination Bar -->
          <div class="pos-pagination d-flex align-items-center justify-content-center gap-1 pt-2 pb-1 flex-shrink-0" v-if="totalPages > 1 || products.length > 0">
            <!-- First / Prev -->
            <button type="button" class="page-nav-btn" @@click="goToPage(1)" :disabled="currentPage === 1" title="Trang đầu">
              <i class="fa-solid fa-angles-left"></i>
            </button>
            <button type="button" class="page-nav-btn" @@click="goToPage(currentPage - 1)" :disabled="currentPage === 1" title="Trang trước">
              <i class="fa-solid fa-angle-left"></i>
            </button>

            <!-- Ellipsis left -->
            <span class="page-ellipsis" v-if="displayedPages[0] > 1">…</span>

            <!-- Page numbers -->
            <button
              type="button"
              v-for="page in displayedPages"
              :key="page"
              class="page-num-btn"
              :class="{ 'page-num-btn-active': page === currentPage }"
              @@click="goToPage(page)"
            >${ page }</button>

            <!-- Ellipsis right -->
            <span class="page-ellipsis" v-if="displayedPages.length > 0 && displayedPages[displayedPages.length - 1] < totalPages">…</span>

            <!-- Next / Last -->
            <button type="button" class="page-nav-btn" @@click="goToPage(currentPage + 1)" :disabled="currentPage === totalPages" title="Trang sau">
              <i class="fa-solid fa-angle-right"></i>
            </button>
            <button type="button" class="page-nav-btn" @@click="goToPage(totalPages)" :disabled="currentPage === totalPages" title="Trang cuối">
              <i class="fa-solid fa-angles-right"></i>
            </button>

            <!-- Page info -->
            <span class="page-info-label ms-2">Trang ${ currentPage }/${ totalPages }</span>
          </div>

        </div>
      </div>

      <!-- Right Panel: Cart & Checkout Form -->
      <div class="col-lg-4 d-flex flex-column h-100 pos-checkout-panel" :class="{ 'd-none d-lg-flex': activeTab !== 'cart' }">
        <!-- ═══ ZONE 1: Cart Items (Scrollable) ═══ -->
        <div class="cart-zone-top d-flex flex-column">
          <!-- Cart Header -->
          <div class="d-flex justify-content-between align-items-center px-4 pt-3 pb-2 flex-shrink-0">
            <h5 class="fw-bold m-0 d-flex align-items-center gap-2" style="font-size: 0.9rem;">
              <i class="fa-solid fa-basket-shopping text-cyan"></i>
              <span style="color: var(--text-primary);">Giỏ hàng</span>
              <span class="badge rounded-pill ms-1" style="background: rgba(0,242,254,0.15); color: var(--accent-color); font-size: 0.65rem;" v-if="cart.length > 0">${ cart.reduce((s,i)=>s+i.quantity,0) } món</span>
            </h5>
            <button type="button" class="btn btn-xs btn-outline-warning rounded-pill px-2 py-1 text-xxs fw-bold d-flex align-items-center gap-1" @@click="holdCurrentCart" :disabled="cart.length === 0">
              <i class="fa-solid fa-clock"></i> Tạm lưu
            </button>
          </div>

          <!-- Held Carts -->
          <div class="held-carts-section mx-3 mb-2 p-2 rounded-3" v-if="heldCarts.length > 0">
            <h6 class="text-xs fw-bold text-cyan mb-2 d-flex align-items-center gap-1">
              <i class="fa-solid fa-clock-rotate-left"></i> Đơn tạm lưu (${ heldCarts.length })
            </h6>
            <div class="d-flex flex-column gap-1" style="max-height: 100px; overflow-y: auto;">
              <div class="d-flex align-items-center justify-content-between p-1.5 rounded-2 text-xxs" v-for="hc in heldCarts" :key="hc.id" style="background: var(--input-bg); border: 1px solid var(--border-color);">
                <div class="min-w-0 flex-grow-1">
                  <div class="fw-bold text-truncate" style="color: var(--text-primary);">${ hc.customerName } (${ hc.time })</div>
                  <div style="color: var(--text-secondary);">${ hc.cart.length } món | ${ formatMoney(hc.total) } đ</div>
                </div>
                <div class="d-flex gap-1 align-items-center ms-2">
                  <button type="button" class="btn btn-xs btn-info text-white px-2 py-0.5 rounded text-xxs fw-bold" @@click="restoreHeldCart(hc.id)">Phục hồi</button>
                  <button type="button" class="btn btn-xs btn-outline-danger px-1 py-0.5 rounded" @@click="deleteHeldCart(hc.id)"><i class="fa-solid fa-trash-can"></i></button>
                </div>
              </div>
            </div>
          </div>

          <!-- Cart Items Scrollable -->
          <div class="cart-items-scroll px-3 pb-2">
            <!-- Empty state -->
            <div class="d-flex flex-column align-items-center justify-content-center text-muted-custom py-4" v-if="cart.length === 0">
              <i class="fa-solid fa-cart-flatbed fs-2 mb-2 text-slate-500"></i>
              <p class="text-xs text-slate-400 m-0">Chưa có sản phẩm nào</p>
              <p class="text-xxs text-slate-600 m-0 mt-1">Click vào sản phẩm bên trái để thêm</p>
            </div>
            <!-- Items -->
            <div class="d-flex flex-column gap-2" v-else>
              <div v-for="item in cart" :key="item.id" class="cart-item d-flex align-items-center gap-2 p-2 rounded-3">
                <div class="flex-grow-1 min-w-0">
                  <div class="text-xs fw-bold cart-item-name text-truncate" :title="item.name">${ item.name }</div>
                  <div class="d-flex align-items-center gap-1 mt-0.5">
                    <span class="sku-badge-mini">${ item.sku }</span>
                    <span class="text-xxs text-emerald fw-bold">${ formatMoney(item.price) }đ</span>
                  </div>
                </div>
                <div class="d-flex align-items-center gap-1 flex-shrink-0">
                  <button type="button" class="qty-btn" @@click="updateQty(item.id, -1)"><i class="fa-solid fa-minus"></i></button>
                  <span class="text-xs fw-bold px-1" style="min-width: 18px; text-align: center; color: var(--text-primary);">${ item.quantity }</span>
                  <button type="button" class="qty-btn" @@click="updateQty(item.id, 1)"><i class="fa-solid fa-plus"></i></button>
                  <button type="button" class="trash-btn" @@click="removeFromCart(item.id)"><i class="fa-solid fa-trash-can"></i></button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ DIVIDER ═══ -->
        <div class="cart-zone-divider flex-shrink-0"></div>

        <!-- ═══ ZONE 2: Checkout (Sticky / Fixed Bottom) ═══ -->
        <div class="cart-zone-bottom flex-shrink-0">
        <form @@submit.prevent="handleCheckout" class="checkout-form px-4 pt-3">
          <div v-if="successMsg" class="alert alert-success text-xs py-2 px-3 mb-3 d-flex align-items-center gap-2">
            <i class="fa-solid fa-circle-check fs-6"></i>
            <span>${ successMsg }</span>
          </div>
          <div v-if="errorMsg" class="alert alert-danger text-xs py-2 px-3 mb-3 d-flex align-items-center gap-2">
            <i class="fa-solid fa-circle-exclamation fs-6"></i>
            <span>${ errorMsg }</span>
          </div>

          <!-- Customer Smart Search (Autocomplete) -->
          <div class="mb-3 customer-search-wrapper" v-click-outside="closeCustomerSearch">
            <label class="form-label text-xxs voucher-label fw-semibold mb-1.5">
              <i class="fa-solid fa-user-tag me-1 text-cyan"></i>Khách hàng
            </label>

            <!-- Selected customer chip (shown after selection) -->
            <div class="customer-selected-chip d-flex align-items-center gap-2 px-3 py-2 rounded-pill" v-if="selectedCustomer" @@click="clearCustomer">
              <div class="customer-avatar-mini" v-text="getInitial(selectedCustomer.name)"></div>
              <div class="flex-grow-1 min-w-0">
                <div class="text-xs fw-bold text-truncate" style="color: var(--text-primary);">${ selectedCustomer.name }</div>
                <div class="text-xxs" style="color: var(--text-secondary);" v-if="selectedCustomer.phone"><i class="fa-solid fa-phone me-1" style="font-size:0.6rem;"></i>${ selectedCustomer.phone }</div>
                <div class="text-xxs text-slate-500" v-else>Khách vãng lai</div>
              </div>
              <i class="fa-solid fa-xmark text-slate-400 hover-text-white flex-shrink-0" style="font-size: 0.7rem; cursor:pointer;" title="Đổi khách hàng"></i>
            </div>

            <!-- Search input (shown when no customer selected) -->
            <div class="position-relative" v-else>
              <div class="customer-search-input-wrap d-flex align-items-center">
                <i class="fa-solid fa-magnifying-glass customer-search-icon"></i>
                <input
                  type="text"
                  v-model="customerSearchQuery"
                  @@input="onCustomerSearch"
                  @@focus="onCustomerSearchFocus"
                  @@keydown.down.prevent="customerNavDown"
                  @@keydown.up.prevent="customerNavUp"
                  @@keydown.enter.prevent="customerNavSelect"
                  @@keydown.escape="closeCustomerSearch"
                  class="customer-search-input"
                  placeholder="Nhập tên hoặc SĐT khách hàng..."
                  autocomplete="off"
                >
                <button type="button" class="customer-search-clear" v-if="customerSearchQuery" @@click="customerSearchQuery = ''; showCustomerDropdown = false">&times;</button>
              </div>

              <!-- Autocomplete dropdown -->
              <div class="customer-autocomplete-dropdown" v-if="showCustomerDropdown">
                <!-- Results list -->
                <div v-if="customerSearchResults.length > 0">
                  <div
                    v-for="(c, i) in customerSearchResults"
                    :key="c.id"
                    class="customer-autocomplete-item"
                    :class="{ 'customer-autocomplete-item-active': i === customerNavIndex }"
                    @@click="selectCustomer(c)"
                    @@mouseenter="customerNavIndex = i"
                  >
                    <div class="customer-avatar-mini" v-text="getInitial(c.name)"></div>
                    <div class="flex-grow-1 min-w-0">
                      <div class="text-xs fw-bold text-truncate" style="color: var(--text-primary);">${ c.name }</div>
                      <div class="text-xxs" style="color: var(--text-secondary);" v-if="c.phone">
                        <i class="fa-solid fa-phone me-1" style="font-size:0.55rem;"></i>${ c.phone }
                      </div>
                    </div>
                    <i class="fa-solid fa-arrow-turn-down-left text-slate-500" style="font-size:0.65rem; transform: scaleX(-1);"></i>
                  </div>
                </div>
                <!-- No results -->
                <div class="px-3 py-2 text-xxs text-slate-400" v-else-if="customerSearchQuery.length > 0">
                  <i class="fa-solid fa-circle-info me-1 text-slate-500"></i>
                  Không tìm thấy —
                  <span class="text-cyan fw-semibold cursor-pointer" @@click="showRegisterForm()" style="cursor:pointer;">Đăng ký khách mới</span>
                </div>
                <!-- Default: walk-in shortcut -->
                <div class="customer-autocomplete-item" @@click="selectWalkIn" v-if="customerSearchResults.length === 0 && customerSearchQuery.length === 0">
                  <div class="customer-avatar-mini" style="background: rgba(148,163,184,0.15); color: #64748b;">?</div>
                  <div>
                    <div class="text-xs fw-semibold" style="color: var(--text-primary);">Khách Hàng Vãng Lai</div>
                    <div class="text-xxs text-slate-500">Không cần đăng ký</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Form đăng ký khách mới (tùy chọn) -->
            <div v-if="showNewCustomerForm" class="mt-2 p-3 rounded-3" style="background: rgba(6,182,212,0.07); border: 1px solid rgba(6,182,212,0.2);">
              <div class="text-xxs fw-bold text-cyan mb-2">
                <i class="fa-solid fa-user-plus me-1"></i>Đăng ký khách hàng mới
              </div>
              <div class="mb-2">
                <input type="text" v-model="newCustomerName" class="form-control form-control-sm input-pos text-xs"
                       placeholder="Họ và Tên (tùy chọn)" autocomplete="off">
              </div>
              <div class="mb-2">
                <input type="tel" v-model="newCustomerPhone" class="form-control form-control-sm input-pos text-xs"
                       placeholder="Số điện thoại *" autocomplete="off"
                       @@keydown.enter.prevent="registerNewCustomer">
              </div>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm flex-grow-1 text-xxs fw-bold"
                        style="background: linear-gradient(135deg,#06b6d4,#0e7490); color:#fff; border-radius:8px;"
                        @@click="registerNewCustomer">
                  <i class="fa-solid fa-check me-1"></i>Lưu & chọn
                </button>
                <button type="button" class="btn btn-sm text-xxs text-slate-400"
                        style="border: 1px solid rgba(100,116,139,0.3); border-radius:8px;"
                        @@click="cancelRegister">
                  Hủy
                </button>
              </div>
            </div>
          </div>


          <!-- Voucher Section (NEW) -->
          <div class="voucher-section mb-3">
            <label class="form-label text-xxs voucher-label fw-semibold mb-1.5">Voucher / Mã giảm giá</label>
            <div class="input-group input-group-sm">
              <input type="text" class="form-control text-xs input-pos" placeholder="Thêm Voucher / Mã giảm giá" v-model="voucherCode">
              <button class="btn btn-apply-voucher text-xs px-3" type="button" @@click="applyVoucher" v-if="!voucherAppliedCode">Áp dụng</button>
              <button class="btn btn-danger text-xs px-3" type="button" @@click="clearVoucher" v-else>Hủy bỏ</button>
            </div>
            <div class="text-xxs text-emerald mt-1.5 fw-semibold" v-if="voucherSuccessMsg">
              ${ voucherSuccessMsg }
            </div>
            <div class="text-xxs text-danger mt-1.5 fw-semibold" v-if="voucherErrorMsg">
              ${ voucherErrorMsg }
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2 pt-1.5 border-top border-secondary border-opacity-10" v-if="voucherDiscountValue > 0">
              <span class="text-xxs voucher-sublabel">Voucher giảm giá:</span>
              <span class="text-xs fw-extrabold text-danger">- ${ formatMoney(voucherDiscountValue) } đ</span>
            </div>
          </div>

          <!-- Pay Option Cards -->
          <div class="mb-3">
            <label class="form-label text-xxs voucher-label fw-semibold mb-1.5">Phương thức thanh toán</label>
            <div class="d-flex gap-2">
              <div class="payment-card flex-grow-1 text-center" :class="{ active: paymentMethod === 'Tiền mặt' }" @@click="paymentMethod = 'Tiền mặt'">
                <i class="fa-solid fa-money-bill-1-wave fs-6 mb-1"></i>
                <span class="text-xxs fw-bold d-block">Tiền mặt</span>
              </div>
              <div class="payment-card flex-grow-1 text-center" :class="{ active: paymentMethod === 'Chuyển khoản' }" @@click="paymentMethod = 'Chuyển khoản'">
                <i class="fa-solid fa-credit-card fs-6 mb-1"></i>
                <span class="text-xxs fw-bold d-block">Chuyển khoản</span>
              </div>
            </div>
          </div>

          <!-- Cash Calculator Section -->
          <div class="cash-calculator-section mb-3 p-3 rounded-3" v-if="paymentMethod === 'Tiền mặt'">
            <div class="row g-2 mb-2">
              <div class="col-6">
                <label class="form-label text-xxs voucher-label fw-semibold mb-1">Tiền khách đưa</label>
                <div class="input-group input-group-sm">
                  <input type="number" v-model.number="cashReceived" class="form-control text-xs input-pos" placeholder="0">
                  <span class="input-group-text bg-dark-custom text-xxs border-slate-800" style="color: var(--text-secondary) !important;">đ</span>
                </div>
              </div>
              <div class="col-6">
                <label class="form-label text-xxs voucher-label fw-semibold mb-1">Tiền thừa trả khách</label>
                <div class="text-emerald text-sm fw-extrabold mt-1.5">
                  ${ formatMoney(changeDue) } đ
                </div>
              </div>
            </div>
            <!-- Quick Cash Buttons -->
            <div class="d-flex flex-wrap gap-1.5 quick-cash-buttons">
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" @@click="cashReceived = totalAmount">Đủ tiền</button>
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" v-if="totalAmount < 50000" @@click="cashReceived = 50000">50k</button>
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" v-if="totalAmount < 100000" @@click="cashReceived = 100000">100k</button>
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" v-if="totalAmount < 200000" @@click="cashReceived = 200000">200k</button>
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" v-if="totalAmount < 500000" @@click="cashReceived = 500000">500k</button>
              <button type="button" class="btn btn-xs btn-outline-slate rounded px-2 py-1 text-xxs fw-bold" v-if="totalAmount < 1000000" @@click="cashReceived = 1000000">1M</button>
            </div>
          </div>

          <!-- Bank Transfer QR Section -->
          <div class="qr-payment-section mb-3 p-3 rounded-3 text-center" v-if="paymentMethod === 'Chuyển khoản'">
            <div v-if="cart.length === 0" class="py-3 text-warning text-xs fw-semibold">
              <i class="fa-solid fa-circle-exclamation fs-5 mb-1.5 d-block text-warning animate-bounce"></i>
              Bạn cần chọn 1 sản phẩm trước khi thanh toán
            </div>
            <div v-else>
              <label class="form-label text-xxs voucher-label fw-semibold mb-2 d-block">Quét mã QR để chuyển khoản</label>
              <div class="qr-container d-inline-block p-2 bg-white rounded-3 shadow-sm mb-2" @@click="zoomQR = true" style="cursor: zoom-in;">
                <img :key="qrCodeUrl" :src="qrCodeUrl" @@error="handleQrError" alt="VietQR Thanh toán" class="img-fluid" style="max-width: 160px; display: block; margin: 0 auto;">
              </div>
              <div class="text-xxs text-secondary mt-1">
                <div>Ngân hàng: <strong class="text-cyan">${ bankConfig.bankId }</strong> | STK: <strong class="text-cyan">${ bankConfig.accountNo }</strong></div>
                <div>Chủ tài khoản: <strong class="text-cyan">${ bankConfig.accountName }</strong></div>
              </div>
            </div>
          </div>

          <!-- Total Bill -->
          <div class="billing-summary d-flex justify-content-between align-items-center p-3 rounded-3 mb-3" style="background: var(--input-bg); border: 1px solid var(--border-color);">
            <div class="d-flex flex-column">
              <span class="fs-5 fw-bold text-white">Tổng tiền thanh toán</span>
              <span class="text-xxs text-muted mt-1" v-if="voucherDiscountValue > 0" style="text-decoration: line-through;">Tạm tính: ${ formatMoney(subtotalAmount) } đ</span>
            </div>
            <span class="fs-3 text-emerald fw-extrabold">${ formatMoney(totalAmount) } đ</span>
          </div>

          <button type="submit" class="btn btn-checkout w-100 py-2.5 fw-bold text-sm" :disabled="cart.length === 0 || checkingOut">
            <span v-if="checkingOut" class="spinner-border spinner-border-sm me-2"></span>
            <i class="fa-solid fa-circle-check me-2" v-if="!checkingOut"></i> Xác nhận & In hóa đơn
          </button>
        </form>
        </div><!-- /cart-zone-bottom -->
      </div>
    </div>

    <!-- Printable Receipt Modal -->
    <div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true" :class="{ show: showReceiptModal, 'd-block': showReceiptModal }" style="background: rgba(0,0,0,0.75);" v-if="showReceiptModal && lastOrder">
      <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
        <div class="modal-content border-0 text-dark bg-white shadow-lg" style="border-radius: 16px;">
          <div class="modal-body p-4" id="printable-receipt">
            <div class="text-center mb-3">
              <h5 class="fw-bold m-0 text-dark">HÓA ĐƠN BÁN LẺ</h5>
              <div class="text-xs text-muted mt-1">NovaTech Store - Hệ thống POS thông minh</div>
              <div class="text-xxs text-muted">Đ/c: 123 Đường Ba Tháng Hai, Quận 10, TP.HCM</div>
            </div>
            
            <hr class="border-secondary border-dashed my-2">
            
            <div class="text-xs mb-3 d-grid gap-1">
              <div class="d-flex justify-content-between">
                <span class="text-muted">Mã hóa đơn:</span>
                <span class="fw-bold text-dark">${ lastOrder.orderCode }</span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Thời gian:</span>
                <span class="text-dark">${ lastOrder.date }</span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Thu ngân:</span>
                <span class="text-dark">${ lastOrder.cashier }</span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Khách hàng:</span>
                <span class="text-dark">${ lastOrder.customerName }</span>
              </div>
              <div class="d-flex justify-content-between" v-if="lastOrder.customerPhone">
                <span class="text-muted">SĐT:</span>
                <span class="text-dark">${ lastOrder.customerPhone }</span>
              </div>
            </div>

            <hr class="border-secondary border-dashed my-2">

            <!-- Items table -->
            <div class="mb-3">
              <table class="w-100 text-xs">
                <thead>
                  <tr class="border-bottom text-muted">
                    <th class="py-1 text-start">Sản phẩm</th>
                    <th class="py-1 text-center" style="width: 50px;">SL</th>
                    <th class="py-1 text-end" style="width: 100px;">Thành tiền</th>
                  </tr>
                </thead>
                <tbody>
                  <tr v-for="item in lastOrder.items" :key="item.id" class="border-bottom">
                    <td class="py-2">
                      <div class="fw-semibold text-dark">${ item.name }</div>
                      <div class="text-xxs text-muted">${ formatMoney(item.price) } đ</div>
                    </td>
                    <td class="py-2 text-center text-dark">${ item.quantity }</td>
                    <td class="py-2 text-end text-dark fw-bold">${ formatMoney(item.price * item.quantity) } đ</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="d-grid gap-1 pt-2">
              <div class="d-flex justify-content-between text-xs" v-if="lastOrder.discount > 0">
                <span class="text-muted">Tạm tính:</span>
                <span class="text-dark fw-bold">${ formatMoney(lastOrder.subtotal) } đ</span>
              </div>
              <div class="d-flex justify-content-between text-xs text-danger fw-semibold" v-if="lastOrder.discount > 0">
                <span>Voucher giảm giá (${ lastOrder.voucherCode }):</span>
                <span>- ${ formatMoney(lastOrder.discount) } đ</span>
              </div>
              <div class="d-flex justify-content-between text-xs">
                <span class="text-muted">Hình thức:</span>
                <span class="text-dark fw-bold">${ lastOrder.paymentMethod }</span>
              </div>
              <div class="d-flex justify-content-between align-items-center text-sm border-top border-secondary border-dashed pt-2 mt-1">
                <span class="fw-bold text-dark">TỔNG CỘNG:</span>
                <span class="fs-5 fw-extrabold text-danger">${ formatMoney(lastOrder.totalAmount) } đ</span>
              </div>
              
              <!-- Cash Calculator Receipt Info -->
              <div class="d-flex justify-content-between text-xs border-top border-secondary border-dashed pt-2 mt-1" v-if="lastOrder.paymentMethod === 'Tiền mặt' && lastOrder.cashReceived > 0">
                <span class="text-muted">Tiền khách đưa:</span>
                <span class="text-dark fw-bold">${ formatMoney(lastOrder.cashReceived) } đ</span>
              </div>
              <div class="d-flex justify-content-between text-xs" v-if="lastOrder.paymentMethod === 'Tiền mặt' && lastOrder.cashReceived > 0">
                <span class="text-muted">Tiền thừa trả khách:</span>
                <span class="text-dark fw-bold text-success">${ formatMoney(lastOrder.changeDue) } đ</span>
              </div>
            </div>
            
            <div class="text-center text-muted text-xxs mt-4">
              Cảm ơn Quý khách. Hẹn gặp lại!
            </div>
          </div>
          <div class="modal-footer border-0 p-3 bg-light d-flex justify-content-end gap-2" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
            <button type="button" class="btn btn-outline-secondary btn-sm px-3" @@click="showReceiptModal = false">Đóng</button>
            <button type="button" class="btn btn-info text-white btn-sm px-4 fw-semibold" @@click="printReceipt">In hóa đơn</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ Variant Selection Modal ═══ -->
    <div class="variant-modal-overlay d-flex align-items-end align-items-md-center justify-content-center"
         v-if="showVariantModal"
         @@click.self="closeVariantModal"
         style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:9998;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);">
      <div class="variant-modal-panel">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between px-4 pt-4 pb-3" style="border-bottom:1px solid var(--border-color);">
          <div>
            <div class="text-xxs text-cyan fw-semibold mb-0.5"><i class="fa-solid fa-layer-group me-1"></i>CHỌN BIẾN THỂ</div>
            <div class="text-sm fw-bold" style="color:var(--text-primary);" v-if="variantProduct">${ variantProduct.name.split(' ').slice(0,2).join(' ') }</div>
          </div>
          <button type="button" class="btn-variant-close" @@click="closeVariantModal">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <!-- Loading -->
        <div class="d-flex align-items-center justify-content-center py-5" v-if="variantLoading">
          <div class="spinner-border spinner-border-sm text-info me-2"></div>
          <span class="text-xs text-slate-400">Đang tải biến thể...</span>
        </div>

        <!-- Variant Grid -->
        <div class="variant-grid px-4 py-3" v-else>
          <div
            v-for="v in variantList"
            :key="v.id"
            class="variant-card"
            :class="{ 'variant-card-out': v.stock <= 0 }"
            @@click="addVariantToCart(v)"
          >
            <div class="variant-card-img">
              <img :src="v.image" :alt="v.name" class="img-fluid">
            </div>
            <div class="variant-card-body">
              <div class="variant-card-name">${ v.name }</div>
              <div class="variant-card-sku"><i class="fa-solid fa-barcode me-1" style="font-size:0.5rem;"></i>${ v.sku }</div>
              <div class="variant-card-price">${ formatMoney(v.price) }đ</div>
              <div class="variant-card-stock" :class="v.stock > 5 ? 'text-emerald' : (v.stock > 0 ? 'text-warning' : 'text-danger')">
                <span v-if="v.stock > 0"><i class="fa-solid fa-circle-check me-1"></i>Tồn: ${ v.stock }</span>
                <span v-else><i class="fa-solid fa-circle-xmark me-1"></i>Hết hàng</span>
              </div>
            </div>
            <div class="variant-card-add" v-if="v.stock > 0">
              <i class="fa-solid fa-plus"></i>
            </div>
          </div>

          <!-- Empty -->
          <div class="text-center py-4 text-slate-400 text-xs" v-if="variantList.length === 0">
            <i class="fa-solid fa-box-open fs-4 mb-2 d-block text-slate-600"></i>
            Không tìm thấy biến thể nào
          </div>
        </div>
      </div>
    </div>

    <!-- Zoomed QR Code Overlay Modal -->
    <div class="qr-zoom-overlay d-flex align-items-center justify-content-center" v-if="zoomQR" @@click="zoomQR = false" style="background: rgba(0,0,0,0.85); position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9999; cursor: zoom-out;">
      <div class="qr-zoom-card p-4 bg-white rounded-4 shadow-lg text-center" @@click.stop style="max-width: 90%; width: 380px; cursor: default; border-radius: 16px;">
        <h5 class="fw-bold text-dark mb-3">MÃ QR THANH TOÁN</h5>
        <div class="p-3 bg-white rounded-3 border border-slate-200 d-inline-block shadow-sm mb-3">
          <img :key="qrCodeUrl" :src="qrCodeUrl" @@error="handleQrError" alt="VietQR Zoomed" class="img-fluid" style="width: 260px; max-width: 100%; display: block; margin: 0 auto;">
        </div>
        <div class="text-xs text-dark mt-2 d-grid gap-1.5 text-start px-2">
          <div class="fw-bold mb-1.5 text-center text-dark">Số tiền cần quét: <span class="text-danger fs-5 d-block mt-0.5 fw-extrabold">${ formatMoney(totalAmount) } đ</span></div>
          <div class="d-flex justify-content-between border-top border-light pt-2">
            <span class="text-muted">Ngân hàng:</span>
            <strong>${ bankConfig.bankId }</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-muted">Số tài khoản:</span>
            <strong>${ bankConfig.accountNo }</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-muted">Chủ tài khoản:</span>
            <strong>${ bankConfig.accountName }</strong>
          </div>
        </div>
        <button type="button" class="btn btn-secondary btn-sm px-4 mt-3.5 rounded-pill fw-bold text-xs" @@click="zoomQR = false">Đóng</button>
      </div>
    </div>
</div>

@{
    var vPrefixes = ViewBag.VariantPrefixes as HashSet<string> ?? new HashSet<string>();
}
<script>
    window.posProducts = @Html.Raw(JsonSerializer.Serialize(Model.Select(p => {
        var w = p.TenSanPham.Trim().Split(' ');
        var pfx = string.Join(" ", w.Take(2));
        return new {
            id = p.MaSanPham,
            name = p.TenSanPham,
            price = p.GiaBan,
            stock = p.SoLuongTon,
            image = p.HinhAnh ?? "https://images.unsplash.com/photo-1531297484001-80022131f5a1?q=80&w=300",
            category = p.DanhMuc != null ? p.DanhMuc.TenDanhMuc : "Khác",
            brand = p.ThuongHieu != null ? p.ThuongHieu.TenThuongHieu : "Khác",
            sku = "SP-" + p.MaSanPham.ToString("D4"),
            hasVariants = vPrefixes.Contains(pfx),
            categoryId = p.MaDanhMuc
        };
    })));

    window.posCustomers = @Html.Raw(JsonSerializer.Serialize(((List<DATN64.Models.KhachHang>)ViewBag.Customers).Select(c => new {
        id = c.MaKhachHang,
        name = c.HoTen,
        phone = c.SoDienThoai ?? ""
    })));

    window.sellerName = @Html.Raw(JsonSerializer.Serialize(ViewBag.SellerName ?? "Nhân viên"));
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/pos.css" asp-append-version="true" />
}

@section Scripts {
    <!-- Vue 2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js"></script>
    <!-- Axios CDN -->
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <!-- POS JS -->
    <script src="~/js/pos.js" asp-append-version="true"></script>
}
