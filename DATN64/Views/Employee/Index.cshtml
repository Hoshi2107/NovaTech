                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted">SỐ ĐIỆN THOẠI</label>
                            <input type="text" name="SoDienThoai" class="form-control form-control-sm" placeholder="0901234567">
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted">MẬT KHẨU <span class="text-danger">*</span></label>
                            <input type="password" name="MatKhau" class="form-control form-control-sm" required placeholder="Nhập mật khẩu">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted">LƯƠNG THEO GIỜ (VNĐ)</label>
                            <input type="number" name="LuongTheoGio" class="form-control form-control-sm" placeholder="Ví dụ: 25000" min="0" step="1000">
