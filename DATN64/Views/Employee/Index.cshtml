@model List<DATN64.Models.MockDataService.Employee>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nhân viên & Phân quyền";
    ViewData["BreadcrumbActive"] = "Nhân sự";
    var rolesList = ViewBag.RolesList as List<DATN64.Models.MockDataService.RolePermission> ?? new();
}

<div class="card card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0"><i class="fa-solid fa-users-gear text-cyan me-2"></i>Quản lý nhân sự & Phân vai trò (RBAC)</h4>
        
        @if (AuthHelper.HasPermission(Context, "Create_Employee"))
        {
            <button class="btn btn-info rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
                <i class="fa-solid fa-plus me-2"></i>Thêm nhân viên mới
            </button>
        }
    </div>

    <!-- Employee List Table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 text-sm align-middle">
            <thead>
                <tr>
                    <th>Họ và tên</th>
                    <th>Email liên hệ</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò / Chức vụ</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td class="fw-bold text-white">@e.FullName</td>
                        <td>@e.Email</td>
                        <td>@e.Phone</td>
                        <td>
                            @foreach (var r in e.Roles)
                            {
                                <span class="badge bg-gradient-cyan text-dark rounded-pill px-2.5 py-1 text-xxs me-1">@r</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-success-subtle text-success border border-success border-opacity-25 rounded-pill px-2">@e.Status</span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                @if (AuthHelper.HasPermission(Context, "Assign_Role"))
                                {
                                    <button class="btn btn-sm btn-outline-info text-xs rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#assignModal-@e.Id">
                                        Phân vai trò
                                    </button>
                                }

                                @if (AuthHelper.HasPermission(Context, "Delete_Employee"))
                                {
                                    <form method="post" action="@Url.Action("Delete", "Employee")" class="d-inline" onsubmit="return confirm('Xóa nhân viên khỏi hệ thống?');">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>

                    <!-- Assign Role Modal -->
                    <div class="modal fade" id="assignModal-@e.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content bg-dark border border-secondary border-opacity-25 text-white">
                                <form method="post" action="@Url.Action("UpdateRoles", "Employee")">
                                    <input type="hidden" name="employeeId" value="@e.Id" />
                                    <div class="modal-header border-secondary border-opacity-25">
                                        <h5 class="modal-title fw-bold">Gán vai trò cho: @e.FullName</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label text-xs text-muted mb-2">Chọn một hoặc nhiều vai trò:</label>
                                            <div class="d-flex flex-column gap-2">
                                                @foreach (var r in rolesList)
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" name="selectedRoles" value="@r.RoleName" id="role-@e.Id-@r.RoleName" @(e.Roles.Contains(r.RoleName) ? "checked" : "")>
                                                        <label class="form-check-label text-sm" for="role-@e.Id-@r.RoleName">
                                                            @r.RoleName
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-secondary border-opacity-25">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                                        <button type="submit" class="btn btn-info rounded-pill px-4">Lưu lại</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border border-secondary border-opacity-25 text-white">
            <form method="post" action="@Url.Action("Create", "Employee")">
                <div class="modal-header border-secondary border-opacity-25">
                    <h5 class="modal-title fw-bold">Thêm nhân sự mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-xs">Họ và tên</label>
                        <input type="text" name="FullName" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="Nguyễn Văn B">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-xs">Email</label>
                        <input type="email" name="Email" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="nhanvien@novatech.vn">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-xs">Số điện thoại</label>
                        <input type="text" name="Phone" class="form-control bg-dark border-secondary border-opacity-50 text-white" required placeholder="09...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-xs">Phân vai trò mặc định</label>
                        <div class="d-flex flex-column gap-2 mt-1">
                            @foreach (var r in rolesList)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="selectedRoles" value="@r.RoleName" id="new-role-@r.RoleName">
                                    <label class="form-check-label text-sm" for="new-role-@r.RoleName">
                                        @r.RoleName
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-info rounded-pill px-4">Tạo nhân viên</button>
                </div>
            </form>
        </div>
    </div>
</div>
