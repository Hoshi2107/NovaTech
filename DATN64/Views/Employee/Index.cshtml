</div>

@* Form toggle status *@
<form id="toggleStatusForm" asp-action="ToggleStatus" method="post" style="display:none">
    <input type="hidden" name="id" id="toggleId">
</form>

@foreach (var cc in chamCongList)
{
    <!-- Modal Cập nhật Chấm công -->
    <div class="modal fade" id="editCcModal-@cc.Id" tabindex="-1" aria-labelledby="editCcModalLabel-@cc.Id" aria-hidden="true" data-bs-backdrop="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <form asp-action="UpdateChamCong" asp-controller="Employee" method="post" class="m-0">
                    <input type="hidden" name="id" value="@cc.Id" />
                    <div class="modal-header border-bottom border-light">
                        <h6 class="modal-title fw-bold text-dark" id="editCcModalLabel-@cc.Id">
                            <i class="fa-solid fa-clock text-primary me-2"></i>Sửa ca làm việc
                        </h6>
                        <button type="button" class="btn-close text-xs" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-start py-3">
                        <div class="mb-2.5">
                            <label class="form-label text-muted fw-semibold text-xs mb-1">Giờ vào thực tế</label>
                            <input type="datetime-local" name="gioVao" class="form-control form-control-sm" value="@(cc.GioVao?.ToString("yyyy-MM-ddTHH:mm") ?? cc.NgayCham.ToString("yyyy-MM-dd") + "T08:00")" required />
                        </div>
                        <div class="mb-2.5">
                            <label class="form-label text-dark fw-semibold text-xs mb-1">Nhập giờ ra thực tế</label>
                            <input type="datetime-local" name="gioRa" class="form-control form-control-sm" value="@(cc.GioRa?.ToString("yyyy-MM-ddTHH:mm") ?? cc.NgayCham.ToString("yyyy-MM-dd") + "T17:30")" required />
                        </div>
                        <div class="mb-0">
                            <label class="form-label text-muted fw-semibold text-xs mb-1">Ghi chú / Lý do sửa</label>
                            <textarea name="ghiChu" class="form-control form-control-sm" rows="2" placeholder="Ví dụ: Bổ sung giờ ra quên checkout">@cc.GhiChu</textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-top border-light py-2">
                        <button type="button" class="btn btn-secondary btn-xs rounded-pill" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary btn-xs rounded-pill px-3 fw-bold">Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

}

@section Scripts {
<script>
    // ─── Tab switching ───────────────────────────────────────────────
    function switchTab(tabName) {
        document.querySelectorAll('.hr-tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.hr-tab-btn').forEach(el => el.classList.remove('active'));
        document.getElementById('tab-' + tabName).classList.add('active');
        event.currentTarget.classList.add('active');
    }

    // ─── Employee search & pagination ─────────────────────────────────────────────
    let currentPage = 1;
    const itemsPerPage = 10;

    function renderTable() {
        const filter = document.getElementById('employeeSearch').value.toUpperCase();
        const rows = Array.from(document.querySelectorAll('#employeesTable tbody tr'));
        
        // Filter rows
        const filteredRows = rows.filter(row => {
            const txtValue = (row.cells[1]?.textContent || '') + ' ' +
                             (row.cells[2]?.textContent || '') + ' ' +
                             (row.cells[3]?.textContent || '');
            return txtValue.toUpperCase().includes(filter);
        });

        // Calculate pagination
        const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
        if (currentPage > totalPages) currentPage = Math.max(totalPages, 1);

        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;

        // Hide all, show paginated
        rows.forEach(row => row.style.display = 'none');
        filteredRows.slice(startIndex, endIndex).forEach(row => row.style.display = '');

        // Update info text
        const infoEl = document.getElementById('paginationInfo');
        if (infoEl) {
            infoEl.textContent = `Hiển thị ${filteredRows.length > 0 ? startIndex + 1 : 0} đến ${Math.min(endIndex, filteredRows.length)} trong tổng số ${filteredRows.length} nhân viên`;
        }
        
        // Update pagination buttons
        const ctrlEl = document.getElementById('paginationControls');
        if (!ctrlEl) return;
        let html = '';
        if (totalPages > 1) {
            html += `<button class="btn btn-sm btn-light border" onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}><i class="fa-solid fa-chevron-left"></i></button>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-light border'} fw-bold" onclick="changePage(${i})">${i}</button>`;
            }
            html += `<button class="btn btn-sm btn-light border" onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}><i class="fa-solid fa-chevron-right"></i></button>`;
        }
        ctrlEl.innerHTML = html;
    }

    function changePage(page) {
        currentPage = page;
        renderTable();
    }

    function filterEmployees() {
        currentPage = 1;
        renderTable();
    }

    // ─── Open edit modal ─────────────────────────────────────────────
    function openEditModal(id, hoTen, email, sdt, trangThai, roleIds, luongTheoGio) {
        document.getElementById('editMaNhanVien').value = id;
        document.getElementById('editHoTen').value = hoTen;
        document.getElementById('editEmail').value = email;
        document.getElementById('editSoDienThoai').value = sdt;
        document.getElementById('editTrangThai').value = trangThai;
        document.getElementById('editLuongTheoGio').value = luongTheoGio || '';

        var checkboxes = document.querySelectorAll('.edit-role-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = roleIds.includes(parseInt(cb.value));
        });

        new bootstrap.Modal(document.getElementById('editEmployeeModal')).show();
    }

    // ─── Toggle status ───────────────────────────────────────────────
    function toggleStatus(id, name, newStatus) {
        var action = newStatus === 'Bị khóa' ? 'VÔ HIỆU HÓA' : 'MỞ KHÓA';
        if (confirm('Bạn có chắc chắn muốn ' + action + ' tài khoản "' + name + '"?')) {
            document.getElementById('toggleId').value = id;
            document.getElementById('toggleStatusForm').submit();
        }
    }

    // ─── RBAC: select role ───────────────────────────────────────────
    var rolePermissionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        rolePermissions.GroupBy(rp => rp.RoleName).ToDictionary(g => g.Key, g => g.Select(x => x.PermissionName).ToList())
    ));
    var roleNamesMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        roles.ToDictionary(r => r.Id.ToString(), r => r.Name)
    ));

    function selectRole(roleId, roleName, roleDesc) {
        // Update active state
        document.querySelectorAll('.role-list-item').forEach(el => el.classList.remove('active'));
        document.getElementById('roleItem-' + roleId).classList.add('active');

        // Show panel
        document.getElementById('rbacPlaceholder').style.display = 'none';
        document.getElementById('rbacPermPanel').style.display = 'block';

        // Set roleId and name
        document.getElementById('rbacRoleId').value = roleId;
        document.getElementById('rbacRoleName').textContent = roleName;

        // Check existing permissions
        var existingPerms = rolePermissionsData[roleName] || [];
        document.querySelectorAll('.rbac-perm-cb').forEach(cb => {
            cb.checked = existingPerms.includes(cb.value);
        });
    }

    // ─── Init tooltips & pagination ──────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        renderTable();
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
    });
    // Also run immediately in case DOMContentLoaded already fired
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        renderTable();
    }
</script>
}
