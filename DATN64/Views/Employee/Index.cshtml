@model List<DATN64.Models.NhanVien>
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Quản lý nhân viên"; }
<div class="container my-5">
    <h2>Quản lý Nhân Viên</h2>
    <table class="table">
        <thead><tr><th>Mã NV</th><th>Họ Tên</th><th>Vai Trò</th><th>Email</th></tr></thead>
        <tbody>
            @foreach(var item in Model) {
                <tr><td>@item.MaNhanVien</td><td>@item.HoTen</td><td>@item.VaiTro</td><td>@item.Email</td></tr>
            }
        </tbody>
    </table>
</div>