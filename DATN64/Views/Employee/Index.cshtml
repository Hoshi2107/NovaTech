                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted">TRẠNG THÁI</label>
                            <select name="TrangThai" class="form-select form-select-sm">
                                <option value="Hoạt động">Hoạt động</option>
                                <option value="Bị khóa">Bị khóa</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label text-xs fw-bold text-muted d-block">VAI TRÒ (CHỌN NHIỀU)</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var r in roles)
                            {
                                <div class="form-check form-check-inline m-0 p-2 border rounded" style="background:#f8fafc;border-color:#e2e8f0 !important">
                                    <input class="form-check-input ms-1 me-2" type="checkbox" name="selectedRoleIds" value="@r.Id" id="addRole-@r.Id">
                                    <label class="form-check-label me-2" for="addRole-@r.Id" style="font-size:.83rem">@r.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="background:#f8fafc;border-top:1px solid #e2e8f0">
                    <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                        <i class="fa-solid fa-user-plus me-1"></i>Thêm nhân viên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


@* Modal sửa nhân viên *@
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true">
