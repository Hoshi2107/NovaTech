@model List<DATN64.Models.MockDataService.Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý sản phẩm";
    ViewData["BreadcrumbActive"] = "Sản phẩm";
    
    var categories = ViewBag.Categories as List<DATN64.Models.MockDataService.Category> ?? new();
    var brands = ViewBag.Brands as List<DATN64.Models.MockDataService.Brand> ?? new();
    var suppliers = ViewBag.Suppliers as List<DATN64.Models.MockDataService.Supplier> ?? new();
}

<div class="card card-glass p-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h4 class="fw-bold m-0"><i class="fa-solid fa-boxes-stacked text-cyan me-2"></i>Danh sách sản phẩm</h4>
        
        @if (AuthHelper.HasPermission(Context, "Create_Product"))
        {
            <button class="btn btn-info rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createProductModal">
                <i class="fa-solid fa-plus me-2"></i>Thêm sản phẩm mới
            </button>
        }
    </div>

    <!-- Filter Form -->
    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm theo tên hoặc SKU..." value="@Context.Request.Query["search"]">
        </div>
        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">-- Tất cả danh mục --</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Name" selected="@(Context.Request.Query["category"] == c.Name)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="brand" class="form-select">
                <option value="">-- Tất cả thương hiệu --</option>
                @foreach (var b in brands)
                {
                    <option value="@b.Name" selected="@(Context.Request.Query["brand"] == b.Name)">@b.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-info w-100 rounded-pill"><i class="fa-solid fa-filter me-2"></i>Lọc</button>
        </div>
    </form>

    <!-- Product Table -->
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 text-sm align-middle">
            <thead>
                <tr>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>SKU</th>
                    <th>Phân loại</th>
                    <th>Giá bán</th>
                    <th>Tồn kho</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <img src="@p.Image" class="rounded-3" style="width: 45px; height: 45px; object-fit: cover;">
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@p.Name</div>
                            <span class="text-xxs text-muted">Hãng: @p.Brand</span>
                        </td>
                        <td><code>@p.SKU</code></td>
                        <td>@p.Category</td>
                        <td class="text-primary fw-bold">
                            @if (p.DiscountExpiry.HasValue && p.DiscountExpiry.Value > DateTime.Now)
                            {
                                <span class="text-danger">@p.Price.ToString("N0") đ</span>
                                <div class="text-xxs text-muted-custom text-decoration-line-through">@p.OriginalPrice.ToString("N0") đ</div>
                            }
                            else
                            {
                                <span>@p.Price.ToString("N0") đ</span>
                            }
                        </td>
                        <td>
                            @if (p.Stock <= 3)
                            {
                                <span class="badge bg-danger">@p.Stock (Ít hàng)</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@p.Stock</span>
                            }
                        </td>
                        <td>
                            @if (p.Status == "Đang bán")
                            {
                                <span class="badge bg-success-subtle text-success border border-success border-opacity-25 rounded-pill px-2.5">@p.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger border-opacity-25 rounded-pill px-2.5">@p.Status</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#erpDetail-@p.Id" title="Xem chi tiết"><i class="fa-solid fa-eye"></i></button>
                                
                                @if (AuthHelper.HasPermission(Context, "Edit_Product"))
                                {
                                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#discountModal-@p.Id" title="Cấu hình giảm giá Flash Sale"><i class="fa-solid fa-tags"></i></button>
                                    <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#editModal-@p.Id" title="Sửa sản phẩm"><i class="fa-solid fa-pen"></i></button>
                                }
                                
                                @if (AuthHelper.HasPermission(Context, "Delete_Product"))
                                {
                                    <form method="post" action="@Url.Action("Delete", "Product")" class="d-inline" onsubmit="return confirm('Bạn thực sự muốn xóa sản phẩm này?');">
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa sản phẩm"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>

                    <!-- Collapsible Inline Details Row -->
                    <tr id="erpDetail-@p.Id" class="collapse">
                        <td colspan="8" class="p-0">
                            <div class="p-4 bg-light border-bottom border-top" style="color: #0f172a;">
                                <div class="row g-4">
                                    <div class="col-md-3 text-center">
                                        <img src="@p.Image" class="img-fluid rounded border border-light shadow-sm" style="max-height: 180px; object-fit: cover;">
                                    </div>
                                    <div class="col-md-9">
                                        <h5 class="fw-bold text-dark mb-3">@p.Name</h5>
                                        <div class="row g-3 text-xs">
                                            <div class="col-md-4"><strong>SKU:</strong> <code>@p.SKU</code></div>
                                            <div class="col-md-4"><strong>Barcode:</strong> @p.Barcode</div>
                                            <div class="col-md-4"><strong>Hãng sản xuất:</strong> @p.Brand</div>
                                            <div class="col-md-4"><strong>Danh mục:</strong> @p.Category</div>
                                            <div class="col-md-4"><strong>Nhà cung cấp:</strong> @p.Supplier</div>
                                            <div class="col-md-4"><strong>Tồn kho:</strong> @p.Stock chiếc</div>
                                            <div class="col-md-4"><strong>Giá nhập:</strong> <span class="fw-bold">@p.ImportPrice.ToString("N0") đ</span></div>
                                            <div class="col-md-4">
                                                <strong>Giá bán:</strong> 
                                                <span class="fw-bold text-primary">@p.Price.ToString("N0") đ</span>
                                                @if (p.DiscountExpiry.HasValue && p.DiscountExpiry.Value > DateTime.Now)
                                                {
                                                    <span class="text-xxs text-muted text-decoration-line-through ms-1">(@p.OriginalPrice.ToString("N0") đ)</span>
                                                }
                                            </div>
                                            <div class="col-md-4">
                                                <strong>Flash Sale:</strong> 
                                                @if (p.DiscountExpiry.HasValue && p.DiscountExpiry.Value > DateTime.Now)
                                                {
                                                    <span class="badge bg-danger">Đang giảm @p.DiscountRate% (Hết hạn lúc: @p.DiscountExpiry.Value.ToString("HH:mm dd/MM"))</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Không áp dụng</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="mt-3 text-xs">
                                            <strong>Thông số kỹ thuật:</strong>
                                            <div class="p-2 bg-white rounded border border-light mt-1 text-muted" style="white-space: pre-line;">@p.Specifications</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@p.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content bg-white border border-light shadow text-dark">
                                <form method="post" action="@Url.Action("Edit", "Product")">
                                    <input type="hidden" name="Id" value="@p.Id" />
                                    <div class="modal-header border-bottom border-light">
                                        <h5 class="modal-title fw-bold text-dark">Sửa sản phẩm: @p.Name</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-xs">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Tên sản phẩm</label>
                                                <input type="text" name="Name" class="form-control" value="@p.Name" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">SKU</label>
                                                <input type="text" name="SKU" class="form-control" value="@p.SKU" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Barcode</label>
                                                <input type="text" name="Barcode" class="form-control" value="@p.Barcode">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Phân loại danh mục</label>
                                                <select name="Category" class="form-select">
                                                    @foreach (var c in categories)
                                                    {
                                                        <option value="@c.Name" selected="@(p.Category == c.Name)">@c.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Thương hiệu</label>
                                                <select name="Brand" class="form-select">
                                                    @foreach (var b in brands)
                                                    {
                                                        <option value="@b.Name" selected="@(p.Brand == b.Name)">@b.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Nhà cung cấp</label>
                                                <select name="Supplier" class="form-select">
                                                    @foreach (var s in suppliers)
                                                    {
                                                        <option value="@s.Name" selected="@(p.Supplier == s.Name)">@s.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Giá nhập</label>
                                                <input type="number" name="ImportPrice" class="form-control" value="@p.ImportPrice" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Giá bán</label>
                                                <input type="number" name="Price" class="form-control" value="@p.Price" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Tồn kho</label>
                                                <input type="number" name="Stock" class="form-control" value="@p.Stock" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-secondary fw-semibold">Trạng thái bán</label>
                                                <select name="Status" class="form-select">
                                                    <option value="Đang bán" selected="@(p.Status == "Đang bán")">Đang bán</option>
                                                    <option value="Ngừng bán" selected="@(p.Status == "Ngừng bán")">Ngừng bán</option>
                                                    <option value="Hết hàng" selected="@(p.Status == "Hết hàng")">Hết hàng</option>
                                                </select>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label text-secondary fw-semibold">Đường dẫn ảnh chính (URL)</label>
                                                <input type="text" name="Image" class="form-control" value="@p.Image">
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label text-secondary fw-semibold">Thông số kỹ thuật</label>
                                                <textarea name="Specifications" rows="3" class="form-control">@p.Specifications</textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top border-light">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Đóng</button>
                                        <button type="submit" class="btn btn-info rounded-pill px-4">Lưu thay đổi</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Discount Configuration Modal -->
                    <div class="modal fade" id="discountModal-@p.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content bg-white border border-light shadow text-dark">
                                <div class="modal-header border-bottom border-light">
                                    <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-tags text-danger me-2"></i>Cấu hình giảm giá: @p.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <form method="post" action="@Url.Action("UpdateDiscount", "Product")">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <div class="modal-body text-xs">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-secondary">Giá bán gốc hiện tại</label>
                                            <div class="form-control bg-light border border-light text-dark fw-semibold">
                                                @p.Price.ToString("N0") đ
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-secondary">Giá bán sau khi giảm (đ)</label>
                                            <input type="number" name="discountPrice" class="form-control" placeholder="Nhập giá giảm..." required min="1" max="@(p.Price - 1)" value="@(p.DiscountExpiry.HasValue ? p.Price : "")">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-secondary">Thời gian áp dụng giảm giá (giờ)</label>
                                            <input type="number" name="hours" class="form-control" placeholder="Nhập số giờ (ví dụ: 24, 48...)" required min="1" max="1000" value="24">
                                        </div>
                                        @if (p.DiscountExpiry.HasValue)
                                        {
                                            <div class="alert alert-warning text-xxs p-2 mb-0">
                                                Sản phẩm này đang được giảm giá. Bạn có thể xóa giảm giá bằng cách đặt Giá bán sau khi giảm là 0 và Thời gian là 0.
                                            </div>
                                        }
                                    </div>
                                    <div class="modal-footer border-top border-light">
                                        <button type="submit" name="discountPrice" value="0" class="btn btn-outline-secondary btn-sm rounded-pill" onclick="this.form.hours.value=0;">Xóa giảm giá</button>
                                        <button type="submit" class="btn btn-danger btn-sm rounded-pill px-4">Lưu cấu hình</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal [NEW] -->
<div class="modal fade" id="createProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-white border border-light shadow text-dark">
            <form method="post" action="@Url.Action("Create", "Product")">
                <div class="modal-header border-bottom border-light">
                    <h5 class="modal-title fw-bold text-dark">Thêm sản phẩm mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-xs">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Tên sản phẩm</label>
                            <input type="text" name="Name" class="form-control" required placeholder="Ví dụ: iPhone 15 Plus">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">SKU</label>
                            <input type="text" name="SKU" class="form-control" required placeholder="IPHONE15P-128">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Barcode</label>
                            <input type="text" name="Barcode" class="form-control" placeholder="893...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Phân loại danh mục</label>
                            <select name="Category" class="form-select">
                                @foreach (var c in categories)
                                {
                                    <option value="@c.Name">@c.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Thương hiệu</label>
                            <select name="Brand" class="form-select">
                                @foreach (var b in brands)
                                {
                                    <option value="@b.Name">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Nhà cung cấp</label>
                            <select name="Supplier" class="form-select">
                                @foreach (var s in suppliers)
                                {
                                    <option value="@s.Name">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Giá nhập</label>
                            <input type="number" name="ImportPrice" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Giá bán</label>
                            <input type="number" name="Price" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Tồn kho ban đầu</label>
                            <input type="number" name="Stock" class="form-control" required value="10">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary fw-semibold">Trạng thái bán</label>
                            <select name="Status" class="form-select">
                                <option value="Đang bán">Đang bán</option>
                                <option value="Ngừng bán">Ngừng bán</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary fw-semibold">Đường dẫn ảnh chính (URL)</label>
                            <input type="text" name="Image" class="form-control" placeholder="https://unsplash.com/...">
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary fw-semibold">Thông số kỹ thuật</label>
                            <textarea name="Specifications" rows="3" class="form-control" placeholder="Nhập cấu hình phần cứng..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-light">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-info rounded-pill px-4">Tạo sản phẩm</button>
                </div>
            </form>
        </div>
    </div>
</div>
