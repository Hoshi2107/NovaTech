@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý danh mục";
}

<div id="app" class="container-fluid animate-fade-in" v-cloak>
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-gradient mb-0"><i class="fa-solid fa-list me-2"></i>Quản lý danh mục</h2>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <button class="btn btn-primary rounded-pill px-4 shadow-sm" @@click="openModal('create')">
                <i class="fa-solid fa-plus me-2"></i>Thêm danh mục
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-glass">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" v-model="search" placeholder="Tên danh mục..." @@keyup.enter="fetchData">
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-primary w-100 rounded-3" @@click="fetchData">
                        <i class="fa-solid fa-filter me-2"></i>Tìm kiếm
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-glass">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 text-muted-custom text-xs fw-bold text-uppercase">Mã DM</th>
                        <th class="px-4 py-3 text-muted-custom text-xs fw-bold text-uppercase">Tên danh mục</th>
                        <th class="px-4 py-3 text-muted-custom text-xs fw-bold text-uppercase">Mô tả</th>
                        <th class="px-4 py-3 text-muted-custom text-xs fw-bold text-uppercase text-end">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-if="loading">
                        <td colspan="4" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </td>
                    </tr>
                    <tr v-else-if="items.length === 0">
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-list fs-1 mb-3 text-opacity-50"></i>
                            <p class="mb-0">Không tìm thấy dữ liệu!</p>
                        </td>
                    </tr>
                    <tr v-else v-for="item in pagedItems" :key="item.maDanhMuc" class="group-hover">
                        <td class="px-4 fw-medium text-secondary">#${item.maDanhMuc}</td>
                        <td class="px-4 fw-bold">${item.tenDanhMuc}</td>
                        <td class="px-4">${item.moTa || 'Không có mô tả'}</td>
                        <td class="px-4 text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm" @@click="openModal('edit', item)" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm" @@click="deleteItem(item.maDanhMuc)" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-3 px-1" v-if="!loading && items.length > 0">
        <div class="text-muted text-sm">
            Hiển thị <strong>${(currentPage - 1) * pageSize + 1}</strong> – <strong>${Math.min(currentPage * pageSize, items.length)}</strong> / <strong>${items.length}</strong> danh mục
        </div>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item" :class="{ disabled: currentPage === 1 }">
                    <a class="page-link rounded-start-3" href="#" @@click.prevent="currentPage--">&laquo;</a>
                </li>
                <li class="page-item" v-for="p in totalPages" :key="p" :class="{ active: p === currentPage }">
                    <a class="page-link" href="#" @@click.prevent="currentPage = p">${p}</a>
                </li>
                <li class="page-item" :class="{ disabled: currentPage === totalPages }">
                    <a class="page-link rounded-end-3" href="#" @@click.prevent="currentPage++">&raquo;</a>
                </li>
            </ul>
        </nav>
    </div>

    <!-- Modal Form -->
    <div class="modal fade" id="dataModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">${modalMode === 'create' ? 'Thêm Danh Mục' : 'Cập Nhật Danh Mục'}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form @@submit.prevent="saveItem">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-medium">Tên danh mục <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" v-model="currentItem.tenDanhMuc" required>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-medium">Mô tả</label>
                                <textarea class="form-control" v-model="currentItem.moTa" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="text-end mt-4">
                            <button type="button" class="btn btn-light rounded-pill px-4 me-2" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm" :disabled="saving">
                                <span v-if="saving" class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                ${modalMode === 'create' ? 'Tạo mới' : 'Lưu thay đổi'}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        [v-cloak] { display: none; }
        .text-gradient { background: linear-gradient(45deg, #4e73df, #224abe); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .bg-glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .group-hover:hover { background-color: rgba(78, 115, 223, 0.05) !important; transition: all 0.2s ease-in-out; }
    </style>

    <script>
        var app = new Vue({
            el: '#app',
            delimiters: ['${', '}'],
            data: {
                items: [],
                loading: false,
                saving: false,
                search: '',
                modalMode: 'create',
                currentItem: {},
                modalInstance: null,
                currentPage: 1,
                pageSize: 10
            },
            computed: {
                totalPages() {
                    return Math.max(1, Math.ceil(this.items.length / this.pageSize));
                },
                pagedItems() {
                    const start = (this.currentPage - 1) * this.pageSize;
                    return this.items.slice(start, start + this.pageSize);
                }
            },
            mounted() {
                const modalEl = document.getElementById('dataModal');
                document.body.appendChild(modalEl);
                this.modalInstance = new bootstrap.Modal(modalEl);
                this.fetchData();
            },
            methods: {
                async fetchData() {
                    this.loading = true;
                    this.currentPage = 1;
                    try {
                        const params = {};
                        if (this.search) params.search = this.search;
                        const res = await axios.get('/api/product/categories', { params });
                        this.items = res.data;
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể tải dữ liệu!', 'error');
                    } finally {
                        this.loading = false;
                    }
                },
                openModal(mode, item = null) {
                    this.modalMode = mode;
                    if (mode === 'create') {
                        this.currentItem = { tenDanhMuc: '', moTa: '' };
                    } else {
                        this.currentItem = { ...item };
                    }
                    this.modalInstance.show();
                },
                async saveItem() {
                    this.saving = true;
                    try {
                        if (this.modalMode === 'create') {
                            await axios.post('/api/product/categories', this.currentItem);
                        } else {
                            await axios.put(`/api/product/categories/${this.currentItem.maDanhMuc}`, this.currentItem);
                        }
                        this.modalInstance.hide();
                        setTimeout(() => {
                            Swal.fire('Thành công', 'Lưu dữ liệu thành công!', 'success');
                            this.fetchData();
                        }, 300);
                    } catch (err) {
                        this.modalInstance.hide();
                        setTimeout(() => { Swal.fire('Lỗi', 'Có lỗi xảy ra khi lưu!', 'error'); }, 300);
                    } finally {
                        this.saving = false;
                    }
                },
                async deleteItem(id) {
                    const result = await Swal.fire({
                        title: 'Bạn có chắc chắn?',
                        text: "Hành động xóa (vô hiệu hóa) không thể hoàn tác, có thể ảnh hưởng đến sản phẩm liên quan!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Vâng, xóa luôn!',
                        cancelButtonText: 'Hủy'
                    });
                    if (result.isConfirmed) {
                        try {
                            await axios.delete(`/api/product/categories/${id}`);
                            Swal.fire('Đã xóa!', 'Danh mục đã bị vô hiệu hóa/xóa khỏi hệ thống.', 'success');
                            this.fetchData();
                        } catch (err) {
                            Swal.fire('Lỗi', 'Không thể xóa danh mục này (có thể do đang có sản phẩm thuộc danh mục).', 'error');
                        }
                    }
                }
            }
        });
    </script>
}
