@model DATN64.Models.ViewModels.AccountingDashboardViewModel
@using DATN64.Helpers
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Tài chính & Kế toán";
    ViewData["BreadcrumbActive"] = "Kế toán";
    
    // Serialize data for Cash Flow Chart
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(Model.CashFlowChartData.Select(x => x.NgayLabel).ToList());
    var chartThu = System.Text.Json.JsonSerializer.Serialize(Model.CashFlowChartData.Select(x => x.Thu).ToList());
    var chartChi = System.Text.Json.JsonSerializer.Serialize(Model.CashFlowChartData.Select(x => x.Chi).ToList());

    // Serialize data for Monthly P&L Chart
    var plLabels = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyPLChartData.Select(x => x.ThangLabel).ToList());
    var plDoanhThu = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyPLChartData.Select(x => x.DoanhThu).ToList());
    var plGiaVon = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyPLChartData.Select(x => x.GiaVon).ToList());
    var plLoiNhuan = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyPLChartData.Select(x => x.LoiNhuan).ToList());

    // Serialize data for Revenue Channel Chart
    var channelLabels = System.Text.Json.JsonSerializer.Serialize(Model.RevenueByChannel.Select(x => x.TenKenh).ToList());
    var channelData = System.Text.Json.JsonSerializer.Serialize(Model.RevenueByChannel.Select(x => x.DoanhThu).ToList());
    var channelColors = System.Text.Json.JsonSerializer.Serialize(Model.RevenueByChannel.Select(x => x.MauSac).ToList());
}

@section Styles {
<style>
    .kpi-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.09); }
    .kpi-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
    }
    .kpi-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: #64748b; }
    .kpi-value { font-size: 1.5rem; font-weight: 700; color: #1e293b; line-height: 1.2; margin-top: 4px; }
    
    /* Tabs customization */
    .nav-tabs-custom {
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 24px;
    }
    .nav-tabs-custom .nav-link {
        border: none;
        color: #64748b;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 10px 20px;
        position: relative;
        background: transparent;
        transition: color 0.2s;
    }
    .nav-tabs-custom .nav-link:hover {
        color: #0ea5e9;
    }
    .nav-tabs-custom .nav-link.active {
        color: #0284c7;
        background: transparent;
    }
    .nav-tabs-custom .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 2px;
        background-color: #0284c7;
        border-radius: 2px;
    }
    .card-glass {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 16px;
    }
</style>
}

<!-- Page Header -->
<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h3 class="fw-bold mb-1" style="color:#1e293b">
                <i class="fa-solid fa-scale-balanced text-primary me-2"></i>Tài chính & Sổ quỹ Kế toán
            </h3>
            <p class="text-muted text-xs mb-0">Quản lý dòng tiền mặt/chuyển khoản, theo dõi công nợ nhà cung cấp gối đầu và báo cáo P&L.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm rounded-pill px-3.5" data-bs-toggle="modal" data-bs-target="#createTransactionModal">
                <i class="fa-solid fa-file-invoice-dollar me-1.5"></i>Lập phiếu thu/chi
            </button>
        </div>
    </div>
</div>

<!-- KPI Summary Section -->
<div class="row g-3 mb-4">
    <!-- Tổng Thu -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="kpi-card">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#f0fdf4;">
                    <i class="fa-solid fa-arrow-trend-up" style="color:#16a34a"></i>
                </div>
                <div>
                    <div class="kpi-label">Tổng dòng tiền thu</div>
                    <div class="kpi-value text-success">@Model.TongThu.ToString("N0")₫</div>
                </div>
            </div>
        </div>
    </div>
    <!-- Tổng Chi -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="kpi-card">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#fef2f2;">
                    <i class="fa-solid fa-arrow-trend-down" style="color:#dc2626"></i>
                </div>
                <div>
                    <div class="kpi-label">Tổng dòng tiền chi</div>
                    <div class="kpi-value text-danger">@Model.TongChi.ToString("N0")₫</div>
                </div>
            </div>
        </div>
    </div>
    <!-- Số Dư Quỹ -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="kpi-card">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#eff6ff;">
                    <i class="fa-solid fa-wallet" style="color:#2563eb"></i>
                </div>
                <div>
                    <div class="kpi-label">Số dư quỹ hiện tại</div>
                    <div class="kpi-value text-primary">@Model.SoDuQuy.ToString("N0")₫</div>
                </div>
            </div>
        </div>
    </div>
    <!-- Công nợ NCC -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="kpi-card">
            <div class="d-flex align-items-center gap-3">
                <div class="kpi-icon" style="background:#faf5ff;">
                    <i class="fa-solid fa-handshake" style="color:#7c3aed"></i>
                </div>
                <div>
                    <div class="kpi-label">Nợ cần trả NCC</div>
                    <div class="kpi-value" style="color: #7c3aed;">@Model.TongNoNCC.ToString("N0")₫</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabbed Workspace -->
<div class="card card-glass p-4 border border-opacity-10">
    <nav class="nav nav-tabs nav-tabs-custom" id="accountingTabs" role="tablist">
        <button class="nav-link active" id="soquy-tab" data-bs-toggle="tab" data-bs-target="#soquy" type="button" role="tab" aria-controls="soquy" aria-selected="true">
            <i class="fa-solid fa-book me-1.5"></i>Sổ quỹ tiền mặt & ngân hàng
        </button>
        <button class="nav-link" id="kenh-tab" data-bs-toggle="tab" data-bs-target="#kenh" type="button" role="tab" aria-controls="kenh" aria-selected="false">
            <i class="fa-solid fa-chart-pie me-1.5"></i>Phân tích kênh bán hàng
        </button>
        <button class="nav-link" id="congno-tab" data-bs-toggle="tab" data-bs-target="#congno" type="button" role="tab" aria-controls="congno" aria-selected="false">
            <i class="fa-solid fa-truck-ramp-box me-1.5"></i>Nợ phải trả nhà cung cấp
        </button>
        <button class="nav-link" id="baocao-tab" data-bs-toggle="tab" data-bs-target="#baocao" type="button" role="tab" aria-controls="baocao" aria-selected="false">
            <i class="fa-solid fa-chart-simple me-1.5"></i>Báo cáo kết quả kinh doanh (P&L)
        </button>
    </nav>

    <div class="tab-content" id="accountingTabsContent">

        <!-- Tab: Phân tích kênh bán hàng -->
        <div class="tab-pane fade" id="kenh" role="tabpanel" aria-labelledby="kenh-tab">
            <div class="row g-4">
                <!-- Left: Donut Chart -->
                <div class="col-12 col-lg-5">
                    <div class="card border p-4 h-100 text-center">
                        <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Tỷ trọng doanh thu theo kênh</h6>
                        <div style="position:relative; height:280px; max-width:280px; margin:0 auto;">
                            <canvas id="channelDonutChart"></canvas>
                        </div>
                        <p class="text-muted text-xs mt-3 mb-0">Doanh thu từ đơn hàng <strong>Hoàn thành</strong> trong kỳ lọc</p>
                    </div>
                </div>
                <!-- Right: Channel Cards -->
                <div class="col-12 col-lg-7">
                    <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-layer-group text-success me-2"></i>Chi tiết doanh thu từng kênh</h6>
                    @{
                        var total = Model.RevenueByChannel.Sum(x => x.DoanhThu);
                    }
                    @foreach (var kenh in Model.RevenueByChannel)
                    {
                        var pct = total > 0 ? (double)kenh.DoanhThu / (double)total * 100 : 0;
                        <div class="card border mb-3 p-3" style="border-left: 4px solid @kenh.MauSac !important;">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="kpi-icon" style="background: @kenh.MauSac + '18'; width:44px; height:44px;">
                                        <i class="@kenh.Icon" style="color:@kenh.MauSac; font-size:1.1rem;"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark" style="font-size:0.95rem;">@kenh.TenKenh</div>
                                        <div class="text-muted text-xs">@kenh.SoDonHang đơn hoàn thành</div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold" style="font-size:1.2rem; color:@kenh.MauSac;">@kenh.DoanhThu.ToString("N0")₫</div>
                                    <div class="text-muted text-xs">@pct.ToString("F1")% tổng doanh thu</div>
                                </div>
                            </div>
                            <div class="progress mt-3" style="height:6px; border-radius:4px; background:#f1f5f9;">
                                <div class="progress-bar" role="progressbar" 
                                     style="width: @pct.ToString("F1")%; background: @kenh.MauSac; border-radius:4px;"
                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }

                    @if (!Model.RevenueByChannel.Any() || Model.RevenueByChannel.All(x => x.DoanhThu == 0))
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fa-solid fa-chart-pie fa-2x mb-2 d-block opacity-25"></i>
                            Chưa có đơn hàng hoàn thành trong kỳ này.
                        </div>
                    }
                </div>
            </div>

            <!-- So sánh P&L theo kênh -->
            <div class="card border mt-4 p-4">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-table-columns text-info me-2"></i>Bảng so sánh doanh thu theo kênh (trong kỳ lọc)</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-sm">
                        <thead class="table-light">
                            <tr class="text-xs text-muted">
                                <th>Kênh bán hàng</th>
                                <th>Số đơn HT</th>
                                <th>Doanh thu</th>
                                <th>Tỷ trọng</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kenh in Model.RevenueByChannel)
                            {
                                var p = total > 0 ? (double)kenh.DoanhThu / (double)total * 100 : 0;
                                <tr>
                                    <td>
                                        <span class="d-flex align-items-center gap-2">
                                            <i class="@kenh.Icon" style="color:@kenh.MauSac;"></i>
                                            <strong>@kenh.TenKenh</strong>
                                        </span>
                                    </td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-dark">@kenh.SoDonHang đơn</span></td>
                                    <td class="fw-bold" style="color:@kenh.MauSac;">@kenh.DoanhThu.ToString("N0")₫</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:8px;">
                                                <div class="progress-bar" style="width:@p.ToString("F1")%; background:@kenh.MauSac;"></div>
                                            </div>
                                            <span class="text-xs fw-semibold">@p.ToString("F1")%</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (kenh.DoanhThu > 0)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success text-xs"><i class="fa-solid fa-circle-check me-1"></i>Có doanh thu</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary bg-opacity-10 text-muted text-xs">Chưa có</span>
                                        }
                                    </td>
                                </tr>
                            }
                            <tr class="table-light fw-bold">
                                <td>TỔNG CỘNG</td>
                                <td>@Model.RevenueByChannel.Sum(x => x.SoDonHang) đơn</td>
                                <td class="text-success">@total.ToString("N0")₫</td>
                                <td>100%</td>
                                <td>—</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab 1: Sổ Quỹ -->

        <div class="tab-pane fade show active" id="soquy" role="tabpanel" aria-labelledby="soquy-tab">
            <form method="get" class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label class="form-label text-xs fw-semibold text-muted">Từ ngày</label>
                    <input type="date" name="tuNgay" class="form-control text-sm" value="@Model.TuNgay?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label text-xs fw-semibold text-muted">Đến ngày</label>
                    <input type="date" name="denNgay" class="form-control text-sm" value="@Model.DenNgay?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-12 col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-info w-100 text-sm fw-semibold"><i class="fa-solid fa-filter me-1.5"></i>Lọc dữ liệu</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle" id="soquyTable">
                    <thead class="table-light">
                        <tr class="text-xs text-muted-custom">
                            <th>Mã GD</th>
                            <th>Ngày thực hiện</th>
                            <th>Loại</th>
                            <th>Nhóm khoản mục</th>
                            <th>Số tiền</th>
                            <th>Đối tượng</th>
                            <th>Phương thức</th>
                            <th>Ghi chú</th>
                            <th>Người lập</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm" id="soquyTableBody">
                        @if (!Model.GiaoDichs.Any())
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted py-4">Chưa có bản ghi giao dịch thu chi nào trong thời gian này.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var gd in Model.GiaoDichs)
                            {
                                var isVoided = gd.TrangThai == "Đã hủy";
                                <tr class="sq-row @(isVoided ? "opacity-50" : "")">
                                    <td class="fw-bold @(isVoided ? "text-muted text-decoration-line-through" : "text-cyan")">@gd.MaGiaoDich</td>
                                    <td>@gd.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @(gd.LoaiGiaoDich == "Thu" ? "bg-success bg-opacity-10 text-success" : "bg-danger bg-opacity-10 text-danger") px-2 py-1 text-xs">
                                            @(gd.LoaiGiaoDich == "Thu" ? "Thu tiền (+)" : "Chi tiền (-)")
                                        </span>
                                    </td>
                                    <td class="fw-medium">@gd.NhomGiaoDich</td>
                                    <td class="fw-bold @(isVoided ? "text-muted text-decoration-line-through" : (gd.LoaiGiaoDich == "Thu" ? "text-success" : "text-danger"))">
                                        @(gd.LoaiGiaoDich == "Thu" ? "+" : "-")@gd.SoTien.ToString("N0")₫
                                    </td>
                                    <td>@gd.DoiTuongGiaoDich</td>
                                    <td>
                                        <span class="badge bg-secondary bg-opacity-10 text-dark text-xxs">@gd.PhuongThucThanhToan</span>
                                    </td>
                                    <td class="text-muted text-xs" style="max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@gd.GhiChu</td>
                                    <td>@gd.NhanVien?.HoTen</td>
                                    <td>
                                        @if (isVoided)
                                        {
                                            <span class="badge bg-secondary text-xs"><i class="fa-solid fa-ban me-1"></i>Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success text-xs"><i class="fa-solid fa-circle-check me-1"></i>Hợp lệ</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-outline-info btn-xs px-2 rounded-pill btn-sq-detail"
                                                    data-id="@gd.Id"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#soQuyDetailModal">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                            @if (!isVoided)
                                            {
                                                <button class="btn btn-outline-danger btn-xs px-2 rounded-pill btn-void-phieu"
                                                        data-id="@gd.Id"
                                                        data-ma="@gd.MaGiaoDich"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#voidTransactionModal">
                                                    <i class="fa-solid fa-ban"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- Soquy Pagination -->
            <div class="d-flex justify-content-between align-items-center mt-3" id="soquyPaginationWrapper">
                <div class="text-muted small" id="soquyPageInfo"></div>
                <nav><ul class="pagination pagination-sm mb-0" id="soquyPagination"></ul></nav>
            </div>
        </div>

        <!-- Tab 2: Công nợ Nhà cung cấp -->
        <div class="tab-pane fade" id="congno" role="tabpanel" aria-labelledby="congno-tab">
            <!-- Filter Bar -->
            <div class="row g-2 mb-4 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label text-xs fw-semibold text-muted">Lọc theo Nhà cung cấp</label>
                    <input type="text" id="filterNCC" class="form-control text-sm" placeholder="Tìm tên NCC...">
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label text-xs fw-semibold text-muted">Trạng thái nợ</label>
                    <select id="filterTrangThai" class="form-select text-sm">
                        <option value="">Tất cả trạng thái</option>
                        <option value="ChuaThanhToan">Chưa thanh toán</option>
                        <option value="ThanhToanMotPhan">Thanh toán một phần</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button id="btnResetFilter" class="btn btn-outline-secondary w-100 text-sm"><i class="fa-solid fa-rotate me-1"></i>Reset</button>
                </div>
            </div>

            <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-circle-info me-2 text-primary"></i>Tổng quan nợ theo Nhà cung cấp</h5>
            <div class="table-responsive mb-5">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr class="text-xs text-muted-custom">
                            <th>Nhà cung cấp</th>
                            <th>Số điện thoại</th>
                            <th>Tổng mua nhập</th>
                            <th>Đã thanh toán</th>
                            <th>Còn nợ NCC</th>
                            <th>Số hóa đơn còn nợ</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm" id="nccSummaryBody">
                        @if (!Model.CongNoSummaries.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Tuyệt vời! Hiện tại không nợ nhà cung cấp nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var ncc in Model.CongNoSummaries)
                            {
                                <tr class="ncc-row" data-ten="@ncc.TenNCC.ToLower()">
                                    <td class="fw-bold">@ncc.TenNCC</td>
                                    <td>@ncc.SoDienThoai</td>
                                    <td>@ncc.TongNo.ToString("N0")₫</td>
                                    <td class="text-success">@ncc.DaThanhToan.ToString("N0")₫</td>
                                    <td class="text-danger fw-bold">@ncc.ConNo.ToString("N0")₫</td>
                                    <td><span class="badge bg-warning text-dark">@ncc.SoPhieuNoActive phiếu nợ</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-receipt me-2 text-danger"></i>Chi tiết các hóa đơn chưa trả hết nợ</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr class="text-xs text-muted-custom">
                            <th>ID nợ</th>
                            <th>Nhà cung cấp</th>
                            <th>Phiếu nhập</th>
                            <th>Ngày nhập hàng</th>
                            <th>Tổng tiền</th>
                            <th>Đã trả</th>
                            <th>Còn nợ</th>
                            <th>Hạn trả nợ</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm" id="congnoTableBody">
                        @if (!Model.ChiTietCongNos.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">Không có hóa đơn nợ hoạt động.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var cn in Model.ChiTietCongNos)
                            {
                                var conNo = cn.TongTien - cn.DaThanhToan;
                                <tr class="cn-row" data-ten="@(cn.NhaCungCap?.TenNCC ?? "").ToLower()" data-trangthai="@cn.TrangThai">
                                    <td>#@cn.Id</td>
                                    <td class="fw-medium">@cn.NhaCungCap?.TenNCC</td>
                                    <td><span class="badge bg-secondary bg-opacity-20 text-dark">PN-@cn.MaPhieuNhap.ToString("D5")</span></td>
                                    <td>@cn.NgayTao.ToString("dd/MM/yyyy")</td>
                                    <td class="fw-bold">@cn.TongTien.ToString("N0")₫</td>
                                    <td class="text-success">@cn.DaThanhToan.ToString("N0")₫</td>
                                    <td class="text-danger fw-bold">@conNo.ToString("N0")₫</td>
                                    <td class="@(cn.HanThanhToan < DateTime.Today ? "text-danger fw-bold" : "")">
                                        @cn.HanThanhToan?.ToString("dd/MM/yyyy")
                                        @if (cn.HanThanhToan < DateTime.Today)
                                        {
                                            <span class="d-block text-xxs text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Quá hạn</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(cn.TrangThai == "ChuaThanhToan" ? "bg-danger bg-opacity-10 text-danger" : "bg-warning bg-opacity-10 text-dark") text-xs">
                                            @(cn.TrangThai == "ChuaThanhToan" ? "Chưa thanh toán" : "Thanh toán một phần")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-nowrap">
                                            <button class="btn btn-outline-primary btn-xs px-2 rounded-pill btn-cn-detail"
                                                    data-id="@cn.Id"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#congNoDetailModal">
                                                <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                            </button>
                                            <button class="btn btn-success btn-xs px-2 rounded-pill btn-pay-debt"
                                                    data-id="@cn.Id"
                                                    data-ncc="@cn.NhaCungCap?.TenNCC"
                                                    data-conno="@conNo"
                                                    data-phieunhap="PN-@cn.MaPhieuNhap.ToString("D5")"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#paySupplierDebtModal">
                                                <i class="fa-solid fa-money-bill-wave me-1"></i>Trả nợ
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- CongNo Pagination -->
            <div class="d-flex justify-content-between align-items-center mt-3" id="congnoPaginationWrapper">
                <div class="text-muted small" id="congnoPageInfo"></div>
                <nav><ul class="pagination pagination-sm mb-0" id="congnoPagination"></ul></nav>
            </div>
        </div>

        <!-- Tab 3: Báo cáo tài chính P&L -->
        <div class="tab-pane fade" id="baocao" role="tabpanel" aria-labelledby="baocao-tab">
            <div class="row g-3 mb-4">
                <!-- Doanh thu thuần -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #fafaf9;">
                        <span class="text-muted text-xs fw-semibold">1. DOANH THU THUẦN</span>
                        <h4 class="fw-bold text-dark mt-2">@Model.ReportPL.DoanhThuThuan.ToString("N0")₫</h4>
                        <span class="text-xxs text-muted mt-1">Từ đơn hàng hoàn thành</span>
                    </div>
                </div>
                <!-- Giá vốn hàng bán -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #fafaf9;">
                        <span class="text-muted text-xs fw-semibold">2. GIÁ VỐN HÀNG BÁN (COGS)</span>
                        <h4 class="fw-bold text-dark mt-2 text-danger">-@Model.ReportPL.GiaVonHangBan.ToString("N0")₫</h4>
                        <span class="text-xxs text-muted mt-1">Chi phí gốc nhập hàng hóa</span>
                    </div>
                </div>
                <!-- Lợi nhuận gộp -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #eff6ff;">
                        <span class="text-primary text-xs fw-semibold">3. LỢI NHUẬN GỘP</span>
                        <h4 class="fw-bold text-primary mt-2">@Model.ReportPL.LoiNhuanGop.ToString("N0")₫</h4>
                        <span class="text-xxs text-primary mt-1">Mục (1) trừ đi mục (2)</span>
                    </div>
                </div>
                <!-- Chi phí lương -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #fafaf9;">
                        <span class="text-muted text-xs fw-semibold">4. CHI PHÍ NHÂN SỰ</span>
                        <h4 class="fw-bold text-dark mt-2 text-danger">-@Model.ReportPL.ChiPhiLuong.ToString("N0")₫</h4>
                        <span class="text-xxs text-muted mt-1">Tổng hợp giờ làm từ chấm công</span>
                    </div>
                </div>
                <!-- Chi phí vận hành khác -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #fafaf9;">
                        <span class="text-muted text-xs fw-semibold">5. CHI PHÍ VẬN HÀNH KHÁC</span>
                        <h4 class="fw-bold text-dark mt-2 text-danger">-@Model.ReportPL.ChiPhiVanhHanhKhac.ToString("N0")₫</h4>
                        <span class="text-xxs text-muted mt-1">Văn phòng, mặt bằng, trả nợ NCC thực tế</span>
                    </div>
                </div>
                <!-- Lợi nhuận ròng -->
                <div class="col-12 col-md-4">
                    <div class="card p-3 border" style="background-color: #f0fdf4;">
                        <span class="text-success text-xs fw-semibold">6. LỢI NHUẬN RÒNG (NET PROFIT)</span>
                        <h4 class="fw-bold text-success mt-2">@Model.ReportPL.LoiNhuanRong.ToString("N0")₫</h4>
                        <span class="text-xxs text-success mt-1">Lợi nhuận cuối cùng của doanh nghiệp</span>
                    </div>
                </div>
            </div>

            <!-- Biểu đồ P&L theo tháng -->
            <div class="card p-4 border rounded-3 mt-4">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-chart-bar text-info me-2"></i>Doanh thu & Lợi nhuận theo tháng (12 tháng gần đây)</h6>
                <div style="position: relative; height:280px;">
                    <canvas id="monthlyPLChart"></canvas>
                </div>
            </div>
            <!-- Dòng tiền 7 ngày -->
            <div class="card p-4 border rounded-3 mt-3">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-chart-line text-success me-2"></i>Dòng tiền Thu vs Chi (7 ngày gần đây)</h6>
                <div style="position: relative; height:220px;">
                    <canvas id="cashFlowChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Modals {
<!-- Modal 1: Thêm Phiếu Giao Dịch Thu Chi Thủ Công -->
<div class="modal fade" id="createTransactionModal" tabindex="-1" aria-labelledby="createTransactionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("CreateTransaction", "Accounting")">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-gradient-cyan text-white">
                    <h6 class="modal-title fw-bold" id="createTransactionModalLabel"><i class="fa-solid fa-receipt me-2"></i>Tạo Phiếu Thu / Chi Thủ Công</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-sm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Loại giao dịch</label>
                        <select name="loaiGiaoDich" class="form-select text-sm" required id="loaiGiaoDichSelect">
                            <option value="Thu">Phiếu Thu (Tiền vào +)</option>
                            <option value="Chi">Phiếu Chi (Tiền ra -)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nhóm giao dịch</label>
                        <select name="nhomGiaoDich" class="form-select text-sm" required id="nhomGiaoDichSelect">
                            <!-- JS will load these based on Thu/Chi -->
                            <option value="Bán hàng">Doanh thu bán lẻ</option>
                            <option value="Khác">Giao dịch khác</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số tiền thanh toán (VND)</label>
                        <input type="number" name="soTien" class="form-control text-sm" placeholder="VD: 500000" min="1000" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Đối tượng giao dịch</label>
                        <input type="text" name="doiTuongGiaoDich" class="form-control text-sm" placeholder="VD: Công ty Điện lực, Nguyễn Văn A" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phương thức</label>
                        <select name="phuongThucThanhToan" class="form-select text-sm" required>
                            <option value="Chuyển khoản">Chuyển khoản ngân hàng</option>
                            <option value="Tiền mặt">Tiền mặt</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú</label>
                        <textarea name="ghiChu" class="form-control text-sm" rows="3" placeholder="Ghi chi tiết lý do thu/chi..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary text-sm rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary text-sm rounded-pill px-4">Lập phiếu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Void / Hủy phiếu -->
<div class="modal fade" id="voidTransactionModal" tabindex="-1" aria-labelledby="voidTransactionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("VoidTransaction", "Accounting")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="voidId">
                <div class="modal-header bg-danger text-white">
                    <h6 class="modal-title fw-bold" id="voidTransactionModalLabel"><i class="fa-solid fa-ban me-2"></i>Hủy (Void) Phiếu Giao Dịch</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-sm">
                    <div class="alert alert-warning py-2 px-3 text-xs mb-3">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        Đang hủy phiếu: <strong id="voidMaGD"></strong>. Thao tác này sẽ loại phiếu khỏi số dư quỹ nhưng không xóa khỏi cơ sở dữ liệu.
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lý do hủy phiếu <span class="text-danger">*</span></label>
                        <textarea name="lyDoHuy" class="form-control text-sm" rows="3" placeholder="VD: Lập nhầm số tiền, nhầm đối tượng..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary text-sm rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-danger text-sm rounded-pill px-4"><i class="fa-solid fa-ban me-1"></i>Xác nhận Void phiếu</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="paySupplierDebtModal" tabindex="-1" aria-labelledby="paySupplierDebtModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("PaySupplierDebt", "Accounting")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="congNoId" id="payDebtId">
                <div class="modal-header bg-success text-white">
                    <h6 class="modal-title fw-bold" id="paySupplierDebtModalLabel"><i class="fa-solid fa-money-bill-transfer me-2"></i>Thanh toán công nợ Nhà Cung Cấp</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-sm">
                    <div class="alert alert-info py-2 px-3 text-xs mb-3">
                        Đang thực hiện trả nợ cho: <strong id="payDebtNCC"></strong><br>
                        Thuộc đơn nhập hàng: <strong id="payDebtPhieuNhap"></strong>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số tiền trả nợ (VND)</label>
                        <input type="number" name="paymentAmount" class="form-control text-sm" id="payDebtAmount" min="1000" required>
                        <div class="form-text text-xxs">Còn nợ tối đa: <strong id="payDebtMax"></strong>₫</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phương thức chi tiền</label>
                        <select name="phuongThucThanhToan" class="form-select text-sm" required>
                            <option value="Chuyển khoản">Chuyển khoản ngân hàng</option>
                            <option value="Tiền mặt">Tiền mặt</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú chi tiền</label>
                        <textarea name="ghiChu" class="form-control text-sm" rows="2" placeholder="VD: Thanh toán tiền đợt 1 cho đơn nhập hàng..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary text-sm rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" id="btnConfirmPayDebt" class="btn btn-success text-sm rounded-pill px-4">
                        <i class="fa-solid fa-money-bill-wave me-1"></i>Xác nhận chi tiền
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Chi tiết phiếu Sổ quỹ -->
<div class="modal fade" id="soQuyDetailModal" tabindex="-1" aria-labelledby="soQuyDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#0ea5e9,#6366f1); color:#fff;">
                <h6 class="modal-title fw-bold" id="soQuyDetailModalLabel"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Chi tiết phiếu giao dịch</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-sm" id="soQuyDetailBody">
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tải...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary text-sm rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Chi tiết công nợ NCC -->
<div class="modal fade modal-lg" id="congNoDetailModal" tabindex="-1" aria-labelledby="congNoDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#7c3aed,#0ea5e9); color:#fff;">
                <h6 class="modal-title fw-bold" id="congNoDetailModalLabel"><i class="fa-solid fa-truck-ramp-box me-2"></i>Chi tiết công nợ Nhà Cung Cấp</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-sm" id="congNoDetailBody">
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tải...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary text-sm rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Dynamic Select Options for Manual Transaction
        const loaiSelect = document.getElementById("loaiGiaoDichSelect");
        const nhomSelect = document.getElementById("nhomGiaoDichSelect");

        const options = {
            "Thu": [
                { value: "Bán hàng", text: "Doanh thu bán lẻ" },
                { value: "Khác", text: "Khoản thu khác" }
            ],
            "Chi": [
                { value: "Trả nợ NCC", text: "Chi trả tiền hàng cho NCC" },
                { value: "Trả lương", text: "Chi trả lương nhân sự" },
                { value: "Mặt bằng", text: "Chi phí thuê mặt bằng" },
                { value: "Điện nước", text: "Chi phí điện, nước, internet" },
                { value: "Marketing", text: "Chi phí marketing, quảng cáo" },
                { value: "Văn phòng phẩm", text: "Chi phí thiết bị, văn phòng phẩm" },
                { value: "Vận hành", text: "Chi phí vận hành khác" },
                { value: "Khác", text: "Khoản chi khác" }
            ]
        };

        if(loaiSelect && nhomSelect) {
            loaiSelect.addEventListener("change", function() {
                const val = loaiSelect.value;
                nhomSelect.innerHTML = "";
                if(options[val]) {
                    options[val].forEach(opt => {
                        const el = document.createElement("option");
                        el.value = opt.value;
                        el.textContent = opt.text;
                        nhomSelect.appendChild(el);
                    });
                }
            });
            // trigger initial load
            loaiSelect.dispatchEvent(new Event('change'));
        }

        // Setup Pay Debt Modal data + anti-spam
        const payButtons = document.querySelectorAll(".btn-pay-debt");
        payButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                const id = this.getAttribute("data-id");
                const ncc = this.getAttribute("data-ncc");
                const conno = this.getAttribute("data-conno");
                const phieunhap = this.getAttribute("data-phieunhap");

                document.getElementById("payDebtId").value = id;
                document.getElementById("payDebtNCC").textContent = ncc;
                document.getElementById("payDebtPhieuNhap").textContent = phieunhap;

                const amountInput = document.getElementById("payDebtAmount");
                amountInput.value = parseFloat(conno);
                amountInput.max = parseFloat(conno);

                document.getElementById("payDebtMax").textContent = parseFloat(conno).toLocaleString('vi-VN');

                // Reset submit button (anti-spam re-enable when modal re-opens)
                const confirmBtn = document.getElementById('btnConfirmPayDebt');
                if (confirmBtn) {
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = '<i class="fa-solid fa-money-bill-wave me-1"></i>Xác nhận chi tiền';
                }
            });
        });

        // Anti-spam: disable submit on first click
        const payForm = document.querySelector('#paySupplierDebtModal form');
        if (payForm) {
            payForm.addEventListener('submit', function() {
                const confirmBtn = document.getElementById('btnConfirmPayDebt');
                if (confirmBtn) {
                    confirmBtn.disabled = true;
                    confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang xử lý...';
                }
            });
        }

        // Setup Void Modal data
        document.querySelectorAll('.btn-void-phieu').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('voidId').value = this.getAttribute('data-id');
                document.getElementById('voidMaGD').textContent = this.getAttribute('data-ma');
            });
        });

        // ====== SoQuy Detail Modal ======
        const fmt = v => parseFloat(v).toLocaleString('vi-VN');
        document.querySelectorAll('.btn-sq-detail').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.getAttribute('data-id');
                const body = document.getElementById('soQuyDetailBody');
                body.innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tải...</div>';
                try {
                    const res = await fetch(`/Accounting/GetSoQuyDetail/${id}`);
                    if (!res.ok) throw new Error('Not found');
                    const d = await res.json();
                    const isVoided = d.trangThai === 'Đã hủy';
                    const isThu = d.loaiGiaoDich === 'Thu';
                    body.innerHTML = `
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">ÊMÃ GIAO DỊCH</div>
                                <div class="fw-bold text-primary fs-6">${d.maGiaoDich}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">TRẠNG THÁI</div>
                                <div>${isVoided ? '<span class="badge bg-secondary"><i class="fa-solid fa-ban me-1"></i>Đã hủy</span>' : '<span class="badge bg-success bg-opacity-10 text-success"><i class="fa-solid fa-circle-check me-1"></i>Hợp lệ</span>'}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">LOẠI GIAO DỊCH</div>
                                <div><span class="badge ${isThu ? 'bg-success bg-opacity-10 text-success' : 'bg-danger bg-opacity-10 text-danger'}">${isThu ? 'Thu tiền (+)' : 'Chi tiền (-)'}</span></div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">NHÓM KHOẢN MỤC</div>
                                <div class="fw-medium">${d.nhomGiaoDich}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">SỐ TIỀN</div>
                                <div class="fw-bold fs-5 ${isThu ? 'text-success' : 'text-danger'}">${isThu ? '+' : '-'}${fmt(d.soTien)}₫</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">NGÀY GIAO DỊCH</div>
                                <div>${d.ngayGiaoDich}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">ĐỐI TƯỢNG</div>
                                <div class="fw-medium">${d.doiTuongGiaoDich || '—'}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">PHƯƠNG THỨC</div>
                                <div><span class="badge bg-secondary bg-opacity-10 text-dark">${d.phuongThucThanhToan}</span></div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted text-xs fw-semibold">NGƯỚI LẬP PHẾU</div>
                                <div>${d.nguoiLap}</div>
                            </div>
                            ${d.maDonHang ? `<div class="col-6"><div class="text-muted text-xs fw-semibold">MÃ ĐỚN HÀNG</div><div class="fw-bold">#${d.maDonHang} ${d.tenKhachHang ? '(' + d.tenKhachHang + ')' : ''}</div></div>` : ''}
                            ${d.ghiChu ? `<div class="col-12"><div class="text-muted text-xs fw-semibold">GHI CHÚ</div><div class="text-muted border rounded p-2 text-xs">${d.ghiChu}</div></div>` : ''}
                        </div>
                    `;
                } catch(e) {
                    body.innerHTML = '<div class="alert alert-danger text-sm">Không thể tải dữ liệu. Vui lòng thử lại!</div>';
                }
            });
        });

        // ====== CongNo Detail Modal ======
        document.querySelectorAll('.btn-cn-detail').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.getAttribute('data-id');
                const body = document.getElementById('congNoDetailBody');
                body.innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tải...</div>';
                try {
                    const res = await fetch(`/Accounting/GetCongNoDetail/${id}`);
                    if (!res.ok) throw new Error('Not found');
                    const d = await res.json();
                    const paidPct = d.tongTien > 0 ? (d.daThanhToan / d.tongTien * 100).toFixed(1) : 0;
                    const hangRows = (d.chiTietHang || []).map(h => `
                        <tr class="text-sm">
                            <td>${h.tenSanPham}</td>
                            <td class="text-center">${h.soLuong}</td>
                            <td class="text-end">${fmt(h.giaNhap)}₫</td>
                            <td class="text-end fw-bold">${fmt(h.thanhTien)}₫</td>
                        </tr>
                    `).join('');
                    const lichSuRows = (d.lichSuThanhToan || []).length > 0
                        ? (d.lichSuThanhToan || []).map(lh => `
                            <tr class="text-sm">
                                <td class="text-cyan fw-bold">${lh.maGiaoDich}</td>
                                <td>${lh.ngayThanhToan}</td>
                                <td class="text-success fw-bold">${fmt(lh.soTien)}₫</td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-dark text-xxs">${lh.phuongThucThanhToan}</span></td>
                            </tr>
                        `).join('')
                        : '<tr><td colspan="4" class="text-center text-muted py-2">Chưa có lịch sử thanh toán</td></tr>';

                    body.innerHTML = `
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="text-muted text-xs fw-semibold">NHÀ CUNG CẤP</div>
                                <div class="fw-bold">${d.tenNCC}</div>
                                <div class="text-muted text-xs">${d.soDienThoai}</div>
                            </div>
                            <div class="col-md-6">
                                <div class="text-muted text-xs fw-semibold">PHẾU NHẬP KHO</div>
                                <div class="fw-bold">${d.maPhieuNhap}</div>
                                <div class="text-muted text-xs">Ngày: ${d.ngayNhap}</div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-muted text-xs fw-semibold">TỔNG TIỀN NỢ</div>
                                <div class="fw-bold">${fmt(d.tongTien)}₫</div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-muted text-xs fw-semibold">ĐÃ THANH TOÁN</div>
                                <div class="fw-bold text-success">${fmt(d.daThanhToan)}₫</div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-muted text-xs fw-semibold">CÒN NỢ</div>
                                <div class="fw-bold text-danger">${fmt(d.conNo)}₫</div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted text-xs fw-semibold mb-1">TIẾN ĐỘ THANH TOÁN</div>
                                <div class="progress" style="height:10px;border-radius:6px;">
                                    <div class="progress-bar bg-success" style="width:${paidPct}%;border-radius:6px;"></div>
                                </div>
                                <div class="text-xs text-muted mt-1">${paidPct}% đã thanh toán ${d.quaHan ? '<span class="text-danger fw-bold">· QUÁ HẠN ' + d.hanThanhToan + '</span>' : '· Hạn: ' + d.hanThanhToan}</div>
                            </div>
                        </div>
                        <h6 class="fw-bold text-dark mb-2"><i class="fa-solid fa-boxes-stacking me-2 text-primary"></i>Hàng hóa trong phiếu nhập</h6>
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr class="text-xs text-muted">
                                        <th>Sản phẩm</th><th class="text-center">Số lượng</th><th class="text-end">Giá nhập</th><th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>${hangRows || '<tr><td colspan="4" class="text-center text-muted">Không có chi tiết</td></tr>'}</tbody>
                            </table>
                        </div>
                        <h6 class="fw-bold text-dark mb-2"><i class="fa-solid fa-clock-rotate-left me-2 text-success"></i>Lịch sử thanh toán</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr class="text-xs text-muted">
                                        <th>Mã phiếu chi</th><th>Ngày TT</th><th>Số tiền</th><th>Phương thức</th>
                                    </tr>
                                </thead>
                                <tbody>${lichSuRows}</tbody>
                            </table>
                        </div>
                    `;
                } catch(e) {
                    body.innerHTML = '<div class="alert alert-danger text-sm">Không thể tải dữ liệu. Vui lòng thử lại!</div>';
                }
            });
        });

        // Congno filter
        const filterNCC = document.getElementById('filterNCC');
        const filterTrangThai = document.getElementById('filterTrangThai');
        const btnReset = document.getElementById('btnResetFilter');

        function applyCongNoFilter() {
            const keyword = (filterNCC ? filterNCC.value.toLowerCase() : '');
            const status = (filterTrangThai ? filterTrangThai.value : '');

            // Filter NCC summary rows
            document.querySelectorAll('.ncc-row').forEach(row => {
                const ten = row.getAttribute('data-ten') || '';
                row.style.display = ten.includes(keyword) ? '' : 'none';
            });
            // Filter detail rows
            document.querySelectorAll('.cn-row').forEach(row => {
                const ten = row.getAttribute('data-ten') || '';
                const tt = row.getAttribute('data-trangthai') || '';
                const matchNCC = ten.includes(keyword);
                const matchStatus = !status || tt === status;
                row.style.display = (matchNCC && matchStatus) ? '' : 'none';
            });
        }

        if (filterNCC) filterNCC.addEventListener('input', applyCongNoFilter);
        if (filterTrangThai) filterTrangThai.addEventListener('change', applyCongNoFilter);
        if (btnReset) btnReset.addEventListener('click', function() {
            if (filterNCC) filterNCC.value = '';
            if (filterTrangThai) filterTrangThai.value = '';
            applyCongNoFilter();
        });

        // Initialize Chart.js for Cash Flow comparing Thu vs Chi
        const chartLabels = @Html.Raw(chartLabels);
        const chartThu = @Html.Raw(chartThu);
        const chartChi = @Html.Raw(chartChi);

        const ctx = document.getElementById('cashFlowChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartLabels,
                    datasets: [
                        {
                            label: 'Dòng tiền Thu (₫)',
                            data: chartThu,
                            borderColor: '#16a34a',
                            backgroundColor: 'rgba(22,163,74,0.05)',
                            borderWidth: 2.5,
                            tension: 0.35,
                            fill: true
                        },
                        {
                            label: 'Dòng tiền Chi (₫)',
                            data: chartChi,
                            borderColor: '#dc2626',
                            backgroundColor: 'rgba(220,38,38,0.05)',
                            borderWidth: 2.5,
                            tension: 0.35,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y.toLocaleString('vi-VN') + '₫';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function(value) {
                                    return value >= 1000000 ? (value/1000000).toFixed(1) + 'M' : value.toLocaleString('vi-VN') + '₫';
                                }
                            },
                            grid: { color: '#f1f5f9' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        // ====== Monthly P&L Bar Chart ======
        const plLabels = @Html.Raw(plLabels);
        const plDoanhThu = @Html.Raw(plDoanhThu);
        const plGiaVon = @Html.Raw(plGiaVon);
        const plLoiNhuan = @Html.Raw(plLoiNhuan);
        const ctxPL = document.getElementById('monthlyPLChart');
        if (ctxPL) {
            new Chart(ctxPL, {
                type: 'bar',
                data: {
                    labels: plLabels,
                    datasets: [
                        {
                            label: 'Doanh thu (₫)',
                            data: plDoanhThu,
                            backgroundColor: 'rgba(14,165,233,0.7)',
                            borderRadius: 5,
                            order: 2
                        },
                        {
                            label: 'Giá vốn (₫)',
                            data: plGiaVon,
                            backgroundColor: 'rgba(220,38,38,0.5)',
                            borderRadius: 5,
                            order: 2
                        },
                        {
                            label: 'Lợi nhuận gộp (₫)',
                            data: plLoiNhuan,
                            type: 'line',
                            borderColor: '#16a34a',
                            backgroundColor: 'rgba(22,163,74,0.08)',
                            borderWidth: 2.5,
                            tension: 0.35,
                            fill: true,
                            pointBackgroundColor: '#16a34a',
                            order: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y.toLocaleString('vi-VN') + '₫';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function(value) {
                                    return value >= 1000000 ? (value/1000000).toFixed(1) + 'M' : value.toLocaleString('vi-VN');
                                }
                            },
                            grid: { color: '#f1f5f9' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
        // ====== Table Paginator ======
        function initTablePagination(rowSelector, pageInfoId, paginationId, pageSize) {
            const rows = Array.from(document.querySelectorAll(rowSelector));
            const pageInfo = document.getElementById(pageInfoId);
            const paginationEl = document.getElementById(paginationId);
            if (!rows.length || !paginationEl) return;
            let currentPage = 1;
            const totalPages = Math.ceil(rows.length / pageSize);
            function render() {
                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;
                rows.forEach((row, i) => { row.style.display = (i >= start && i < end) ? '' : 'none'; });
                if (pageInfo) {
                    pageInfo.innerHTML = `Hiển thị <strong>${start + 1}</strong> – <strong>${Math.min(end, rows.length)}</strong> / <strong>${rows.length}</strong> mục`;
                }
                paginationEl.innerHTML = '';
                const prev = document.createElement('li');
                prev.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
                prev.innerHTML = `<a class="page-link rounded-start-3" href="#">&laquo;</a>`;
                prev.addEventListener('click', e => { e.preventDefault(); if (currentPage > 1) { currentPage--; render(); } });
                paginationEl.appendChild(prev);
                for (let p = 1; p <= totalPages; p++) {
                    const li = document.createElement('li');
                    li.className = 'page-item' + (p === currentPage ? ' active' : '');
                    li.innerHTML = `<a class="page-link" href="#">${p}</a>`;
                    const page = p;
                    li.addEventListener('click', e => { e.preventDefault(); currentPage = page; render(); });
                    paginationEl.appendChild(li);
                }
                const next = document.createElement('li');
                next.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
                next.innerHTML = `<a class="page-link rounded-end-3" href="#">&raquo;</a>`;
                next.addEventListener('click', e => { e.preventDefault(); if (currentPage < totalPages) { currentPage++; render(); } });
                paginationEl.appendChild(next);
            }
            render();
        }

        // Init pagination for Sổ quỹ & Công nợ tabs
        initTablePagination('#soquyTableBody .sq-row', 'soquyPageInfo', 'soquyPagination', 15);
        initTablePagination('#congnoTableBody .cn-row', 'congnoPageInfo', 'congnoPagination', 10);

        // ====== Channel Donut Chart (lazy init when tab is shown) ======
        const channelLabels = @Html.Raw(channelLabels);
        const channelData = @Html.Raw(channelData);
        const channelColors = @Html.Raw(channelColors);

        let channelChartInstance = null;

        function initChannelChart() {
            const ctx = document.getElementById('channelDonutChart');
            if (!ctx || channelChartInstance) return;
            channelChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: channelLabels,
                    datasets: [{
                        data: channelData,
                        backgroundColor: channelColors,
                        borderColor: '#fff',
                        borderWidth: 3,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 16, font: { size: 12 } }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const val = context.parsed;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = total > 0 ? (val / total * 100).toFixed(1) : 0;
                                    return ` ${val.toLocaleString('vi-VN')}₫ (${pct}%)`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // Init immediately if tab is default active, else wait for click
        const kenhTabBtn = document.getElementById('kenh-tab');
        if (kenhTabBtn) {
            kenhTabBtn.addEventListener('shown.bs.tab', function() {
                initChannelChart();
            });
        }
    });
</script>
}
