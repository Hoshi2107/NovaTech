@{
    ViewData["Title"] = "Trung tâm duyệt phiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var pendingOrders    = ViewBag.PendingOrders    as List<DATN64.Models.DonHang>   ?? new();
    var pendingInventory = ViewBag.PendingInventory as List<DATN64.Models.InventoryTransaction> ?? new();
    bool canApproveOrder = ViewBag.CanApproveOrder  == true;
    bool canApproveInv   = ViewBag.CanApproveInv    == true;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h4 fw-bold mb-1">Trung tâm duyệt phiếu</h1>
        <p class="text-muted small mb-0">Quản lý và phê duyệt các yêu cầu đang chờ xử lý</p>
    </div>
    <div class="d-flex gap-2">
        @if (canApproveOrder)
        {
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                <i class="fa-solid fa-clock me-1"></i>
                @pendingOrders.Count đơn hàng chờ
            </span>
        }
        @if (canApproveInv)
        {
            <span class="badge bg-info text-dark fs-6 px-3 py-2">
                <i class="fa-solid fa-boxes-stacked me-1"></i>
                @pendingInventory.Count phiếu kho chờ
            </span>
        }
    </div>
</div>

<!-- Nav Tabs -->
<ul class="nav nav-tabs border-0 mb-4" id="approvalTabs" role="tablist">
    @if (canApproveOrder)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-semibold" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders-panel" type="button" role="tab">
                <i class="fa-solid fa-file-invoice-dollar me-2"></i>
                Đơn hàng
                @if (pendingOrders.Count > 0)
                {
                    <span class="badge bg-danger rounded-pill ms-1">@pendingOrders.Count</span>
                }
            </button>
        </li>
    }
    @if (canApproveInv)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link @(!canApproveOrder ? "active" : "") fw-semibold" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory-panel" type="button" role="tab">
                <i class="fa-solid fa-warehouse me-2"></i>
                Phiếu kho
                @if (pendingInventory.Count > 0)
                {
                    <span class="badge bg-danger rounded-pill ms-1">@pendingInventory.Count</span>
                }
            </button>
        </li>
    }
</ul>

<div class="tab-content" id="approvalTabContent">

    
    @if (canApproveOrder)
    {
        <div class="tab-pane fade show active" id="orders-panel" role="tabpanel">
            @if (!pendingOrders.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa-solid fa-circle-check fa-3x mb-3 text-success opacity-50"></i>
                    <p class="fs-5 fw-semibold">Không có đơn hàng nào chờ duyệt</p>
                    <p class="small">Tất cả đơn hàng đã được xử lý!</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="ordersTable">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Khách hàng</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Phương thức TT</th>
                                <th>Ghi chú</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody id="ordersTableBody">
                            @foreach (var order in pendingOrders)
                            {
                                <tr class="order-row">
                                    <td><span class="badge bg-secondary">#@order.MaDonHang</span></td>
                                    <td>
                                        <div class="fw-semibold">@(order.KhachHang?.HoTen ?? "Khách vãng lai")</div>
                                        <div class="text-muted small">@(order.KhachHang?.SoDienThoai ?? "")</div>
                                    </td>
                                    <td class="text-muted small">@order.NgayDat?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold text-success">@order.TongTien?.ToString("N0") VNĐ</td>
                                    <td><span class="badge bg-light text-dark border">@(order.PhuongThucThanhToan ?? "—")</span></td>
                                    <td class="text-muted small" style="max-width:180px;">
                                        <span class="text-truncate d-inline-block" style="max-width:180px;">@(order.GhiChu ?? "—")</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-view-order-detail"
                                                    data-order-id="@order.MaDonHang">
                                                <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                            </button>
                                            <form method="post" asp-action="ApproveOrder" asp-route-id="@order.MaDonHang" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="action" value="approve" />
                                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Duyệt đơn hàng #@order.MaDonHang?')">
                                                    <i class="fa-solid fa-check me-1"></i>Duyệt
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal" data-bs-target="#rejectOrderModal"
                                                    data-order-id="@order.MaDonHang">
                                                <i class="fa-solid fa-xmark me-1"></i>Từ chối
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Orders Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-3" id="ordersPaginationWrapper">
                    <div class="text-muted small" id="ordersPageInfo"></div>
                    <nav><ul class="pagination pagination-sm mb-0" id="ordersPagination"></ul></nav>
                </div>
            }
        </div>
    }

    
    @if (canApproveInv)
    {
        <div class="tab-pane fade @(!canApproveOrder ? "show active" : "")" id="inventory-panel" role="tabpanel">
            @if (!pendingInventory.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa-solid fa-circle-check fa-3x mb-3 text-success opacity-50"></i>
                    <p class="fs-5 fw-semibold">Không có phiếu kho nào chờ duyệt</p>
                    <p class="small">Tất cả phiếu kho đã được xử lý!</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="invTable">
                        <thead class="table-light">
                            <tr>
                                <th>Mã phiếu</th>
                                <th>Loại</th>
                                <th>Sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Người tạo</th>
                                <th>Ngày tạo</th>
                                <th>Ghi chú</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody id="invTableBody">
                            @foreach (var txn in pendingInventory)
                            {
                                <tr class="inv-row">
                                    <td><span class="badge bg-secondary">@txn.Code</span></td>
                                    <td>
                                        @if (txn.Type == "Nhập kho")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                                <i class="fa-solid fa-circle-down me-1"></i>Nhập kho
                                            </span>
                                        }
                                        else if (txn.Type == "Xuất kho")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                                <i class="fa-solid fa-circle-up me-1"></i>Xuất kho
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info-subtle text-info border border-info-subtle">@txn.Type</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@txn.ProductName</div>
                                        <div class="text-muted small">SKU: @txn.ProductSKU</div>
                                    </td>
                                    <td>
                                        <span class="fw-bold @(txn.QuantityChange > 0 ? "text-success" : "text-danger")">
                                            @(txn.QuantityChange > 0 ? "+" : "")@txn.QuantityChange
                                        </span>
                                    </td>
                                    <td class="text-muted small">@txn.Creator</td>
                                    <td class="text-muted small">@txn.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-muted small" style="max-width:150px;">
                                        <span class="text-truncate d-inline-block" style="max-width:150px;">@(txn.Note ?? "—")</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <form method="post" asp-action="ApproveInventory" asp-route-id="@txn.Id" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="action" value="approve" />
                                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Duyệt phiếu @txn.Code?')">
                                                    <i class="fa-solid fa-check me-1"></i>Duyệt
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal" data-bs-target="#rejectInvModal"
                                                    data-txn-id="@txn.Id"
                                                    data-txn-code="@txn.Code">
                                                <i class="fa-solid fa-xmark me-1"></i>Từ chối
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Inventory Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-3" id="invPaginationWrapper">
                    <div class="text-muted small" id="invPageInfo"></div>
                    <nav><ul class="pagination pagination-sm mb-0" id="invPagination"></ul></nav>
                </div>
            }
        </div>
    }

</div>

@section Modals {
    
    <!-- Modal Chi tiết đơn hàng -->
    <div class="modal fade" id="orderDetailModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 bg-primary text-white rounded-top">
                    <h5 class="modal-title"><i class="fa-solid fa-circle-info me-2"></i>Chi tiết đơn hàng <span id="detailOrderId"></span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4" id="orderDetailContent">
                    <!-- Dynamic details loading spinner -->
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="rejectOrderModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" asp-action="ApproveOrder">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="reject" />
                    <input type="hidden" name="id" id="rejectOrderId" />
                    <div class="modal-header border-0 bg-danger text-white rounded-top">
                        <h5 class="modal-title"><i class="fa-solid fa-ban me-2"></i>Từ chối đơn hàng</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <label class="form-label fw-semibold">Lý do từ chối <span class="text-danger">*</span></label>
                        <textarea name="lyDo" class="form-control" rows="3" placeholder="Nhập lý do từ chối..." required></textarea>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger"><i class="fa-solid fa-ban me-1"></i>Xác nhận từ chối</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    
    <div class="modal fade" id="rejectInvModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" asp-action="ApproveInventory">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="reject" />
                    <input type="hidden" name="id" id="rejectInvId" />
                    <div class="modal-header border-0 bg-danger text-white rounded-top">
                        <h5 class="modal-title"><i class="fa-solid fa-ban me-2"></i>Từ chối phiếu kho <span id="rejectInvCode"></span></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <label class="form-label fw-semibold">Lý do từ chối <span class="text-danger">*</span></label>
                        <textarea name="lyDo" class="form-control" rows="3" placeholder="Nhập lý do từ chối..." required></textarea>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger"><i class="fa-solid fa-ban me-1"></i>Xác nhận từ chối</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<script>
    // ====== Generic table paginator ======
    function initTablePagination(rowSelector, pageInfoId, paginationId, pageSize) {
        const rows = Array.from(document.querySelectorAll(rowSelector));
        const pageInfo = document.getElementById(pageInfoId);
        const paginationEl = document.getElementById(paginationId);
        if (!rows.length || !paginationEl) return;

        let currentPage = 1;
        const totalPages = Math.ceil(rows.length / pageSize);

        function render() {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            rows.forEach((row, i) => {
                row.style.display = (i >= start && i < end) ? '' : 'none';
            });
            if (pageInfo) {
                pageInfo.innerHTML = `Hiển thị <strong>${start + 1}</strong> – <strong>${Math.min(end, rows.length)}</strong> / <strong>${rows.length}</strong> mục`;
            }
            // Build page buttons
            paginationEl.innerHTML = '';
            // Prev
            const prev = document.createElement('li');
            prev.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
            prev.innerHTML = `<a class="page-link rounded-start-3" href="#">&laquo;</a>`;
            prev.addEventListener('click', e => { e.preventDefault(); if (currentPage > 1) { currentPage--; render(); } });
            paginationEl.appendChild(prev);
            // Pages
            for (let p = 1; p <= totalPages; p++) {
                const li = document.createElement('li');
                li.className = 'page-item' + (p === currentPage ? ' active' : '');
                li.innerHTML = `<a class="page-link" href="#">${p}</a>`;
                const page = p;
                li.addEventListener('click', e => { e.preventDefault(); currentPage = page; render(); });
                paginationEl.appendChild(li);
            }
            // Next
            const next = document.createElement('li');
            next.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
            next.innerHTML = `<a class="page-link rounded-end-3" href="#">&raquo;</a>`;
            next.addEventListener('click', e => { e.preventDefault(); if (currentPage < totalPages) { currentPage++; render(); } });
            paginationEl.appendChild(next);
        }

        render();
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Init pagination for orders & inventory tabs
        initTablePagination('#ordersTableBody .order-row', 'ordersPageInfo', 'ordersPagination', 10);
        initTablePagination('#invTableBody .inv-row', 'invPageInfo', 'invPagination', 10);

        // Modal reject order
        var rejectOrderModal = document.getElementById('rejectOrderModal');
        if (rejectOrderModal) {
            rejectOrderModal.addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('rejectOrderId').value = btn.getAttribute('data-order-id');
            });
        }

        var rejectInvModal = document.getElementById('rejectInvModal');
        if (rejectInvModal) {
            rejectInvModal.addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('rejectInvId').value = btn.getAttribute('data-txn-id');
                document.getElementById('rejectInvCode').textContent = '#' + btn.getAttribute('data-txn-code');
            });
        }

        // Modal view order details
        var orderDetailModalEl = document.getElementById('orderDetailModal');
        var orderDetailModal = orderDetailModalEl ? new bootstrap.Modal(orderDetailModalEl) : null;
        
        var ordersTableBody = document.getElementById('ordersTableBody');
        if (ordersTableBody && orderDetailModal) {
            ordersTableBody.addEventListener('click', function(e) {
                var btn = e.target.closest('.btn-view-order-detail');
                if (!btn) return;
                
                var orderId = btn.getAttribute('data-order-id');
                document.getElementById('detailOrderId').textContent = '#' + orderId;
                
                var contentEl = document.getElementById('orderDetailContent');
                contentEl.innerHTML = 
                    '<div class="text-center py-4">' +
                        '<div class="spinner-border text-primary" role="status">' +
                            '<span class="visually-hidden">Đang tải...</span>' +
                        '</div>' +
                    '</div>';
                
                orderDetailModal.show();

                fetch('/Approval/GetOrderDetails?id=' + orderId)
                    .then(function(res) {
                        if (!res.ok) throw new Error('Không thể tải chi tiết đơn hàng');
                        return res.json();
                    })
                    .then(function(data) {
                        var itemsHtml = '';
                        (data.items || []).forEach(function(item) {
                            var imgHtml = item.hinhAnh 
                                ? '<img src="' + item.hinhAnh + '" class="img-thumbnail me-2" style="width: 50px; height: 50px; object-fit: cover;" />' 
                                : '<div class="bg-light text-muted d-inline-flex align-items-center justify-content-center me-2 border rounded" style="width: 50px; height: 50px;"><i class="fa-solid fa-image"></i></div>';
                            
                            itemsHtml += '<tr>' +
                                '<td>' +
                                    '<div class="d-flex align-items-center">' +
                                        imgHtml +
                                        '<div>' +
                                            '<div class="fw-semibold">' + item.tenSanPham + '</div>' +
                                            '<div class="text-muted small">Mã SP: ' + item.maSanPham + '</div>' +
                                        '</div>' +
                                    '</div>' +
                                '</td>' +
                                '<td class="text-end text-nowrap">' + item.donGia.toLocaleString('vi-VN') + ' VNĐ</td>' +
                                '<td class="text-center">' + item.soLuong + '</td>' +
                                '<td class="text-end text-success fw-bold text-nowrap">' + item.thanhTien.toLocaleString('vi-VN') + ' VNĐ</td>' +
                            '</tr>';
                        });

                        contentEl.innerHTML = 
                            '<div class="row g-3 mb-4">' +
                                '<div class="col-md-6">' +
                                    '<div class="p-3 bg-light rounded-3 h-100">' +
                                        '<h6 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-user me-2"></i>Thông tin khách hàng</h6>' +
                                        '<div class="mb-1"><strong>Họ tên:</strong> ' + data.khachHang.hoTen + '</div>' +
                                        '<div class="mb-1"><strong>SĐT:</strong> ' + (data.khachHang.soDienThoai || '—') + '</div>' +
                                        '<div class="mb-1"><strong>Email:</strong> ' + (data.khachHang.email || '—') + '</div>' +
                                        '<div><strong>Địa chỉ:</strong> ' + (data.khachHang.diaChi || '—') + '</div>' +
                                    '</div>' +
                                '</div>' +
                                '<div class="col-md-6">' +
                                    '<div class="p-3 bg-light rounded-3 h-100">' +
                                        '<h6 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-circle-info me-2"></i>Thông tin đơn hàng</h6>' +
                                        '<div class="mb-1"><strong>Ngày đặt:</strong> ' + (data.ngayDat || '—') + '</div>' +
                                        '<div class="mb-1">' +
                                            '<strong>Trạng thái:</strong> ' +
                                            '<span class="badge bg-warning text-dark">' + data.trangThai + '</span>' +
                                        '</div>' +
                                        '<div class="mb-1"><strong>Phương thức thanh toán:</strong> ' + (data.phuongThucThanhToan || '—') + '</div>' +
                                        '<div><strong>Ghi chú:</strong> ' + (data.ghiChu || '—') + '</div>' +
                                    '</div>' +
                                '</div>' +
                            '</div>' +
                            
                            '<h6 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-list me-2"></i>Danh sách sản phẩm</h6>' +
                            '<div class="table-responsive">' +
                                '<table class="table table-bordered align-middle">' +
                                    '<thead class="table-light">' +
                                        '<tr>' +
                                            '<th>Sản phẩm</th>' +
                                            '<th class="text-end" style="width: 130px;">Đơn giá</th>' +
                                            '<th class="text-center" style="width: 80px;">SL</th>' +
                                            '<th class="text-end" style="width: 150px;">Thành tiền</th>' +
                                        '</tr>' +
                                    '</thead>' +
                                    '<tbody>' +
                                        itemsHtml +
                                        '<tr class="table-light fw-bold">' +
                                            '<td colspan="3" class="text-end">Tổng tiền thanh toán:</td>' +
                                            '<td class="text-end text-danger fs-5">' + data.tongTien.toLocaleString('vi-VN') + ' VNĐ</td>' +
                                        '</tr>' +
                                    '</tbody>' +
                                '</table>' +
                            '</div>';
                    })
                    .catch(function(err) {
                        contentEl.innerHTML = 
                            '<div class="alert alert-danger mb-0">' +
                                '<i class="fa-solid fa-triangle-exclamation me-2"></i>' + err.message +
                            '</div>';
                    });
            });
        }

        // Preserve active tab state across reloads/redirects
        var activeTabId = sessionStorage.getItem('activeApprovalTab');
        if (activeTabId) {
            var tabButton = document.getElementById(activeTabId);
            if (tabButton) {
                var tabInstance = bootstrap.Tab.getInstance(tabButton) || new bootstrap.Tab(tabButton);
                tabInstance.show();
            }
        }

        var tabButtons = document.querySelectorAll('#approvalTabs button[data-bs-toggle="tab"]');
        tabButtons.forEach(function(btn) {
            btn.addEventListener('shown.bs.tab', function(e) {
                sessionStorage.setItem('activeApprovalTab', e.target.id);
            });
        });
    });
</script>
