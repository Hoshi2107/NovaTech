@model DATN64.Models.DonHang
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Chi tiết đơn hàng"; }
<div class="container my-5">
    <h2>Chi tiết đơn hàng #@Model.MaDonHang</h2>
    <p>Khách hàng: @(Model.KhachHang?.HoTen ?? "Không rõ")</p>
    <p>Trạng thái: @Model.TrangThai</p>
    <p>Tổng tiền: @Model.TongTien?.ToString("N0") đ</p>
    <h4>Danh sách sản phẩm</h4>
    <ul>
        @if(Model.ChiTietDonHangs != null) {
            foreach(var c in Model.ChiTietDonHangs) {
                <li>@(c.SanPham?.TenSanPham ?? "SP") - SL: @c.SoLuong - Đơn giá: @c.DonGia.ToString("N0") đ</li>
            }
        }
    </ul>
</div>