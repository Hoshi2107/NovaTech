@model List<DATN64.Models.DonHang>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "In vận đơn";
    ViewData["BreadcrumbActive"] = "In vận đơn";

    var keyword = ViewBag.Keyword as string ?? "";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 20;
    var totalItems = ViewBag.TotalItems as int? ?? 0;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

@functions {
    string GetStringProp(object obj, string propName, string fallback = "")
    {
        var prop = obj.GetType().GetProperty(propName);
        var value = prop?.GetValue(obj);
        return value?.ToString() ?? fallback;
    }

    string FormatMoney(decimal? value)
    {
        return value.HasValue ? value.Value.ToString("N0") + " đ" : "0 đ";
    }

    string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("HH:mm - dd/MM/yyyy") : "";
    }

    string GetOrderCode(DATN64.Models.DonHang item)
    {
        var code = GetStringProp(item, "MaDonHangHienThi", "");

        if (!string.IsNullOrWhiteSpace(code))
        {
            return code;
        }

        var date = item.NgayDat ?? DateTime.Now;
        return $"ORD-{date:yyMMdd}{item.MaDonHang:D2}";
    }

    string GetOrderChannel(DATN64.Models.DonHang item)
    {
        var note = item.GhiChu ?? "";
        var payment = item.PhuongThucThanhToan ?? "";

        if (
            note.Contains("Địa chỉ giao hàng", StringComparison.OrdinalIgnoreCase) ||
            note.Contains("Voucher sử dụng", StringComparison.OrdinalIgnoreCase) ||
            note.Contains("giao hàng", StringComparison.OrdinalIgnoreCase) ||
            note.Contains("website", StringComparison.OrdinalIgnoreCase) ||
            note.Contains("online", StringComparison.OrdinalIgnoreCase) ||
            note.Contains("TikTok", StringComparison.OrdinalIgnoreCase) ||
            payment.Contains("online", StringComparison.OrdinalIgnoreCase) ||
            payment.Contains("website", StringComparison.OrdinalIgnoreCase) ||
            payment.Contains("TikTok", StringComparison.OrdinalIgnoreCase)
        )
        {
            return "Website";
        }

        return "Cửa hàng";
    }

    string GetChannelIcon(string channel)
    {
        if (channel == "Website")
        {
            return "fa-globe text-primary";
        }

        return "fa-store text-warning";
    }
}

<div class="card card-glass p-4 border-0 shadow-sm rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0 text-dark">
                <i class="fa-solid fa-print text-cyan me-2"></i>
                Trung tâm in vận đơn giao hàng
            </h4>
            <div class="text-muted small mt-1">
                Các đơn hàng thuộc trạng thái <strong>Đã xác nhận</strong> hoặc <strong>Đã duyệt</strong> cần dán nhãn vận chuyển trước khi bàn giao cho shipper.
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="button" id="btnBulkPrint" class="btn btn-primary rounded-pill px-4" disabled>
                <i class="fa-solid fa-print me-1"></i>
                In nhãn hàng loạt (<span id="printCount">0</span>)
            </button>
            <a href="@Url.Action("ShippingLabels", "Order")" class="btn btn-outline-secondary rounded-pill px-3">
                <i class="fa-solid fa-rotate-left me-1"></i>
                Đặt lại
            </a>
        </div>
    </div>

    <!-- Filter and Search -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input type="text"
                       name="keyword"
                       value="@keyword"
                       class="form-control border-start-0"
                       placeholder="Tìm nhanh theo Mã đơn hàng, Tên khách hàng, Số điện thoại...">
            </div>
        </div>

        <div class="col-md-2">
            <select name="pageSize" class="form-select" onchange="this.form.submit()">
                <option value="10" selected="@(pageSize == 10)">10 dòng</option>
                <option value="20" selected="@(pageSize == 20)">20 dòng</option>
                <option value="50" selected="@(pageSize == 50)">50 dòng</option>
            </select>
        </div>

        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-info text-white rounded-pill">
                <i class="fa-solid fa-filter me-1"></i>
                Lọc kết quả
            </button>
        </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="text-muted small">
            Đơn hàng cần in nhãn: <strong>@totalItems</strong>
        </div>

        <div class="text-muted small">
            Trang <strong>@currentPage</strong> / <strong>@(totalPages <= 0 ? 1 : totalPages)</strong>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 40px;" class="text-center">
                        <div class="form-check d-flex justify-content-center">
                            <input class="form-check-input check-all" type="checkbox" id="checkAll">
                        </div>
                    </th>
                    <th style="width: 120px;">Mã Đơn</th>
                    <th>Khách hàng</th>
                    <th>Địa chỉ giao hàng</th>
                    <th>Tổng tiền</th>
                    <th>Kênh bán</th>
                    <th>Ngày xác nhận</th>
                    <th class="text-end" style="width: 150px;">Hành động</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <div class="py-4">
                                <i class="fa-solid fa-box-open fa-3x mb-3 text-secondary opacity-50"></i>
                                <p class="mb-0 fw-semibold">Không tìm thấy đơn hàng nào cần in nhãn.</p>
                                <p class="small text-muted">Chỉ hiển thị các đơn hàng ở trạng thái 'Đã xác nhận' hoặc 'Đã duyệt'.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        var channel = GetOrderChannel(item);
                        var orderCode = GetOrderCode(item);

                        <tr>
                            <td class="text-center">
                                <div class="form-check d-flex justify-content-center">
                                    <input class="form-check-input order-checkbox" type="checkbox" value="@item.MaDonHang">
                                </div>
                            </td>

                            <td>
                                <code class="text-danger fw-bold">@orderCode</code>
                            </td>

                            <td>
                                <div class="fw-bold text-dark">@(item.KhachHang?.HoTen ?? "Khách vãng lai")</div>
                                <span class="text-xs text-muted">
                                    <i class="fa-solid fa-phone me-1"></i>@(item.KhachHang?.SoDienThoai ?? "—")
                                </span>
                            </td>

                            <td style="max-width: 250px;">
                                <div class="text-truncate" title="@(item.KhachHang?.DiaChi ?? "—")">
                                    @(item.KhachHang?.DiaChi ?? "—")
                                </div>
                            </td>

                            <td class="text-info fw-bold">
                                @FormatMoney(item.TongTien)
                            </td>

                            <td>
                                <i class="fa-solid @GetChannelIcon(channel)"></i>
                                <span class="ms-1">@channel</span>
                            </td>

                            <td class="text-muted small">
                                @FormatDate(item.NgayDat)
                            </td>

                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="@Url.Action("PrintLabels", "Order", new { ids = item.MaDonHang })"
                                       target="_blank"
                                       class="btn btn-sm btn-info text-white rounded-pill px-3">
                                        <i class="fa-solid fa-print"></i> In nhãn
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="text-muted small">
                Hiển thị @pageSize dòng / trang
            </div>

            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("ShippingLabels", new {
                               page = currentPage - 1,
                               pageSize = pageSize,
                               keyword = keyword
                           })">
                            Trước
                        </a>
                    </li>

                    @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("ShippingLabels", new {
                                   page = p,
                                   pageSize = pageSize,
                                   keyword = keyword
                               })">
                                @p
                            </a>
                        </li>
                    }

                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("ShippingLabels", new {
                               page = currentPage + 1,
                               pageSize = pageSize,
                               keyword = keyword
                           })">
                            Sau
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const checkAll = document.getElementById("checkAll");
        const checkboxes = document.querySelectorAll(".order-checkbox");
        const btnBulkPrint = document.getElementById("btnBulkPrint");
        const printCount = document.getElementById("printCount");

        function updateBulkButton() {
            const checkedIds = Array.from(checkboxes)
                                   .filter(cb => cb.checked)
                                   .map(cb => cb.value);

            printCount.textContent = checkedIds.length;
            
            if (checkedIds.length > 0) {
                btnBulkPrint.removeAttribute("disabled");
            } else {
                btnBulkPrint.setAttribute("disabled", "true");
            }
        }

        if (checkAll) {
            checkAll.addEventListener("change", function () {
                checkboxes.forEach(cb => cb.checked = checkAll.checked);
                updateBulkButton();
            });
        }

        checkboxes.forEach(cb => {
            cb.addEventListener("change", function () {
                // If any is unchecked, checkAll is unchecked
                if (!cb.checked) {
                    checkAll.checked = false;
                } else {
                    // Check if all are checked
                    const allChecked = Array.from(checkboxes).every(x => x.checked);
                    checkAll.checked = allChecked;
                }
                updateBulkButton();
            });
        });

        if (btnBulkPrint) {
            btnBulkPrint.addEventListener("click", function () {
                const checkedIds = Array.from(checkboxes)
                                       .filter(cb => cb.checked)
                                       .map(cb => cb.value)
                                       .join(",");
                
                if (checkedIds) {
                    const url = '@Url.Action("PrintLabels", "Order")?ids=' + checkedIds;
                    window.open(url, '_blank');
                }
            });
        }
    });
</script>
