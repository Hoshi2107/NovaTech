@model List<DATN64.Models.DonHang>
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Quản lý đơn hàng"; }
<div class="container my-5">
    <h2>Quản lý đơn hàng</h2>
    <table class="table">
        <thead><tr><th>Mã ĐH</th><th>Khách Hàng</th><th>Ngày Đặt</th><th>Tổng Tiền</th><th>Trạng Thái</th><th>Thao tác</th></tr></thead>
        <tbody>
            @foreach(var item in Model) {
                <tr>
                    <td>@item.MaDonHang</td>
                    <td>@(item.KhachHang?.HoTen ?? "Khách vãng lai")</td>
                    <td>@item.NgayDat?.ToString("dd/MM/yyyy")</td>
                    <td>@item.TongTien?.ToString("N0") đ</td>
                    <td>@item.TrangThai</td>
                    <td><a href="@Url.Action("Detail", "Order", new { id = item.MaDonHang })" class="btn btn-sm btn-primary">Chi tiết</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>