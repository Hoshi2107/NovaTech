@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Bán hàng & Chăm sóc khách hàng";
    ViewData["BreadcrumbActive"] = "Bán hàng & Chăm sóc khách hàng";
}

@section Styles {
    <style>
        .cskh-shell {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 18px;
            min-height: 660px;
        }

        .cskh-panel {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
            overflow: hidden;
        }

        .thread-list {
            max-height: 520px;
            overflow-y: auto;
        }

        .thread-item {
            padding: 14px 16px;
            border-bottom: 1px solid #e2e8f0;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .thread-item:hover,
        .thread-item.active {
            background: #eff6ff;
        }

        .thread-name {
            font-weight: 800;
            color: #0f172a;
        }

        .thread-subject {
            font-size: 13px;
            color: #475569;
            margin-top: 4px;
        }

        .thread-last {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .badge-unread {
            background: #ef4444;
            color: #ffffff;
            border-radius: 999px;
            padding: 3px 8px;
            font-size: 11px;
            font-weight: 800;
        }

        .thread-delete-btn {
            width: 30px;
            height: 30px;
            min-width: 30px;
            border: none;
            border-radius: 999px;
            background: #fee2e2;
            color: #dc2626;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .thread-item:hover .thread-delete-btn,
        .thread-item.active .thread-delete-btn {
            opacity: 1;
        }

        .thread-delete-btn:hover {
            background: #fecaca;
            color: #b91c1c;
        }

        .chat-main {
            display: flex;
            flex-direction: column;
            min-height: 660px;
        }

        .chat-main-header {
            padding: 18px;
            border-bottom: 1px solid #e2e8f0;
            background: #f8fafc;
        }

        .chat-messages {
            flex: 1;
            padding: 18px;
            overflow-y: auto;
            background: #f8fafc;
        }

        .chat-message {
            display: flex;
            margin-bottom: 12px;
        }

        .chat-message.customer {
            justify-content: flex-start;
        }

        .chat-message.staff {
            justify-content: flex-end;
        }

        .chat-bubble {
            max-width: 70%;
            padding: 11px 13px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.45;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
        }

        .chat-message.customer .chat-bubble {
            background: #ffffff;
            color: #0f172a;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }

        .chat-message.staff .chat-bubble {
            background: #2563eb;
            color: #ffffff;
            border-bottom-right-radius: 4px;
        }

        .chat-sender {
            font-size: 11px;
            font-weight: 800;
            opacity: 0.75;
            margin-bottom: 4px;
        }

        .chat-time {
            display: block;
            font-size: 10px;
            opacity: 0.7;
            margin-top: 5px;
        }

        .reply-box {
            padding: 16px;
            border-top: 1px solid #e2e8f0;
            background: #ffffff;
        }

        .empty-state {
            height: 100%;
            min-height: 520px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            text-align: center;
        }

        .inbox-filter {
            background: #ffffff;
        }

        .inbox-pagination {
            min-height: 56px;
        }

        .pagination-info {
            font-size: 12px;
            color: #64748b;
            line-height: 1.35;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-dark mb-1">
            <i class="fa-solid fa-headset text-info me-2"></i>
            Bán hàng & Chăm sóc khách hàng
        </h3>
        <div class="text-muted small">Quản lý hội thoại khách hàng từ website NovaTech Store.</div>
    </div>

    <button class="btn btn-outline-primary rounded-pill" onclick="loadInbox(true, inboxPage)">
        <i class="fa-solid fa-rotate me-2"></i>Làm mới
    </button>
</div>

<div class="cskh-shell">
    <div class="cskh-panel">
        <div class="p-3 border-bottom inbox-filter">
            <h6 class="fw-bold mb-3">Hộp thư khách hàng</h6>

            <div class="mb-2">
                <input type="text"
                       id="inboxKeyword"
                       class="form-control form-control-sm"
                       placeholder="Tìm tên, SĐT, nội dung chat...">
            </div>

            <div class="d-flex gap-2">
                <select id="inboxStatus" class="form-select form-select-sm">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Unread">Chưa đọc</option>
                    <option value="Processing">Đang xử lý</option>
                    <option value="Replied">Đã phản hồi</option>
                </select>

                <select id="inboxPageSize" class="form-select form-select-sm">
                    <option value="10">10 dòng</option>
                    <option value="20" selected>20 dòng</option>
                    <option value="50">50 dòng</option>
                </select>
            </div>

            <button type="button"
                    class="btn btn-sm btn-info text-white rounded-pill w-100 mt-2"
                    onclick="searchInbox()">
                <i class="fa-solid fa-magnifying-glass me-1"></i>
                Lọc hội thoại
            </button>
        </div>

        <div id="threadList" class="thread-list">
            <div class="p-4 text-center text-muted">Đang tải hội thoại...</div>
        </div>

        <div id="inboxPagination" class="p-2 border-top bg-white inbox-pagination"></div>
    </div>

    <div class="cskh-panel chat-main">
        <div id="chatHeader" class="chat-main-header">
            <div class="fw-bold text-dark">Chưa chọn hội thoại</div>
            <div class="text-muted small">Chọn một khách hàng bên trái để xem nội dung.</div>
        </div>

        <div id="chatMessages" class="chat-messages">
            <div class="empty-state">
                <div>
                    <i class="fa-regular fa-comments fs-1 mb-3 text-info"></i>
                    <div>Chọn hội thoại để bắt đầu chăm sóc khách hàng.</div>
                </div>
            </div>
        </div>

        <div class="reply-box">
            <textarea id="replyText" class="form-control mb-2" rows="3" placeholder="Nhập phản hồi cho khách hàng..."></textarea>
            <div class="d-flex justify-content-between align-items-center">
                <div id="replyStatus" class="small text-muted"></div>
                <button class="btn btn-primary rounded-pill px-4" onclick="sendReply()">
                    <i class="fa-solid fa-paper-plane me-2"></i>Gửi phản hồi
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedThreadId = null;
        let currentThreads = [];
        let inboxRequestRunning = false;
        let threadRequestToken = 0;

        let inboxPage = 1;
        let inboxPageSize = 20;
        let inboxTotalItems = 0;
        let inboxTotalPages = 1;
        let inboxKeyword = '';
        let inboxStatus = '';

        const CSKH_REFRESH_INTERVAL = 60 * 1000;

        const formatTime = (value) => {
            if (!value) return '';

            return new Date(value).toLocaleString('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                day: '2-digit',
                month: '2-digit'
            });
        };

        const escapeHtml = (value) => {
            return String(value || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        };

        const sameId = (a, b) => {
            return String(a) === String(b);
        };

        const postJson = async (url, body) => {
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.message || 'Có lỗi xảy ra.');
            }

            return data;
        };

        const renderInbox = () => {
            const list = document.getElementById('threadList');

            if (!currentThreads.length) {
                list.innerHTML = '<div class="p-4 text-center text-muted">Chưa có hội thoại nào.</div>';
                return;
            }

            list.innerHTML = currentThreads.map(thread => `
                <div class="thread-item ${sameId(selectedThreadId, thread.id) ? 'active' : ''}" onclick="selectThread(${thread.id})">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="thread-name">${escapeHtml(thread.customerName || 'Khách vãng lai')}</div>
                                ${thread.unreadCount > 0 ? `<span class="badge-unread">${thread.unreadCount}</span>` : ''}
                            </div>
                            <div class="thread-subject">${escapeHtml(thread.subject || '')}</div>
                            <div class="thread-last">${escapeHtml(thread.lastMessage || '')}</div>
                            <div class="small text-muted mt-1">${formatTime(thread.updatedAt)}</div>
                        </div>

                        <button type="button"
                                class="thread-delete-btn"
                                title="Xóa hội thoại"
                                onclick="deleteThread(event, ${thread.id})">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            `).join('');
        };

        const renderInboxPagination = () => {
            const box = document.getElementById('inboxPagination');

            if (!box) {
                return;
            }

            if (inboxTotalPages <= 1) {
                box.innerHTML = `
                    <div class="pagination-info text-center">
                        Tổng: ${inboxTotalItems} hội thoại
                    </div>
                `;
                return;
            }

            const prevDisabled = inboxPage <= 1 ? 'disabled' : '';
            const nextDisabled = inboxPage >= inboxTotalPages ? 'disabled' : '';

            box.innerHTML = `
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            ${prevDisabled}
                            onclick="loadInbox(true, ${inboxPage - 1})">
                        Trước
                    </button>

                    <div class="pagination-info text-center">
                        Trang ${inboxPage}/${inboxTotalPages}
                        <br>
                        ${inboxTotalItems} hội thoại
                    </div>

                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            ${nextDisabled}
                            onclick="loadInbox(true, ${inboxPage + 1})">
                        Sau
                    </button>
                </div>
            `;
        };

        const loadInbox = async (showLoading = false, page = inboxPage) => {
            const list = document.getElementById('threadList');

            if (inboxRequestRunning) {
                return;
            }

            inboxRequestRunning = true;

            if (showLoading) {
                list.innerHTML = '<div class="p-4 text-center text-muted">Đang tải hội thoại...</div>';
            }

            try {
                inboxPage = page;
                inboxPageSize = Number(document.getElementById('inboxPageSize')?.value || inboxPageSize);
                inboxKeyword = document.getElementById('inboxKeyword')?.value.trim() || '';
                inboxStatus = document.getElementById('inboxStatus')?.value || '';

                const url =
                    `/SalesCSKH/GetCustomerInbox?page=${inboxPage}` +
                    `&pageSize=${inboxPageSize}` +
                    `&keyword=${encodeURIComponent(inboxKeyword)}` +
                    `&status=${encodeURIComponent(inboxStatus)}`;

                const response = await fetch(url);

                if (!response.ok) {
                    throw new Error('Không tải được danh sách hội thoại.');
                }

                const data = await response.json();

                currentThreads = Array.isArray(data.items) ? data.items : [];
                inboxPage = data.currentPage || 1;
                inboxPageSize = data.pageSize || 20;
                inboxTotalItems = data.totalItems || 0;
                inboxTotalPages = data.totalPages || 1;

                renderInbox();
                renderInboxPagination();
            } catch (err) {
                list.innerHTML = `<div class="p-4 text-danger text-center">${escapeHtml(err.message)}</div>`;
            } finally {
                inboxRequestRunning = false;
            }
        };

        const searchInbox = () => {
            selectedThreadId = null;
            inboxPage = 1;
            clearSelectedThreadView();
            loadInbox(true, 1);
        };

        const selectThread = async (id) => {
            selectedThreadId = id;

            document.getElementById('replyStatus').textContent = '';
            document.getElementById('replyText').value = '';

            renderInbox();

            await loadThread(id, false);

            try {
                await postJson('/SalesCSKH/MarkCustomerThreadRead', {
                    threadId: id
                });

                const thread = currentThreads.find(t => sameId(t.id, id));

                if (thread) {
                    thread.unreadCount = 0;

                    if (thread.status === 'Unread') {
                        thread.status = 'Processing';
                    }
                }

                renderInbox();
            } catch (err) {
                console.error(err);
            }
        };

        const clearSelectedThreadView = () => {
            selectedThreadId = null;

            document.getElementById('replyStatus').textContent = '';
            document.getElementById('replyText').value = '';

            document.getElementById('chatHeader').innerHTML = `
                <div class="fw-bold text-dark">Chưa chọn hội thoại</div>
                <div class="text-muted small">Chọn một khách hàng bên trái để xem nội dung.</div>
            `;

            document.getElementById('chatMessages').innerHTML = `
                <div class="empty-state">
                    <div>
                        <i class="fa-regular fa-comments fs-1 mb-3 text-info"></i>
                        <div>Chọn hội thoại để bắt đầu chăm sóc khách hàng.</div>
                    </div>
                </div>
            `;
        };

        const deleteThread = async (event, id) => {
            event.preventDefault();
            event.stopPropagation();

            const thread = currentThreads.find(t => sameId(t.id, id));
            const customerName = thread?.customerName || 'Khách vãng lai';

            const ok = confirm(`Bạn có chắc muốn xóa toàn bộ hội thoại của "${customerName}" không?`);

            if (!ok) {
                return;
            }

            try {
                await postJson('/SalesCSKH/DeleteCustomerThread', {
                    threadId: id
                });

                currentThreads = currentThreads.filter(t => !sameId(t.id, id));

                if (sameId(selectedThreadId, id)) {
                    clearSelectedThreadView();
                }

                renderInbox();

                if (currentThreads.length === 0 && inboxPage > 1) {
                    await loadInbox(true, inboxPage - 1);
                } else {
                    await loadInbox(false, inboxPage);
                }
            } catch (err) {
                alert(err.message || 'Xóa hội thoại thất bại.');
            }
        };

        const loadThread = async (id, silent = false) => {
            const header = document.getElementById('chatHeader');
            const messagesBox = document.getElementById('chatMessages');

            const requestToken = ++threadRequestToken;

            if (!silent) {
                messagesBox.innerHTML = '<div class="p-4 text-center text-muted">Đang tải nội dung...</div>';
            }

            try {
                const response = await fetch(`/SalesCSKH/GetCustomerThread?id=${id}`);

                if (!response.ok) {
                    throw new Error('Không tải được nội dung hội thoại.');
                }

                const thread = await response.json();

                if (requestToken !== threadRequestToken || !sameId(selectedThreadId, id)) {
                    return;
                }

                header.innerHTML = `
                    <div class="fw-bold text-dark">${escapeHtml(thread.customerName || 'Khách vãng lai')}</div>
                    <div class="text-muted small">
                        ${escapeHtml(thread.subject || '')}
                        ${thread.customerPhone ? ` · ${escapeHtml(thread.customerPhone)}` : ''}
                    </div>
                `;

                const messages = Array.isArray(thread.messages) ? thread.messages : [];

                if (!messages.length) {
                    messagesBox.innerHTML = '<div class="empty-state">Hội thoại chưa có tin nhắn.</div>';
                    return;
                }

                messagesBox.innerHTML = messages.map(message => `
                    <div class="chat-message ${message.sender === 'customer' ? 'customer' : 'staff'}">
                        <div class="chat-bubble">
                            <div class="chat-sender">${message.sender === 'customer' ? 'Khách hàng' : 'NovaTech'}</div>
                            <div>${escapeHtml(message.text)}</div>
                            <span class="chat-time">${formatTime(message.timestamp)}</span>
                        </div>
                    </div>
                `).join('');

                messagesBox.scrollTop = messagesBox.scrollHeight;
            } catch (err) {
                if (!silent) {
                    messagesBox.innerHTML = `<div class="p-4 text-danger text-center">${escapeHtml(err.message)}</div>`;
                }
            }
        };

        const sendReply = async () => {
            const status = document.getElementById('replyStatus');
            const input = document.getElementById('replyText');
            const message = input.value.trim();

            status.textContent = '';

            if (!selectedThreadId) {
                status.textContent = 'Vui lòng chọn hội thoại.';
                status.className = 'small text-danger';
                return;
            }

            if (!message) {
                status.textContent = 'Vui lòng nhập nội dung phản hồi.';
                status.className = 'small text-danger';
                return;
            }

            try {
                status.textContent = 'Đang gửi...';
                status.className = 'small text-muted';

                await postJson('/SalesCSKH/ReplyCustomerMessage', {
                    threadId: selectedThreadId,
                    message: message,
                    status: 'Replied'
                });

                input.value = '';
                status.textContent = 'Đã gửi phản hồi.';
                status.className = 'small text-success';

                const thread = currentThreads.find(t => sameId(t.id, selectedThreadId));

                if (thread) {
                    thread.lastMessage = message;
                    thread.updatedAt = new Date().toISOString();
                    thread.status = 'Replied';
                    thread.unreadCount = 0;
                }

                renderInbox();

                await loadThread(selectedThreadId, false);
                await loadInbox(false, inboxPage);
            } catch (err) {
                status.textContent = err.message;
                status.className = 'small text-danger';
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            const keywordInput = document.getElementById('inboxKeyword');
            const statusSelect = document.getElementById('inboxStatus');
            const pageSizeSelect = document.getElementById('inboxPageSize');

            keywordInput?.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    searchInbox();
                }
            });

            statusSelect?.addEventListener('change', searchInbox);
            pageSizeSelect?.addEventListener('change', searchInbox);

            loadInbox(true, 1);

            setInterval(async () => {
                await loadInbox(false, inboxPage);

                if (selectedThreadId) {
                    await loadThread(selectedThreadId, true);
                }
            }, CSKH_REFRESH_INTERVAL);
        });
    </script>
}